---
/**
 * BaseLayout — shared HTML shell for all pages.
 * Absorbs the ~30 lines of <head> boilerplate duplicated across 29 pages.
 */

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  robots?: string;
  schemaJson?: Record<string, unknown>;
  bodyClass?: string;
  includeMainCss?: boolean;
}

const {
  title,
  description = '',
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://bertrandbrands.ca/og-image.png',
  robots,
  schemaJson,
  bodyClass = '',
  includeMainCss = true,
} = Astro.props;

const effectiveOgTitle = ogTitle || title;
const effectiveOgDescription = ogDescription || description;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0a0a0a">

  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {canonical && <link rel="canonical" href={canonical} />}
  {robots && <meta name="robots" content={robots} />}

  {/* Open Graph */}
  <meta property="og:title" content={effectiveOgTitle} />
  {effectiveOgDescription && <meta property="og:description" content={effectiveOgDescription} />}
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_CA" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Bertrand Brands | Brand & Web Systems" />

  {/* Twitter / X Card */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={effectiveOgTitle} />
  {effectiveOgDescription && <meta name="twitter:description" content={effectiveOgDescription} />}
  <meta name="twitter:image" content={ogImage} />

  {/* Favicon & Touch Icons */}
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="BG Brands" />
  <link rel="manifest" href="/site.webmanifest" />

  {/* Schema.org */}
  {schemaJson && (
    <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />
  )}

  {/* Third-party preconnect */}
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
  <link rel="preconnect" href="https://use.typekit.net" crossorigin />
  <link rel="dns-prefetch" href="https://formspree.io" />

  {/* Google Ads + GA4 conversion tracking — global on all pages */}
  <script is:inline src="https://www.googletagmanager.com/gtag/js?id=AW-17925090292" async></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-17925090292');
    /* GA4 Analytics */
    gtag('config', 'G-CFMDTBXNV7');

    /* Unified conversion helper — fires both GA4 + Google Ads events */
    window.bbConvert = function(type, label, value) {
      if (typeof gtag !== 'function') return;
      gtag('event', 'generate_lead', {
        event_category: type,
        event_label: label,
        value: value || 0,
        currency: 'CAD'
      });
      gtag('event', 'conversion', {
        send_to: 'AW-17925090292/3B0-CJDv6vUbEPTXrONC',
        value: value || 1.0,
        currency: 'CAD'
      });
    };
  </script>

  {/* Global tel: and mailto: click tracking */}
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href]');
        if (!link) return;
        var href = link.getAttribute('href') || '';
        if (href.startsWith('tel:')) {
          gtag('event', 'conversion', {
            send_to: 'AW-17925090292/ueyZCPOf6_UbEPTXrONC'
          });
          if (typeof bbConvert === 'function') bbConvert('phone_click', 'global_tel');
        }
        if (href.startsWith('mailto:')) {
          gtag('event', 'conversion', {
            send_to: 'AW-17925090292/ueyZCPOf6_UbEPTXrONC'
          });
          if (typeof bbConvert === 'function') bbConvert('email_click', 'global_mailto');
        }
      });
    });
  </script>

  {/* Fonts */}
  <link rel="stylesheet" href="https://use.typekit.net/dmk8daz.css">
  <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/styles/fonts.css">

  {/* Styles */}
  {includeMainCss && <link rel="stylesheet" href="/styles/tokens.css" />}
  {includeMainCss && <link rel="stylesheet" href="/styles/main.css" />}

  {/* Page-specific head content */}
  <slot name="head" />
</head>
<body class={bodyClass}>
  <slot />

  {/* Phone modal — desktop intercept for tel: links */}
  <div class="phone-modal-backdrop" id="phoneModal" aria-hidden="true" role="dialog" aria-label="Phone number">
    <div class="phone-modal">
      <button class="phone-modal__close" aria-label="Close" id="phoneModalClose">&times;</button>
      <p class="phone-modal__label">Please call</p>
      <p class="phone-modal__number" id="phoneModalNumber">(705) 413-3705</p>
      <button class="phone-modal__copy" id="phoneModalCopy">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        <span id="phoneModalCopyText">Copy number</span>
      </button>
    </div>
  </div>
  <script is:inline>
    (function() {
      var isDesktop = window.matchMedia('(min-width: 769px)').matches && !('ontouchstart' in window);
      if (!isDesktop) return;

      var backdrop = document.getElementById('phoneModal');
      var closeBtn = document.getElementById('phoneModalClose');
      var copyBtn = document.getElementById('phoneModalCopy');
      var copyText = document.getElementById('phoneModalCopyText');
      var numberEl = document.getElementById('phoneModalNumber');
      if (!backdrop) return;

      var triggerEl = null;

      function trapFocus(e) {
        if (e.key !== 'Tab') return;
        var focusable = backdrop.querySelectorAll('button, [href], [tabindex]:not([tabindex="-1"])');
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) { e.preventDefault(); last.focus(); }
        } else {
          if (document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      }

      function show(number) {
        var clean = number.replace(/^tel:\+?1?/, '').replace(/\D/g, '');
        var formatted = clean.length === 10
          ? '(' + clean.slice(0,3) + ') ' + clean.slice(3,6) + '-' + clean.slice(6)
          : number.replace('tel:', '');
        numberEl.textContent = formatted;
        copyBtn.dataset.number = clean.length === 10 ? '1' + clean : clean;
        copyText.textContent = 'Copy number';
        copyBtn.classList.remove('is-copied');
        backdrop.classList.add('is-visible');
        backdrop.setAttribute('aria-hidden', 'false');
        closeBtn.focus();
        backdrop.addEventListener('keydown', trapFocus);
      }

      function hide() {
        backdrop.classList.remove('is-visible');
        backdrop.setAttribute('aria-hidden', 'true');
        backdrop.removeEventListener('keydown', trapFocus);
        if (triggerEl) { triggerEl.focus(); triggerEl = null; }
      }

      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href^="tel:"]');
        if (!link) return;
        if (window.matchMedia('(min-width: 769px)').matches && !('ontouchstart' in window)) {
          e.preventDefault();
          triggerEl = link;
          show(link.getAttribute('href'));
        }
      });

      closeBtn.addEventListener('click', hide);
      backdrop.addEventListener('click', function(e) {
        if (e.target === backdrop) hide();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && backdrop.classList.contains('is-visible')) hide();
      });

      copyBtn.addEventListener('click', function() {
        var num = copyBtn.dataset.number || '';
        if (navigator.clipboard) {
          navigator.clipboard.writeText(num).then(function() {
            copyText.textContent = 'Copied!';
            copyBtn.classList.add('is-copied');
            setTimeout(function() {
              copyText.textContent = 'Copy number';
              copyBtn.classList.remove('is-copied');
            }, 2000);
          });
        }
      });
    })();
  </script>
</body>
</html>
