---
/**
 * BaseLayout — shared HTML shell for all pages.
 * Absorbs the ~30 lines of <head> boilerplate duplicated across 29 pages.
 */
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  robots?: string;
  schemaJson?: Record<string, unknown>;
  bodyClass?: string;
  includeMainCss?: boolean;
}

const {
  title,
  description = '',
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://bertrandbrands.ca/og-image.png',
  robots,
  schemaJson,
  bodyClass = '',
  includeMainCss = true,
} = Astro.props;

const gtmId = import.meta.env.PUBLIC_GTM_ID || '';
const effectiveOgTitle = ogTitle || title;
const effectiveOgDescription = ogDescription || description;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0a0a0a">

  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {canonical && <link rel="canonical" href={canonical} />}
  {robots && <meta name="robots" content={robots} />}

  {/* Open Graph */}
  <meta property="og:title" content={effectiveOgTitle} />
  {effectiveOgDescription && <meta property="og:description" content={effectiveOgDescription} />}
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_CA" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Bertrand Brands | Brand & Web Systems" />

  {/* Twitter / X Card */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={effectiveOgTitle} />
  {effectiveOgDescription && <meta name="twitter:description" content={effectiveOgDescription} />}
  <meta name="twitter:image" content={ogImage} />

  {/* Favicon & Touch Icons */}
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="BG Brands" />
  <link rel="manifest" href="/site.webmanifest" />

  {/* Schema.org */}
  {schemaJson && (
    <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />
  )}

  {/* Third-party preconnect */}
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
  <link rel="preconnect" href="https://use.typekit.net" crossorigin />
  <link rel="dns-prefetch" href="https://formspree.io" />

  {/* Analytics — GTM container (PUBLIC_GTM_ID) or direct gtag.js fallback */}
  {gtmId && (
    <script is:inline define:vars={{ gtmId }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',gtmId);
    </script>
  )}
  {!gtmId && <script is:inline src="https://www.googletagmanager.com/gtag/js?id=AW-17925090292" async></script>}
  {!gtmId && (
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-17925090292');
      gtag('config', 'G-CFMDTBXNV7');
    </script>
  )}

  {/* Conversion + event tracking — dataLayer-first (GTM-ready) + gtag fallback */}
  <script is:inline>
    window.dataLayer = window.dataLayer || [];

    /* Unified conversion helper — pushes to dataLayer (GTM) + fires gtag (direct) */
    window.bbConvert = function(type, label, value) {
      dataLayer.push({
        event: 'bb_convert',
        bb_type: type,
        bb_label: label,
        bb_value: value || 0,
        bb_currency: 'CAD'
      });
      if (typeof gtag === 'function') {
        gtag('event', 'generate_lead', {
          event_category: type,
          event_label: label,
          value: value || 0,
          currency: 'CAD'
        });
        gtag('event', 'conversion', {
          send_to: 'AW-17925090292/3B0-CJDv6vUbEPTXrONC',
          value: value || 1.0,
          currency: 'CAD'
        });
      }
    };
  </script>

  {/* Global tel: and mailto: click tracking */}
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href]');
        if (!link) return;
        var href = link.getAttribute('href') || '';
        if (href.startsWith('tel:') || href.startsWith('mailto:')) {
          var isPhone = href.startsWith('tel:');
          dataLayer.push({ event: isPhone ? 'phone_click' : 'email_click', bb_label: isPhone ? 'global_tel' : 'global_mailto' });
          if (typeof gtag === 'function') {
            gtag('event', 'conversion', { send_to: 'AW-17925090292/ueyZCPOf6_UbEPTXrONC' });
          }
        }
      });
    });
  </script>

  {/* Fonts */}
  <link rel="stylesheet" href="https://use.typekit.net/dmk8daz.css">
  <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/styles/fonts.css">

  {/* Styles — tokens loaded sync (7KB, custom properties), shared deferred (58KB) */}
  {includeMainCss && <link rel="stylesheet" href="/styles/tokens.css" />}
  {includeMainCss && <link rel="stylesheet" href="/styles/shared.css" media="print" />}
  {includeMainCss && (
    <script is:inline>
      /* Defer shared.css — load after first paint, then apply */
      (function(){
        var s = document.querySelector('link[href="/styles/shared.css"]');
        if (s) { s.onload = function(){ s.media = 'all'; }; }
      })();
    </script>
  )}
  {includeMainCss && (
    <noscript><link rel="stylesheet" href="/styles/shared.css" /></noscript>
  )}

  {/* Critical CSS — inlined above-the-fold styles for fast first paint */}
  {includeMainCss && (
    <style is:inline>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html { font-size: 15px; touch-action: pan-x pan-y; }
      @media (min-width: 768px) { html { font-size: 16px; } }
      @supports (-webkit-touch-callout: none) { html { -webkit-text-size-adjust: 100%; } }
      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }
      .form-honeypot { display: none; }
      .page { min-height: 100vh; min-height: 100dvh; display: flex; flex-direction: column; }
      .container { width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }
      .header {
        padding: 0.75rem clamp(1rem, 4vw, 2rem);
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        opacity: 0; transform: translateY(-20px); visibility: hidden; pointer-events: none;
      }
      .header.visible { opacity: 1; transform: translateY(0); z-index: 1050; visibility: visible; pointer-events: auto; }
      .header__glass {
        max-width: 1200px; margin: 0 auto; padding: 0.75rem 1.5rem;
        background: color-mix(in srgb, var(--bg) 25%, transparent);
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--border); border-radius: var(--radius-md);
        position: relative; overflow: visible;
      }
      .header__inner { display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1; }
      .header__logo { display: flex; align-items: center; white-space: nowrap; flex-shrink: 0; }
      .header__logo-icon { width: 32px; height: auto; margin-right: 0.75rem; filter: brightness(0) invert(1); opacity: 0; }
      .header__logo.show-text .header__logo-icon { opacity: 1; }
      .header__wordmark {
        display: inline-flex; align-items: baseline; opacity: 0;
        font-family: var(--font-display); font-weight: var(--font-normal);
        font-size: 0.9rem; letter-spacing: 0.2em; text-transform: uppercase;
        color: var(--text); white-space: nowrap; overflow: hidden;
      }
      .header__logo.show-text .header__wordmark { opacity: 1; }
      .header__wordmark-short { display: none; }
      .header__wordmark-full { display: inline-flex; align-items: baseline; white-space: nowrap; }
      .header__wordmark-sep { display: inline-block; opacity: 0; max-width: 0; overflow: hidden; }
      .header__wordmark-sub { display: inline-block; opacity: 0; max-width: 0; overflow: hidden; }
      .header__nav { display: flex; align-items: center; gap: 1.5rem; }
      .header__link { font-size: var(--text-xs); color: var(--text-muted); padding: 0.5rem 0; white-space: nowrap; }
      .header__link--cta { color: var(--accent); font-weight: var(--font-medium); }
      .header__link--portal {
        padding: 0.375rem 0.75rem; border: 1px solid var(--border);
        border-radius: var(--radius-sm); font-size: var(--text-xs); color: var(--text-muted);
      }
      .header__divider { display: inline-block; width: 1px; height: 1.5rem; background: var(--border); }
      .header__toggle { display: none; }
      .header__link--cta-call { display: none; }
      .header__link--cta-form { display: inline-flex; }
      @media (max-width: 1024px) {
        .header__toggle {
          display: flex; width: 24px; height: 24px; flex-direction: column;
          justify-content: space-between; background: none; border: none;
          cursor: pointer; padding: 10px; box-sizing: content-box;
        }
        .header__toggle span { display: block; width: 100%; height: 2px; background: currentColor; filter: brightness(0) invert(1); transition: transform 0.3s ease, opacity 0.3s ease; }
        .header__toggle.is-open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
        .header__toggle.is-open span:nth-child(2) { opacity: 0; }
        .header__toggle.is-open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
        .header__nav { display: none; }
        .header__nav.is-open {
          display: flex; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
          width: 100vw; height: 100vh; height: 100dvh;
          background: rgba(var(--bg-rgb), 0.98);
          backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
          flex-direction: column; align-items: center; justify-content: center;
          gap: 2rem; z-index: 1100;
          padding: 4rem 2rem calc(2rem + env(safe-area-inset-bottom, 0px));
          box-sizing: border-box; overflow-y: auto; overflow-x: hidden;
        }
        .header__nav.is-open .header__link { font-size: var(--text-xl); }
        .header__nav.is-open .header__link--cta-call { display: inline-flex; }
        .header__nav.is-open .header__link--cta-form { display: inline-flex; }
        .header__wordmark-short { display: inline !important; }
        .header__wordmark-full { display: none !important; }
        .header__wordmark { font-size: 0.8rem; }
        .header__link--cta-call { display: inline-flex; }
        .header__link--cta-form { display: none; }
      }
      .intake-header {
        position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
        padding: var(--space-sm) 1.5rem;
        background: rgba(var(--bg-rgb), 0.9);
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
      }
      .intake-header__inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
      .intake-header__back { font-size: var(--text-sm); color: var(--text-muted); display: flex; align-items: center; gap: 0.375rem; min-width: 80px; }
      .intake-header__logo { display: flex; align-items: center; gap: 0.75rem; color: var(--text); }
      .intake-header__logo-icon { width: 24px; height: auto; filter: brightness(0) invert(1); }
      .intake-header__logo-text {
        font-family: var(--font-display); font-size: var(--text-sm);
        font-weight: var(--font-normal); letter-spacing: 0.15em; text-transform: uppercase;
      }
      .intake-header__spacer { min-width: 80px; }
      .skip-link {
        position: fixed; top: -100%; left: 1rem; padding: 0.75rem 1rem;
        background: var(--text); color: var(--bg); border-radius: var(--radius-sm);
        z-index: 10001; text-decoration: none;
      }
      .skip-link:focus { top: 1rem; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
  )}

  {/* Page-specific head content */}
  <slot name="head" />

  {/* Astro View Transitions — smooth page navigation */}
  <ClientRouter fallback="none" />
</head>
<body class={bodyClass}>
  {/* GTM noscript fallback — only renders when PUBLIC_GTM_ID is set */}
  {gtmId && (
    <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`} height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  )}
  <slot />

  {/* Phone modal — desktop intercept for tel: links (requires shared.css for styling) */}
  {includeMainCss && (
    <Fragment>
      <div class="phone-modal-backdrop" id="phoneModal" aria-hidden="true" role="dialog" aria-label="Phone number">
        <div class="phone-modal">
          <button class="phone-modal__close" aria-label="Close" id="phoneModalClose">&times;</button>
          <p class="phone-modal__label">Please call</p>
          <p class="phone-modal__number" id="phoneModalNumber">(705) 413-3705</p>
          <button class="phone-modal__copy" id="phoneModalCopy">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <span id="phoneModalCopyText">Copy number</span>
          </button>
        </div>
      </div>
      <script is:inline>
        (function() {
          var isDesktop = window.matchMedia('(min-width: 769px)').matches && !('ontouchstart' in window);
          if (!isDesktop) return;

          var backdrop = document.getElementById('phoneModal');
          var closeBtn = document.getElementById('phoneModalClose');
          var copyBtn = document.getElementById('phoneModalCopy');
          var copyText = document.getElementById('phoneModalCopyText');
          var numberEl = document.getElementById('phoneModalNumber');
          if (!backdrop) return;

          var triggerEl = null;

          function trapFocus(e) {
            if (e.key !== 'Tab') return;
            var focusable = backdrop.querySelectorAll('button, [href], [tabindex]:not([tabindex="-1"])');
            var first = focusable[0];
            var last = focusable[focusable.length - 1];
            if (e.shiftKey) {
              if (document.activeElement === first) { e.preventDefault(); last.focus(); }
            } else {
              if (document.activeElement === last) { e.preventDefault(); first.focus(); }
            }
          }

          function show(number) {
            var clean = number.replace(/^tel:\+?1?/, '').replace(/\D/g, '');
            var formatted = clean.length === 10
              ? '(' + clean.slice(0,3) + ') ' + clean.slice(3,6) + '-' + clean.slice(6)
              : number.replace('tel:', '');
            numberEl.textContent = formatted;
            copyBtn.dataset.number = clean.length === 10 ? '1' + clean : clean;
            copyText.textContent = 'Copy number';
            copyBtn.classList.remove('is-copied');
            backdrop.classList.add('is-visible');
            backdrop.setAttribute('aria-hidden', 'false');
            closeBtn.focus();
            backdrop.addEventListener('keydown', trapFocus);
          }

          function hide() {
            backdrop.classList.remove('is-visible');
            backdrop.setAttribute('aria-hidden', 'true');
            backdrop.removeEventListener('keydown', trapFocus);
            if (triggerEl) { triggerEl.focus(); triggerEl = null; }
          }

          document.addEventListener('click', function(e) {
            var link = e.target.closest('a[href^="tel:"]');
            if (!link) return;
            if (window.matchMedia('(min-width: 769px)').matches && !('ontouchstart' in window)) {
              e.preventDefault();
              triggerEl = link;
              show(link.getAttribute('href'));
            }
          });

          closeBtn.addEventListener('click', hide);
          backdrop.addEventListener('click', function(e) {
            if (e.target === backdrop) hide();
          });
          document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && backdrop.classList.contains('is-visible')) hide();
          });

          copyBtn.addEventListener('click', function() {
            var num = copyBtn.dataset.number || '';
            if (navigator.clipboard) {
              navigator.clipboard.writeText(num).then(function() {
                copyText.textContent = 'Copied!';
                copyBtn.classList.add('is-copied');
                setTimeout(function() {
                  copyText.textContent = 'Copy number';
                  copyBtn.classList.remove('is-copied');
                }, 2000);
              });
            }
          });
        })();
      </script>
    </Fragment>
  )}
</body>
</html>
