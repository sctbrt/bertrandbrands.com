                        </ul>
                    </div>
                </div>
            </section>

            <!-- goods.scottbertrand.com -->
            <section class="domain">
                <div class="domain__header">
                    <svg class="domain__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    <span class="domain__name"><a href="https://goods.scottbertrand.com" target="_blank" rel="noopener noreferrer">goods.scottbertrand.com</a></span>
                    <span class="domain__badge domain__badge--secondary">Store</span>
                </div>
                <div class="domain__pages">
                    <div class="domain__section">
                        <h2 class="domain__section-title">Store</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://goods.scottbertrand.com/" target="_blank" rel="noopener noreferrer">Shop</a></li>
                        </ul>
                    </div>
                </div>
            </section>
        </div>

        <footer class="sitemap__footer">
            <p>Updated March 2026 &middot; <a href="/">Back to Bertrand Brands</a></p>
        </footer>
    </main>

    <GesturePrevention />
    <VisitorNotify />
    <VersionStamp />
</BaseLayout>
