                    <span class="domain__name"><a href="https://notes.scottbertrand.com" target="_blank" rel="noopener noreferrer">notes.scottbertrand.com</a></span>
                    <span class="domain__badge domain__badge--secondary">Blog</span>
                </div>
                <div class="domain__pages">
                    <div class="domain__section">
                        <h2 class="domain__section-title">Notes</h2>
                        <ul class="page-list">
