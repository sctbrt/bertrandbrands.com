                            <li class="page-list__item"><a href="https://scottbertrand.com/contact" target="_blank" rel="noopener noreferrer">Contact</a></li>
                        </ul>
                    </div>
                    <div class="domain__section">
                        <h2 class="domain__section-title">Content Pages</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://scottbertrand.com/field-notes" target="_blank" rel="noopener noreferrer">Field Notes</a></li>
                        </ul>
                    </div>
                </div>
            </section>

            <!-- dashboard.bertrandgroup.ca -->
            <section class="domain">
                <div class="domain__header">
                    <svg class="domain__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    <span class="domain__name"><a href="https://dashboard.bertrandgroup.ca" target="_blank" rel="noopener noreferrer">dashboard.bertrandgroup.ca</a></span>
                    <span class="domain__badge domain__badge--secondary">Internal</span>
                </div>
                <div class="domain__pages">
                    <div class="domain__section">
                        <h2 class="domain__section-title">Dashboard Pages</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://dashboard.bertrandgroup.ca/" target="_blank" rel="noopener noreferrer">Overview</a></li>
                            <li class="page-list__item"><a href="https://dashboard.bertrandgroup.ca/leads" target="_blank" rel="noopener noreferrer">Leads</a></li>
                            <li class="page-list__item"><a href="https://dashboard.bertrandgroup.ca/clients" target="_blank" rel="noopener noreferrer">Clients</a></li>
                            <li class="page-list__item"><a href="https://dashboard.bertrandgroup.ca/projects" target="_blank" rel="noopener noreferrer">Projects</a></li>
                            <li class="page-list__item"><a href="https://dashboard.bertrandgroup.ca/invoices" target="_blank" rel="noopener noreferrer">Invoices</a></li>
                            <li class="page-list__item"><a href="https://dashboard.bertrandgroup.ca/templates" target="_blank" rel="noopener noreferrer">Templates</a></li>
                        </ul>
                    </div>
                </div>
            </section>

            <!-- clients.bertrandgroup.ca -->
            <section class="domain">
                <div class="domain__header">
                    <svg class="domain__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    <span class="domain__name"><a href="https://clients.bertrandgroup.ca" target="_blank" rel="noopener noreferrer">clients.bertrandgroup.ca</a></span>
