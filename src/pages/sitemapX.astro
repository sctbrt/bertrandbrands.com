---
/**
 * Ecosystem Sitemap — All pages across Scott Bertrand digital properties.
 * Self-contained page with inline styles. Does not use main.css.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SkipLink from '../components/SkipLink.astro';
import GesturePrevention from '../components/GesturePrevention.astro';
import VisitorNotify from '../components/VisitorNotify.astro';
import VersionStamp from '../components/VersionStamp.astro';

---

<BaseLayout
    title="Ecosystem Sitemap — Bertrand Brands"
    description="Complete page listing for Bertrand Brands and related properties."
    robots="noindex"
    includeMainCss={false}
>
    <Fragment slot="head">
        <style is:inline>
            *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
            html { touch-action: pan-x pan-y; }
            @supports (-webkit-touch-callout: none) { html { -webkit-text-size-adjust: 100%; } }

            :root {
                --bg: #0a0a0a; --bg-elevated: #111111; --bg-card: #161616;
                --text: #fafafa; --text-muted: #888888; --text-subtle: #555555;
                --accent: #D97706; --accent-hover: #B45309;
                --border: rgba(255, 255, 255, 0.08);
                --font-display: halyard-display, sans-serif;
                --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                --radius-md: 8px; --radius-lg: 12px;
                --text-xs: 0.75rem; --text-sm: 0.875rem; --text-base: 1rem;
            }

            @media (prefers-reduced-motion: reduce) {
                *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
            }

            body {
                font-family: var(--font-body); background: var(--bg); color: var(--text);
                line-height: 1.6; -webkit-font-smoothing: antialiased;
                min-height: 100vh; padding: 2rem;
            }

            .sitemap { max-width: 1000px; margin: 0 auto; }
            .sitemap__header { text-align: center; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
            .sitemap__logomark {
                width: 48px; height: auto; margin-bottom: 1rem;
                filter: brightness(0) saturate(100%) invert(48%) sepia(89%) saturate(1000%) hue-rotate(4deg) brightness(88%);
            }
            .sitemap__title { font-family: var(--font-display); font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 400; margin-bottom: 0.5rem; color: var(--text); }
            .sitemap__subtitle { font-size: var(--text-base); color: var(--text-muted); }
            .sitemap__domains { display: grid; gap: 2rem; }
            .domain { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; }
            .domain__header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
            .domain__icon { width: 24px; height: 24px; color: var(--accent); }
            .domain__name { font-size: var(--text-base); font-weight: 600; color: var(--text); }
            .domain__name a { color: inherit; text-decoration: none; }
            .domain__name a:hover { color: var(--accent); }
            .domain__badge { font-size: var(--text-xs); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.25rem 0.5rem; border-radius: 4px; background: var(--accent); color: white; margin-left: auto; }
            .domain__badge--secondary { background: var(--border); color: var(--text-muted); }
            .domain__pages { list-style: none; }
            .domain__section { margin-bottom: 1rem; }
            .domain__section:last-child { margin-bottom: 0; }
            .domain__section-title { font-size: var(--text-xs); font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-subtle); margin-bottom: 0.5rem; }
            .page-list { list-style: none; display: grid; gap: 0.25rem; }
            .page-list__item a { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; color: var(--text-muted); text-decoration: none; font-size: var(--text-sm); border-radius: 6px; transition: all 0.15s ease; }
            .page-list__item a:hover { background: rgba(255, 255, 255, 0.04); color: var(--text); }
            .page-list__item a::before { content: '\2192'; color: var(--text-subtle); font-size: var(--text-xs); }
            .page-list__item a:hover::before { color: var(--accent); }
            .sitemap__footer { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); text-align: center; font-size: var(--text-sm); color: var(--text-subtle); }
            .sitemap__footer a { color: var(--text-muted); text-decoration: none; }
            .sitemap__footer a:hover { color: var(--accent); }
            :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
        </style>
    </Fragment>

    <SkipLink />

    <main class="sitemap" id="main-content">
        <header class="sitemap__header">
            <img src="/assets/dot-logomark.svg" alt="" class="sitemap__logomark" width="40" height="40" loading="eager" fetchpriority="high" />
            <h1 class="sitemap__title">Ecosystem Sitemap</h1>
            <p class="sitemap__subtitle">All pages across the Scott Bertrand digital properties</p>
        </header>

        <div class="sitemap__domains">
            <!-- bertrandbrands.ca -->
            <section class="domain">
                <div class="domain__header">
                    <svg class="domain__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    <span class="domain__name"><a href="https://bertrandbrands.ca" target="_blank" rel="noopener noreferrer">bertrandbrands.ca</a></span>
                    <span class="domain__badge">Primary</span>
                </div>
                <div class="domain__pages">
                    <div class="domain__section">
                        <h2 class="domain__section-title">Main Pages</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/" target="_blank" rel="noopener noreferrer">Homepage</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/?skip#packages" target="_blank" rel="noopener noreferrer">Services</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/?skip#process" target="_blank" rel="noopener noreferrer">How It Works</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/?skip#about" target="_blank" rel="noopener noreferrer">About</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/?skip#contact" target="_blank" rel="noopener noreferrer">Contact</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/compare" target="_blank" rel="noopener noreferrer">Compare Services</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/intake" target="_blank" rel="noopener noreferrer">Get a Quote</a></li>
                        </ul>
                    </div>
                    <div class="domain__section">
                        <h2 class="domain__section-title">B Build (Amber)</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/build" target="_blank" rel="noopener noreferrer">Build Hub</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/build/starter-onepage" target="_blank" rel="noopener noreferrer">Starter One-Page + Contact ($750)</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/build/starter-multipage" target="_blank" rel="noopener noreferrer">Starter Multi-Page + Contact</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/build/fullsite-booking" target="_blank" rel="noopener noreferrer">Full Site + Booking</a></li>
                        </ul>
                    </div>
                    <div class="domain__section">
                        <h2 class="domain__section-title">B Transform (Violet)</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/transform" target="_blank" rel="noopener noreferrer">Transform Hub</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/transform/foundation-growth" target="_blank" rel="noopener noreferrer">Website Foundation + Growth System</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/transform/smb-platform" target="_blank" rel="noopener noreferrer">SMB Platform Development</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/transform/brand-platform" target="_blank" rel="noopener noreferrer">Brand Design + Platform Development</a></li>
                        </ul>
                    </div>
                    <div class="domain__section">
                        <h2 class="domain__section-title">B Care (Blue)</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/care" target="_blank" rel="noopener noreferrer">Care Hub</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/care/bronze" target="_blank" rel="noopener noreferrer">Bronze Plan ($249/mo)</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/care/silver" target="_blank" rel="noopener noreferrer">Silver Plan ($649/mo)</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/care/gold" target="_blank" rel="noopener noreferrer">Gold Plan (by application)</a></li>
                        </ul>
                    </div>
                    <div class="domain__section">
                        <h2 class="domain__section-title">Campaigns</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/sudbury" target="_blank" rel="noopener noreferrer">Sudbury Local Campaign</a></li>
                        </ul>
                    </div>
                    <div class="domain__section">
                        <h2 class="domain__section-title">Booking &amp; Confirmation</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/booking/schedule" target="_blank" rel="noopener noreferrer">Schedule a Call</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/booking-confirmed" target="_blank" rel="noopener noreferrer">Booking Confirmed</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/payment-confirmed" target="_blank" rel="noopener noreferrer">Payment Confirmed</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/snapshot-confirmed" target="_blank" rel="noopener noreferrer">Snapshot Confirmed</a></li>
                        </ul>
                    </div>
                    <div class="domain__section">
                        <h2 class="domain__section-title">Utility</h2>
                        <ul class="page-list">
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/scottbertrand" target="_blank" rel="noopener noreferrer">Scott Bertrand</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/group" target="_blank" rel="noopener noreferrer">Bertrand Group</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/thanks" target="_blank" rel="noopener noreferrer">Thank You</a></li>
                            <li class="page-list__item"><a href="https://bertrandbrands.ca/sitemapX" target="_blank" rel="noopener noreferrer">Ecosystem Sitemap</a></li>
                        </ul>
                    </div>
                </div>
            </section>

            <!-- scottbertrand.com -->
            <section class="domain">
                <div class="domain__header">
                    <svg class="domain__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <span class="domain__name"><a href="https://scottbertrand.com" target="_blank" rel="noopener noreferrer">scottbertrand.com</a></span>
                    <span class="domain__badge domain__badge--secondary">Hub</span>
                </div>
                <div class="domain__pages">
                    <div class="domain__section">
                        <h2 class="domain__section-title">Main Pages</h2>
                        <ul class="page-list">
