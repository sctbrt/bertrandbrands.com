</BaseLayout>

<style is:inline>
    :root {
      --bg: #0a0a0a;
      --bg-elevated: #161618;
      --text: #fafafa;
      --text-muted: #a3a3a3;
      --text-subtle: #737373;
      --accent: #D97706;
      --border: rgba(255, 255, 255, 0.10);
      --border-hover: rgba(255, 255, 255, 0.20);
      --font-display: halyard-display, sans-serif;
      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { font-size: 16px; -webkit-text-size-adjust: 100%; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      min-height: 100vh;
      min-height: 100dvh;
    }

    .lab {
      max-width: 920px;
      margin: 0 auto;
      padding: clamp(2rem, 6vw, 5rem) clamp(1.5rem, 4vw, 3rem) clamp(3rem, 8vw, 6rem);
    }

    .lab__header { margin-bottom: 3rem; }
    .lab__eyebrow {
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-subtle);
      margin-bottom: 1rem;
    }
    .lab__title {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: clamp(2.5rem, 6vw, 3.5rem);
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 0.75rem;
    }
    .lab__sub {
      color: var(--text-muted);
      font-size: 1rem;
      max-width: 560px;
    }

    .lab {
      max-width: 1400px;
    }
    .lab__grid {
      display: grid;
      gap: 1.25rem;
      grid-template-columns: repeat(3, 1fr);
    }
    @media (max-width: 1100px) {
      .lab__grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 720px) {
      .lab__grid { grid-template-columns: 1fr; }
    }

    .lab__card {
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
    }
    .lab__card-label {
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 500;
    }
    .lab__card-desc {
      color: var(--text-muted);
      font-size: 0.875rem;
      line-height: 1.65;
      min-height: 5rem;
    }
    .lab__card-desc em {
      color: var(--text);
      font-style: normal;
      font-weight: 500;
    }

    .lab__note {
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      color: var(--text-subtle);
      font-size: 0.8125rem;
      line-height: 1.7;
    }

    /* ============================================================
       Auto-play control
       ============================================================ */
    .lab__controls {
      margin-top: 1.5rem;
    }
    .lab__autoplay {
      display: inline-flex;
      align-items: center;
      gap: 0.625rem;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text-muted);
      font-family: var(--font-body);
      font-size: 0.8125rem;
      padding: 0.625rem 1.125rem 0.625rem 0.875rem;
      cursor: pointer;
      transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
    }
    .lab__autoplay:hover {
      border-color: var(--border-hover);
      color: var(--text);
    }
    .lab__autoplay-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--text-subtle);
      transition: background 0.2s ease, box-shadow 0.2s ease;
    }
    .lab__autoplay[aria-pressed="true"] {
      color: var(--text);
      border-color: var(--accent);
    }
    .lab__autoplay[aria-pressed="true"] .lab__autoplay-dot {
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
      animation: autoplayPulse 1.6s ease-in-out infinite;
    }
    @keyframes autoplayPulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* ============================================================
       Shared toggle button shell — bumped to 140px so the icon is
       actually evaluable
       ============================================================ */
    .lab__toggle {
      align-self: center;
      width: 140px;
      height: 140px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border);
      border-radius: 18px;
      cursor: pointer;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.25s ease, border-color 0.25s ease;
      margin-top: 1rem;
      color: var(--text);
    }
    .lab__toggle:hover {
      background: rgba(255, 255, 255, 0.07);
      border-color: var(--border-hover);
    }
    .lab__toggle:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* ============================================================
       Variant A — Pen-stroke draw
       Hamburger and X are SVG <line>s using stroke-dasharray and
       stroke-dashoffset to retract or draw themselves. No morphing,
       no rotation — the lines live in two separate sets that
       cross-fade via stroke geometry alone.
       ============================================================ */
    .lab__toggle--a .lab__toggle-strokes {
      color: var(--text);
      overflow: visible;
    }
    .lab__toggle--a .lab__stroke {
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      transition: stroke-dashoffset 0.36s cubic-bezier(0.65, 0, 0.35, 1);
    }
    /* Closed state: hamburger drawn, X retracted */
    .lab__toggle--a .lab__stroke--ham {
      stroke-dasharray: 18;       /* line length = 21 - 3 = 18 */
      stroke-dashoffset: 0;
    }
    .lab__toggle--a .lab__stroke--x {
      stroke-dasharray: 20;       /* line length ≈ 19.8 */
      stroke-dashoffset: 20;
    }
    /* Open state: hamburger retracted, X drawn */
    .lab__toggle--a.is-open .lab__stroke--ham {
      stroke-dashoffset: 18;
    }
    .lab__toggle--a.is-open .lab__stroke--x {
      stroke-dashoffset: 0;
    }
    /* Internal stagger — top hamburger first, X arms slightly offset */
    .lab__toggle--a .lab__stroke--ham[data-line="0"] { transition-delay: 0ms; }
    .lab__toggle--a .lab__stroke--ham[data-line="1"] { transition-delay: 40ms; }
    .lab__toggle--a .lab__stroke--ham[data-line="2"] { transition-delay: 80ms; }
    .lab__toggle--a .lab__stroke--x[data-line="0"]   { transition-delay: 0ms; }
    .lab__toggle--a .lab__stroke--x[data-line="1"]   { transition-delay: 70ms; }

    /* ============================================================
       Variant B — Pixel-grid morph (5×5 dot matrix)
       Hamburger and X are two patterns drawn in the same fixed
       grid. Five dots (corners + center) belong to both patterns
       and stay lit throughout — they are anchors. Ham-only and
       x-only dots cross-fade with a top→bottom row stagger.
       ============================================================ */
    .lab__toggle--b .lab__toggle-grid {
      color: var(--text);
      overflow: visible;
    }
    .lab__toggle--b .lab__dot {
      fill: currentColor;
      transform-origin: center;
      transform-box: fill-box;
      transition:
        opacity 0.30s ease,
        transform 0.34s cubic-bezier(0.34, 1.4, 0.64, 1);
    }

    /* Closed state: hamburger pattern + anchors lit, X-only off */
    .lab__toggle--b .lab__dot--ham,
    .lab__toggle--b .lab__dot--both {
      opacity: 0.92;
      transform: scale(1);
    }
    .lab__toggle--b .lab__dot--x {
      opacity: 0;
      transform: scale(0.25);
    }

    /* Open state: X pattern + anchors lit, ham-only off */
    .lab__toggle--b.is-open .lab__dot--ham {
      opacity: 0;
      transform: scale(0.25);
    }
    .lab__toggle--b.is-open .lab__dot--x {
      opacity: 0.92;
      transform: scale(1);
    }
    /* .lab__dot--both intentionally unchanged across states */

    /* Wave stagger top→bottom by row */
    .lab__toggle--b .lab__dot[data-row="0"] { transition-delay: 0ms; }
    .lab__toggle--b .lab__dot[data-row="1"] { transition-delay: 35ms; }
    .lab__toggle--b .lab__dot[data-row="2"] { transition-delay: 70ms; }
    .lab__toggle--b .lab__dot[data-row="3"] { transition-delay: 105ms; }
    .lab__toggle--b .lab__dot[data-row="4"] { transition-delay: 140ms; }

    /* ============================================================
       Variant C — Refined pixel-grid (center-out + anchor pulse +
       brighter anchors). Same DOM shape as B, swap stagger basis.
       ============================================================ */
    .lab__toggle--c .lab__toggle-grid {
      color: var(--text);
      overflow: visible;
    }
    .lab__toggle--c .lab__dot {
      fill: currentColor;
      transform-origin: center;
      transform-box: fill-box;
      transition:
        opacity 0.30s ease,
        transform 0.34s cubic-bezier(0.34, 1.4, 0.64, 1);
    }

    /* Closed: hamburger + anchors lit. Anchors brighter (1.0 vs 0.82). */
    .lab__toggle--c .lab__dot--ham { opacity: 0.82; transform: scale(1); }
    .lab__toggle--c .lab__dot--both { opacity: 1; transform: scale(1); }
    .lab__toggle--c .lab__dot--x { opacity: 0; transform: scale(0.25); }

    /* Open: X + anchors lit */
    .lab__toggle--c.is-open .lab__dot--ham {
      opacity: 0;
      transform: scale(0.25);
    }
    .lab__toggle--c.is-open .lab__dot--x {
      opacity: 0.82;
      transform: scale(1);
    }

    /* Center-out radial stagger (data-tier 0 = center, 5 = corners) */
    .lab__toggle--c .lab__dot[data-tier="0"] { transition-delay: 0ms; }
    .lab__toggle--c .lab__dot[data-tier="1"] { transition-delay: 30ms; }
    .lab__toggle--c .lab__dot[data-tier="2"] { transition-delay: 55ms; }
    .lab__toggle--c .lab__dot[data-tier="3"] { transition-delay: 80ms; }
    .lab__toggle--c .lab__dot[data-tier="4"] { transition-delay: 105ms; }
    .lab__toggle--c .lab__dot[data-tier="5"] { transition-delay: 130ms; }

    /* Anchor pulse — runs on every toggle via .is-pulsing class (added by JS) */
    .lab__toggle--c.is-pulsing .lab__dot--both {
      animation: anchorPulse 0.46s ease;
    }
    @keyframes anchorPulse {
      0%   { transform: scale(1);    opacity: 1; }
      40%  { transform: scale(1.18); opacity: 1; }
      100% { transform: scale(1);    opacity: 1; }
    }

    /* ============================================================
       Variant D — C + Pull Focus blur tie-in
       Mid-transition the entire grid briefly softens, then resolves.
       Direct callback to v13.7 intro mechanic.
       ============================================================ */
    .lab__toggle--d .lab__toggle-grid {
      color: var(--text);
      overflow: visible;
    }
    .lab__toggle--d .lab__dot {
      fill: currentColor;
      transform-origin: center;
      transform-box: fill-box;
      transition:
        opacity 0.30s ease,
        transform 0.34s cubic-bezier(0.34, 1.4, 0.64, 1);
    }
    .lab__toggle--d .lab__dot--ham { opacity: 0.82; transform: scale(1); }
    .lab__toggle--d .lab__dot--both { opacity: 1; transform: scale(1); }
    .lab__toggle--d .lab__dot--x { opacity: 0; transform: scale(0.25); }

    .lab__toggle--d.is-open .lab__dot--ham {
      opacity: 0;
      transform: scale(0.25);
    }
    .lab__toggle--d.is-open .lab__dot--x {
      opacity: 0.82;
      transform: scale(1);
    }

    .lab__toggle--d .lab__dot[data-tier="0"] { transition-delay: 0ms; }
    .lab__toggle--d .lab__dot[data-tier="1"] { transition-delay: 30ms; }
    .lab__toggle--d .lab__dot[data-tier="2"] { transition-delay: 55ms; }
    .lab__toggle--d .lab__dot[data-tier="3"] { transition-delay: 80ms; }
    .lab__toggle--d .lab__dot[data-tier="4"] { transition-delay: 105ms; }
    .lab__toggle--d .lab__dot[data-tier="5"] { transition-delay: 130ms; }

    .lab__toggle--d.is-pulsing .lab__dot--both {
      animation: anchorPulse 0.46s ease;
    }
    /* Pull Focus blur on the whole grid */
    .lab__toggle--d.is-pulsing .lab__toggle-grid {
      animation: pullFocus 0.50s ease;
    }
    @keyframes pullFocus {
      0%   { filter: blur(0); }
      45%  { filter: blur(1.4px); }
      100% { filter: blur(0); }
    }

    /* ============================================================
       Variant E — Magnetic snap
       Three lines slide vertically to collide at center, then outer
       two rotate 45° to form X. Middle vanishes at the impact moment.
       Heavy under-/over-shoot bezier gives the "snap" feel.
       ============================================================ */
    .lab__toggle--e .lab__toggle-mag { color: var(--text); overflow: visible; }
    .lab__toggle--e .lab__mag-line {
      fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round;
      transform-origin: center; transform-box: fill-box;
      transition: transform 0.46s cubic-bezier(0.9, -0.4, 0.1, 1.4),
                  opacity 0.28s ease;
    }
    .lab__toggle--e .lab__mag-line[data-line="top"] { transform: translateY(0); }
    .lab__toggle--e .lab__mag-line[data-line="mid"] { transform: scale(1); opacity: 1; }
    .lab__toggle--e .lab__mag-line[data-line="bot"] { transform: translateY(0); }
    .lab__toggle--e.is-open .lab__mag-line[data-line="top"] {
      transform: translateY(6px) rotate(45deg);
    }
    .lab__toggle--e.is-open .lab__mag-line[data-line="mid"] {
      transform: scale(0); opacity: 0;
    }
    .lab__toggle--e.is-open .lab__mag-line[data-line="bot"] {
      transform: translateY(-6px) rotate(-45deg);
    }

    /* ============================================================
       Variant F — Spring overshoot
       Same dot matrix as B; heavy overshoot bezier for theatrical pop.
       ============================================================ */
    .lab__toggle--f .lab__toggle-grid { color: var(--text); overflow: visible; }
    .lab__toggle--f .lab__dot {
      fill: currentColor;
      transform-origin: center; transform-box: fill-box;
      transition: opacity 0.36s ease,
                  transform 0.44s cubic-bezier(0.34, 2.0, 0.55, 0.95);
    }
    .lab__toggle--f .lab__dot--ham,
    .lab__toggle--f .lab__dot--both { opacity: 0.92; transform: scale(1); }
    .lab__toggle--f .lab__dot--x    { opacity: 0; transform: scale(0.25); }
    .lab__toggle--f.is-open .lab__dot--ham { opacity: 0; transform: scale(0.25); }
    .lab__toggle--f.is-open .lab__dot--x   { opacity: 0.92; transform: scale(1); }
    .lab__toggle--f .lab__dot[data-tier="0"] { transition-delay: 0ms; }
    .lab__toggle--f .lab__dot[data-tier="1"] { transition-delay: 30ms; }
    .lab__toggle--f .lab__dot[data-tier="2"] { transition-delay: 55ms; }
    .lab__toggle--f .lab__dot[data-tier="3"] { transition-delay: 80ms; }
    .lab__toggle--f .lab__dot[data-tier="4"] { transition-delay: 105ms; }
    .lab__toggle--f .lab__dot[data-tier="5"] { transition-delay: 130ms; }

    /* ============================================================
       Variant G — Origami fold (card flip)
       Whole icon flips 180° on Y axis. Front face = hamburger,
       back face = X. CSS 3D transforms with preserve-3d.
       ============================================================ */
    .lab__toggle--g { perspective: 600px; }
    .lab__toggle--g .lab__flipper {
      position: relative;
      width: 80px; height: 80px;
      transform-style: preserve-3d;
      transition: transform 0.62s cubic-bezier(0.65, 0, 0.35, 1);
      color: var(--text);
    }
    .lab__toggle--g .lab__flipper-face {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
    }
    .lab__toggle--g .lab__flipper-face--back { transform: rotateY(180deg); }
    .lab__toggle--g.is-open .lab__flipper { transform: rotateY(180deg); }

    /* ============================================================
       Variant H — Logomark cameo
       Inline dotted-B logomark cross-fades with a 9-dot X pattern.
       Subtle scale anchors the transition.
       ============================================================ */
    .lab__toggle--h .lab__toggle-logo { color: var(--text); }
    .lab__toggle--h .lab__logo-b,
    .lab__toggle--h .lab__logo-x {
      transition: opacity 0.36s ease,
                  transform 0.42s cubic-bezier(0.34, 1.4, 0.64, 1);
      transform-origin: center;
      transform-box: fill-box;
    }
    .lab__toggle--h .lab__logo-b { opacity: 1; transform: scale(1); }
    .lab__toggle--h .lab__logo-x { opacity: 0; transform: scale(0.65); }
    .lab__toggle--h.is-open .lab__logo-b { opacity: 0; transform: scale(0.65); }
    .lab__toggle--h.is-open .lab__logo-x { opacity: 1; transform: scale(1); }

    /* ============================================================
       Variant I — Glyph swap (≡ ↔ ×)
       Real Unicode characters cross-dissolve. No vector tricks.
       ============================================================ */
    .lab__toggle--i .lab__glyph {
      position: absolute;
      font-family: var(--font-display);
      font-weight: 300;
      font-size: 64px;
      line-height: 1;
      color: var(--text);
      transition: opacity 0.26s ease, transform 0.26s ease;
      display: block;
    }
    .lab__toggle--i .lab__glyph--ham { opacity: 1; transform: scale(1); letter-spacing: -0.05em; }
    .lab__toggle--i .lab__glyph--x   { opacity: 0; transform: scale(0.8); }
    .lab__toggle--i.is-open .lab__glyph--ham { opacity: 0; transform: scale(0.8); }
    .lab__toggle--i.is-open .lab__glyph--x   { opacity: 1; transform: scale(1); }

    /* ============================================================
       Variant J — Negative-space invert
       Toggle background flips dark → light on open. Lines swap to
       the opposite color via currentColor inheritance.
       ============================================================ */
    .lab__toggle--j {
      transition: background-color 0.36s ease,
                  border-color 0.36s ease,
                  color 0.36s ease;
    }
    .lab__toggle--j .lab__invert-ham,
    .lab__toggle--j .lab__invert-x {
      transition: opacity 0.28s ease;
    }
    .lab__toggle--j .lab__invert-ham { opacity: 1; }
    .lab__toggle--j .lab__invert-x   { opacity: 0; }
    .lab__toggle--j.is-open {
      background-color: var(--text);
      border-color: var(--text);
      color: var(--bg);
    }
    .lab__toggle--j.is-open .lab__invert-ham { opacity: 0; }
    .lab__toggle--j.is-open .lab__invert-x   { opacity: 1; }

    /* ============================================================
       Variant K — Snap-cut (no animation)
       Same dot grid as B, but every transition / animation disabled.
       ============================================================ */
    .lab__toggle--k .lab__toggle-grid { color: var(--text); }
    .lab__toggle--k .lab__dot {
      fill: currentColor;
      transition: none !important;
      animation: none !important;
    }
    .lab__toggle--k .lab__dot--ham,
    .lab__toggle--k .lab__dot--both { opacity: 0.92; }
    .lab__toggle--k .lab__dot--x    { opacity: 0; }
    .lab__toggle--k.is-open .lab__dot--ham { opacity: 0; }
    .lab__toggle--k.is-open .lab__dot--x   { opacity: 0.92; }

    /* ============================================================
       Variant L — Asymmetric timing
       Same dot grid; JS sets --toggle-dur per direction.
       Open ~0.45s, close ~0.20s.
       ============================================================ */
    .lab__toggle--l .lab__toggle-grid { color: var(--text); overflow: visible; }
    .lab__toggle--l .lab__dot {
      fill: currentColor;
      transform-origin: center; transform-box: fill-box;
      transition: opacity var(--toggle-dur, 0.45s) ease,
                  transform calc(var(--toggle-dur, 0.45s) + 0.04s) cubic-bezier(0.34, 1.4, 0.64, 1);
    }
    .lab__toggle--l .lab__dot--ham,
    .lab__toggle--l .lab__dot--both { opacity: 0.92; transform: scale(1); }
    .lab__toggle--l .lab__dot--x    { opacity: 0; transform: scale(0.25); }
    .lab__toggle--l.is-open .lab__dot--ham { opacity: 0; transform: scale(0.25); }
    .lab__toggle--l.is-open .lab__dot--x   { opacity: 0.92; transform: scale(1); }

    /* ============================================================
       Variant M — Inhale / exhale
       L's directional timing plus a brief scale shimmer on the whole
       SVG: ~1.08 on open (breath in), ~0.94 on close (sharp contract).
       Driven by is-opening / is-closing classes from JS.
       ============================================================ */
    .lab__toggle--m .lab__toggle-grid {
      color: var(--text); overflow: visible;
      transform-origin: center;
    }
    .lab__toggle--m .lab__dot {
      fill: currentColor;
      transform-origin: center; transform-box: fill-box;
      transition: opacity var(--toggle-dur, 0.45s) ease,
                  transform calc(var(--toggle-dur, 0.45s) + 0.04s) cubic-bezier(0.34, 1.4, 0.64, 1);
    }
    .lab__toggle--m .lab__dot--ham,
    .lab__toggle--m .lab__dot--both { opacity: 0.92; transform: scale(1); }
    .lab__toggle--m .lab__dot--x    { opacity: 0; transform: scale(0.25); }
    .lab__toggle--m.is-open .lab__dot--ham { opacity: 0; transform: scale(0.25); }
    .lab__toggle--m.is-open .lab__dot--x   { opacity: 0.92; transform: scale(1); }
    .lab__toggle--m.is-opening .lab__toggle-grid { animation: inhale 0.46s ease; }
    .lab__toggle--m.is-closing .lab__toggle-grid { animation: exhale 0.22s ease; }
    @keyframes inhale {
      0%   { transform: scale(1); }
      55%  { transform: scale(1.08); }
      100% { transform: scale(1); }
    }
    @keyframes exhale {
      0%   { transform: scale(1); }
      55%  { transform: scale(0.94); }
      100% { transform: scale(1); }
    }

    /* ============================================================
       Variant N — Amber flash
       C plus a single chromatic punctuation: anchors flash amber at
       the peak of the transition.
       ============================================================ */
    .lab__toggle--n .lab__toggle-grid { color: var(--text); overflow: visible; }
    .lab__toggle--n .lab__dot {
      fill: currentColor;
      transform-origin: center; transform-box: fill-box;
      transition: opacity 0.30s ease,
                  transform 0.34s cubic-bezier(0.34, 1.4, 0.64, 1);
    }
    .lab__toggle--n .lab__dot--ham  { opacity: 0.82; transform: scale(1); }
    .lab__toggle--n .lab__dot--both { opacity: 1;    transform: scale(1); }
    .lab__toggle--n .lab__dot--x    { opacity: 0;    transform: scale(0.25); }
    .lab__toggle--n.is-open .lab__dot--ham { opacity: 0; transform: scale(0.25); }
    .lab__toggle--n.is-open .lab__dot--x   { opacity: 0.82; transform: scale(1); }
    .lab__toggle--n .lab__dot[data-tier="0"] { transition-delay: 0ms; }
    .lab__toggle--n .lab__dot[data-tier="1"] { transition-delay: 30ms; }
    .lab__toggle--n .lab__dot[data-tier="2"] { transition-delay: 55ms; }
    .lab__toggle--n .lab__dot[data-tier="3"] { transition-delay: 80ms; }
    .lab__toggle--n .lab__dot[data-tier="4"] { transition-delay: 105ms; }
    .lab__toggle--n .lab__dot[data-tier="5"] { transition-delay: 130ms; }
    .lab__toggle--n.is-pulsing .lab__dot--both {
      animation: anchorAmberFlash 0.48s ease;
    }
    @keyframes anchorAmberFlash {
      0%   { fill: currentColor; transform: scale(1); }
      40%  { fill: #D97706; transform: scale(1.18); }
      100% { fill: currentColor; transform: scale(1); }
    }

    /* ============================================================
       Variant O — Tier-color flash
       N taken further: amber → violet → blue cycle on anchors.
       ============================================================ */
    .lab__toggle--o .lab__toggle-grid { color: var(--text); overflow: visible; }
    .lab__toggle--o .lab__dot {
      fill: currentColor;
      transform-origin: center; transform-box: fill-box;
      transition: opacity 0.30s ease,
                  transform 0.34s cubic-bezier(0.34, 1.4, 0.64, 1);
    }
    .lab__toggle--o .lab__dot--ham  { opacity: 0.82; transform: scale(1); }
    .lab__toggle--o .lab__dot--both { opacity: 1;    transform: scale(1); }
    .lab__toggle--o .lab__dot--x    { opacity: 0;    transform: scale(0.25); }
    .lab__toggle--o.is-open .lab__dot--ham { opacity: 0; transform: scale(0.25); }
    .lab__toggle--o.is-open .lab__dot--x   { opacity: 0.82; transform: scale(1); }
    .lab__toggle--o .lab__dot[data-tier="0"] { transition-delay: 0ms; }
    .lab__toggle--o .lab__dot[data-tier="1"] { transition-delay: 30ms; }
    .lab__toggle--o .lab__dot[data-tier="2"] { transition-delay: 55ms; }
    .lab__toggle--o .lab__dot[data-tier="3"] { transition-delay: 80ms; }
    .lab__toggle--o .lab__dot[data-tier="4"] { transition-delay: 105ms; }
    .lab__toggle--o .lab__dot[data-tier="5"] { transition-delay: 130ms; }
    .lab__toggle--o.is-pulsing .lab__dot--both {
      animation: anchorTierCycle 0.58s ease;
    }
    @keyframes anchorTierCycle {
      0%   { fill: currentColor; transform: scale(1); }
      22%  { fill: #D97706;      transform: scale(1.18); }
      50%  { fill: #8B5CF6;      transform: scale(1.18); }
      78%  { fill: #2563EB;      transform: scale(1.18); }
      100% { fill: currentColor; transform: scale(1); }
    }

    @media (prefers-reduced-motion: reduce) {
      .lab__toggle--a .lab__stroke,
      .lab__toggle--b .lab__dot,
      .lab__toggle--c .lab__dot,
      .lab__toggle--d .lab__dot,
      .lab__toggle--e .lab__mag-line,
      .lab__toggle--f .lab__dot,
      .lab__toggle--g .lab__flipper,
      .lab__toggle--h .lab__logo-b,
      .lab__toggle--h .lab__logo-x,
      .lab__toggle--i .lab__glyph,
      .lab__toggle--j,
      .lab__toggle--l .lab__dot,
      .lab__toggle--m .lab__dot,
      .lab__toggle--n .lab__dot,
      .lab__toggle--o .lab__dot {
        transition: none !important;
        transition-delay: 0ms !important;
      }
      .lab__toggle--c.is-pulsing .lab__dot--both,
      .lab__toggle--d.is-pulsing .lab__dot--both,
      .lab__toggle--d.is-pulsing .lab__toggle-grid,
      .lab__toggle--m.is-opening .lab__toggle-grid,
      .lab__toggle--m.is-closing .lab__toggle-grid,
      .lab__toggle--n.is-pulsing .lab__dot--both,
      .lab__toggle--o.is-pulsing .lab__dot--both {
        animation: none !important;
      }
    }
</style>

<script is:inline>
    function toggleOne(btn) {
        var willOpen = !btn.classList.contains('is-open');

        /* L, M: directional duration via CSS variable */
        if (btn.matches('.lab__toggle--l, .lab__toggle--m')) {
            btn.style.setProperty('--toggle-dur', willOpen ? '0.45s' : '0.20s');
        }

        btn.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');

        /* C/D/N/O use .is-pulsing to re-trigger their keyframe animations
           (anchor pulse, Pull Focus blur, amber flash, tier-color cycle).
           CSS alone can't re-fire keyframes per toggle. */
        if (btn.matches('.lab__toggle--c, .lab__toggle--d, .lab__toggle--n, .lab__toggle--o')) {
            btn.classList.add('is-pulsing');
            setTimeout(function() { btn.classList.remove('is-pulsing'); }, 600);
        }

        /* M: direction-tagged classes drive the inhale/exhale shimmer */
        if (btn.classList.contains('lab__toggle--m')) {
            var dirClass = willOpen ? 'is-opening' : 'is-closing';
            var dur = willOpen ? 470 : 230;
            btn.classList.add(dirClass);
            setTimeout(function() { btn.classList.remove(dirClass); }, dur);
        }
    }

    document.querySelectorAll('.lab__toggle').forEach(function(btn) {
        btn.addEventListener('click', function() { toggleOne(btn); });
    });

    /* Auto-play: triggers all four toggles in sync every 1.6s */
    (function() {
        var btn = document.getElementById('autoplay');
        if (!btn) return;
        var timer = null;
        var toggles = document.querySelectorAll('.lab__toggle');

        function tick() { toggles.forEach(toggleOne); }

        btn.addEventListener('click', function() {
            var on = btn.getAttribute('aria-pressed') === 'true';
            if (on) {
                clearInterval(timer);
                timer = null;
                btn.setAttribute('aria-pressed', 'false');
            } else {
                tick();
                timer = setInterval(tick, 1600);
                btn.setAttribute('aria-pressed', 'true');
            }
        });
    })();
</script>
