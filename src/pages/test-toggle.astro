---
/**
 * Hamburger toggle animation comparison.
 * Private, unlisted: noindex, nofollow, not in sitemap, not linked.
 *
 * Self-contained styles (no shared.css). Two functional toggles side-by-side.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import VisitorNotify from '../components/VisitorNotify.astro';
---

<BaseLayout
    title="Toggle test — A, B, C, D"
    description="Hamburger toggle animation comparison"
    robots="noindex, nofollow"
    includeMainCss={false}
>
    <main class="lab">
        <header class="lab__header">
            <p class="lab__eyebrow">Hamburger toggle</p>
            <h1 class="lab__title">Pick one: A through O.</h1>
            <p class="lab__sub">Fifteen variants. Click each toggle independently, or use auto-play to loop them all in sync. A is linework; B/C/D/F/K/L/M/N/O are dot-matrix family; E is kinetic; G is 3D; H is the brand mark; I is typography; J is color inversion.</p>
            <div class="lab__controls">
                <button id="autoplay" class="lab__autoplay" type="button" aria-pressed="false">
                    <span class="lab__autoplay-dot" aria-hidden="true"></span>
                    Auto-play all (1.6s loop)
                </button>
            </div>
        </header>

        <div class="lab__grid">
            <article class="lab__card">
                <p class="lab__card-label">A &mdash; Pen-stroke draw</p>
                <p class="lab__card-desc">
                    Lines aren't morphed &mdash; they're <em>drawn and un-drawn</em>
                    via SVG <code>stroke-dashoffset</code>. Hamburger lines retract
                    left-to-right with a small stagger; X lines simultaneously draw
                    in. Suggests calligraphy, not mechanics. <em>Distinct concept
                    from the dot-matrix family.</em>
                </p>
                <button class="lab__toggle lab__toggle--a" type="button" aria-label="Toggle A">
                    <svg class="lab__toggle-strokes" viewBox="0 0 24 24" width="80" height="80" aria-hidden="true">
                        <line class="lab__stroke lab__stroke--ham" x1="3"  y1="6"  x2="21" y2="6"  data-line="0"/>
                        <line class="lab__stroke lab__stroke--ham" x1="3"  y1="12" x2="21" y2="12" data-line="1"/>
                        <line class="lab__stroke lab__stroke--ham" x1="3"  y1="18" x2="21" y2="18" data-line="2"/>
                        <line class="lab__stroke lab__stroke--x"   x1="5"  y1="5"  x2="19" y2="19" data-line="0"/>
                        <line class="lab__stroke lab__stroke--x"   x1="19" y1="5"  x2="5"  y2="19" data-line="1"/>
                    </svg>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">B &mdash; Pixel-grid morph</p>
                <p class="lab__card-desc">
                    The icon is a 5&times;5 dot matrix &mdash; same DNA as the dotted-B
                    logomark. Hamburger and X are two patterns drawn in the same fixed
                    grid. On toggle, dots fade in/out in a top-down wave; the corner
                    + center anchors stay lit throughout. <em>On-brand, no rotation
                    theater, ~440ms total.</em>
                </p>
                <button class="lab__toggle lab__toggle--b" type="button" aria-label="Toggle B">
                    <svg class="lab__toggle-grid" viewBox="0 0 24 24" width="80" height="80" aria-hidden="true">
                        <!-- Row 0 -->
                        <circle cx="2"  cy="2"  r="1.5" class="lab__dot lab__dot--both" data-row="0"/>
                        <circle cx="7"  cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-row="0"/>
                        <circle cx="12" cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-row="0"/>
                        <circle cx="17" cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-row="0"/>
                        <circle cx="22" cy="2"  r="1.5" class="lab__dot lab__dot--both" data-row="0"/>
                        <!-- Row 1 (X-only inner) -->
                        <circle cx="7"  cy="7"  r="1.5" class="lab__dot lab__dot--x"    data-row="1"/>
                        <circle cx="17" cy="7"  r="1.5" class="lab__dot lab__dot--x"    data-row="1"/>
                        <!-- Row 2 (middle hamburger line + center X anchor) -->
                        <circle cx="2"  cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-row="2"/>
                        <circle cx="7"  cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-row="2"/>
                        <circle cx="12" cy="12" r="1.5" class="lab__dot lab__dot--both" data-row="2"/>
                        <circle cx="17" cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-row="2"/>
                        <circle cx="22" cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-row="2"/>
                        <!-- Row 3 (X-only inner) -->
                        <circle cx="7"  cy="17" r="1.5" class="lab__dot lab__dot--x"    data-row="3"/>
                        <circle cx="17" cy="17" r="1.5" class="lab__dot lab__dot--x"    data-row="3"/>
                        <!-- Row 4 -->
                        <circle cx="2"  cy="22" r="1.5" class="lab__dot lab__dot--both" data-row="4"/>
                        <circle cx="7"  cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-row="4"/>
                        <circle cx="12" cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-row="4"/>
                        <circle cx="17" cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-row="4"/>
                        <circle cx="22" cy="22" r="1.5" class="lab__dot lab__dot--both" data-row="4"/>
                    </svg>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">C &mdash; B refined</p>
                <p class="lab__card-desc">
                    Same morph as B, but: (1) center-out <em>radial</em> stagger
                    &mdash; dots ripple outward from the middle; (2) anchors briefly
                    pulse (scale 1.18, full opacity) during the gesture &mdash; heartbeat
                    on the constants; (3) anchors stay slightly brighter at rest.
                    <em>Recommended bundle.</em>
                </p>
                <button class="lab__toggle lab__toggle--c" type="button" aria-label="Toggle C">
                    <svg class="lab__toggle-grid" viewBox="0 0 24 24" width="80" height="80" aria-hidden="true">
                        <!-- Row 0 -->
                        <circle cx="2"  cy="2"  r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                        <circle cx="7"  cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="12" cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="17" cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="22" cy="2"  r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                        <!-- Row 1 (X-only inner) -->
                        <circle cx="7"  cy="7"  r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <circle cx="17" cy="7"  r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <!-- Row 2 (middle hamburger line + center anchor) -->
                        <circle cx="2"  cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="7"  cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="1"/>
                        <circle cx="12" cy="12" r="1.5" class="lab__dot lab__dot--both" data-tier="0"/>
                        <circle cx="17" cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="1"/>
                        <circle cx="22" cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <!-- Row 3 (X-only inner) -->
                        <circle cx="7"  cy="17" r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <circle cx="17" cy="17" r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <!-- Row 4 -->
                        <circle cx="2"  cy="22" r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                        <circle cx="7"  cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="12" cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="17" cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="22" cy="22" r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                    </svg>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">D &mdash; Signature (C + Pull Focus)</p>
                <p class="lab__card-desc">
                    Everything C does, plus a <em>Pull Focus</em> tie-in: mid-transition,
                    the entire grid briefly goes soft (~1.2px blur) then resolves crisp.
                    Direct callback to the v13.7 intro mechanic &mdash; the toggle becomes
                    part of a brand language, not a one-off widget.
                </p>
                <button class="lab__toggle lab__toggle--d" type="button" aria-label="Toggle D">
                    <svg class="lab__toggle-grid" viewBox="0 0 24 24" width="80" height="80" aria-hidden="true">
                        <!-- Row 0 -->
                        <circle cx="2"  cy="2"  r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                        <circle cx="7"  cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="12" cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="17" cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="22" cy="2"  r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                        <!-- Row 1 (X-only inner) -->
                        <circle cx="7"  cy="7"  r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <circle cx="17" cy="7"  r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <!-- Row 2 (middle hamburger line + center anchor) -->
                        <circle cx="2"  cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="7"  cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="1"/>
                        <circle cx="12" cy="12" r="1.5" class="lab__dot lab__dot--both" data-tier="0"/>
                        <circle cx="17" cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="1"/>
                        <circle cx="22" cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <!-- Row 3 (X-only inner) -->
                        <circle cx="7"  cy="17" r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <circle cx="17" cy="17" r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <!-- Row 4 -->
                        <circle cx="2"  cy="22" r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                        <circle cx="7"  cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="12" cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="17" cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="22" cy="22" r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                    </svg>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">E &mdash; Magnetic snap</p>
                <p class="lab__card-desc">
                    Three lines slide vertically and <em>collide</em> at center
                    (kinetic, almost audible), then the outer two rotate outward
                    as X arms. The middle vanishes at impact.
                </p>
                <button class="lab__toggle lab__toggle--e" type="button" aria-label="Toggle E">
                    <svg class="lab__toggle-mag" viewBox="0 0 24 24" width="80" height="80" aria-hidden="true">
                        <line class="lab__mag-line" x1="3" y1="6"  x2="21" y2="6"  data-line="top"/>
                        <line class="lab__mag-line" x1="3" y1="12" x2="21" y2="12" data-line="mid"/>
                        <line class="lab__mag-line" x1="3" y1="18" x2="21" y2="18" data-line="bot"/>
                    </svg>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">F &mdash; Spring overshoot</p>
                <p class="lab__card-desc">
                    Same dot matrix as B, but with a <em>theatrical</em> bouncy
                    easing curve. Dots overshoot ~30% past their target then
                    settle. Personality at the cost of restraint.
                </p>
                <button class="lab__toggle lab__toggle--f" type="button" aria-label="Toggle F">
                    <svg class="lab__toggle-grid" viewBox="0 0 24 24" width="80" height="80" aria-hidden="true">
                        <circle cx="2"  cy="2"  r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                        <circle cx="7"  cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="12" cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="17" cy="2"  r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="22" cy="2"  r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                        <circle cx="7"  cy="7"  r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <circle cx="17" cy="7"  r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <circle cx="2"  cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="7"  cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="1"/>
                        <circle cx="12" cy="12" r="1.5" class="lab__dot lab__dot--both" data-tier="0"/>
                        <circle cx="17" cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="1"/>
                        <circle cx="22" cy="12" r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="7"  cy="17" r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <circle cx="17" cy="17" r="1.5" class="lab__dot lab__dot--x"    data-tier="2"/>
                        <circle cx="2"  cy="22" r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                        <circle cx="7"  cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="12" cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-tier="3"/>
                        <circle cx="17" cy="22" r="1.5" class="lab__dot lab__dot--ham"  data-tier="4"/>
                        <circle cx="22" cy="22" r="1.5" class="lab__dot lab__dot--both" data-tier="5"/>
                    </svg>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">G &mdash; Origami fold</p>
                <p class="lab__card-desc">
                    The toggle <em>flips 180&deg;</em> on its Y axis like a card.
                    Front face is hamburger, back face is X. Paper-folding metaphor,
                    cinematic feel.
                </p>
                <button class="lab__toggle lab__toggle--g" type="button" aria-label="Toggle G">
                    <span class="lab__flipper">
                        <span class="lab__flipper-face lab__flipper-face--front">
                            <svg viewBox="0 0 24 24" width="80" height="80" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <line x1="3" y1="6"  x2="21" y2="6"/>
                                <line x1="3" y1="12" x2="21" y2="12"/>
                                <line x1="3" y1="18" x2="21" y2="18"/>
                            </svg>
                        </span>
                        <span class="lab__flipper-face lab__flipper-face--back">
                            <svg viewBox="0 0 24 24" width="80" height="80" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <line x1="5"  y1="5" x2="19" y2="19"/>
                                <line x1="19" y1="5" x2="5"  y2="19"/>
                            </svg>
                        </span>
                    </span>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">H &mdash; Logomark cameo</p>
                <p class="lab__card-desc">
                    The actual <em>dotted-B logomark</em> sits in the toggle.
                    On click, the 28 B dots fade out, 9 X dots fade in. Brand
                    mark literally is the menu icon. Maximally on-brand.
                </p>
                <button class="lab__toggle lab__toggle--h" type="button" aria-label="Toggle H">
                    <svg class="lab__toggle-logo" viewBox="0 0 512 512" width="80" height="80" aria-hidden="true">
                        <g class="lab__logo-b" fill="currentColor">
                            <circle cx="144" cy="88"  r="22"/><circle cx="200" cy="88"  r="22"/><circle cx="256" cy="88"  r="22"/><circle cx="312" cy="88"  r="22"/>
                            <circle cx="144" cy="144" r="22"/><circle cx="200" cy="144" r="22"/><circle cx="312" cy="144" r="22"/><circle cx="368" cy="144" r="22"/>
                            <circle cx="144" cy="200" r="22"/><circle cx="200" cy="200" r="22"/><circle cx="312" cy="200" r="22"/><circle cx="368" cy="200" r="22"/>
                            <circle cx="144" cy="256" r="22"/><circle cx="200" cy="256" r="22"/><circle cx="256" cy="256" r="22"/><circle cx="312" cy="256" r="22"/>
                            <circle cx="144" cy="312" r="22"/><circle cx="200" cy="312" r="22"/><circle cx="312" cy="312" r="22"/><circle cx="368" cy="312" r="22"/>
                            <circle cx="144" cy="368" r="22"/><circle cx="200" cy="368" r="22"/><circle cx="312" cy="368" r="22"/><circle cx="368" cy="368" r="22"/>
                            <circle cx="144" cy="424" r="22"/><circle cx="200" cy="424" r="22"/><circle cx="256" cy="424" r="22"/><circle cx="312" cy="424" r="22"/>
                        </g>
                        <g class="lab__logo-x" fill="currentColor">
                            <circle cx="88"  cy="88"  r="32"/><circle cx="424" cy="88"  r="32"/>
                            <circle cx="172" cy="172" r="32"/><circle cx="340" cy="172" r="32"/>
                            <circle cx="256" cy="256" r="32"/>
                            <circle cx="172" cy="340" r="32"/><circle cx="340" cy="340" r="32"/>
                            <circle cx="88"  cy="424" r="32"/><circle cx="424" cy="424" r="32"/>
                        </g>
                    </svg>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">I &mdash; Glyph swap</p>
                <p class="lab__card-desc">
                    Two real typographic characters cross-dissolve:
                    <em>&equiv;</em> becomes <em>&times;</em>. No morph, no
                    animation theater &mdash; just type. Completely different
                    visual family.
                </p>
                <button class="lab__toggle lab__toggle--i" type="button" aria-label="Toggle I">
                    <span class="lab__glyph lab__glyph--ham" aria-hidden="true">&equiv;</span>
                    <span class="lab__glyph lab__glyph--x" aria-hidden="true">&times;</span>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">J &mdash; Negative-space invert</p>
                <p class="lab__card-desc">
                    Click flips the whole button: dark background becomes white,
                    white lines become dark. Hamburger and X exist as <em>negative
                    space</em> within the inverted surface. Design-magazine move.
                </p>
                <button class="lab__toggle lab__toggle--j" type="button" aria-label="Toggle J">
                    <svg class="lab__toggle-invert" viewBox="0 0 24 24" width="80" height="80" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <g class="lab__invert-ham">
                            <line x1="3" y1="6"  x2="21" y2="6"/>
                            <line x1="3" y1="12" x2="21" y2="12"/>
                            <line x1="3" y1="18" x2="21" y2="18"/>
                        </g>
                        <g class="lab__invert-x">
                            <line x1="5"  y1="5" x2="19" y2="19"/>
                            <line x1="19" y1="5" x2="5"  y2="19"/>
                        </g>
                    </svg>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">K &mdash; Snap-cut</p>
                <p class="lab__card-desc">
                    <em>No animation.</em> Click swaps hamburger and X instantly.
                    The anti-choice &mdash; confident, decisive, ages well. Reads
                    as utility, not theater.
                </p>
                <button class="lab__toggle lab__toggle--k" type="button" aria-label="Toggle K">
                    <svg class="lab__toggle-grid" viewBox="0 0 24 24" width="80" height="80" aria-hidden="true">
                        <circle cx="2"  cy="2"  r="1.5" class="lab__dot lab__dot--both"/>
                        <circle cx="7"  cy="2"  r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="12" cy="2"  r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="17" cy="2"  r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="22" cy="2"  r="1.5" class="lab__dot lab__dot--both"/>
                        <circle cx="7"  cy="7"  r="1.5" class="lab__dot lab__dot--x"/>
                        <circle cx="17" cy="7"  r="1.5" class="lab__dot lab__dot--x"/>
                        <circle cx="2"  cy="12" r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="7"  cy="12" r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="12" cy="12" r="1.5" class="lab__dot lab__dot--both"/>
                        <circle cx="17" cy="12" r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="22" cy="12" r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="7"  cy="17" r="1.5" class="lab__dot lab__dot--x"/>
                        <circle cx="17" cy="17" r="1.5" class="lab__dot lab__dot--x"/>
                        <circle cx="2"  cy="22" r="1.5" class="lab__dot lab__dot--both"/>
                        <circle cx="7"  cy="22" r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="12" cy="22" r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="17" cy="22" r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="22" cy="22" r="1.5" class="lab__dot lab__dot--both"/>
                    </svg>
                </button>
            </article>

            <article class="lab__card">
                <p class="lab__card-label">L &mdash; Asymmetric timing</p>
                <p class="lab__card-desc">
                    Same dot grid as C, but with directional personality: open
                    is slow and deliberate (~450ms), close is brisk (~180ms).
                    Opening feels like a <em>reveal</em>, closing like dismissal.
                </p>
                <button class="lab__toggle lab__toggle--l" type="button" aria-label="Toggle L">
                    <svg class="lab__toggle-grid" viewBox="0 0 24 24" width="80" height="80" aria-hidden="true">
                        <circle cx="2"  cy="2"  r="1.5" class="lab__dot lab__dot--both"/>
                        <circle cx="7"  cy="2"  r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="12" cy="2"  r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="17" cy="2"  r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="22" cy="2"  r="1.5" class="lab__dot lab__dot--both"/>
                        <circle cx="7"  cy="7"  r="1.5" class="lab__dot lab__dot--x"/>
                        <circle cx="17" cy="7"  r="1.5" class="lab__dot lab__dot--x"/>
                        <circle cx="2"  cy="12" r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="7"  cy="12" r="1.5" class="lab__dot lab__dot--ham"/>
                        <circle cx="12" cy="12" r="1.5" class="lab__dot lab__dot--both"/>
