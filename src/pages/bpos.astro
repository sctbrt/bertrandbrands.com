---
/**
 * B-POS — Dedicated product landing page for B-POS Food Service POS.
 * Electric blue/violet/starlight accent palette. Hero + features + screenshots + pricing + FAQ.
 * Uses ServiceDetailLayout (HeaderUniversal + VisitorNotify included via layout).
 * NOTE: noindex — page is in development, not yet public.
 */
import ServiceDetailLayout from '../layouts/ServiceDetailLayout.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import BPOSSection from '../components/BPOSSection.astro';
import { breadcrumbList, schemaGraph, PROVIDER, AREA_SERVED } from '../lib/schema';

const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="B-POS — Offline-First Food Service POS | Bertrand Brands"
    description="Full-suite food service POS for dine-in, bar, and takeout. Offline-first, runs on any device. From $59/mo."
    canonical="https://bertrandbrands.ca/bpos"
    ogTitle="B-POS — Food Service POS That Works Offline"
    ogDescription="Full-suite food service POS for dine-in, bar, and takeout. Offline-first, runs on any device. From $59/mo."
    ogImage="https://bertrandbrands.ca/assets/bpos-og-hero.png"
    robots="noindex, nofollow"
    spotlightColor="rgba(96, 165, 250, 0.10)"
    accentRgb="245, 158, 11"
    serviceName="B-POS Food Service POS"
    serviceTier="software"
    serviceSlug="bpos"
    servicePrice="59"
    schemaJson={schemaGraph(
        breadcrumbList([
            { name: "Bertrand Brands", url: "https://bertrandbrands.ca/" },
            { name: "B-POS", url: "https://bertrandbrands.ca/bpos" }
        ]),
        {
            "@type": "SoftwareApplication",
            "name": "B-POS Food Service POS",
            "url": "https://bertrandbrands.ca/bpos",
            "applicationCategory": "BusinessApplication",
            "operatingSystem": "Web, macOS, Windows, iOS, Android",
            "description": "Offline-first, full-suite food service point of sale for dine-in, bar, and takeout. Runs on any device.",
            "provider": PROVIDER,
            "areaServed": AREA_SERVED,
            "offers": [
                {
                    "@type": "Offer",
                    "name": "B-POS Standard",
                    "price": "59",
                    "priceCurrency": "CAD",
                    "priceSpecification": {
                        "@type": "UnitPriceSpecification",
                        "price": "59",
                        "priceCurrency": "CAD",
                        "billingDuration": "P1M"
                    },
                    "availability": "https://schema.org/InStock",
                    "description": "Full POS with orders, payments, floor plan, up to 3 terminals."
                },
                {
                    "@type": "Offer",
                    "name": "B-POS Pro",
                    "price": "129",
                    "priceCurrency": "CAD",
                    "priceSpecification": {
                        "@type": "UnitPriceSpecification",
                        "price": "129",
                        "priceCurrency": "CAD",
                        "billingDuration": "P1M"
                    },
                    "availability": "https://schema.org/InStock",
                    "description": "Everything in Standard plus unlimited terminals, KDS, inventory, advanced reporting."
                }
            ]
        }
    )}
>
    <Fragment slot="head">
        <style is:inline>
            /* ── BPOS Color Tokens ─────────────────────────── */
            :root {
                --bpos-blue: #60A5FA;
                --bpos-blue-bright: #93C5FD;
                --bpos-blue-dim: rgba(96, 165, 250, 0.12);
                --bpos-amber: #E8D5B0;
                --bpos-amber-dim: rgba(232, 213, 176, 0.08);
                --bpos-amber-glow: rgba(232, 213, 176, 0.06);
                --bpos-blue-glow: rgba(96, 165, 250, 0.08);
                --bpos-violet: #A78BFA;
                --bpos-violet-dim: rgba(167, 139, 250, 0.08);
            }

            /* ── Override parent Bertrand Brands warm tones ── */
            .service-page {
                background: #050810 !important;
                background-image:
                    radial-gradient(ellipse 120% 50% at 20% 0%, rgba(167, 139, 250, 0.04) 0%, transparent 50%),
                    radial-gradient(ellipse 100% 60% at 80% 100%, rgba(96, 165, 250, 0.03) 0%, transparent 50%) !important;
            }
            .service-page__spotlight--1,
            .service-page__spotlight--2 {
                display: none !important;
            }
            .sticky-cta__button {
                background: linear-gradient(135deg, #60A5FA, #3B82F6) !important;
                color: #050a14 !important;
                font-weight: 700 !important;
                box-shadow: 0 0 16px rgba(96, 165, 250, 0.3);
            }
            .sticky-cta {
                border-top: 1px solid rgba(96, 165, 250, 0.15) !important;
                background: rgba(5, 8, 16, 0.95) !important;
            }
            .service-back {
                color: var(--bpos-blue) !important;
                border-color: rgba(96, 165, 250, 0.15) !important;
                background: rgba(96, 165, 250, 0.04) !important;
            }
            .service-back:hover {
                border-color: rgba(96, 165, 250, 0.3) !important;
                background: rgba(96, 165, 250, 0.08) !important;
            }

            /* ── Trial modal ──────────────────────────────── */
            .bpos-trial-overlay {
                display: none;
                position: fixed;
                inset: 0;
                z-index: 9999;
                background: rgba(0,0,0,0.75);
                backdrop-filter: blur(4px);
                align-items: center;
                justify-content: center;
                padding: 24px;
            }
            .bpos-trial-overlay.is-open { display: flex; }
            .bpos-trial-modal {
                background: #0e1117;
                border: 1px solid rgba(96, 165, 250, 0.15);
                border-radius: 16px;
                padding: 32px;
                max-width: 420px;
                width: 100%;
                position: relative;
                box-shadow: 0 0 60px rgba(96, 165, 250, 0.06), 0 0 60px rgba(232, 213, 176, 0.04);
            }
            .bpos-trial-modal__title {
                font-family: var(--font-display, Inter, sans-serif);
                font-size: 18px;
                font-weight: 600;
                color: var(--text, #f5f5f5);
                margin-bottom: 4px;
            }
            .bpos-trial-modal__subtitle {
                font-size: 13px;
                color: var(--text-muted, #999);
                margin-bottom: 24px;
            }
            .bpos-trial-modal__close {
                position: absolute;
                top: 16px;
                right: 16px;
                background: none;
                border: none;
                color: var(--text-muted, #999);
                font-size: 20px;
                cursor: pointer;
                padding: 4px 8px;
                line-height: 1;
            }
            .bpos-trial-field {
                margin-bottom: 16px;
            }
            .bpos-trial-field label {
                display: block;
                font-size: 11px;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--text-subtle, #aaa);
                margin-bottom: 6px;
            }
            .bpos-trial-field input {
                width: 100%;
                padding: 10px 12px;
                font-size: 14px;
                font-family: var(--font-body, Inter, sans-serif);
                background: rgba(96, 165, 250, 0.04);
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 8px;
                color: var(--text, #f5f5f5);
                outline: none;
                transition: border-color 0.15s, box-shadow 0.15s;
                box-sizing: border-box;
            }
            .bpos-trial-field input:focus {
                border-color: rgba(96, 165, 250, 0.4);
                box-shadow: 0 0 12px rgba(96, 165, 250, 0.08);
            }
            .bpos-trial-submit {
                width: 100%;
                padding: 12px;
                font-size: 15px;
                font-weight: 700;
                font-family: var(--font-body, Inter, sans-serif);
                background: linear-gradient(135deg, #60A5FA, #3B82F6);
                color: #050a14;
                border: none;
                border-radius: 10px;
                cursor: pointer;
                margin-top: 8px;
                transition: all 0.2s;
                box-shadow: 0 0 16px rgba(96, 165, 250, 0.25);
            }
            .bpos-trial-submit:hover {
                box-shadow: 0 0 24px rgba(96, 165, 250, 0.4);
                transform: translateY(-1px);
            }
            .bpos-trial-submit:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                box-shadow: none;
            }
            .bpos-trial-error {
                color: #ef4444;
                font-size: 12px;
                margin-top: 8px;
                display: none;
            }
            .bpos-trial-success {
                text-align: center;
                padding: 24px 0;
            }
            .bpos-trial-success__key {
                font-family: 'JetBrains Mono', monospace;
                font-size: 18px;
                font-weight: 600;
                color: var(--bpos-amber);
                letter-spacing: 0.04em;
                margin: 16px 0;
                padding: 12px;
                background: rgba(232, 213, 176, 0.06);
                border: 1px solid rgba(232, 213, 176, 0.2);
                border-radius: 8px;
            }
        </style>
    </Fragment>

    <main id="main-content">
        <BPOSSection />
    </main>

    <script is:inline>
    /* Reveal on scroll — IntersectionObserver for BPOSSection */
    (function() {
        var reveals = document.querySelectorAll('.reveal');
        if (!reveals.length) return;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            reveals.forEach(function(el) { el.classList.add('is-visible'); });
            return;
        }

        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        reveals.forEach(function(el) { observer.observe(el); });
    })();
    </script>

    <footer class="service-footer">
        <div class="service-footer__cta">
            <p class="service-footer__cta-text">Questions?</p>
            <a href="mailto:hello@bertrandgroup.ca" class="service-footer__cta-link">hello@bertrandgroup.ca</a>
        </div>
        <p class="service-footer__text">&copy; {currentYear} Bertrand Brands. All rights reserved.</p>
        <p class="footer-division"><a href="https://bertrandgroup.ca" target="_blank" rel="noopener noreferrer">A division of Bertrand Group Canada</a> &middot; <a href="/privacy">Privacy</a></p>
        <p class="service-footer__phone"><a href="tel:+17054133705">(705) 413-3705</a></p>
    </footer>

    <!-- Trial modal -->
    <div class="bpos-trial-overlay" id="bposTrialOverlay">
        <div class="bpos-trial-modal">
            <button class="bpos-trial-modal__close" type="button" id="bposTrialClose">&times;</button>
            <div id="bposTrialForm">
                <p class="bpos-trial-modal__title">Start your free trial</p>
                <p class="bpos-trial-modal__subtitle">14 days, no credit card. Your license key is generated instantly.</p>
                <input type="hidden" id="bposTrialPlan" value="standard" />
                <div class="bpos-trial-field">
                    <label for="bposTrialName">Business Name</label>
                    <input type="text" id="bposTrialName" placeholder="e.g. Chez Marcel" required />
                </div>
                <div class="bpos-trial-field">
                    <label for="bposTrialContact">Your Name</label>
                    <input type="text" id="bposTrialContact" placeholder="First Last" required />
                </div>
                <div class="bpos-trial-field">
                    <label for="bposTrialEmail">Email</label>
                    <input type="email" id="bposTrialEmail" placeholder="you@business.com" required />
                </div>
                <div class="bpos-trial-field">
                    <label for="bposTrialPhone">Phone <span style="font-weight:400;text-transform:none;letter-spacing:0">(optional)</span></label>
                    <input type="tel" id="bposTrialPhone" placeholder="(555) 123-4567" />
                </div>
                <button type="button" class="bpos-trial-submit" id="bposTrialSubmit">Get License Key</button>
                <p class="bpos-trial-error" id="bposTrialError"></p>
            </div>
            <div id="bposTrialSuccess" class="bpos-trial-success" style="display:none">
                <p class="bpos-trial-modal__title">You're in!</p>
                <p class="bpos-trial-modal__subtitle">Your 14-day trial license key:</p>
                <div class="bpos-trial-success__key" id="bposTrialKey"></div>
                <p style="font-size:13px;color:var(--text-muted,#999);margin-top:12px">
                    Enter this key when you launch B-POS.<br/>
                    We've also sent it to your email.
                </p>
                <a href="https://pos.bertrandgroup.ca" target="_blank" rel="noopener noreferrer" class="bpos-plan__cta bpos-plan__cta--primary" style="display:inline-block;margin-top:20px;padding:12px 32px;text-decoration:none">
                    Launch B-POS &rarr;
                </a>
            </div>
        </div>
    </div>

    <StickyMobileCTA
        href="https://pos.bertrandgroup.ca"
        text="Try B·POS Free"
        subtext="Live demo — no signup required"
        heroSelector=".bpos-hero"
        formSelector=".service-footer"
    />
</ServiceDetailLayout>

<script is:inline>
    (function() {
        var API_BASE = 'https://bpos-api.bertrandbrands.workers.dev';
        var currentBilling = 'month';

        /* Billing toggle */
        var toggle = document.getElementById('bposToggle');
        var grid = document.getElementById('bposPlans');
        if (toggle && grid) {
            var buttons = toggle.querySelectorAll('.bpos-toggle__btn');
            buttons.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    currentBilling = btn.getAttribute('data-billing');
                    buttons.forEach(function(b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    grid.querySelectorAll('[data-' + currentBilling + ']').forEach(function(el) {
                        el.textContent = el.getAttribute('data-' + currentBilling);
                    });
                });
            });
        }

        /* FAQ accordion */
        var faq = document.getElementById('bposFaq');
        if (faq) {
            faq.querySelectorAll('.bpos-faq__q').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var item = btn.closest('.bpos-faq__item');
                    var wasOpen = item.classList.contains('is-open');
                    faq.querySelectorAll('.bpos-faq__item').forEach(function(i) { i.classList.remove('is-open'); });
                    if (!wasOpen) item.classList.add('is-open');
                });
            });
        }

        /* Trial modal */
        var overlay = document.getElementById('bposTrialOverlay');
        var closeBtn = document.getElementById('bposTrialClose');
        var formDiv = document.getElementById('bposTrialForm');
        var successDiv = document.getElementById('bposTrialSuccess');
        var submitBtn = document.getElementById('bposTrialSubmit');
        var errorEl = document.getElementById('bposTrialError');
        var planInput = document.getElementById('bposTrialPlan');

        function openTrialModal(plan) {
            planInput.value = plan;
            formDiv.style.display = '';
            successDiv.style.display = 'none';
            errorEl.style.display = 'none';
            overlay.classList.add('is-open');
            document.body.style.overflow = 'hidden';
        }

        function closeTrialModal() {
            overlay.classList.remove('is-open');
            document.body.style.overflow = '';
        }

        if (closeBtn) closeBtn.addEventListener('click', closeTrialModal);
        if (overlay) overlay.addEventListener('click', function(e) {
            if (e.target === overlay) closeTrialModal();
        });

        /* Trial form submit */
        if (submitBtn) {
            submitBtn.addEventListener('click', async function() {
                var name = document.getElementById('bposTrialName').value.trim();
                var contact = document.getElementById('bposTrialContact').value.trim();
                var email = document.getElementById('bposTrialEmail').value.trim();
                var phone = document.getElementById('bposTrialPhone').value.trim();

                if (!name || !contact || !email) {
                    errorEl.textContent = 'Please fill in all required fields.';
                    errorEl.style.display = 'block';
                    return;
                }

                submitBtn.disabled = true;
                submitBtn.textContent = 'Generating...';
                errorEl.style.display = 'none';

                try {
                    var res = await fetch(API_BASE + '/trial', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            restaurantName: name,
                            contactName: contact,
                            email: email,
                            phone: phone || undefined
                        })
                    });

                    var data = await res.json();

                    if (!res.ok) {
                        throw new Error(data.error || 'Something went wrong');
                    }

                    document.getElementById('bposTrialKey').textContent = data.licenseKey;
                    formDiv.style.display = 'none';
                    successDiv.style.display = '';

                    /* GA4 event */
                    if (typeof gtag === 'function') {
                        gtag('event', 'generate_lead', {
                            event_category: 'bpos',
                            event_label: planInput.value + '_trial',
                            value: 0
                        });
                    }
                } catch (err) {
                    errorEl.textContent = err.message || 'Failed to generate trial. Please try again.';
                    errorEl.style.display = 'block';
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Get License Key';
                }
            });
        }

        /* Subscribe buttons → Stripe Checkout */
        document.querySelectorAll('.bpos-plan__cta--subscribe').forEach(function(btn) {
            btn.addEventListener('click', async function() {
                var plan = btn.getAttribute('data-plan');
                btn.disabled = true;
                btn.textContent = 'Redirecting...';

                try {
                    var res = await fetch(API_BASE + '/checkout', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            plan: plan,
                            billing: currentBilling,
                            earlyBird: currentBilling === 'year',
                            successUrl: window.location.origin + '/bpos?checkout=success',
                            cancelUrl: window.location.origin + '/bpos?checkout=cancelled'
                        })
                    });

                    var data = await res.json();
                    if (!res.ok) throw new Error(data.error);

                    window.location.href = data.url;
                } catch (err) {
                    alert('Could not start checkout: ' + (err.message || 'Please try again.'));
                    btn.disabled = false;
                    btn.textContent = 'Subscribe';
                }
            });
        });

        /* Trial buttons → open modal */
        document.querySelectorAll('.bpos-trial-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                openTrialModal(btn.getAttribute('data-plan'));
            });
        });

        /* Handle checkout success/cancel URL params */
        var params = new URLSearchParams(window.location.search);
        if (params.get('checkout') === 'success') {
            alert('Payment successful! Check your email for your license key.');
            window.history.replaceState({}, '', '/bpos');
        }
    })();
</script>
