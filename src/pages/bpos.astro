---
/**
 * B-POS — Dedicated product landing page for B-POS Restaurant POS.
 * Amber accent (#D97706). Hero + features + screenshots + pricing + FAQ.
 * Uses ServiceDetailLayout (HeaderUniversal + VisitorNotify included via layout).
 */
import ServiceDetailLayout from '../layouts/ServiceDetailLayout.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import { breadcrumbList, schemaGraph, PROVIDER, AREA_SERVED } from '../lib/schema';

const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="B-POS — Offline-First Restaurant POS | Bertrand Brands"
    description="Full-suite restaurant POS for dine-in, bar, and takeout. Offline-first, runs on any device. From $59/mo."
    canonical="https://bertrandbrands.ca/bpos"
    ogTitle="B-POS — Restaurant POS That Works Offline"
    ogDescription="Full-suite restaurant POS for dine-in, bar, and takeout. Offline-first, runs on any device. From $59/mo."
    spotlightColor="rgba(217, 119, 6, 0.15)"
    accentRgb="217, 119, 6"
    serviceName="B-POS Restaurant POS"
    serviceTier="software"
    serviceSlug="bpos"
    servicePrice="59"
    schemaJson={schemaGraph(
        breadcrumbList([
            { name: "Bertrand Brands", url: "https://bertrandbrands.ca/" },
            { name: "B-POS", url: "https://bertrandbrands.ca/bpos" }
        ]),
        {
            "@type": "SoftwareApplication",
            "name": "B-POS Restaurant POS",
            "url": "https://bertrandbrands.ca/bpos",
            "applicationCategory": "BusinessApplication",
            "operatingSystem": "Web, macOS, Windows, iOS, Android",
            "description": "Offline-first, full-suite restaurant point of sale for dine-in, bar, and takeout. Runs on any device.",
            "provider": PROVIDER,
            "areaServed": AREA_SERVED,
            "offers": [
                {
                    "@type": "Offer",
                    "name": "B-POS Standard",
                    "price": "59",
                    "priceCurrency": "CAD",
                    "priceSpecification": {
                        "@type": "UnitPriceSpecification",
                        "price": "59",
                        "priceCurrency": "CAD",
                        "billingDuration": "P1M"
                    },
                    "availability": "https://schema.org/InStock",
                    "description": "Full POS with orders, payments, floor plan, up to 3 terminals."
                },
                {
                    "@type": "Offer",
                    "name": "B-POS Pro",
                    "price": "129",
                    "priceCurrency": "CAD",
                    "priceSpecification": {
                        "@type": "UnitPriceSpecification",
                        "price": "129",
                        "priceCurrency": "CAD",
                        "billingDuration": "P1M"
                    },
                    "availability": "https://schema.org/InStock",
                    "description": "Everything in Standard plus unlimited terminals, KDS, inventory, advanced reporting."
                }
            ]
        }
    )}
>
    <Fragment slot="head">
        <style is:inline>
            /* ── Hero ──────────────────────────────────────── */
            .bpos-hero {
                padding: var(--space-xl) 0 var(--space-lg);
                text-align: center;
                position: relative;
                z-index: 1;
            }
            .bpos-hero__badge {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: rgba(217, 119, 6, 1);
                border: 1px solid rgba(217, 119, 6, 0.3);
                border-radius: 20px;
                padding: 4px 14px;
                margin-bottom: var(--space-md);
            }
            .bpos-hero__badge-dot {
                width: 6px;
                height: 6px;
                background: rgba(217, 119, 6, 1);
                border-radius: 50%;
                animation: bposPulse 2s ease-in-out infinite;
            }
            @keyframes bposPulse {
                0%, 100% { opacity: 1; }
                50% { opacity: 0.4; }
            }
            .bpos-hero__title {
                font-family: var(--font-display);
                font-size: clamp(2rem, 5vw, 3rem);
                font-weight: 300;
                line-height: 1.2;
                color: var(--text);
                max-width: 700px;
                margin: 0 auto var(--space-sm);
            }
            .bpos-hero__title em {
                font-style: normal;
                color: rgba(217, 119, 6, 1);
            }
            .bpos-hero__sub {
                font-family: var(--font-body);
                font-size: var(--text-lg);
                color: var(--text-muted);
                max-width: 540px;
                margin: 0 auto var(--space-lg);
                line-height: 1.6;
            }
            .bpos-hero__actions {
                display: flex;
                justify-content: center;
                gap: var(--space-sm);
                flex-wrap: wrap;
            }
            .bpos-hero__cta {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 0.875rem 2rem;
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 600;
                text-decoration: none;
                border-radius: 8px;
                min-height: 48px;
                transition: all var(--duration-fast) ease;
            }
            .bpos-hero__cta--primary {
                background: rgba(217, 119, 6, 1);
                color: #0a0a0a;
            }
            .bpos-hero__cta--primary:hover {
                filter: brightness(0.9);
                transform: translateY(-1px);
            }
            .bpos-hero__cta--secondary {
                background: rgba(217, 119, 6, 0.1);
                border: 1px solid rgba(217, 119, 6, 0.3);
                color: var(--text);
            }
            .bpos-hero__cta--secondary:hover {
                background: rgba(217, 119, 6, 0.18);
                border-color: rgba(217, 119, 6, 0.5);
                transform: translateY(-1px);
            }

            /* ── Features grid ─────────────────────────────── */
            .bpos-features {
                padding: var(--space-xl) 0;
                position: relative;
                z-index: 1;
            }
            .bpos-features__label {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: rgba(217, 119, 6, 1);
                text-align: center;
                margin-bottom: var(--space-md);
            }
            .bpos-features__grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: var(--space-md);
                max-width: 900px;
                margin: 0 auto;
            }
            .bpos-feature {
                background: rgba(217, 119, 6, 0.04);
                border: 1px solid rgba(217, 119, 6, 0.1);
                border-radius: var(--radius-lg);
                padding: var(--space-lg);
            }
            .bpos-feature__icon {
                font-size: 1.5rem;
                margin-bottom: var(--space-sm);
                line-height: 1;
            }
            .bpos-feature__name {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 600;
                color: var(--text);
                margin-bottom: 4px;
            }
            .bpos-feature__desc {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-muted);
                line-height: 1.5;
            }

            /* ── How it works ──────────────────────────────── */
            .bpos-how {
                padding: var(--space-xl) 0;
                position: relative;
                z-index: 1;
            }
            .bpos-how__label {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: rgba(217, 119, 6, 1);
                text-align: center;
                margin-bottom: var(--space-lg);
            }
            .bpos-how__steps {
                display: flex;
                gap: var(--space-lg);
                max-width: 800px;
                margin: 0 auto;
                justify-content: center;
            }
            .bpos-step {
                flex: 1;
                text-align: center;
                max-width: 220px;
            }
            .bpos-step__num {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: rgba(217, 119, 6, 0.12);
                border: 1px solid rgba(217, 119, 6, 0.25);
                color: rgba(217, 119, 6, 1);
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 700;
                margin-bottom: var(--space-sm);
            }
            .bpos-step__title {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 600;
                color: var(--text);
                margin-bottom: 4px;
            }
            .bpos-step__desc {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-muted);
                line-height: 1.5;
            }

            /* ── Pricing ───────────────────────────────────── */
            .bpos-pricing {
                padding: var(--space-xl) 0;
                position: relative;
                z-index: 1;
            }
            .bpos-pricing__label {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: rgba(217, 119, 6, 1);
                text-align: center;
                margin-bottom: var(--space-xs);
            }
            .bpos-pricing__headline {
                font-family: var(--font-display);
                font-size: clamp(1.25rem, 3vw, 1.75rem);
                font-weight: 300;
                color: var(--text);
                text-align: center;
                margin-bottom: var(--space-md);
            }

            /* Toggle */
            .bpos-toggle {
                display: flex;
                justify-content: center;
                gap: 2px;
                background: rgba(255, 255, 255, 0.04);
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 8px;
                padding: 3px;
                max-width: 280px;
                margin: 0 auto var(--space-sm);
            }
            .bpos-toggle__btn {
                flex: 1;
                background: none;
                border: none;
                color: var(--text-subtle);
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 500;
                padding: 0.5rem 1rem;
                border-radius: 6px;
                cursor: pointer;
                transition: all var(--duration-fast) ease;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 6px;
            }
            .bpos-toggle__btn.active {
                background: rgba(255, 255, 255, 0.08);
                color: var(--text);
            }
            .bpos-toggle__badge {
                font-size: 0.625rem;
                background: rgba(217, 119, 6, 1);
                color: #000;
                padding: 1px 5px;
                border-radius: 3px;
                font-weight: 600;
                letter-spacing: 0.02em;
            }

            /* Early bird */
            .bpos-early-bird {
                text-align: center;
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-muted);
                margin-bottom: var(--space-md);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
            }
            .bpos-early-bird__tag {
                font-size: 0.625rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: rgba(217, 119, 6, 1);
                border: 1px solid rgba(217, 119, 6, 0.4);
                border-radius: 3px;
                padding: 1px 6px;
            }

            /* Plan grid */
            .bpos-plans {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: var(--space-sm);
                max-width: 720px;
                margin: 0 auto var(--space-md);
            }
            .bpos-plan {
                position: relative;
                background: rgba(217, 119, 6, 0.04);
                border: 1px solid rgba(217, 119, 6, 0.12);
                border-radius: var(--radius-lg);
                padding: var(--space-lg);
            }
            .bpos-plan--featured {
                border-color: rgba(217, 119, 6, 0.3);
                background: rgba(217, 119, 6, 0.06);
            }
            .bpos-plan__badge {
                position: absolute;
                top: -10px;
                left: 50%;
                transform: translateX(-50%);
                background: rgba(217, 119, 6, 1);
                color: #000;
                font-family: var(--font-body);
                font-size: 0.625rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                padding: 3px 10px;
                border-radius: 4px;
                white-space: nowrap;
            }
            .bpos-plan__name {
                font-family: var(--font-body);
                font-size: var(--text-lg);
                font-weight: 600;
                color: var(--text);
                margin-bottom: 2px;
            }
            .bpos-plan__tagline {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-muted);
                margin-bottom: var(--space-sm);
            }
            .bpos-plan__pricing {
                display: flex;
                align-items: baseline;
                gap: 6px;
                margin-bottom: 4px;
            }
            .bpos-plan__price-early {
                font-family: var(--font-display);
                font-size: clamp(1.5rem, 3vw, 2rem);
                font-weight: 600;
                color: rgba(217, 119, 6, 1);
            }
            .bpos-plan__price-regular {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                color: var(--text-subtle);
                text-decoration: line-through;
            }
            .bpos-plan__period {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-subtle);
            }
            .bpos-plan__savings {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: rgba(217, 119, 6, 1);
                min-height: 1.2em;
                margin-bottom: var(--space-sm);
            }
            .bpos-plan__features {
                list-style: none;
                padding: 0;
                margin: 0 0 var(--space-md);
            }
            .bpos-plan__features li {
                position: relative;
                padding-left: 1.25rem;
                margin-bottom: 6px;
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-muted);
                line-height: 1.5;
            }
            .bpos-plan__features li::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0.4em;
                width: 5px;
                height: 5px;
                background: rgba(217, 119, 6, 0.5);
                border-radius: 50%;
            }
            .bpos-plan__cta {
                display: block;
                width: 100%;
                padding: 0.75rem 1rem;
                text-align: center;
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 600;
                text-decoration: none;
                border-radius: 8px;
                min-height: 44px;
                transition: all var(--duration-fast) ease;
                margin-bottom: 8px;
            }
            .bpos-plan__cta--primary {
                background: rgba(217, 119, 6, 1);
                color: #0a0a0a;
            }
            .bpos-plan__cta--primary:hover {
                filter: brightness(0.9);
                transform: translateY(-1px);
            }
            .bpos-plan__cta--subscribe {
                background: rgba(217, 119, 6, 0.10);
                border: 1px solid rgba(217, 119, 6, 0.3);
                color: rgb(217, 119, 6);
                font-weight: 600;
            }
            .bpos-plan__cta--subscribe:hover {
                background: rgba(217, 119, 6, 0.20);
                transform: translateY(-1px);
            }
            .bpos-plan__cta--secondary {
                background: rgba(217, 119, 6, 0.08);
                border: 1px solid rgba(217, 119, 6, 0.2);
                color: var(--text-muted);
                font-weight: 500;
                font-size: var(--text-xs);
            }
            .bpos-plan__cta--secondary:hover {
                background: rgba(217, 119, 6, 0.15);
                color: var(--text);
            }

            /* Trial modal */
            .bpos-trial-overlay {
                display: none;
                position: fixed;
                inset: 0;
                z-index: 9999;
                background: rgba(0,0,0,0.7);
                align-items: center;
                justify-content: center;
                padding: 24px;
            }
            .bpos-trial-overlay.is-open { display: flex; }
            .bpos-trial-modal {
                background: var(--bg-secondary, #141210);
                border: 1px solid rgba(217, 119, 6, 0.2);
                border-radius: 16px;
                padding: 32px;
                max-width: 420px;
                width: 100%;
                position: relative;
            }
            .bpos-trial-modal__title {
                font-family: var(--font-display, Inter, sans-serif);
                font-size: 18px;
                font-weight: 600;
                color: var(--text, #f5f5f5);
                margin-bottom: 4px;
            }
            .bpos-trial-modal__subtitle {
                font-size: 13px;
                color: var(--text-muted, #999);
                margin-bottom: 24px;
            }
            .bpos-trial-modal__close {
                position: absolute;
                top: 16px;
                right: 16px;
                background: none;
                border: none;
                color: var(--text-muted, #999);
                font-size: 20px;
                cursor: pointer;
                padding: 4px 8px;
                line-height: 1;
            }
            .bpos-trial-field {
                margin-bottom: 16px;
            }
            .bpos-trial-field label {
                display: block;
                font-size: 11px;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--text-subtle, #aaa);
                margin-bottom: 6px;
            }
            .bpos-trial-field input {
                width: 100%;
                padding: 10px 12px;
                font-size: 14px;
                font-family: var(--font-body, Inter, sans-serif);
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.12);
                border-radius: 8px;
                color: var(--text, #f5f5f5);
                outline: none;
                transition: border-color 0.15s;
            }
            .bpos-trial-field input:focus {
                border-color: rgba(217, 119, 6, 0.5);
            }
            .bpos-trial-submit {
                width: 100%;
                padding: 12px;
                font-size: 15px;
                font-weight: 700;
                font-family: var(--font-body, Inter, sans-serif);
                background: rgb(217, 119, 6);
                color: #0a0a0a;
                border: none;
                border-radius: 10px;
                cursor: pointer;
                margin-top: 8px;
                transition: filter 0.15s;
            }
            .bpos-trial-submit:hover { filter: brightness(0.9); }
            .bpos-trial-submit:disabled {
                opacity: 0.6;
                cursor: not-allowed;
            }
            .bpos-trial-error {
                color: #ef4444;
                font-size: 12px;
                margin-top: 8px;
                display: none;
            }
            .bpos-trial-success {
                text-align: center;
                padding: 24px 0;
            }
            .bpos-trial-success__key {
                font-family: 'JetBrains Mono', monospace;
                font-size: 18px;
                font-weight: 600;
                color: rgb(217, 119, 6);
                letter-spacing: 0.04em;
                margin: 16px 0;
                padding: 12px;
                background: rgba(217, 119, 6, 0.08);
                border: 1px solid rgba(217, 119, 6, 0.2);
                border-radius: 8px;
            }
            .bpos-pricing__footnote {
                text-align: center;
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-subtle);
            }

            /* ── FAQ ───────────────────────────────────────── */
            .bpos-faq {
                padding: var(--space-xl) 0;
                position: relative;
                z-index: 1;
            }
            .bpos-faq__label {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: rgba(217, 119, 6, 1);
                text-align: center;
                margin-bottom: var(--space-lg);
            }
            .bpos-faq__list {
                max-width: 640px;
                margin: 0 auto;
            }
            .bpos-faq__item {
                border-bottom: 1px solid rgba(255, 255, 255, 0.06);
                padding: var(--space-md) 0;
            }
            .bpos-faq__item:first-child {
                border-top: 1px solid rgba(255, 255, 255, 0.06);
            }
            .bpos-faq__q {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 600;
                color: var(--text);
                cursor: pointer;
                display: flex;
                justify-content: space-between;
                align-items: center;
                gap: var(--space-sm);
                width: 100%;
                background: none;
                border: none;
                text-align: left;
                padding: 0;
                min-height: 44px;
            }
            .bpos-faq__q:hover { color: rgba(217, 119, 6, 1); }
            .bpos-faq__chevron {
                flex-shrink: 0;
                width: 16px;
                height: 16px;
                color: var(--text-subtle);
                transition: transform var(--duration-fast) ease;
            }
            .bpos-faq__item.is-open .bpos-faq__chevron {
                transform: rotate(180deg);
            }
            .bpos-faq__a {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                color: var(--text-muted);
                line-height: 1.6;
                max-height: 0;
                overflow: hidden;
                transition: max-height 0.3s ease, padding 0.3s ease;
                padding-top: 0;
            }
            .bpos-faq__item.is-open .bpos-faq__a {
                max-height: 200px;
                padding-top: var(--space-sm);
            }

            /* ── Responsive ────────────────────────────────── */
            @media (max-width: 768px) {
                .bpos-hero { padding: var(--space-md) 0 var(--space-sm); }
                .bpos-hero__title { font-size: clamp(1.5rem, 6vw, 2rem); }
                .bpos-hero__sub { font-size: var(--text-sm); }
                .bpos-features__grid { grid-template-columns: 1fr 1fr; gap: var(--space-sm); }
                .bpos-feature { padding: var(--space-md); }
                .bpos-how__steps { flex-direction: column; align-items: center; gap: var(--space-md); }
                .bpos-step { max-width: 300px; }
                .bpos-plans { grid-template-columns: 1fr; max-width: 400px; }
                .bpos-plan { padding: var(--space-md); }
            }
            @media (max-width: 480px) {
                .bpos-features__grid { grid-template-columns: 1fr; }
                .bpos-hero__actions { flex-direction: column; align-items: center; }
                .bpos-hero__cta { width: 100%; max-width: 280px; }
            }

            @media (prefers-reduced-motion: reduce) {
                .bpos-hero__badge-dot { animation: none; opacity: 0.7; }
            }
        </style>
    </Fragment>

    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/?skip#packages" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Services
            </a>

            <!-- ── Hero ──────────────────────────────────── -->
            <section class="bpos-hero">
                <div class="bpos-hero__badge">
                    <span class="bpos-hero__badge-dot"></span>
                    Restaurant POS Software
                </div>
