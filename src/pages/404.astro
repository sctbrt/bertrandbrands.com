---
/**
 * 404 — Page Not Found.
 * Self-contained page with inline styles. Does not use main.css.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SkipLink from '../components/SkipLink.astro';
import VisitorNotify from '../components/VisitorNotify.astro';
import VersionStamp from '../components/VersionStamp.astro';
import GesturePrevention from '../components/GesturePrevention.astro';
---

<BaseLayout
    title="Page Not Found — Bertrand Brands"
    description="The page you're looking for doesn't exist or has been moved."
    robots="noindex"
    includeMainCss={false}
>
    <Fragment slot="head">
        <style is:inline>
            *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
            html { touch-action: pan-x pan-y; }
            @supports (-webkit-touch-callout: none) { html { -webkit-text-size-adjust: 100%; } }

            :root {
                --bg: #0a0a0a; --bg-elevated: #111111; --text: #fafafa; --text-muted: #a3a3a3;
                --text-subtle: #737373; --accent: #D97706; --accent-hover: #B45309;
                --border: rgba(255, 255, 255, 0.08);
                --font-display: halyard-display, sans-serif;
                --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                --radius-md: 8px; --text-sm: 0.875rem; --text-base: 1rem;
            }

            @media (prefers-reduced-motion: reduce) {
                *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
            }

            body {
                font-family: var(--font-body); background: var(--bg); color: var(--text);
                line-height: 1.6; -webkit-font-smoothing: antialiased;
                min-height: 100vh; display: flex; flex-direction: column;
                align-items: center; justify-content: center; padding: 2rem;
            }

            /* Subtle background glow */
            body::before {
                content: '';
                position: fixed; top: 0; left: 0; right: 0; bottom: 0;
                background:
                    radial-gradient(ellipse 600px 400px at var(--bg-glow-1-x, 20%) var(--bg-glow-1-y, 30%), rgba(37, 99, 235, 0.04), transparent 70%),
                    radial-gradient(ellipse 500px 350px at var(--bg-glow-2-x, 80%) var(--bg-glow-2-y, 70%), rgba(217, 119, 6, 0.03), transparent 70%);
                pointer-events: none; z-index: -1;
            }

            .error-page { text-align: center; max-width: 480px; }
            .error-page__code {
                font-family: var(--font-display); font-size: clamp(5rem, 15vw, 8rem);
                font-weight: 300; letter-spacing: -0.04em; color: var(--text-subtle);
                line-height: 1; margin-bottom: 1rem;
            }
            .error-page__title {
                font-family: halyard-display, sans-serif; font-size: clamp(1.5rem, 4vw, 2rem);
                font-weight: 400; margin-bottom: 1rem; color: var(--text);
            }
            .error-page__message { font-size: var(--text-base); color: var(--text-muted); margin-bottom: 2rem; line-height: 1.7; }
            .error-page__actions { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
            .error-page__link {
                display: inline-flex; align-items: center; gap: 0.5rem;
                padding: 0.875rem 1.5rem; font-size: var(--text-base); font-weight: 500;
                border-radius: var(--radius-md); transition: all 0.2s ease;
            }
            .error-page__link--primary { background: var(--accent); color: white; }
            .error-page__link--primary:hover { background: var(--accent-hover); }
            .error-page__link--secondary { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
            .error-page__link--secondary:hover { color: var(--text); border-color: var(--text-subtle); }
            .error-page__footer { margin-top: 4rem; font-size: var(--text-sm); color: var(--text-subtle); }
            .error-page__footer a { color: var(--text-muted); transition: color 0.2s ease; }
            .error-page__footer a:hover { color: var(--accent); }
            :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
            .skip-link {
                position: fixed; top: -100%; left: 1rem; padding: 0.75rem 1rem;
                background: var(--text); color: var(--bg); font-family: var(--font-body);
                font-size: 0.875rem; font-weight: 500; border-radius: 6px;
                z-index: 10001; text-decoration: none; transition: top 0.15s ease;
            }
            .skip-link:focus { top: 1rem; }
        </style>
    </Fragment>

    <SkipLink />

    <main class="error-page" id="main-content">
        <p class="error-page__code">404</p>
        <h1 class="error-page__title">Page not found</h1>
        <p class="error-page__message">
            The page you're looking for doesn't exist or may have moved.
            Let's get you back on track.
        </p>
        <div class="error-page__actions">
            <a href="/" class="error-page__link error-page__link--primary">
                Back to homepage
            </a>
            <a href="/#contact" class="error-page__link error-page__link--secondary">
                Get in touch
            </a>
        </div>
        <p class="error-page__footer">
            <a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a>
        </p>
    </main>

    <script is:inline>
        // Background glow drift animation
        (function() {
            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

            var glow1X = 20, glow1Y = 30;
            var glow2X = 80, glow2Y = 70;
            var dir1X = 1, dir1Y = 1;
            var dir2X = -1, dir2Y = -1;

            var glowRafId = null;
            function animateBgGlow() {
                glow1X += 0.015 * dir1X;
                glow1Y += 0.012 * dir1Y;
                glow2X += 0.018 * dir2X;
                glow2Y += 0.014 * dir2Y;

                if (glow1X > 35 || glow1X < 10) dir1X *= -1;
                if (glow1Y > 45 || glow1Y < 20) dir1Y *= -1;
                if (glow2X > 90 || glow2X < 65) dir2X *= -1;
                if (glow2Y > 80 || glow2Y < 55) dir2Y *= -1;

                document.body.style.setProperty('--bg-glow-1-x', glow1X + '%');
                document.body.style.setProperty('--bg-glow-1-y', glow1Y + '%');
                document.body.style.setProperty('--bg-glow-2-x', glow2X + '%');
                document.body.style.setProperty('--bg-glow-2-y', glow2Y + '%');
                glowRafId = requestAnimationFrame(animateBgGlow);
            }
            glowRafId = requestAnimationFrame(animateBgGlow);

            document.addEventListener('visibilitychange', function() {
                if (document.hidden && glowRafId) {
                    cancelAnimationFrame(glowRafId);
                    glowRafId = null;
                } else if (!document.hidden && !glowRafId) {
                    glowRafId = requestAnimationFrame(animateBgGlow);
                }
            });
        })();
    </script>

    <GesturePrevention />
    <VisitorNotify />
    <VersionStamp />
</BaseLayout>
