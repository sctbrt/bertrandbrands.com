---
/**
 * Thanks — Formspree redirect confirmation page.
 * Self-contained page with inline styles. Does not use shared.css/homepage.css.
 * Matches confirmation page pattern: HeaderTierBadge + cross-sell + back link.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SkipLink from '../components/SkipLink.astro';
import HeaderTierBadge from '../components/HeaderTierBadge.astro';
import VisitorNotify from '../components/VisitorNotify.astro';
import VersionStamp from '../components/VersionStamp.astro';
import GesturePrevention from '../components/GesturePrevention.astro';
---

<BaseLayout
    title="Thanks for reaching out — Bertrand Brands"
    description="Your message has been received. We'll be in touch shortly."
    robots="noindex"
    includeMainCss={false}
>
    <Fragment slot="head">
        <style is:inline>
            *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
            html { touch-action: pan-x pan-y; }
            @supports (-webkit-touch-callout: none) { html { -webkit-text-size-adjust: 100%; } }

            :root {
                --bg: #0a0a0a; --text: #fafafa; --text-muted: #a3a3a3;
                --text-subtle: #737373; --accent: #D97706;
                --font-display: halyard-display, sans-serif;
                --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                --text-xs: 0.75rem; --text-sm: 0.875rem; --text-base: 1rem;
                --text-2xl: 1.5rem; --text-4xl: 2.25rem;
            }

            @media (prefers-reduced-motion: reduce) {
                *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
            }

            body {
                font-family: var(--font-body); background: var(--bg); color: var(--text);
                line-height: 1.6; -webkit-font-smoothing: antialiased;
                min-height: 100vh; display: flex; flex-direction: column;
                align-items: center; justify-content: center; padding: 2rem;
                text-align: center;
            }

            /* Background glow */
            body::before {
                content: '';
                position: fixed; top: 0; left: 0; right: 0; bottom: 0;
                background:
                    radial-gradient(ellipse 600px 400px at var(--bg-glow-1-x, 20%) var(--bg-glow-1-y, 30%), rgba(37, 99, 235, 0.06) 0%, rgba(37, 99, 235, 0.03) 30%, rgba(37, 99, 235, 0.01) 50%, rgba(37, 99, 235, 0.003) 65%, transparent 78%),
                    radial-gradient(ellipse 500px 350px at var(--bg-glow-2-x, 80%) var(--bg-glow-2-y, 70%), rgba(37, 99, 235, 0.04) 0%, rgba(37, 99, 235, 0.02) 30%, rgba(37, 99, 235, 0.006) 50%, rgba(37, 99, 235, 0.002) 65%, transparent 78%);
                pointer-events: none; z-index: -1;
            }

            /* Header (shared with HeaderTierBadge) */
            .header {
                position: fixed; top: 0; left: 0; right: 0;
                padding: 0.75rem clamp(1rem, 4vw, 2rem); z-index: 100;
            }
            .header__glass {
                max-width: 1200px; margin: 0 auto; padding: 0.75rem 1.5rem;
                background: color-mix(in srgb, var(--bg) 60%, transparent);
                backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
                border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.06);
                position: relative; overflow: hidden;
                --orange-pos-1: 15%; --orange-pos-2: 85%;
            }
            .header__glass::before {
                content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
                background:
                    radial-gradient(ellipse 280px 90px at var(--orange-pos-1) 60%, rgba(217, 119, 6, 0.15), transparent 70%),
                    radial-gradient(ellipse 220px 80px at var(--orange-pos-2) 40%, rgba(217, 119, 6, 0.10), transparent 70%);
                pointer-events: none; z-index: 0; border-radius: inherit;
            }
            .header__inner {
                display: flex; justify-content: space-between; align-items: center;
                position: relative; z-index: 1;
            }
            .header__logo {
                display: flex; align-items: center; text-decoration: none; transition: opacity 0.2s ease;
            }
            .header__logo:hover { opacity: 0.7; }
            .header__logo-icon { width: 24px; height: auto; margin-right: 0.75rem; filter: brightness(0) invert(1); }
            .header__wordmark {
                font-family: var(--font-body); font-size: 0.7rem; font-weight: 400;
                letter-spacing: 0.14em; text-transform: uppercase; color: var(--text); white-space: nowrap;
            }
            .header__tier {
                font-family: var(--font-body); font-size: var(--text-sm); font-weight: 500; letter-spacing: 0.02em;
            }

            /* Content */
            .container { max-width: 480px; padding-top: 5rem; width: 100%; }

            h1 {
                font-family: var(--font-display); font-size: var(--text-4xl);
                font-weight: 300; margin-bottom: 1rem; letter-spacing: -0.02em;
            }
            p { color: var(--text-muted); line-height: 1.6; margin-bottom: 1.5rem; }

            .next-steps {
                background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 12px; padding: 1.5rem; margin-top: 2rem; text-align: left;
            }
            .next-steps h2 {
                font-family: var(--font-body); font-size: var(--text-xs); font-weight: 500;
                text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1rem;
            }
            .next-steps ul { list-style: none; }
            .next-steps li {
                position: relative; padding-left: 1.5rem; margin-bottom: 0.75rem;
                color: var(--text-muted); font-size: var(--text-base); line-height: 1.5;
            }
            .next-steps li::before {
                content: ''; position: absolute; left: 0; top: 0.5rem;
                width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
            }
            .next-steps li:last-child { margin-bottom: 0; }

            /* Cross-sell */
            .explore-next {
                margin-top: 2.5rem; text-align: left;
                background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 12px; padding: 1.5rem;
            }
            .explore-next__title {
                font-family: var(--font-body); font-size: var(--text-xs); font-weight: 500;
                text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1rem;
            }
            .explore-next__links { display: flex; flex-direction: column; gap: 0.75rem; }
            .explore-next__link {
                display: flex; justify-content: space-between; align-items: center;
                padding: 0.75rem 1rem; background: rgba(255, 255, 255, 0.02);
                border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 8px;
                color: var(--text); text-decoration: none; font-size: var(--text-sm); font-weight: 500;
                transition: border-color 0.2s ease, background 0.2s ease;
            }
            .explore-next__link--amber:hover { border-color: rgba(217, 119, 6, 0.4); background: rgba(217, 119, 6, 0.05); }
            .explore-next__link--violet:hover { border-color: rgba(139, 92, 246, 0.4); background: rgba(139, 92, 246, 0.05); }
            .explore-next__link--blue:hover { border-color: rgba(37, 99, 235, 0.4); background: rgba(37, 99, 235, 0.05); }
            .explore-next__arrow { color: var(--text-muted); font-size: var(--text-sm); }
            .explore-next__desc { font-size: var(--text-xs); color: var(--text-muted); font-weight: 400; }

            .back-link {
                display: inline-block; margin-top: 2rem; color: var(--text-muted);
                text-decoration: none; font-size: var(--text-sm); transition: color 0.2s ease;
            }
            .back-link:hover { color: var(--text); }

            .footer-phone {
                margin-top: 1.5rem; font-size: var(--text-sm); color: var(--text-subtle);
            }
            .footer-phone a { color: var(--text-muted); text-decoration: none; transition: color 0.2s ease; }
            .footer-phone a:hover { color: var(--text); }

            .footer-brand {
                margin-top: 1.5rem; font-size: var(--text-sm); color: var(--text-subtle);
            }
            .footer-brand a { color: var(--text-muted); text-decoration: none; transition: color 0.2s ease; }
            .footer-brand a:hover { color: var(--text); }

            :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

            @media (max-width: 480px) {
                h1 { font-size: var(--text-2xl); }
            }
        </style>
    </Fragment>

    <SkipLink />
    <HeaderTierBadge tierLabel="Inquiry" tierColor="rgba(217, 119, 6, 0.9)" />

    <div class="container" id="main-content">
        <h1>Thanks for reaching out</h1>
        <p>Your message has been received. We'll review it and get back to you within 1–2 business days.</p>

        <div class="next-steps">
            <h2>What happens next</h2>
            <ul>
                <li>We review your message and any details you've shared</li>
                <li>You'll hear back within 1–2 business days</li>
                <li>If it's a fit, we'll outline a clear next step</li>
            </ul>
        </div>

        <div class="explore-next">
            <h3 class="explore-next__title">While you're here</h3>
            <div class="explore-next__links">
                <a href="/build" class="explore-next__link explore-next__link--amber">
                    <div><span>Build</span><br><span class="explore-next__desc">Quick builds — from $750</span></div>
                    <span class="explore-next__arrow">&rarr;</span>
                </a>
                <a href="/transform" class="explore-next__link explore-next__link--violet">
                    <div><span>Transform</span><br><span class="explore-next__desc">Bigger commitments, discovery-led</span></div>
                    <span class="explore-next__arrow">&rarr;</span>
                </a>
                <a href="/care" class="explore-next__link explore-next__link--blue">
                    <div><span>Care</span><br><span class="explore-next__desc">Ongoing support after launch</span></div>
                    <span class="explore-next__arrow">&rarr;</span>
                </a>
            </div>
        </div>

        <a href="https://bertrandbrands.ca" class="back-link">&larr; Back to Bertrand Brands</a>

        <p class="footer-phone">
            <a href="tel:+17054133705">(705) 413-3705</a>
        </p>
        <p class="footer-brand">
            <a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a>
        </p>
    </div>

    {/* Fire conversion on page load — uses bbConvert() for consistent GA4 + Ads tracking */}
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof bbConvert === 'function' && !sessionStorage.getItem('bb_thanks_fired')) {
          bbConvert('form_submit', 'contact_form');
          sessionStorage.setItem('bb_thanks_fired', '1');
        }
      });
    </script>

    <script is:inline>
        // Background glow drift animation
        (function() {
            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

            var glow1X = 20, glow1Y = 30;
            var glow2X = 80, glow2Y = 70;
            var dir1X = 1, dir1Y = 1;
            var dir2X = -1, dir2Y = -1;

            function animateBgGlow() {
                glow1X += 0.015 * dir1X;
                glow1Y += 0.012 * dir1Y;
                glow2X += 0.018 * dir2X;
                glow2Y += 0.014 * dir2Y;

                if (glow1X > 35 || glow1X < 10) dir1X *= -1;
                if (glow1Y > 45 || glow1Y < 20) dir1Y *= -1;
                if (glow2X > 90 || glow2X < 65) dir2X *= -1;
                if (glow2Y > 80 || glow2Y < 55) dir2Y *= -1;

                document.body.style.setProperty('--bg-glow-1-x', glow1X + '%');
                document.body.style.setProperty('--bg-glow-1-y', glow1Y + '%');
                document.body.style.setProperty('--bg-glow-2-x', glow2X + '%');
                document.body.style.setProperty('--bg-glow-2-y', glow2Y + '%');
                requestAnimationFrame(animateBgGlow);
            }
            requestAnimationFrame(animateBgGlow);
        })();
    </script>

    <GesturePrevention />
    <VisitorNotify />
    <VersionStamp />
</BaseLayout>
