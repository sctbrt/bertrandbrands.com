---
/**
 * Build — B Build tier hub page.
 * Amber accent (#D97706). Three-offer catalog: Starter One-Page, Starter Multi-Page, Full Site + Booking.
 * Uses ServiceDetailLayout (HeaderUniversal + VisitorNotify included via layout).
 */
import ServiceDetailLayout from '../layouts/ServiceDetailLayout.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import { breadcrumbList, schemaGraph, PROVIDER, AREA_SERVED } from '../lib/schema';
import { Image } from 'astro:assets';
import logomark from '../assets/bg-brands-logomark.png';

const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="Build — Quick Builds | Bertrand Brands"
    description="Fast-launch websites for new and growing businesses. One-Page from $750, Multi-Page, and Full Site + Booking."
    canonical="https://bertrandbrands.ca/build"
    ogTitle="Build — Quick Builds | Bertrand Brands"
    ogDescription="Fast-launch websites for new and growing businesses. One-Page from $750, Multi-Page, and Full Site + Booking."
    schemaJson={schemaGraph(
        breadcrumbList([
            { name: "Bertrand Brands", url: "https://bertrandbrands.ca/" },
            { name: "Build", url: "https://bertrandbrands.ca/build" }
        ]),
        {
            "@type": "Service",
            "name": "Build — Quick Builds",
            "url": "https://bertrandbrands.ca/build",
            "description": "Fast-launch websites for businesses that need to get live, look credible, and start converting.",
            "provider": PROVIDER,
            "areaServed": AREA_SERVED,
            "hasOfferCatalog": {
                "@type": "OfferCatalog",
                "name": "Build Offers",
                "itemListElement": [
                    {
                        "@type": "Offer",
                        "name": "Starter Site — One-Page + Contact",
                        "url": "https://bertrandbrands.ca/build/starter-onepage",
                        "price": "750",
                        "priceCurrency": "CAD",
                        "availability": "https://schema.org/InStock",
                        "description": "One-page marketing website, mobile-first, single primary CTA, contact form, light brand cleanup, basic local SEO setup."
                    },
                    {
                        "@type": "Offer",
                        "name": "Starter Site — Multi-Page + Contact",
                        "url": "https://bertrandbrands.ca/build/starter-multipage",
                        "availability": "https://schema.org/InStock",
                        "description": "3–5 page marketing website with service or product pages, contact form + CTAs, light brand cleanup, SEO fundamentals."
                    },
                    {
                        "@type": "Offer",
                        "name": "Full Site — Multi-Page + Booking",
                        "url": "https://bertrandbrands.ca/build/fullsite-booking",
                        "availability": "https://schema.org/InStock",
                        "description": "5–10 page website with booking or scheduling integration, service pages with conversion UX, reviews, FAQ, analytics."
                    }
                ]
            }
        }
    )}
    spotlightColor="rgba(217, 119, 6, 0.15)"
>
    <Fragment slot="head">
        <style is:inline>
            .service-page { min-height: 100vh; padding-top: 80px; position: relative; overflow: hidden; }

            .service-page__spotlight { position: fixed; border-radius: 50%; filter: blur(80px); pointer-events: none; z-index: 0; will-change: transform, opacity; }
            .service-page__spotlight--1 { width: 400px; height: 400px; background: rgba(217, 119, 6, 0.15); top: 10%; left: -10%; animation: organicBreathe 18s ease-in-out infinite; }
            .service-page__spotlight--2 { width: 350px; height: 350px; background: rgba(217, 119, 6, 0.12); bottom: 20%; right: -5%; animation: organicBreathe 22s ease-in-out infinite 0.5s; }

            @keyframes organicBreathe {
                0%, 100% { opacity: 0.85; transform: translate(0, 0) scale(1); }
                25% { opacity: 0.95; transform: translate(15px, -10px) scale(1.05); }
                50% { opacity: 0.75; transform: translate(-10px, 15px) scale(0.95); }
                75% { opacity: 0.9; transform: translate(10px, 5px) scale(1.02); }
            }

            .service-subbrand { display: flex; align-items: center; justify-content: center; gap: 0.625rem; margin-bottom: 0; text-decoration: none; transition: opacity var(--duration-fast) ease; }
            .service-subbrand:hover { opacity: 0.8; }
            .service-subbrand__mark { width: 32px; height: 32px; filter: brightness(0) invert(1); }
            .service-subbrand__name { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 300; letter-spacing: 0.02em; color: var(--text); }

            .service-hero { padding: var(--space-sm) 0 var(--space-md); text-align: center; position: relative; z-index: 1; }
            .service-hero__headline { font-family: var(--font-display); font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 300; line-height: 1.25; color: var(--text); max-width: 700px; margin: 0 auto var(--space-md); }
            .service-hero__description { font-size: var(--text-lg); color: var(--text-muted); max-width: 600px; margin: 0 auto; line-height: 1.6; }

            .service-content { padding: var(--space-xl) 0; position: relative; z-index: 1; }
            .service-card { background: rgba(217, 119, 6, 0.05); border: 1px solid rgba(217, 119, 6, 0.15); border-radius: var(--radius-lg); padding: var(--space-xl); max-width: 700px; margin: 0 auto var(--space-lg); }
            .service-card__title { font-family: 'Inter', -apple-system, sans-serif; font-size: var(--text-xl); font-weight: 500; color: var(--text); margin: 0 0 var(--space-xs); }
            .service-card__bestfor { font-size: var(--text-sm); color: rgba(217, 119, 6, 1); margin: 0 0 var(--space-md); }
            .service-card__section { margin-bottom: var(--space-lg); }
            .service-card__section:last-child { margin-bottom: 0; }
            .service-card__label { font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(217, 119, 6, 1); margin-bottom: var(--space-sm); }
            .service-card__list { list-style: none; padding: 0; margin: 0; }
            .service-card__list li { position: relative; padding-left: 1.5rem; margin-bottom: 0.5rem; font-size: var(--text-base); color: var(--text-muted); line-height: 1.5; }
            .service-card__list li::before { content: ''; position: absolute; left: 0; top: 0.5rem; width: 6px; height: 6px; background: rgba(217, 119, 6, 0.6); border-radius: 50%; }
            .service-card__list--excluded li::before { background: rgba(255, 255, 255, 0.15); }
            .service-card__text { font-size: var(--text-base); color: var(--text-muted); line-height: 1.6; }
            .service-card__meta { display: flex; gap: var(--space-lg); flex-wrap: wrap; }
            .service-card__meta-item { flex: 1; min-width: 120px; }
            .service-card__meta-value { font-size: var(--text-lg); font-weight: 500; color: var(--text); }

            .service-card__cta { text-align: center; margin-top: var(--space-md); }
            .service-card__cta-link {
                display: inline-block; padding: 0.75rem 2rem;
                background: rgba(217, 119, 6, 0.12); border: 1px solid rgba(217, 119, 6, 0.3);
                color: var(--text); font-size: var(--text-sm); font-weight: 600;
                text-decoration: none; border-radius: 8px; min-height: 44px; line-height: 1.4;
                transition: background var(--duration-fast) ease, border-color var(--duration-fast) ease, transform var(--duration-fast) ease;
            }
            .service-card__cta-link:hover { background: rgba(217, 119, 6, 0.2); border-color: rgba(217, 119, 6, 0.5); transform: translateY(-1px); }
            .service-card__cta-link:active { transform: translateY(0); }

            .service-back { display: inline-flex; align-items: center; gap: 0.5rem; font-size: var(--text-sm); color: var(--text-muted); text-decoration: none; margin-bottom: var(--space-md); transition: color var(--duration-fast) ease; }
            .service-back:hover { color: var(--text); }

            .service-footer { padding: var(--space-lg) 0; text-align: center; border-top: 1px solid var(--border); position: relative; z-index: 1; }
            .service-footer__text { font-size: var(--text-sm); color: var(--text-subtle); }
            .service-footer__phone { font-size: var(--text-sm); margin-top: 0.5rem; }
            .service-footer__phone a { color: var(--text-muted); text-decoration: none; }
            .service-footer__phone a:hover { color: var(--text); }
            .service-footer__cta { margin-bottom: 1rem; }
            .service-footer__cta-text { font-size: var(--text-sm); color: var(--text-subtle); margin-bottom: 0.25rem; }
            .service-footer__cta-link { font-size: var(--text-sm); color: var(--text-muted); text-decoration: none; transition: color 0.15s ease; }
            .service-footer__cta-link:hover { color: var(--accent); }
            .service-footer__compare { font-size: var(--text-sm); color: var(--text-subtle); margin-top: 0.5rem; }
            .service-footer__compare a { color: var(--text-muted); text-decoration: underline; text-underline-offset: 2px; transition: color 0.2s ease; }
            .service-footer__compare a:hover { color: var(--text); }

            @media (max-width: 768px) {
                .service-page__spotlight { filter: blur(40px); }
                .service-page__spotlight--1 { width: 250px; height: 250px; }
                .service-page__spotlight--2 { width: 200px; height: 200px; }
                .service-page .container { padding: 0 0.75rem; }
                .service-hero { padding: var(--space-xs) 1rem var(--space-sm); }
                .service-hero__illustration-wrap { width: clamp(160px, 40vw, 240px); }
                .service-hero__headline { font-size: clamp(1.5rem, 5vw, 2rem); margin-bottom: 0.75rem; max-width: 100%; }
                .service-hero__description { font-size: var(--text-sm); line-height: 1.5; max-width: 100%; }
                .service-subbrand__name { font-size: var(--text-xl); }
                .service-subbrand__mark { width: 26px; height: 26px; }
                .service-content { padding: var(--space-sm) 0; }
                .service-card { padding: 1.5rem; max-width: 100%; }
                .service-card__title { font-size: var(--text-lg); }
                .service-card__label { font-size: 0.75rem; margin-bottom: 0.375rem; }
                .service-card__list li { font-size: var(--text-sm); margin-bottom: 0.25rem; line-height: 1.45; }
                .service-card__text { font-size: var(--text-sm); line-height: 1.5; }
                .service-card__meta-value { font-size: var(--text-sm); }
                .service-card__section { margin-bottom: var(--space-sm); }
                .service-subbrand { margin-bottom: 0.25rem; gap: 0.5rem; }
                .service-back { font-size: var(--text-sm); margin-bottom: 0.5rem; padding: 0.5rem 0; min-height: 44px; }
                .service-footer { padding: var(--space-md) 0; }
            }
            @media (max-width: 480px) {
                .service-hero__illustration-wrap { width: clamp(130px, 38vw, 180px); }
                .service-card { padding: 1rem; }
                .service-hero__headline { font-size: clamp(1.5rem, 5.5vw, 1.75rem); margin-bottom: 0.5rem; }
                .service-hero__description { font-size: var(--text-sm); line-height: 1.5; }
                .service-card__title { font-size: var(--text-base); }
                .service-card__label { font-size: 0.6875rem; }
                .service-card__list li { font-size: var(--text-sm); margin-bottom: 0.1875rem; }
                .service-card__text { font-size: var(--text-sm); }
                .service-card__meta-value { font-size: var(--text-sm); }
                .service-subbrand__name { font-size: var(--text-lg); }
                .service-subbrand__mark { width: 22px; height: 22px; }
                .service-subbrand { gap: 0.375rem; }
                .service-hero { padding: 0.25rem 0.75rem 0.5rem; }
            }
            .service-hero { position: relative; }
            .service-hero__illustration-wrap {
                position: relative; display: block; margin: 0 auto 0.5rem; width: clamp(240px, 42vw, 400px);
            }
            .service-hero__illustration-wrap::after {
                content: ''; position: absolute; top: 50%; left: 50%; width: 130%; height: 130%;
                transform: translate(-50%, -50%);
                background: radial-gradient(circle, rgba(var(--bg-rgb), 0.7) 0%, rgba(var(--bg-rgb), 0) 60%);
                filter: blur(50px); pointer-events: none; z-index: 0;
            }
            .service-hero__illustration-wrap::before {
                content: ''; position: absolute; top: 50%; left: 50%; width: 90%; height: 90%;
                transform: translate(-50%, -50%);
                background: radial-gradient(circle, rgba(217, 119, 6, 0.5) 0%, rgba(217, 119, 6, 0) 65%);
                filter: blur(35px); opacity: 0; pointer-events: none; z-index: 0;
                animation: svcGlowPulse 3s cubic-bezier(0.33, 1, 0.68, 1) 0.1s forwards;
            }
            .service-hero__illustration {
                position: relative; z-index: 1; display: block; width: 100%; height: auto; pointer-events: none;
                opacity: 0; transform: scale(0.92);
                animation: svcFadeIn 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
            }
            .service-hero__illustration line,
            .service-hero__illustration path,
            .service-hero__illustration rect,
            .service-hero__illustration circle,
            .service-hero__illustration ellipse,
            .service-hero__illustration polygon {
                stroke-dasharray: 800; stroke-dashoffset: 800;
                animation: svcLineDraw 2.4s cubic-bezier(0.33, 1, 0.68, 1) 0.6s forwards;
            }
            .service-hero__illustration circle[fill]:not([fill="none"]),
            .service-hero__illustration rect[fill]:not([fill="none"]),
            .service-hero__illustration ellipse[fill]:not([fill="none"]),
            .service-hero__illustration polygon[fill]:not([fill="none"]) {
                opacity: 0; animation: svcLineDraw 2.4s cubic-bezier(0.33, 1, 0.68, 1) 0.6s forwards, svcFillReveal 1s ease 1.4s forwards;
            }
            @keyframes svcGlowPulse {
                0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.7); }
                30%  { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
                100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
            }
            @keyframes svcFadeIn {
                0%   { opacity: 0; transform: scale(0.92); }
                100% { opacity: 1; transform: scale(1); }
            }
            @keyframes svcLineDraw {
                0%   { stroke-dashoffset: 800; }
                100% { stroke-dashoffset: 0; }
            }
            @keyframes svcFillReveal {
                0%   { opacity: 0; }
                100% { opacity: 1; }
            }
            @media (max-width: 900px) { .service-hero__illustration-wrap { width: clamp(200px, 50vw, 320px); } }
            @media (max-width: 480px) { .service-hero__illustration-wrap { width: clamp(130px, 38vw, 180px); } }

            @media (prefers-reduced-motion: reduce) {
                .service-page__spotlight { animation: none !important; }
                .service-hero__illustration-wrap::before { animation: none; opacity: 0.6; }
                .service-hero__illustration { animation: none; opacity: 1; transform: none; }
                .service-hero__illustration line, .service-hero__illustration path,
                .service-hero__illustration rect, .service-hero__illustration circle,
                .service-hero__illustration ellipse, .service-hero__illustration polygon { animation: none; stroke-dasharray: none; stroke-dashoffset: 0; opacity: 1; }
            }
        </style>
    </Fragment>

    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/?skip#packages" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Services
            </a>

            <a href="/?skip#packages" class="service-subbrand">
                <Image src={logomark} alt="" class="service-subbrand__mark" width={40} height={40} format="webp" />
                <span class="service-subbrand__name">Build</span>
            </a>

            <section class="service-hero">
                <div class="service-hero__illustration-wrap">
                <svg class="service-hero__illustration" viewBox="20 20 460 360" fill="none" aria-hidden="true">
                    <!-- Grid -->
                    <line x1="50" y1="200" x2="450" y2="200" stroke="rgba(255, 255, 255, 0.03)" stroke-width="1"/>
                    <line x1="250" y1="40" x2="250" y2="370" stroke="rgba(255, 255, 255, 0.03)" stroke-width="1"/>
                    <line x1="150" y1="40" x2="150" y2="370" stroke="rgba(255, 255, 255, 0.02)" stroke-width="1" stroke-dasharray="2 12"/>
                    <line x1="350" y1="40" x2="350" y2="370" stroke="rgba(255, 255, 255, 0.02)" stroke-width="1" stroke-dasharray="2 12"/>

                    <!-- Foundation baseline -->
                    <line x1="80" y1="320" x2="420" y2="320" stroke="rgba(217, 119, 6, 0.20)" stroke-width="1.5"/>

                    <!-- Rising framework columns -->
                    <line x1="120" y1="320" x2="120" y2="220" stroke="rgba(217, 119, 6, 0.40)" stroke-width="2"/>
                    <line x1="250" y1="320" x2="250" y2="140" stroke="rgba(217, 119, 6, 0.50)" stroke-width="2"/>
                    <line x1="380" y1="320" x2="380" y2="180" stroke="rgba(217, 119, 6, 0.45)" stroke-width="2"/>

                    <!-- Cross beams -->
                    <line x1="120" y1="220" x2="250" y2="180" stroke="rgba(217, 119, 6, 0.25)" stroke-width="1.5"/>
                    <line x1="250" y1="180" x2="380" y2="200" stroke="rgba(217, 119, 6, 0.25)" stroke-width="1.5"/>
                    <line x1="120" y1="260" x2="380" y2="260" stroke="rgba(217, 119, 6, 0.12)" stroke-width="1" stroke-dasharray="4 6"/>

                    <!-- Upward trajectory -->
                    <path d="M 80 300 Q 200 180 420 80" stroke="rgba(217, 119, 6, 0.35)" stroke-width="1.5" fill="none"/>

                    <!-- Node joints -->
                    <circle cx="120" cy="220" r="5" stroke="rgba(217, 119, 6, 0.40)" stroke-width="1.5"/>
                    <circle cx="120" cy="220" r="2" fill="rgba(217, 119, 6, 0.50)"/>
                    <circle cx="250" cy="140" r="6" stroke="rgba(217, 119, 6, 0.45)" stroke-width="1.5"/>
                    <circle cx="250" cy="140" r="2.5" fill="rgba(217, 119, 6, 0.55)"/>
                    <circle cx="380" cy="180" r="5" stroke="rgba(217, 119, 6, 0.40)" stroke-width="1.5"/>
                    <circle cx="380" cy="180" r="2" fill="rgba(217, 119, 6, 0.50)"/>

                    <!-- Base anchors -->
                    <circle cx="120" cy="320" r="3" fill="rgba(217, 119, 6, 0.30)"/>
                    <circle cx="250" cy="320" r="3" fill="rgba(217, 119, 6, 0.30)"/>
                    <circle cx="380" cy="320" r="3" fill="rgba(217, 119, 6, 0.30)"/>

                    <!-- Target marker (top of trajectory) -->
                    <circle cx="420" cy="80" r="8" stroke="rgba(217, 119, 6, 0.30)" stroke-width="1"/>
                    <circle cx="420" cy="80" r="3" fill="rgba(217, 119, 6, 0.45)"/>

                    <!-- Construction arcs -->
                    <path d="M 120 320 Q 185 250 250 180" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1" stroke-dasharray="2 8" fill="none"/>
                    <path d="M 250 320 Q 315 230 380 200" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1" stroke-dasharray="2 8" fill="none"/>

                    <!-- Subtle filled zone -->
                    <rect x="200" y="180" width="100" height="80" rx="2" fill="rgba(217, 119, 6, 0.03)" stroke="rgba(217, 119, 6, 0.06)" stroke-width="1"/>
                </svg>
                </div>
                <h1 class="service-hero__headline">Quick Builds</h1>
                <p class="service-hero__description">Fast-launch websites for businesses that need to get live, look credible, and start converting.</p>
            </section>

            <section class="service-content">

                <!-- Offer 1: Starter Site — One-Page + Contact -->
                <div class="service-card" id="offer-onepage">
                    <h2 class="service-card__title">Starter Site &mdash; One-Page + Contact</h2>
                    <p class="service-card__bestfor">Best for: New businesses, first website</p>

                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">$750 CAD</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Timeline</p>
                                <p class="service-card__meta-value">7&ndash;10 business days</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Revisions</p>
                                <p class="service-card__meta-value">1 round</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meetings</p>
                                <p class="service-card__meta-value">0 meetings</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__text" style="font-size: var(--text-sm); color: var(--text-subtle); margin-top: -0.5rem;">Optional 15-min clarification call</p>
                    </div>

                    <div class="service-card__section">
                        <p class="service-card__label">What&rsquo;s included</p>
                        <ul class="service-card__list">
                            <li>One-page marketing website</li>
                            <li>Mobile-first fast-loading</li>
                            <li>Single primary CTA</li>
                            <li>Contact form</li>
                            <li>Light brand cleanup</li>
                            <li>Basic local SEO setup</li>
                        </ul>
                    </div>

                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Custom brand identity</li>
                            <li>Multi-page architecture</li>
                            <li>Booking/scheduling integration</li>
                            <li>Ongoing maintenance</li>
                        </ul>
                    </div>

                    <div class="service-card__cta">
                        <a href="/intake?tier=amber&offer=starter-onepage" class="service-card__cta-link">Get Started &rarr;</a>
                    </div>
                </div>

                <!-- Offer 2: Starter Site — Multi-Page + Contact -->
                <div class="service-card" id="offer-multipage">
                    <h2 class="service-card__title">Starter Site &mdash; Multi-Page + Contact</h2>
                    <p class="service-card__bestfor">Best for: Growing businesses, multiple service pages</p>

                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">Scoped to project</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Timeline</p>
                                <p class="service-card__meta-value">2&ndash;3 weeks</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Revisions</p>
                                <p class="service-card__meta-value">2 rounds</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meetings</p>
                                <p class="service-card__meta-value">0 meetings</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__text" style="font-size: var(--text-sm); color: var(--text-subtle); margin-top: -0.5rem;">Optional 15-min clarification call</p>
                    </div>

                    <div class="service-card__section">
                        <p class="service-card__label">What&rsquo;s included</p>
                        <ul class="service-card__list">
                            <li>3&ndash;5 page marketing website</li>
                            <li>Mobile-first fast-loading</li>
                            <li>Service or product pages</li>
                            <li>Contact form + CTAs</li>
                            <li>Light brand cleanup</li>
                            <li>SEO fundamentals</li>
                        </ul>
                    </div>

                    <div class="service-card__section">
