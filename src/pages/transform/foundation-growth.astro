---
/**
 * Website Foundation + Growth System — Violet (Transform) offer detail page.
 * Violet accent (#8B5CF6). Follows starter.astro pattern with violet colors.
 */
import ServiceDetailLayout from '../../layouts/ServiceDetailLayout.astro';
import InlineIntakeForm from '../../components/InlineIntakeForm.astro';
import StickyMobileCTA from '../../components/StickyMobileCTA.astro';
import { breadcrumbList, schemaGraph, PROVIDER, AREA_SERVED } from '../../lib/schema';
import { Image } from 'astro:assets';
import logomark from '../../assets/bg-brands-logomark.png';

const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="Website Foundation + Growth System | Bertrand Brands"
    description="Full website rebuild with content strategy, conversion UX, SEO foundation, and growth playbook. Discovery-led, 4-8 weeks."
    canonical="https://bertrandbrands.ca/transform/foundation-growth"
    ogTitle="Website Foundation + Growth System — Bertrand Brands"
    ogDescription="Full website rebuild with content strategy, conversion UX, SEO foundation, and growth playbook. Discovery-led, 4-8 weeks."
    serviceName="Website Foundation + Growth System"
    serviceTier="Transform"
    serviceSlug="foundation-growth"
    schemaJson={schemaGraph(
        breadcrumbList([
            { name: "Bertrand Brands", url: "https://bertrandbrands.ca/" },
            { name: "Transform", url: "https://bertrandbrands.ca/transform" },
            { name: "Foundation + Growth", url: "https://bertrandbrands.ca/transform/foundation-growth" }
        ]),
        {
            "@type": "Service",
            "name": "Website Foundation + Growth System",
            "url": "https://bertrandbrands.ca/transform/foundation-growth",
            "description": "Full website rebuild with content strategy, conversion UX, SEO foundation, and growth playbook.",
            "provider": PROVIDER,
            "areaServed": AREA_SERVED
        }
    )}
    spotlightColor="rgba(139, 92, 246, 0.15)"
    accentRgb="139, 92, 246"
    labelColor="#A78BFA"
>
    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/transform" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Transform
            </a>

            <a href="/transform" class="service-subbrand">
                <Image src={logomark} alt="" class="service-subbrand__mark" width={40} height={40} format="webp" />
                <span class="service-subbrand__name">Foundation + Growth</span>
            </a>

            <section class="service-hero">
                <div class="service-hero__illustration-wrap">
                <svg class="service-hero__illustration" viewBox="45 50 410 290" fill="none" aria-hidden="true">
                    <!-- Growth trajectory curve -->
                    <path d="M 80 310 Q 160 280 220 220 Q 280 160 340 130 Q 400 100 430 80" stroke="rgba(139, 92, 246, 0.25)" stroke-width="1.5" fill="none"/>
                    <!-- Horizontal measurement lines -->
                    <line x1="60" y1="140" x2="440" y2="140" stroke="rgba(139, 92, 246, 0.12)" stroke-width="1"/>
                    <line x1="60" y1="200" x2="440" y2="200" stroke="rgba(139, 92, 246, 0.18)" stroke-width="1"/>
                    <line x1="60" y1="260" x2="440" y2="260" stroke="rgba(139, 92, 246, 0.12)" stroke-width="1"/>
                    <line x1="60" y1="320" x2="440" y2="320" stroke="rgba(139, 92, 246, 0.08)" stroke-width="1"/>
                    <!-- Vertical measurement marks -->
                    <line x1="160" y1="70" x2="160" y2="340" stroke="rgba(139, 92, 246, 0.06)" stroke-width="1" stroke-dasharray="3 8"/>
                    <line x1="260" y1="70" x2="260" y2="340" stroke="rgba(139, 92, 246, 0.10)" stroke-width="1" stroke-dasharray="4 6"/>
                    <line x1="360" y1="70" x2="360" y2="340" stroke="rgba(139, 92, 246, 0.06)" stroke-width="1" stroke-dasharray="3 8"/>
                    <!-- Node points along the curve -->
                    <circle cx="140" cy="275" r="5" stroke="rgba(139, 92, 246, 0.20)" stroke-width="1.5"/>
                    <circle cx="140" cy="275" r="2" fill="rgba(139, 92, 246, 0.30)"/>
                    <circle cx="220" cy="220" r="6" stroke="rgba(139, 92, 246, 0.22)" stroke-width="1.5"/>
                    <circle cx="220" cy="220" r="2.5" fill="rgba(139, 92, 246, 0.35)"/>
                    <circle cx="300" cy="155" r="6" stroke="rgba(139, 92, 246, 0.22)" stroke-width="1.5"/>
                    <circle cx="300" cy="155" r="2.5" fill="rgba(139, 92, 246, 0.35)"/>
                    <circle cx="380" cy="105" r="5" stroke="rgba(139, 92, 246, 0.20)" stroke-width="1.5"/>
                    <circle cx="380" cy="105" r="2" fill="rgba(139, 92, 246, 0.30)"/>
                    <!-- Target marker at peak -->
                    <circle cx="430" cy="80" r="14" stroke="rgba(139, 92, 246, 0.18)" stroke-width="1"/>
                    <circle cx="430" cy="80" r="6" stroke="rgba(139, 92, 246, 0.25)" stroke-width="1.5"/>
                    <circle cx="430" cy="80" r="2" fill="rgba(139, 92, 246, 0.30)"/>
                    <!-- Base marker -->
                    <circle cx="80" cy="310" r="4" stroke="rgba(139, 92, 246, 0.18)" stroke-width="1"/>
                    <!-- Growth zone -->
                    <rect x="195" y="200" width="130" height="40" rx="2" fill="rgba(139, 92, 246, 0.03)" stroke="rgba(139, 92, 246, 0.06)" stroke-width="1"/>
                    <!-- Tick marks on measurement lines -->
                    <line x1="156" y1="260" x2="164" y2="260" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1.5"/>
                    <line x1="256" y1="200" x2="264" y2="200" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1.5"/>
                    <line x1="356" y1="140" x2="364" y2="140" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1.5"/>
                </svg>
                </div>
                <h1 class="service-hero__headline">A website built to grow with you.</h1>
                <p class="service-hero__description">A discovery-led website rebuild with content strategy, conversion UX, SEO infrastructure, and a growth playbook for what comes next.</p>
            </section>

            <section class="service-content">
                <div class="service-card">
                    <div class="service-card__section">
                        <p class="service-card__text">This is for businesses that have outgrown their current site. We rebuild your website from the ground up with a clear content strategy, conversion-focused UX, and the SEO and analytics foundation to measure what matters.</p>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">What's included</p>
                        <ul class="service-card__list">
                            <li>Full website rebuild</li>
                            <li>Content strategy + information architecture</li>
                            <li>Conversion UX throughout</li>
                            <li>SEO + analytics foundation</li>
                            <li>Growth playbook</li>
                            <li>Launch support</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Brand identity design</li>
                            <li>CRM or dashboard build</li>
                            <li>Ongoing maintenance</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <ul class="service-card__list">
                            <li>Businesses that have outgrown their current site</li>
                            <li>Teams that need a clear growth path after launch</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Timeline</p>
                                <p class="service-card__meta-value">4&ndash;8 weeks</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">Scoped to project</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Revisions</p>
                                <p class="service-card__meta-value">Tied to approval gates</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meetings</p>
                                <p class="service-card__meta-value">2&ndash;4 meetings</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__text" style="font-size: var(--text-sm); color: var(--text-subtle);">Discovery, Direction Approval, Pre-Launch QA, Optional Training</p>
                    </div>
                </div>
            </section>

            <section class="service-cta">
                <div id="intakePrompt">
                    <InlineIntakeForm
                        serviceName="Foundation + Growth"
                        serviceSlug="foundation-growth"
                        tierColor="#8B5CF6"
                        tierName="TRANSFORM"
                    />
                </div>
                <div class="service-cta__card" id="bookingPrompt" style="display: none;">
                    <h2 class="service-cta__title">Ready to schedule</h2>
                    <p class="service-cta__text">Your intake is complete. We'll be in touch within 1 business day to confirm next steps.</p>
                    <a href="/intake" class="service-cta__button">View intake form &rarr;</a>
                </div>
            </section>
        </div>
    </main>

    <footer class="service-footer">
        <div class="service-footer__cta">
            <p class="service-footer__cta-text">Not sure which Transform offer?</p>
            <a href="/transform" class="service-footer__cta-link">View all Transform offers &rarr;</a>
        </div>
        <p class="service-footer__text">&copy; {currentYear} Bertrand Brands. All rights reserved.</p>
        <p class="footer-division"><a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a> &middot; <a href="/privacy">Privacy</a></p>
        <p class="service-footer__phone"><a href="tel:+17054133705" class="phone-link__mobile">(705) 413-3705</a><span class="phone-link__desktop">(705) 413-3705</span></p>
    </footer>

    <script is:inline>
        (function() {
            var intakePrompt = document.getElementById('intakePrompt');
            var bookingPrompt = document.getElementById('bookingPrompt');
            function hasIntakeAccess() {
                return document.cookie.split(';').some(function(c) {
                    return c.trim().startsWith('bb_intake_completed=') || c.trim().startsWith('bb_returning_client=');
                });
            }
            if (hasIntakeAccess() && intakePrompt && bookingPrompt) {
                intakePrompt.style.display = 'none';
                bookingPrompt.style.display = 'block';
            }
        })();
    </script>

    <StickyMobileCTA
        href="#inlineIntakeCard"
        heroSelector=".service-hero"
        formSelector="#inlineIntakeCard"
    />
</ServiceDetailLayout>
