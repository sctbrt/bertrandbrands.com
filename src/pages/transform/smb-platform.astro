---
/**
 * SMB Platform Development — Violet (Transform) offer detail page.
 * Violet accent (#8B5CF6). Follows starter.astro pattern with violet colors.
 */
import ServiceDetailLayout from '../../layouts/ServiceDetailLayout.astro';
import InlineIntakeForm from '../../components/InlineIntakeForm.astro';
import StickyMobileCTA from '../../components/StickyMobileCTA.astro';

const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="SMB Platform Development | Bertrand Brands"
    description="Multi-page website or application with CRM portals, booking, automation, and analytics. 6-12 weeks, discovery-led."
    canonical="https://bertrandbrands.ca/transform/smb-platform"
    ogTitle="SMB Platform Development — Bertrand Brands"
    ogDescription="Multi-page website or application with CRM portals, booking, automation, and analytics. 6-12 weeks, discovery-led."
    schemaJson={{
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "SMB Platform Development",
        "description": "Multi-page website or application with CRM portals, booking systems, automation, and analytics.",
        "provider": {
            "@type": "ProfessionalService",
            "name": "Bertrand Brands — Brand & Web Systems",
            "url": "https://bertrandbrands.ca"
        }
    }}
    spotlightColor="rgba(139, 92, 246, 0.15)"
    accentRgb="139, 92, 246"
>
    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/transform" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Transform
            </a>

            <a href="/transform" class="service-subbrand">
                <img src="/assets/bg-brands-logomark.png" alt="" class="service-subbrand__mark" width="40" height="40">
                <span class="service-subbrand__name">SMB Platform</span>
            </a>

            <section class="service-hero">
                <div class="service-hero__illustration-wrap">
                <svg class="service-hero__illustration" viewBox="45 50 410 290" fill="none" aria-hidden="true">
                    <!-- Central hub node -->
                    <circle cx="250" cy="190" r="30" stroke="rgba(139, 92, 246, 0.22)" stroke-width="1.5"/>
                    <circle cx="250" cy="190" r="12" stroke="rgba(139, 92, 246, 0.18)" stroke-width="1"/>
                    <circle cx="250" cy="190" r="4" fill="rgba(139, 92, 246, 0.35)"/>
                    <!-- Outer system ring -->
                    <circle cx="250" cy="190" r="80" stroke="rgba(139, 92, 246, 0.08)" stroke-width="1" stroke-dasharray="6 4"/>
                    <!-- Component boxes -->
                    <rect x="90" y="100" width="70" height="40" rx="4" stroke="rgba(139, 92, 246, 0.20)" stroke-width="1.5" fill="rgba(139, 92, 246, 0.03)"/>
                    <rect x="340" y="100" width="70" height="40" rx="4" stroke="rgba(139, 92, 246, 0.20)" stroke-width="1.5" fill="rgba(139, 92, 246, 0.03)"/>
                    <rect x="90" y="250" width="70" height="40" rx="4" stroke="rgba(139, 92, 246, 0.20)" stroke-width="1.5" fill="rgba(139, 92, 246, 0.03)"/>
                    <rect x="340" y="250" width="70" height="40" rx="4" stroke="rgba(139, 92, 246, 0.20)" stroke-width="1.5" fill="rgba(139, 92, 246, 0.03)"/>
                    <rect x="215" y="70" width="70" height="35" rx="4" stroke="rgba(139, 92, 246, 0.18)" stroke-width="1.5" fill="rgba(139, 92, 246, 0.03)"/>
                    <rect x="215" y="295" width="70" height="35" rx="4" stroke="rgba(139, 92, 246, 0.18)" stroke-width="1.5" fill="rgba(139, 92, 246, 0.03)"/>
                    <!-- Connector lines from hub to boxes -->
                    <line x1="220" y1="175" x2="160" y2="140" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1"/>
                    <line x1="280" y1="175" x2="340" y2="140" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1"/>
                    <line x1="220" y1="205" x2="160" y2="250" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1"/>
                    <line x1="280" y1="205" x2="340" y2="250" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1"/>
                    <line x1="250" y1="160" x2="250" y2="105" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1"/>
                    <line x1="250" y1="220" x2="250" y2="295" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1"/>
                    <!-- Small nodes at connector intersections -->
                    <circle cx="190" cy="158" r="2.5" fill="rgba(139, 92, 246, 0.25)"/>
                    <circle cx="310" cy="158" r="2.5" fill="rgba(139, 92, 246, 0.25)"/>
                    <circle cx="190" cy="228" r="2.5" fill="rgba(139, 92, 246, 0.25)"/>
                    <circle cx="310" cy="228" r="2.5" fill="rgba(139, 92, 246, 0.25)"/>
                    <!-- Horizontal grid lines -->
                    <line x1="60" y1="120" x2="440" y2="120" stroke="rgba(139, 92, 246, 0.06)" stroke-width="1" stroke-dasharray="3 8"/>
                    <line x1="60" y1="270" x2="440" y2="270" stroke="rgba(139, 92, 246, 0.06)" stroke-width="1" stroke-dasharray="3 8"/>
                </svg>
                </div>
                <h1 class="service-hero__headline">Systems that run your business.</h1>
                <p class="service-hero__description">A multi-page website or application with the integrations, portals, and automation your business actually needs.</p>
            </section>

            <section class="service-content">
                <div class="service-card">
                    <div class="service-card__section">
                        <p class="service-card__text">For established businesses juggling multiple systems. We build a unified platform that connects your website, CRM, booking, and workflows into one coherent system.</p>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">What's included</p>
                        <ul class="service-card__list">
                            <li>Multi-page website or application</li>
                            <li>CRM portals or dashboards</li>
                            <li>Booking + scheduling systems</li>
                            <li>Automation + integration</li>
                            <li>Analytics + conversion infrastructure</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Brand identity design</li>
                            <li>Ongoing maintenance</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <ul class="service-card__list">
                            <li>Established businesses with multiple systems to integrate</li>
                            <li>Teams that need portals, dashboards, or custom workflows</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Timeline</p>
                                <p class="service-card__meta-value">6&ndash;12 weeks</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">Scoped to project</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Revisions</p>
                                <p class="service-card__meta-value">Tied to approval gates</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meetings</p>
                                <p class="service-card__meta-value">2&ndash;4 meetings</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="service-cta">
                <div id="intakePrompt">
                    <InlineIntakeForm
                        serviceName="SMB Platform"
                        serviceSlug="smb-platform"
                        tierColor="#8B5CF6"
                        tierName="TRANSFORM"
                    />
                </div>
                <div class="service-cta__card" id="bookingPrompt" style="display: none;">
                    <h2 class="service-cta__title">Ready to schedule</h2>
                    <p class="service-cta__text">Your intake is complete. We'll be in touch within 1 business day to confirm next steps.</p>
                    <a href="/intake" class="service-cta__button">View intake form &rarr;</a>
                </div>
            </section>
        </div>
    </main>

    <footer class="service-footer">
        <div class="service-footer__cta">
            <p class="service-footer__cta-text">Not sure which Transform offer?</p>
            <a href="/transform" class="service-footer__cta-link">View all Transform offers &rarr;</a>
        </div>
        <p class="service-footer__text">&copy; {currentYear} Bertrand Brands. All rights reserved.</p>
        <p class="footer-division"><a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a> &middot; <a href="/privacy">Privacy</a></p>
        <p class="service-footer__phone"><a href="tel:+17054133705" class="phone-link__mobile">(705) 413-3705</a><span class="phone-link__desktop">(705) 413-3705</span></p>
    </footer>

    <script is:inline>
        (function() {
            var intakePrompt = document.getElementById('intakePrompt');
            var bookingPrompt = document.getElementById('bookingPrompt');
            function hasIntakeAccess() {
                return document.cookie.split(';').some(function(c) {
                    return c.trim().startsWith('bb_intake_completed=') || c.trim().startsWith('bb_returning_client=');
                });
            }
            if (hasIntakeAccess() && intakePrompt && bookingPrompt) {
                intakePrompt.style.display = 'none';
                bookingPrompt.style.display = 'block';
            }
        })();
    </script>

    <StickyMobileCTA
        href="#inlineIntakeCard"
        heroSelector=".service-hero"
        formSelector="#inlineIntakeCard"
    />
</ServiceDetailLayout>
