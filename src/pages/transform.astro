---
/**
 * Violet (B Transform) — Tier hub page.
 * Violet accent (#8B5CF6). 3 offers: Foundation+Growth, SMB Platform, Brand+Platform.
 */
import ServiceDetailLayout from '../layouts/ServiceDetailLayout.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';

const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="Transform — Bigger Commitments | Bertrand Brands"
    description="Discovery-led website and brand projects. Website Foundation + Growth, SMB Platform Development, and Brand Design + Platform."
    canonical="https://bertrandbrands.ca/transform"
    ogTitle="Transform — Bertrand Brands"
    ogDescription="Discovery-led website and brand projects. Website Foundation + Growth, SMB Platform Development, and Brand Design + Platform."
    schemaJson={{
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "Transform",
        "description": "Discovery-led website and brand projects for businesses ready for a serious investment.",
        "provider": {
            "@type": "ProfessionalService",
            "name": "Bertrand Brands — Brand & Web Systems",
            "url": "https://bertrandbrands.ca"
        },
        "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Transform Offers",
            "itemListElement": [
                {
                    "@type": "Offer",
                    "itemOffered": {
                        "@type": "Service",
                        "name": "Website Foundation + Growth System",
                        "description": "Full website rebuild with content strategy, conversion UX, SEO foundation, and growth playbook."
                    }
                },
                {
                    "@type": "Offer",
                    "itemOffered": {
                        "@type": "Service",
                        "name": "SMB Platform Development",
                        "description": "Multi-page website or application with CRM portals, booking systems, automation, and analytics."
                    }
                },
                {
                    "@type": "Offer",
                    "itemOffered": {
                        "@type": "Service",
                        "name": "Brand Design + Platform Development",
                        "description": "Full rebrand with identity system, logo, typography, color system, website or platform build, and brand guidelines."
                    }
                }
            ]
        }
    }}
    spotlightColor="rgba(139, 92, 246, 0.15)"
>
    <Fragment slot="head">
        <style is:inline>
            .service-page { min-height: 100vh; padding-top: 80px; position: relative; overflow: hidden; }

            .service-page__spotlight { position: fixed; border-radius: 50%; filter: blur(80px); pointer-events: none; z-index: 0; will-change: transform, opacity; }
            .service-page__spotlight--1 { width: 400px; height: 400px; background: rgba(139, 92, 246, 0.15); top: 10%; left: -10%; animation: organicBreathe 18s ease-in-out infinite; }
            .service-page__spotlight--2 { width: 350px; height: 350px; background: rgba(139, 92, 246, 0.12); bottom: 20%; right: -5%; animation: organicBreathe 22s ease-in-out infinite 0.5s; }

            @keyframes organicBreathe {
                0%, 100% { opacity: 0.85; transform: translate(0, 0) scale(1); border-radius: 50% 50% 50% 50%; }
                15% { opacity: 0.95; transform: translate(15px, -20px) scale(1.06); border-radius: 60% 40% 55% 45%; }
                35% { opacity: 0.75; transform: translate(-10px, 10px) scale(0.94); border-radius: 45% 55% 40% 60%; }
                50% { opacity: 0.9; transform: translate(20px, 5px) scale(1.02); border-radius: 55% 45% 60% 40%; }
                70% { opacity: 0.8; transform: translate(-5px, -15px) scale(0.97); border-radius: 40% 60% 45% 55%; }
                85% { opacity: 0.92; transform: translate(8px, 12px) scale(1.04); border-radius: 58% 42% 48% 52%; }
            }

            .service-subbrand { display: flex; align-items: center; justify-content: center; gap: 0.625rem; margin-bottom: 0; text-decoration: none; transition: opacity var(--duration-fast) ease; }
            .service-subbrand:hover { opacity: 0.8; }
            .service-subbrand__mark { width: 32px; height: 32px; filter: brightness(0) invert(1); }
            .service-subbrand__name { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 300; letter-spacing: 0.02em; color: var(--text); }

            .service-hero { padding: var(--space-sm) 0 var(--space-md); text-align: center; position: relative; z-index: 1; }
            .service-hero__headline { font-family: 'Inter', -apple-system, sans-serif; font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 400; line-height: 1.25; color: var(--text); max-width: 700px; margin: 0 auto var(--space-md); }
            .service-hero__description { font-size: var(--text-lg); color: var(--text-muted); max-width: 600px; margin: 0 auto; line-height: 1.6; }

            .service-content { padding: var(--space-xl) 0; position: relative; z-index: 1; }
            .service-card { background: rgba(139, 92, 246, 0.05); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: var(--radius-lg); padding: var(--space-xl); max-width: 700px; margin: 0 auto var(--space-lg); }
            .service-card__section { margin-bottom: var(--space-lg); }
            .service-card__section:last-child { margin-bottom: 0; }
            .service-card__label { font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(139, 92, 246, 0.8); margin-bottom: var(--space-sm); }
            .service-card__title { font-family: 'Inter', -apple-system, sans-serif; font-size: var(--text-xl); font-weight: 500; color: var(--text); margin: 0 0 var(--space-sm); line-height: 1.3; }
            .service-card__list { list-style: none; padding: 0; margin: 0; }
            .service-card__list li { position: relative; padding-left: 1.5rem; margin-bottom: 0.5rem; font-size: var(--text-base); color: var(--text-muted); line-height: 1.5; }
            .service-card__list li::before { content: ''; position: absolute; left: 0; top: 0.5rem; width: 6px; height: 6px; background: rgba(139, 92, 246, 0.6); border-radius: 50%; }
            .service-card__list--excluded li::before { background: rgba(255, 255, 255, 0.15); }
            .service-card__text { font-size: var(--text-base); color: var(--text-muted); line-height: 1.6; }
            .service-card__meta { display: flex; gap: var(--space-lg); flex-wrap: wrap; }
            .service-card__meta-item { flex: 1; min-width: 150px; }
            .service-card__meta-value { font-size: var(--text-lg); font-weight: 500; color: var(--text); }

            .service-card__cta { text-align: center; padding-top: var(--space-sm); }
            .service-card__button {
                display: inline-block; padding: 0.75rem 2rem;
                background: rgba(139, 92, 246, 0.15); color: var(--text);
                font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600;
                text-decoration: none; border-radius: 8px;
                border: 1px solid rgba(139, 92, 246, 0.3);
                transition: background var(--duration-fast) ease, border-color var(--duration-fast) ease, transform var(--duration-fast) ease;
                min-height: 44px; line-height: 1.4;
            }
            .service-card__button:hover {
                background: rgba(139, 92, 246, 0.25);
                border-color: rgba(139, 92, 246, 0.5);
                transform: translateY(-1px);
            }
            .service-card__button:active { transform: translateY(0); }

            .service-back { display: inline-flex; align-items: center; gap: 0.5rem; font-size: var(--text-sm); color: var(--text-muted); text-decoration: none; margin-bottom: var(--space-md); transition: color var(--duration-fast) ease; }
            .service-back:hover { color: var(--text); }

            .service-footer { padding: var(--space-lg) 0; text-align: center; border-top: 1px solid var(--border); position: relative; z-index: 1; }
            .service-footer__text { font-size: var(--text-sm); color: var(--text-subtle); }
            .service-footer__phone { font-size: var(--text-sm); margin-top: 0.5rem; }
            .service-footer__phone a { color: var(--text-muted); text-decoration: none; }
            .service-footer__phone a:hover { color: var(--text); }
            .service-footer__cta { margin-bottom: 1rem; }
            .service-footer__cta-text { font-size: var(--text-sm); color: var(--text-subtle); margin-bottom: 0.25rem; }
            .service-footer__cta-link { font-size: var(--text-sm); color: var(--text-muted); text-decoration: none; transition: color 0.15s ease; }
            .service-footer__cta-link:hover { color: var(--accent); }

            .service-hero { position: relative; }
            .service-hero__illustration-wrap {
                position: relative; display: block; margin: 0 auto 0.5rem; width: clamp(240px, 42vw, 400px);
            }
            .service-hero__illustration-wrap::after {
                content: ''; position: absolute; top: 50%; left: 50%; width: 130%; height: 130%;
                transform: translate(-50%, -50%);
                background: radial-gradient(circle, rgba(10, 10, 10, 0.7) 0%, rgba(10, 10, 10, 0) 60%);
                filter: blur(50px); pointer-events: none; z-index: 0;
            }
            .service-hero__illustration-wrap::before {
                content: ''; position: absolute; top: 50%; left: 50%; width: 90%; height: 90%;
                transform: translate(-50%, -50%);
                background: radial-gradient(circle, rgba(139, 92, 246, 0.5) 0%, rgba(139, 92, 246, 0) 65%);
                filter: blur(35px); opacity: 0; pointer-events: none; z-index: 0;
                animation: svcGlowPulse 3s cubic-bezier(0.33, 1, 0.68, 1) 0.1s forwards;
            }
            .service-hero__illustration {
                position: relative; z-index: 1; display: block; width: 100%; height: auto; pointer-events: none;
                opacity: 0; transform: scale(0.92); filter: brightness(2.2);
                animation: svcFadeIn 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
            }
            .service-hero__illustration line,
            .service-hero__illustration path,
            .service-hero__illustration rect,
            .service-hero__illustration circle,
            .service-hero__illustration ellipse,
            .service-hero__illustration polygon {
                stroke-dasharray: 800; stroke-dashoffset: 800;
                animation: svcLineDraw 2.4s cubic-bezier(0.33, 1, 0.68, 1) 0.6s forwards;
            }
            .service-hero__illustration circle[fill]:not([fill="none"]),
            .service-hero__illustration rect[fill]:not([fill="none"]),
            .service-hero__illustration ellipse[fill]:not([fill="none"]),
            .service-hero__illustration polygon[fill]:not([fill="none"]) {
                opacity: 0; animation: svcLineDraw 2.4s cubic-bezier(0.33, 1, 0.68, 1) 0.6s forwards, svcFillReveal 1s ease 1.4s forwards;
            }
            @keyframes svcGlowPulse {
                0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.7); }
                30%  { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
                100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
            }
            @keyframes svcFadeIn {
                0%   { opacity: 0; transform: scale(0.92); }
                100% { opacity: 1; transform: scale(1); }
            }
            @keyframes svcLineDraw {
                0%   { stroke-dashoffset: 800; }
                100% { stroke-dashoffset: 0; }
            }
            @keyframes svcFillReveal {
                0%   { opacity: 0; }
                100% { opacity: 1; }
            }
            @media (max-width: 900px) { .service-hero__illustration-wrap { width: clamp(200px, 50vw, 320px); } }
            @media (max-width: 480px) { .service-hero__illustration-wrap { width: clamp(130px, 38vw, 180px); } }
            @media (prefers-reduced-motion: reduce) {
                .service-page__spotlight { animation: none !important; }
                .service-hero__illustration-wrap::before { animation: none; opacity: 0.6; }
                .service-hero__illustration { animation: none; opacity: 1; transform: none; }
                .service-hero__illustration line, .service-hero__illustration path,
                .service-hero__illustration rect, .service-hero__illustration circle,
                .service-hero__illustration ellipse, .service-hero__illustration polygon { animation: none; stroke-dasharray: none; stroke-dashoffset: 0; opacity: 1; }
            }

            @media (max-width: 768px) {
                .service-page__spotlight { filter: blur(40px); }
                .service-page__spotlight--1 { width: 250px; height: 250px; }
                .service-page__spotlight--2 { width: 200px; height: 200px; }
                .service-page .container { padding: 0 0.75rem; }
                .service-hero { padding: var(--space-xs) 1rem var(--space-sm); }
                .service-hero__illustration-wrap { width: clamp(160px, 40vw, 240px); }
                .service-hero__headline { font-size: clamp(1.25rem, 4.5vw, 1.75rem); margin-bottom: 0.75rem; max-width: 100%; }
                .service-hero__description { font-size: var(--text-xs); line-height: 1.5; max-width: 100%; }
                .service-subbrand__name { font-size: var(--text-xl); }
                .service-subbrand__mark { width: 26px; height: 26px; }
                .service-content { padding: var(--space-sm) 0; }
                .service-card { padding: 1.5rem; max-width: 100%; }
                .service-card__title { font-size: var(--text-lg); }
                .service-card__label { font-size: 0.625rem; margin-bottom: 0.375rem; }
                .service-card__list li { font-size: var(--text-xs); margin-bottom: 0.25rem; line-height: 1.45; }
                .service-card__text { font-size: var(--text-xs); line-height: 1.5; }
                .service-card__meta-value { font-size: var(--text-sm); }
                .service-card__section { margin-bottom: var(--space-sm); }
                .service-subbrand { margin-bottom: 0.25rem; gap: 0.5rem; }
                .service-back { font-size: var(--text-sm); margin-bottom: 0.5rem; padding: 0.5rem 0; min-height: 44px; }
                .service-footer { padding: var(--space-md) 0; }
            }
            @media (max-width: 480px) {
                .service-hero__illustration-wrap { width: clamp(130px, 38vw, 180px); }
                .service-card { padding: 1rem; }
                .service-card__title { font-size: var(--text-base); }
                .service-hero__headline { font-size: clamp(1.125rem, 4.5vw, 1.375rem); margin-bottom: 0.5rem; }
                .service-hero__description { font-size: 0.6875rem; line-height: 1.5; }
                .service-card__label { font-size: 0.5625rem; }
                .service-card__list li { font-size: 0.6875rem; margin-bottom: 0.1875rem; }
                .service-card__text { font-size: 0.6875rem; }
                .service-card__meta-value { font-size: var(--text-xs); }
                .service-subbrand__name { font-size: var(--text-lg); }
                .service-subbrand__mark { width: 22px; height: 22px; }
                .service-subbrand { gap: 0.375rem; }
                .service-hero { padding: 0.25rem 0.75rem 0.5rem; }
            }
        </style>
    </Fragment>

    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/?skip#packages" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Packages
            </a>

            <a href="/?skip#packages" class="service-subbrand">
                <img src="/assets/bg-brands-logomark.png" alt="" class="service-subbrand__mark" width="40" height="40">
                <span class="service-subbrand__name">Transform</span>
            </a>

            <section class="service-hero">
                <div class="service-hero__illustration-wrap">
                <svg class="service-hero__illustration" viewBox="45 50 410 290" fill="none" aria-hidden="true">
                    <!-- Transformation arc -->
                    <path d="M 80 300 Q 180 80 420 100" stroke="rgba(139, 92, 246, 0.25)" stroke-width="1.5" fill="none"/>
                    <!-- Horizontal grid -->
                    <line x1="60" y1="140" x2="440" y2="140" stroke="rgba(139, 92, 246, 0.12)" stroke-width="1"/>
                    <line x1="60" y1="200" x2="440" y2="200" stroke="rgba(139, 92, 246, 0.18)" stroke-width="1"/>
                    <line x1="60" y1="260" x2="440" y2="260" stroke="rgba(139, 92, 246, 0.12)" stroke-width="1"/>
                    <!-- Vertical grid -->
                    <line x1="170" y1="70" x2="170" y2="340" stroke="rgba(139, 92, 246, 0.08)" stroke-width="1" stroke-dasharray="4 6"/>
                    <line x1="280" y1="70" x2="280" y2="340" stroke="rgba(139, 92, 246, 0.10)" stroke-width="1" stroke-dasharray="4 6"/>
                    <line x1="390" y1="70" x2="390" y2="340" stroke="rgba(139, 92, 246, 0.08)" stroke-width="1" stroke-dasharray="3 8"/>
                    <!-- Three hub nodes (representing 3 offers) -->
                    <circle cx="170" cy="200" r="22" stroke="rgba(139, 92, 246, 0.18)" stroke-width="1.5"/>
                    <circle cx="170" cy="200" r="4" fill="rgba(139, 92, 246, 0.30)"/>
                    <circle cx="280" cy="170" r="26" stroke="rgba(139, 92, 246, 0.22)" stroke-width="1.5"/>
                    <circle cx="280" cy="170" r="4.5" fill="rgba(139, 92, 246, 0.35)"/>
                    <circle cx="390" cy="140" r="20" stroke="rgba(139, 92, 246, 0.16)" stroke-width="1.5"/>
                    <circle cx="390" cy="140" r="3.5" fill="rgba(139, 92, 246, 0.28)"/>
                    <!-- Connector paths -->
                    <path d="M 192 200 Q 226 185 254 170" stroke="rgba(139, 92, 246, 0.12)" stroke-width="1" stroke-dasharray="2 6" fill="none"/>
                    <path d="M 306 170 Q 340 155 370 140" stroke="rgba(139, 92, 246, 0.12)" stroke-width="1" stroke-dasharray="2 6" fill="none"/>
                    <!-- Growth zone -->
                    <rect x="145" y="240" width="270" height="50" rx="3" fill="rgba(139, 92, 246, 0.03)" stroke="rgba(139, 92, 246, 0.06)" stroke-width="1"/>
                    <!-- Base marker -->
                    <circle cx="80" cy="300" r="4" stroke="rgba(139, 92, 246, 0.18)" stroke-width="1"/>
                    <!-- Outer ring -->
                    <circle cx="280" cy="170" r="50" stroke="rgba(139, 92, 246, 0.08)" stroke-width="1" stroke-dasharray="6 4"/>
                </svg>
                </div>
                <h1 class="service-hero__headline">Bigger Commitments</h1>
                <p class="service-hero__description">Discovery-led projects for businesses ready for a serious website or brand investment.</p>
            </section>

            <section class="service-content">

                <!-- Offer 1: Website Foundation + Growth System -->
                <div class="service-card">
                    <div class="service-card__section">
                        <h2 class="service-card__title">Website Foundation + Growth System</h2>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <p class="service-card__text">Outgrown your current site</p>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">What's included</p>
                        <ul class="service-card__list">
                            <li>Full website rebuild</li>
                            <li>Content strategy + IA</li>
                            <li>Conversion UX throughout</li>
                            <li>SEO + analytics foundation</li>
                            <li>Growth playbook</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Brand identity design</li>
                            <li>CRM or dashboard build</li>
                            <li>Ongoing maintenance</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Timeline</p>
                                <p class="service-card__meta-value">4–8 weeks</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">Scoped to project</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Revisions</p>
                                <p class="service-card__meta-value">Tied to approval gates</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meetings</p>
                                <p class="service-card__meta-value">2–4 meetings</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__text" style="font-size: var(--text-sm); color: var(--text-subtle);">Discovery, Direction Approval, Pre-Launch QA, Optional Training</p>
                    </div>
                    <div class="service-card__cta">
                        <a href="/intake?tier=violet&offer=foundation-growth" class="service-card__button">Request a Quote &rarr;</a>
                    </div>
                </div>

                <!-- Offer 2: SMB Platform Development -->
                <div class="service-card">
                    <div class="service-card__section">
                        <h2 class="service-card__title">SMB Platform Development</h2>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <p class="service-card__text">Established businesses, multiple systems</p>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">What's included</p>
                        <ul class="service-card__list">
                            <li>Multi-page website or application</li>
                            <li>CRM portals or dashboards</li>
                            <li>Booking + scheduling systems</li>
                            <li>Automation + integration</li>
                            <li>Analytics + conversion infrastructure</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Brand identity design</li>
                            <li>Ongoing maintenance</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Timeline</p>
                                <p class="service-card__meta-value">6–12 weeks</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">Scoped to project</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Revisions</p>
                                <p class="service-card__meta-value">Tied to approval gates</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meetings</p>
                                <p class="service-card__meta-value">2–4 meetings</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__cta">
                        <a href="/intake?tier=violet&offer=smb-platform" class="service-card__button">Request a Quote &rarr;</a>
                    </div>
                </div>

                <!-- Offer 3: Brand Design + Platform Development -->
                <div class="service-card">
                    <div class="service-card__section">
                        <h2 class="service-card__title">Brand Design + Platform Development</h2>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <p class="service-card__text">Full rebrand + digital build</p>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">What's included</p>
                        <ul class="service-card__list">
                            <li>Brand strategy + identity system</li>
                            <li>Logo typography color system</li>
                            <li>Full website or platform build</li>
                            <li>Brand guidelines document</li>
                            <li>Launch support</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Ongoing maintenance</li>
                            <li>Print production</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
