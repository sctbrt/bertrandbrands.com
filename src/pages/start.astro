---
/**
 * /start — First-client outreach landing page.
 * Sent personally by Scott to potential clients.
 * No intro animation. No tier jargon. Personal, clear, direct.
 * Pattern: sudbury.astro (sl- prefix for start landing).
 * Formspree: xnjjgoay (shared). source='start-landing'.
 * Pushover: type='intake', source='start-landing'.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderMinimal from '../components/HeaderMinimal.astro';
import SkipLink from '../components/SkipLink.astro';
import FooterMinimal from '../components/FooterMinimal.astro';
import VisitorNotify from '../components/VisitorNotify.astro';
import VersionStamp from '../components/VersionStamp.astro';
import GesturePrevention from '../components/GesturePrevention.astro';

const currentYear = new Date().getFullYear();
---

<BaseLayout
    title="Work with Bertrand Brands — Custom Websites for Small Businesses"
    description="Bertrand Brands is a brand and web studio in Sudbury, Ontario. Custom websites for small businesses starting at $499. Fixed pricing, fast turnaround, real team."
    canonical="https://bertrandbrands.ca/start"
    ogTitle="Work with Bertrand Brands — Custom Websites from $499"
    ogDescription="A small studio in Sudbury with a real brand strategist and full-stack developer. Fixed pricing, no templates. Let's talk."
    robots="noindex, nofollow"
    schemaJson={{
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Bertrand Brands — Brand & Web Systems",
        "description": "Brand and web systems studio in Greater Sudbury, Ontario. Custom websites for small businesses starting at $499.",
        "url": "https://bertrandbrands.ca",
        "telephone": "+17054133705",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Greater Sudbury",
            "addressRegion": "Ontario",
            "addressCountry": "CA"
        }
    }}
>
    <Fragment slot="head">
        <style is:inline>
            html { touch-action: pan-x pan-y; }

            /* Show header immediately on landing pages */
            .header {
                opacity: 1 !important;
                visibility: visible !important;
                pointer-events: auto !important;
                transform: translateY(0) !important;
            }
            .header__logo-icon { opacity: 1 !important; }
            .header__wordmark { opacity: 1 !important; }

            /* Mobile header: clean split — logo left, pill CTA right */
            @media (max-width: 768px) {
                .header { padding: 0.5rem 0.75rem !important; }
                .header__glass { padding: 0.5rem 0.875rem; }
                .header-minimal__phone { display: none; }
                .header__wordmark { display: none !important; }
                /* Pill button CTA */
                .header__inner > div > a:not(.header-minimal__phone) {
                    background: rgba(255, 255, 255, 0.06) !important;
                    border: 1px solid rgba(255, 255, 255, 0.15) !important;
                    border-radius: 100px !important;
                    padding: 0.4rem 1rem !important;
                    font-size: var(--text-xs) !important;
                    color: var(--text) !important;
                    letter-spacing: 0.02em !important;
                    white-space: nowrap !important;
                }
            }

            /* ============================================================
               START LANDING PAGE — sl- prefix
               ============================================================ */

            .sl-container {
                max-width: 720px;
                margin: 0 auto;
                padding: 0 clamp(1.5rem, 5vw, 3rem);
            }

            /* ---- Hero ---- */
            .sl-hero {
                position: relative;
                overflow: hidden;
                display: flex;
                align-items: center;
                justify-content: center;
                text-align: center;
                padding: 10rem var(--space-md) var(--space-lg);
            }
            .sl-hero__content {
                position: relative;
                z-index: 1;
                max-width: 580px;
            }

            /* Hero Spotlights */
            .sl-hero__spotlight {
                position: absolute;
                border-radius: 50%;
                filter: blur(100px);
                opacity: 0;
                pointer-events: none;
                z-index: 0;
                will-change: transform, opacity;
                transform: translateZ(0);
                backface-visibility: hidden;
                contain: layout style;
            }
            .sl-hero__spotlight--amber {
                width: 500px; height: 500px;
                background: radial-gradient(circle, rgba(217, 119, 6, 0.8) 0%, rgba(217, 119, 6, 0.25) 40%, transparent 65%);
                bottom: 5%; left: -8%;
                animation: slFadeIn 3s ease-out forwards, slFloatAmber 45s ease-in-out 3s infinite;
            }
            .sl-hero__spotlight--violet {
                width: 450px; height: 450px;
                background: radial-gradient(circle, rgba(139, 92, 246, 0.7) 0%, rgba(139, 92, 246, 0.22) 40%, transparent 65%);
                top: 10%; left: 25%;
                animation: slFadeIn 3.5s ease-out 0.4s forwards, slFloatViolet 38s ease-in-out 3.9s infinite;
            }
            .sl-hero__spotlight--blue {
                width: 450px; height: 450px;
                background: radial-gradient(circle, rgba(37, 99, 235, 0.7) 0%, rgba(37, 99, 235, 0.22) 40%, transparent 65%);
                top: 0%; right: -6%;
                animation: slFadeIn 4s ease-out 0.8s forwards, slFloatBlue 50s ease-in-out 4.8s infinite;
            }

            @keyframes slFadeIn {
                0% { opacity: 0; transform: scale(0.85) translateZ(0); filter: blur(140px); }
                100% { opacity: 0.4; transform: scale(1) translateZ(0); filter: blur(100px); }
            }
            @keyframes slFloatAmber {
                0%, 100% { transform: translate(0, 0) scale(1) translateZ(0); opacity: 0.4; border-radius: 50%; }
                12% { transform: translate(12vw, -6vh) scale(1.06) translateZ(0); opacity: 0.36; border-radius: 58% 42% 55% 45%; }
                28% { transform: translate(28vw, -12vh) scale(0.95) translateZ(0); opacity: 0.32; border-radius: 44% 56% 42% 58%; }
                45% { transform: translate(36vw, -4vh) scale(1.04) translateZ(0); opacity: 0.38; border-radius: 55% 45% 58% 42%; }
                62% { transform: translate(24vw, 4vh) scale(0.96) translateZ(0); opacity: 0.34; border-radius: 42% 58% 46% 54%; }
                80% { transform: translate(10vw, 2vh) scale(1.03) translateZ(0); opacity: 0.38; border-radius: 56% 44% 50% 50%; }
            }
            @keyframes slFloatViolet {
                0%, 100% { transform: translate(0, 0) scale(1) translateZ(0); opacity: 0.3; border-radius: 50%; }
                14% { transform: translate(14vw, -8vh) scale(1.05) translateZ(0); opacity: 0.34; border-radius: 56% 44% 52% 48%; }
                30% { transform: translate(6vw, 8vh) scale(0.94) translateZ(0); opacity: 0.27; border-radius: 46% 54% 44% 56%; }
                48% { transform: translate(-12vw, 5vh) scale(1.03) translateZ(0); opacity: 0.32; border-radius: 54% 46% 56% 44%; }
                66% { transform: translate(-8vw, -6vh) scale(0.97) translateZ(0); opacity: 0.28; border-radius: 44% 56% 48% 52%; }
                82% { transform: translate(4vw, -2vh) scale(1.02) translateZ(0); opacity: 0.31; border-radius: 52% 48% 54% 46%; }
            }
            @keyframes slFloatBlue {
                0%, 100% { transform: translate(0, 0) scale(1) translateZ(0); opacity: 0.34; border-radius: 50%; }
                12% { transform: translate(-10vw, 5vh) scale(1.04) translateZ(0); opacity: 0.3; border-radius: 54% 46% 48% 52%; }
                28% { transform: translate(-24vw, 10vh) scale(0.96) translateZ(0); opacity: 0.28; border-radius: 43% 57% 54% 46%; }
                45% { transform: translate(-32vw, 4vh) scale(1.05) translateZ(0); opacity: 0.32; border-radius: 57% 43% 46% 54%; }
                62% { transform: translate(-20vw, -2vh) scale(0.95) translateZ(0); opacity: 0.29; border-radius: 46% 54% 57% 43%; }
                80% { transform: translate(-8vw, -1vh) scale(1.02) translateZ(0); opacity: 0.32; border-radius: 52% 48% 43% 57%; }
            }

            .sl-hero__eyebrow {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.18em;
                color: var(--transform-text, #a78bfa);
                margin-bottom: var(--space-md);
            }
            .sl-hero__title {
                font-family: var(--font-display);
                font-size: clamp(1.75rem, 6vw, 3rem);
                font-weight: 600;
                line-height: 1.2;
                letter-spacing: -0.02em;
                color: var(--text);
                margin-bottom: var(--space-sm);
            }
            .sl-hero__subhead {
                font-family: var(--font-body);
                font-size: var(--text-base);
                color: var(--text-muted);
                line-height: 1.7;
                margin-bottom: var(--space-md);
                max-width: 520px;
                margin-left: auto;
                margin-right: auto;
            }
            .sl-hero__actions {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: var(--space-xs);
            }
            .sl-hero__cta {
                display: inline-block;
                position: relative;
                background: var(--bg);
                color: var(--text);
                font-family: var(--font-body);
                font-size: var(--text-base);
                font-weight: 500;
                padding: 0.875rem 2rem;
                border-radius: var(--radius-md);
                letter-spacing: 0.01em;
                text-decoration: none;
                border: 1.5px solid transparent;
                background-clip: padding-box;
                transition: transform var(--duration-fast) ease, box-shadow var(--duration-fast) ease;
            }
            .sl-hero__cta::before {
                content: "";
                position: absolute;
                inset: -1.5px;
                border-radius: inherit;
                background: linear-gradient(135deg, #D97706, #8B5CF6, #2563EB);
                z-index: -1;
            }
            .sl-hero__cta:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 20px rgba(139, 92, 246, 0.15);
            }
            .sl-hero__or {
                font-family: var(--font-body);
                font-size: var(--text-2xs);
                color: var(--text-subtle);
                text-transform: uppercase;
                letter-spacing: 0.1em;
                margin: 0.125rem 0;
            }
            .sl-hero__phone {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                color: var(--text-muted);
                text-decoration: none;
                transition: color var(--duration-fast) ease;
            }
            .sl-hero__phone:hover { color: var(--text); }

            @media (max-width: 768px) {
                .sl-hero__spotlight { filter: blur(50px); }
                .sl-hero__spotlight--amber { width: 350px; height: 350px; }
                .sl-hero__spotlight--violet { width: 300px; height: 300px; }
                .sl-hero__spotlight--blue { width: 300px; height: 300px; }
            }
            @media (max-width: 480px) {
                .sl-hero { padding: 7rem var(--space-sm) var(--space-lg); }
                .sl-hero__title { font-size: clamp(1.5rem, 8vw, 2.25rem); }
                .sl-hero__spotlight--amber { width: 280px; height: 280px; }
                .sl-hero__spotlight--violet { width: 240px; height: 240px; }
                .sl-hero__spotlight--blue { width: 240px; height: 240px; }
            }
            @media (prefers-reduced-motion: reduce) {
                .sl-hero__spotlight { animation: none !important; opacity: 0.25; }
            }

            /* ---- Method Strip ---- */
            .sl-strip { padding: 0 0 var(--space-lg); }
            .sl-strip__grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: var(--space-sm);
                max-width: 620px;
                margin: 0 auto;
            }
            .sl-strip__item { text-align: center; padding: var(--space-sm) var(--space-xs); }
            .sl-strip__label {
                display: block;
                font-family: var(--font-display);
                font-size: var(--text-2xl);
                font-weight: 300;
                color: var(--text);
                letter-spacing: -0.02em;
                line-height: 1.1;
            }
            .sl-strip__desc {
                display: block;
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-subtle);
                margin-top: 0.35rem;
                letter-spacing: 0.02em;
            }
            @media (max-width: 480px) {
                .sl-strip__label { font-size: var(--text-xl); }
                .sl-strip__desc { font-size: var(--text-2xs); }
            }

            /* ---- Who We Are ---- */
            .sl-team { padding: var(--space-lg) 0; }
            .sl-team__title {
                font-family: var(--font-display);
                font-size: clamp(1rem, 3vw, 1.25rem);
                font-weight: 500;
                color: var(--text);
                margin-bottom: var(--space-md);
                letter-spacing: -0.01em;
                text-align: center;
            }
            .sl-team__cards {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: var(--space-sm);
            }
            .sl-team__card {
                position: relative;
                overflow: hidden;
                background: var(--bg-elevated);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg, 16px);
                padding: 1.5rem;
            }
            .sl-team__accent {
                position: absolute;
                top: 1rem;
                right: 1rem;
                pointer-events: none;
                opacity: 0.12;
            }
            .sl-team__accent--scott { color: var(--build-accent, #D97706); }
            .sl-team__accent--devin { color: var(--transform-accent, #8B5CF6); }
            .sl-team__name {
                font-family: var(--font-display);
                font-size: var(--text-xl);
                font-weight: 400;
                color: var(--text);
                letter-spacing: -0.02em;
                margin-bottom: 0.25rem;
            }
            .sl-team__role {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-subtle);
                text-transform: uppercase;
                letter-spacing: 0.06em;
                margin-bottom: var(--space-sm);
            }
            .sl-team__bio {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                color: var(--text-muted);
                line-height: 1.7;
                margin-bottom: 0.5rem;
            }
            .sl-team__bio:last-of-type { margin-bottom: 0; }
            .sl-team__studio-note {
                margin-top: var(--space-sm);
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-subtle);
                font-style: italic;
                line-height: 1.6;
                text-align: center;
            }
            @media (max-width: 768px) {
                .sl-team__cards { grid-template-columns: 1fr; }
            }

            /* ---- Featured Offer ---- */
            .sl-offer {
                padding: var(--space-lg) 0;
                position: relative;
            }
            .sl-offer::before {
                content: "";
                position: absolute;
                inset: -2rem -20%;
                background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(217, 119, 6, 0.04) 0%, transparent 70%);
                pointer-events: none;
                z-index: -1;
            }
            .sl-offer__card {
                background: linear-gradient(135deg, #1a1207 0%, #16110a 100%);
                border: 1px solid rgba(217, 119, 6, 0.2);
                border-radius: var(--radius-lg, 16px);
                padding: var(--space-md);
                max-width: 520px;
                margin: 0 auto;
            }
            .sl-offer__badge {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                margin-bottom: var(--space-sm);
                flex-wrap: wrap;
            }
            .sl-offer__chip {
                font-family: var(--font-body);
                font-size: 0.6875rem;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                color: #fbbf24;
                background: rgba(217, 119, 6, 0.15);
                padding: 0.25rem 0.625rem;
                border-radius: var(--radius-sm, 4px);
            }
            .sl-offer__timeline {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-muted);
            }
            .sl-offer__title {
                font-family: var(--font-display);
                font-size: clamp(1.25rem, 4vw, 1.5rem);
                font-weight: 600;
                color: var(--text);
                margin-bottom: 0.75rem;
                letter-spacing: -0.01em;
            }
            .sl-offer__desc {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                color: var(--text-muted);
                line-height: 1.7;
                margin-bottom: var(--space-sm);
            }
            .sl-offer__list {
                list-style: none;
                padding: 0;
                margin: 0 0 var(--space-md);
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
            }
            .sl-offer__list li {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                color: #e4e4e7;
                padding-left: 1.25rem;
                position: relative;
            }
            .sl-offer__list li::before {
                content: "\2713";
                position: absolute;
                left: 0;
                color: var(--transform-text, #a78bfa);
                font-size: var(--text-sm);
            }
            .sl-offer__cta {
                display: inline-block;
                position: relative;
                background: rgba(255, 255, 255, 0.04);
                color: var(--text);
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 500;
                padding: 0.75rem 1.75rem;
                border-radius: var(--radius-md, 8px);
                text-decoration: none;
                border: 1.5px solid transparent;
                background-clip: padding-box;
                transition: transform var(--duration-fast) ease, box-shadow var(--duration-fast) ease;
                margin-bottom: var(--space-sm);
            }
            .sl-offer__cta::before {
                content: "";
                position: absolute;
                inset: -1.5px;
                border-radius: inherit;
                background: linear-gradient(135deg, #D97706, #8B5CF6, #2563EB);
                z-index: -1;
            }
            .sl-offer__cta:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 20px rgba(139, 92, 246, 0.15);
            }
            .sl-offer__price-row {
                display: flex;
                align-items: baseline;
                gap: 0.5rem;
                flex-wrap: wrap;
                margin-bottom: 0.25rem;
            }
            .sl-offer__amount {
                font-family: var(--font-display);
                font-size: var(--text-xl);
                font-weight: 600;
                color: var(--text);
            }
            .sl-offer__note {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-subtle);
            }
            @media (max-width: 480px) {
                .sl-offer__card { padding: var(--space-sm); }
            }

            /* ---- We Also Do ---- */
            .sl-more { padding: var(--space-lg) 0; }
            .sl-more__intro {
                font-family: var(--font-display);
                font-size: clamp(1rem, 3vw, 1.25rem);
                font-weight: 500;
                color: var(--text);
                margin-bottom: var(--space-md);
                letter-spacing: -0.01em;
                text-align: center;
            }
            .sl-more__grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: var(--space-sm);
            }
            .sl-more__card {
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
                text-decoration: none;
                color: inherit;
                background: var(--bg-elevated);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg, 16px);
                padding: 1.25rem;
                transition: border-color var(--duration-fast) ease;
            }
            .sl-more__card--transform:hover { border-color: rgba(139, 92, 246, 0.3); }
            .sl-more__card--care:hover { border-color: rgba(37, 99, 235, 0.3); }
            .sl-more__name {
                font-family: var(--font-display);
                font-size: var(--text-base);
                font-weight: 500;
                color: var(--text);
                letter-spacing: -0.01em;
            }
            .sl-more__sub {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-subtle);
            }
            .sl-more__desc {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                color: var(--text-muted);
                line-height: 1.6;
            }
            .sl-more__arrow {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                color: var(--text-muted);
                margin-top: auto;
                transition: color var(--duration-fast) ease;
            }
            .sl-more__card--transform:hover .sl-more__arrow { color: var(--transform-text, #a78bfa); }
            .sl-more__card--care:hover .sl-more__arrow { color: var(--care-accent, #2563EB); }
            @media (max-width: 768px) {
                .sl-more__grid { grid-template-columns: 1fr; }
            }

            /* ---- Form ---- */
            .sl-form { padding: var(--space-lg) 0; }
            .sl-form__title {
                font-family: var(--font-display);
                font-size: clamp(1.25rem, 4vw, 1.5rem);
                font-weight: 600;
                color: var(--text);
                margin-bottom: 0.5rem;
                letter-spacing: -0.01em;
                text-align: center;
            }
            .sl-form__subhead {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                color: var(--text-muted);
                line-height: 1.6;
                margin-bottom: var(--space-md);
                max-width: 480px;
                margin-left: auto;
                margin-right: auto;
                text-align: center;
            }
            .sl-form__form {
                max-width: 480px;
                margin: 0 auto;
                display: flex;
                flex-direction: column;
                gap: var(--space-sm);
            }
            .sl-form__field {
                display: flex;
                flex-direction: column;
                gap: 0.375rem;
            }
            .sl-form__label {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 500;
                color: var(--text);
            }
            .sl-form__input {
                font-family: var(--font-body);
                font-size: var(--text-base);
                color: var(--text);
                background: var(--bg-elevated);
                border: 1px solid var(--border);
                border-radius: var(--radius-md, 8px);
                padding: 0.75rem 0.875rem;
                transition: border-color var(--duration-fast) ease;
                width: 100%;
                box-sizing: border-box;
            }
            .sl-form__input::placeholder { color: var(--text-subtle); }
            .sl-form__input:focus { outline: none; border-color: rgba(255, 255, 255, 0.25); }
            .sl-form__submit {
                display: inline-block;
                position: relative;
                font-family: var(--font-body);
                font-size: var(--text-base);
                font-weight: 500;
                padding: 0.875rem 2rem;
                border-radius: var(--radius-md, 8px);
                border: 1.5px solid transparent;
                background: var(--bg);
                background-clip: padding-box;
                color: var(--text);
                cursor: pointer;
                transition: transform var(--duration-fast) ease, box-shadow var(--duration-fast) ease;
                align-self: center;
                min-height: 44px;
            }
            .sl-form__submit::before {
                content: "";
                position: absolute;
                inset: -1.5px;
                border-radius: inherit;
                background: linear-gradient(135deg, #D97706, #8B5CF6, #2563EB);
                z-index: -1;
            }
            .sl-form__submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 20px rgba(139, 92, 246, 0.15);
            }
            .sl-form__submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
            .sl-form__disclaimer {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-subtle);
                margin-top: 0.25rem;
                text-align: center;
