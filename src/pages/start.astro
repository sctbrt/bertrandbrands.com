    <!-- Form Submission -->
    <script is:inline>
    (function() {
        var form = document.getElementById('startForm');
        var submitBtn = document.getElementById('sl-submitBtn');
        var feedback = document.getElementById('sl-formFeedback');
        if (!form || !submitBtn) return;

        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending...';
            feedback.className = 'sl-form__feedback';
            feedback.textContent = '';

            try {
                var formData = new FormData(form);
                var response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(Object.fromEntries(formData))
                });

                if (response.ok) {
                    feedback.className = 'sl-form__feedback sl-form__feedback--success';
                    feedback.textContent = 'Got it. We\'ll be in touch within 1 business day.';
                    form.reset();

                    // Pushover notification
                    fetch('/api/notify', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            type: 'intake',
                            source: 'start-landing',
                            name: formData.get('name') || '',
                            email: formData.get('email') || '',
                            phone: formData.get('phone') || ''
                        })
                    }).catch(function() {});

                    // GA conversion tracking (if configured)
                    if (typeof gtag === 'function') {
                        gtag('set', 'user_data', { email: formData.get('email') || '' });
                        gtag('event', 'conversion', {
                            'send_to': 'AW-17925090292/3B0-CJDv6vUbEPTXrONC',
                            'value': 1.0,
                            'currency': 'CAD'
                        });
                    }
                } else {
                    throw new Error('Submission failed');
                }
            } catch (error) {
                feedback.className = 'sl-form__feedback sl-form__feedback--error';
                feedback.textContent = 'Something went wrong. Please try again or email hello@bertrandgroup.ca';
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Send my details \u2192';
            }
        });
    })();
    </script>

    <!-- Sticky CTA Observer -->
    <script is:inline>
    (function() {
        var hero = document.getElementById('hero');
        var formSection = document.getElementById('get-started');
        var sticky = document.getElementById('sl-stickyCta');
        if (!hero || !sticky) return;

        var heroVisible = true;
        var formVisible = false;

        function updateVisibility() {
            var shouldShow = !heroVisible && !formVisible;
            sticky.classList.toggle('sl-sticky--visible', shouldShow);
            sticky.setAttribute('aria-hidden', String(!shouldShow));
        }

        new IntersectionObserver(function(entries) {
            heroVisible = entries[0].isIntersecting;
            updateVisibility();
        }, { threshold: 0 }).observe(hero);

        if (formSection) {
            new IntersectionObserver(function(entries) {
                formVisible = entries[0].isIntersecting;
                updateVisibility();
            }, { threshold: 0.1 }).observe(formSection);
        }
    })();
    </script>

    <!-- Scroll Fade-In -->
    <script is:inline>
    (function() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.querySelectorAll('.sl-fade').forEach(function(el) {
                el.classList.add('revealed');
            });
            return;
        }
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });
        document.querySelectorAll('.sl-fade').forEach(function(el) {
            observer.observe(el);
        });
    })();
    </script>

