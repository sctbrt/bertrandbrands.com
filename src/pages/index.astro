---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderCanonical from '../components/HeaderCanonical.astro';
import SkipLink from '../components/SkipLink.astro';
import VisitorNotify from '../components/VisitorNotify.astro';
import VersionStamp from '../components/VersionStamp.astro';
import GesturePrevention from '../components/GesturePrevention.astro';
import OfferCard from '../components/OfferCard.astro';
import TierGroupHeader from '../components/TierGroupHeader.astro';
import PhoneFirstCTA from '../components/PhoneFirstCTA.astro';
import FAQ from '../components/FAQ.astro';
import DotLogo from '../components/DotLogo.astro';
import { breadcrumbList, schemaGraph, AREA_SERVED } from '../lib/schema';

const currentYear = new Date().getFullYear();

const homepageFAQ = [
    { question: "How much does a website cost?", answer: "Our Starter One-Page site is $750 CAD. Multi-page builds and Transform-tier projects are scoped to your needs \u2014 <a href='/intake'>fill out an intake form</a> or call us for a quote." },
    { question: "How long does a project take?", answer: "Build-tier sites launch in 7 days to 4 weeks depending on scope. Transform projects take 4\u201312+ weeks. Care plan requests are handled on a monthly cycle." },
    { question: "Do I need to attend meetings?", answer: "Build projects are async-first \u2014 zero meetings by default with an optional 15-minute clarification call. Transform projects include 2\u20134 structured meetings. Care requests are handled asynchronously." },
    { question: "How many revisions do I get?", answer: "Starter One-Page includes 1 revision round. Multi-Page and Full Site builds include 2 rounds. Transform revisions are tied to approval gates in the project timeline." },
    { question: "What if I'm not sure what I need?", answer: "Call us at <a href='tel:+17054133705'>(705) 413-3705</a> or <a href='/intake'>fill out a general intake form</a>. Our intake process helps us understand your situation and route you to the right service." },
    { question: "Do you offer ongoing support?", answer: "Yes. Our <a href='/care'>Care plans</a> start at $249/month (Bronze) for scoped maintenance, updates, and conversion tuning. Silver and Gold plans offer more credits and faster response." },
    { question: "How do I get started?", answer: "Call us at <a href='tel:+17054133705'>(705) 413-3705</a> or fill out an <a href='/intake'>intake form</a>. We'll get back to you within one business day." },
];

const schemaJson = schemaGraph(
  breadcrumbList([
    { name: "Bertrand Brands", url: "https://bertrandbrands.ca/" }
  ]),
  {
    "@type": "ProfessionalService",
    "name": "Bertrand Brands \u2014 Brand & Web Systems",
    "description": "Brand and web systems studio in Sudbury, Ontario. Starter sites, redesigns, and full platform builds. Fixed pricing, fast turnaround.",
    "url": "https://bertrandbrands.ca",
    "email": "hello@bertrandgroup.ca",
    "telephone": "+17054133705",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Greater Sudbury",
      "addressRegion": "Ontario",
      "addressCountry": "CA"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 46.4917,
      "longitude": -80.9930
    },
    "areaServed": AREA_SERVED,
    "priceRange": "$750 - $6,500+ CAD",
    "sameAs": [
      "https://linkedin.com/in/sudburyon"
    ],
    "founder": {
      "@type": "Person",
      "name": "Scott Bertrand",
      "url": "https://scottbertrand.com"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Brand & Web Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Starter Site \u2014 One-Page + Contact" }, "price": "750", "priceCurrency": "CAD", "url": "https://bertrandbrands.ca/build/starter-onepage" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Starter Site \u2014 Multi-Page + Contact" }, "description": "Multi-page marketing website, scoped to project", "url": "https://bertrandbrands.ca/build/starter-multipage" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Full Site \u2014 Multi-Page + Booking" }, "description": "Full-featured website with booking integration", "url": "https://bertrandbrands.ca/build/fullsite-booking" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Website Foundation + Growth System" }, "description": "Website rebuild with content strategy and growth tools", "url": "https://bertrandbrands.ca/transform/foundation-growth" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SMB Platform Development" }, "description": "Multi-system platform for established businesses", "url": "https://bertrandbrands.ca/transform/smb-platform" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Brand Design + Platform Development" }, "description": "Full brand system + web platform, built together", "url": "https://bertrandbrands.ca/transform/brand-platform" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bronze Care" }, "price": "249", "priceCurrency": "CAD", "url": "https://bertrandbrands.ca/care/bronze" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Silver Care" }, "price": "649", "priceCurrency": "CAD", "url": "https://bertrandbrands.ca/care/silver" },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Gold Care" }, "description": "Premium care, by application", "url": "https://bertrandbrands.ca/care/gold" }
      ]
    }
  }
);
---

<BaseLayout
  title="Bertrand Brands \u2014 Brand & Web Systems \u2014 Sudbury, Ontario"
  description="Brand and web systems studio in Sudbury, Ontario. Website builds, platform development, and monthly care plans. Fixed pricing, fast turnaround."
  canonical="https://bertrandbrands.ca/"
  ogTitle="Bertrand Brands \u2014 Brand & Web Systems \u2014 Sudbury, Ontario"
  ogDescription="Brand and web systems studio based in Greater Sudbury, Ontario. Clear scope, fixed pricing, fast turnaround. Serving Northern Ontario and across Canada."
  schemaJson={schemaJson}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/styles/homepage.css" />
    <link rel="stylesheet" href="/styles/founder-lightbox.css" />
    <style is:inline>
        /* V12 concept: editorial sentence hero (overrides shared.css fragment-style sizing) */
        .hero__content {
            text-align: left;
            max-width: 900px;
            padding-left: clamp(2rem, 8vw, 6rem);
        }
        .hero__title {
            font-size: clamp(2.25rem, 6vw, 4.25rem);
            line-height: 1.15;
            max-width: 780px;
        }
        .hero__title span {
            display: inline;
        }
        .hero__subtitle {
            margin-left: 0;
            margin-right: 0;
        }
    </style>
  </Fragment>

  <SkipLink />

  <!-- Cinematic Intro -->
  <div class="intro">
      <div class="intro__glow intro__glow--orange"></div>
      <div class="intro__glow intro__glow--violet"></div>
      <div class="intro__glow intro__glow--blue"></div>
      <div class="intro__fade"></div>
      <div class="intro__grid"></div>
      <DotLogo class="intro__logo" />
      <div class="intro__brand">
          <span class="intro__brand-main">Bertrand Brands</span>
          <span class="intro__brand-sub">Brand &amp; Web Systems</span>
          <span class="intro__brand-division">a division of Bertrand Group Canada</span>
      </div>
  </div>

  <div class="page">
      <!-- Header -->
      <HeaderCanonical />

      <!-- Hero -->
      <section class="hero" id="main-content">
          <div class="hero__bg">
              <div class="hero__gradient hero__gradient--1"></div>
              <div class="hero__gradient hero__gradient--2"></div>
              <div class="hero__grid"></div>
          </div>
          <div class="hero__spotlight hero__spotlight--orange"></div>
          <div class="hero__spotlight hero__spotlight--blue"></div>
          <div class="hero__spotlight hero__spotlight--violet"></div>

          <div class="hero__content">
              <h1 class="hero__title">We build brands and <span class="accent">web systems</span> for businesses that need clarity.</h1>
              <p class="hero__subtitle">
                  Sudbury-based studio. Fixed pricing, fast turnaround, no meetings unless you want one.
              </p>
              <div style="display:flex;gap:0.625rem;flex-wrap:wrap;">
                  <a href="tel:+17054133705" class="hero__cta cta-glow phone-link__mobile">Call (705) 413-3705</a>
                  <span class="hero__cta cta-glow phone-link__desktop" aria-label="Phone number">(705) 413-3705</span>
                  <a href="#packages" class="hero__cta hero__cta--secondary" style="background:transparent;border:1px solid var(--border-hover);color:var(--text-muted);">See Services</a>
              </div>
          </div>
      </section>

      <!-- Services -->
      <section class="section section--alt" id="packages">
          <div class="container">
              <div class="section__header reveal" data-scroll="fade-up">
                  <p class="section__label">Services</p>
                  <h2 class="section__title">Choose your starting point<span class="title-dots" aria-hidden="true"><span class="title-dot title-dot--amber"></span><span class="title-dot title-dot--violet"></span><span class="title-dot title-dot--blue"></span></span></h2>
                  <p class="section__scope">Fixed scope. Clear timelines. Defined revision rounds.</p>
              </div>

              <!-- Intake Prompt with Tier Selector -->
              <div class="intake-prompt reveal" id="tierSelector" data-scroll="fade-up">
                  <p class="intake-prompt__text">Not sure which option fits? We'll help you figure it out.</p>

                  <div class="tier-selector" role="group" aria-label="Choose by situation">
                      <button class="tier-selector__option" data-target-tier="build" type="button">
                          <span class="tier-selector__accent tier-selector__accent--build" aria-hidden="true"></span>
                          <span class="tier-selector__content">
                              <span class="tier-selector__label">I need a website</span>
                              <span class="tier-selector__sub">New site from scratch</span>
                          </span>
                      </button>
                      <button class="tier-selector__option" data-target-tier="transform" type="button">
                          <span class="tier-selector__accent tier-selector__accent--transform" aria-hidden="true"></span>
                          <span class="tier-selector__content">
                              <span class="tier-selector__label">I need to rebuild or grow</span>
                              <span class="tier-selector__sub">Redesign, rebrand, or scale</span>
                          </span>
                      </button>
                      <button class="tier-selector__option" data-target-tier="care" type="button">
                          <span class="tier-selector__accent tier-selector__accent--care" aria-hidden="true"></span>
                          <span class="tier-selector__content">
                              <span class="tier-selector__label">I have a site &amp; need support</span>
                              <span class="tier-selector__sub">Ongoing updates &amp; maintenance</span>
                          </span>
                      </button>
                  </div>

                  <div class="intake-prompt__secondary">
                      <a href="/intake" class="intake-prompt__secondary-link">Fill out an intake form</a>
                      <span class="intake-prompt__sep" aria-hidden="true">&middot;</span>
                      <a href="tel:+17054133705" class="intake-prompt__secondary-link intake-prompt__secondary-link--phone">Call (705) 413-3705</a>
                      <span class="intake-prompt__sep" aria-hidden="true">&middot;</span>
                      <a href="/compare" class="intake-prompt__secondary-link">Compare all services</a>
                  </div>
              </div>

              <!-- B Build — Quick Builds (Amber) -->
              <div class="tier-group reveal" data-scroll="cascade" data-tier="build">
                  <TierGroupHeader tierName="Build" tierClass="build" subtitle="Quick Builds" />
                  <div class="offer-grid">
                      <OfferCard
                          name="Starter Site"
                          headline="One-Page + Contact"
                          bestFor="First website"
                          price="$750"
                          timeline="7\u201310 business days"
                          tierClass="build"
                          ctaHref="/intake?tier=amber&offer=starter-onepage"
                          detailHref="/build/starter-onepage"
                          revisionRounds={1}
                          meetingPolicy="0 meetings"
                          features={[
                              "One-page marketing website",
                              "Mobile-first, fast-loading",
                              "Single primary CTA",
                              "Contact form",
                              "Light brand cleanup",
                              "Basic local SEO setup",
                          ]}
                          exclusions={[
                              "Multi-page structure",
                              "Booking integration",
                              "Custom brand design",
                              "Ongoing maintenance",
                          ]}
                      />
                      <OfferCard
                          name="Starter Site"
                          headline="Multi-Page + Contact"
                          bestFor="Multi-page site needed"
                          timeline="2\u20133 weeks"
                          tierClass="build"
                          ctaText="Request a Quote"
                          ctaHref="/intake?tier=amber&offer=starter-multipage"
                          detailHref="/build/starter-multipage"
                          revisionRounds={2}
                          meetingPolicy="0 meetings"
                          features={[
                              "3\u20135 page marketing website",
                              "Mobile-first, fast-loading",
                              "Service or product pages",
                              "Contact form + CTAs",
                              "Light brand cleanup",
                              "SEO fundamentals",
                          ]}
                          exclusions={[
                              "Booking or calendar integration",
                              "Custom brand design",
                              "E-commerce",
                              "Ongoing maintenance",
                          ]}
                      />
                      <OfferCard
                          name="Full Site"
                          headline="Multi-Page + Booking"
                          bestFor="Ready for online booking"
                          timeline="3\u20134 weeks"
                          tierClass="build"
                          ctaText="Request a Quote"
                          ctaHref="/intake?tier=amber&offer=fullsite-booking"
                          detailHref="/build/fullsite-booking"
                          revisionRounds={2}
                          meetingPolicy="0 meetings"
                          features={[
                              "5\u201310 page website",
                              "Booking or scheduling integration",
                              "Service pages with conversion UX",
                              "Reviews + testimonials section",
                              "FAQ + sticky CTAs",
                              "Analytics setup",
                          ]}
                          exclusions={[
                              "Custom brand system",
                              "CRM or portal build",
                              "E-commerce",
                              "Ongoing maintenance",
                          ]}
                      />
                  </div>
              </div>

              <!-- B Transform — Bigger Commitments (Violet) -->
              <div class="tier-group reveal" data-scroll="cascade" data-tier="transform">
                  <TierGroupHeader tierName="Transform" tierClass="transform" subtitle="Bigger Commitments" />
                  <div class="offer-grid">
                      <OfferCard
                          name="Website Foundation"
                          headline="+ Growth System"
                          bestFor="Outgrown your site"
                          timeline="4\u20138 weeks"
                          tierClass="transform"
                          ctaText="Request a Quote"
                          ctaHref="/intake?tier=violet&offer=foundation-growth"
                          detailHref="/transform/foundation-growth"
                          meetingPolicy="2\u20134 meetings"
                          features={[
                              "Full website rebuild",
                              "Content strategy + IA",
                              "Conversion UX throughout",
                              "SEO + analytics foundation",
                              "Growth playbook",
                          ]}
                          exclusions={[
                              "Full brand system design",
                              "CRM or portal build",
                              "Custom application development",
                          ]}
                      />
                      <OfferCard
                          name="SMB Platform"
                          headline="Development"
                          bestFor="Multiple systems needed"
                          timeline="6\u201312 weeks"
                          tierClass="transform"
                          ctaText="Request a Quote"
                          ctaHref="/intake?tier=violet&offer=smb-platform"
                          detailHref="/transform/smb-platform"
                          featured={true}
                          meetingPolicy="2\u20134 meetings"
                          features={[
                              "Multi-page website or application",
                              "CRM, portals, or dashboards",
                              "Booking + scheduling systems",
                              "Automation + integration",
                              "Analytics + conversion infrastructure",
                          ]}
                          exclusions={[
                              "Full brand system design",
                              "Ongoing maintenance included",
                          ]}
                      />
                      <OfferCard
                          name="Brand Design"
                          headline="+ Platform Development"
                          bestFor="Full rebrand + build"
                          timeline="8\u201316 weeks"
                          tierClass="transform"
                          ctaText="Request a Quote"
                          ctaHref="/intake?tier=violet&offer=brand-platform"
                          detailHref="/transform/brand-platform"
                          meetingPolicy="2\u20134 meetings"
                          features={[
                              "Brand strategy + identity system",
                              "Logo, typography, color system",
                              "Full website or platform build",
                              "Brand guidelines document",
                              "Launch support",
                          ]}
                          exclusions={[
                              "Ongoing maintenance included",
                              "Advertising or marketing services",
                          ]}
                      />
                  </div>
              </div>

              <!-- B Care — Ongoing Care (Blue) -->
              <div class="tier-group reveal" data-scroll="cascade" data-tier="care">
                  <TierGroupHeader tierName="Care" tierClass="care" subtitle="Ongoing Care" />
                  <div class="offer-grid">
                      <OfferCard
                          name="Bronze"
                          headline="Essential maintenance"
                          bestFor="Occasional updates"
                          price="$249"
                          priceNote="CAD / month"
                          timeline="3\u20135 day turnaround"
                          tierClass="care"
                          ctaHref="/intake?tier=blue&offer=bronze"
                          detailHref="/care/bronze"
                          meetingPolicy="0 meetings"
                          features={[
                              "4 credits per month",
                              "Response within 1 business day",
                              "Text swaps, image updates, fixes",
                              "Small CSS tweaks",
                              "Metadata updates",
                          ]}
                      />
                      <OfferCard
                          name="Silver"
                          headline="Active growth support"
                          bestFor="Regular updates"
                          price="$649"
                          priceNote="CAD / month"
                          timeline="1\u20133 day turnaround"
                          tierClass="care"
                          featured={true}
                          ctaHref="/intake?tier=blue&offer=silver"
                          detailHref="/care/silver"
                          meetingPolicy="Monthly optional"
                          features={[
                              "10 credits per month",
                              "Same or next business day response",
                              "New sections, landing pages",
                              "Form + integration changes",
                              "Performance sweeps",
                          ]}
                      />
                      <OfferCard
                          name="Gold"
                          headline="Premium partnership"
                          bestFor="Always-on support"
                          price="By application"
                          timeline="24\u201372 hour target"
                          tierClass="care"
                          ctaText="Apply"
                          ctaHref="/intake?tier=blue&offer=gold"
                          detailHref="/care/gold"
                          meetingPolicy="1\u20132x monthly"
                          features={[
                              "24 credits per month",
                              "Same business day response",
                              "New pages + layout work",
                              "CRO passes + implementation",
                              "Priority scheduling",
                          ]}
                      />
                  </div>
                  <p style="text-align:center;margin-top:1.5rem;font-size:var(--text-sm);color:var(--text-subtle);">
                      <a href="/care" style="color:var(--text-muted);text-decoration:underline;">See full Care plan details &rarr;</a>
                  </p>
              </div>
          </div>
      </section>

      <!-- Process (How It Works) -->
      <section class="section section--alt section--process" id="process">
          <div class="container">
              <div class="section__header section__header--process reveal" data-scroll="blur-in">
                  <p class="section__label">How It Works</p>
                  <h2 class="section__title section__title--clear-phrase"><span class="text-fade">A </span><span class="text-spotlight text-spotlight--clear">clear</span><span class="text-fade"> path</span><br><span class="text-fade">towards what's next</span></h2>
                  <p class="section__scope">Regardless of where you're starting</p>

                  <!-- Process Journey Visual -->
                  <div class="process-journey__track">
                      <div class="process-journey" id="processJourney">
                          <div class="process-journey__step is-active" data-step="0" data-tooltip="01 \u2014 You share context via a guided intake">
                              <div class="process-journey__ring">
                                  <svg class="process-journey__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                      <path d="M9 11V6a3 3 0 0 1 6 0v5"/>
                                      <rect x="4" y="11" width="16" height="10" rx="2"/>
                                  </svg>
                              </div>
                              <span class="process-journey__step-label">Lock</span>
                              <span class="process-journey__label">01 \u2014 Share context</span>
                          </div>
                          <div class="process-journey__connector"></div>
                          <div class="process-journey__step" data-step="1" data-tooltip="02 \u2014 We analyze your inputs across brand, web, and systems">
                              <div class="process-journey__ring">
                                  <svg class="process-journey__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                      <circle cx="11" cy="11" r="8"/>
                                      <path d="m21 21-4.3-4.3"/>
                                  </svg>
                              </div>
                              <span class="process-journey__step-label">Discover</span>
                              <span class="process-journey__label">02 \u2014 Analyze</span>
                          </div>
                          <div class="process-journey__connector"></div>
                          <div class="process-journey__step" data-step="2" data-tooltip="03 \u2014 You receive a written direction brief with priorities">
                              <div class="process-journey__ring">
                                  <svg class="process-journey__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                      <polyline points="14 2 14 8 20 8"/>
                                      <line x1="16" y1="13" x2="8" y2="13"/>
                                      <line x1="16" y1="17" x2="8" y2="17"/>
                                  </svg>
                              </div>
                              <span class="process-journey__step-label">Plan</span>
                              <span class="process-journey__label">03 \u2014 Direction brief</span>
                          </div>
                          <div class="process-journey__connector"></div>
                          <div class="process-journey__step" data-step="3" data-tooltip="04 \u2014 Optional clarification call to walk through findings">
                              <div class="process-journey__ring">
                                  <svg class="process-journey__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                                  </svg>
                              </div>
                              <span class="process-journey__step-label">Align</span>
                              <span class="process-journey__label">04 \u2014 Clarify</span>
                          </div>
                          <div class="process-journey__connector"></div>
                          <div class="process-journey__step process-journey__step--final" data-step="4" data-tooltip="05 \u2014 You move forward with a clear next step">
                              <div class="process-journey__ring">
                                  <svg class="process-journey__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                      <polyline points="20 6 9 17 4 12"/>
                                  </svg>
                              </div>
                              <span class="process-journey__step-label">Deliver</span>
                              <span class="process-journey__label">05 \u2014 Move forward</span>
                          </div>
                      </div>
                      <p class="process-journey__hint">Tap or hover each step for details</p>
                  </div>

                  <!-- Summary row: swaps on hover -->
                  <p class="process-journey__summary" id="processSummary">We confirm scope, constraints, and what "done" means.</p>

                  <ul class="process-journey__outcomes">
                      <li>Written direction</li>
                      <li>Clear next steps</li>
                      <li>No scope creep</li>
                  </ul>

                  <!-- Process CTA — closes the dead end -->
                  <div class="process-cta">
                      <p class="process-cta__text">Ready to start?</p>
                      <div class="process-cta__actions">
                          <a href="tel:+17054133705" class="process-cta__link process-cta__link--phone phone-link__mobile">Call (705) 413-3705</a>
                          <span class="process-cta__link process-cta__link--phone phone-link__desktop" aria-label="Phone number">(705) 413-3705</span>
                          <a href="/intake" class="process-cta__link process-cta__link--form">Fill out an intake form &rarr;</a>
                      </div>
                  </div>
              </div>
          </div>
      </section>

      <!-- About -->
      <section class="section" id="about">
          <div class="about__glow--violet" aria-hidden="true"></div>
          <div class="about__glow--blue" aria-hidden="true"></div>
          <div class="container">
              <div class="section__header section__header--about reveal" data-scroll="blur-in">
                  <p class="section__label">About</p>
                  <h2 class="section__title">Forward thinking, <span class="text-spotlight text-spotlight--focused">focused</span> work</h2>
              </div>

              <div class="about reveal" data-scroll="fade-up">
                  <div class="about__content">
                      <p class="about__text">Bertrand Brands is a design studio for businesses who know their brand or website needs work, but aren't sure where to start.</p>
