                    <div class="intake-form__group">
                        <label class="intake-form__label" for="email">Email</label>
                        <input class="intake-form__input" type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email">
                        <div class="intake-form__error">Please enter a valid email</div>
                    </div>

                    <div class="intake-form__group">
                        <label class="intake-form__label" for="phone">Phone <span>(recommended)</span></label>
                        <input class="intake-form__input" type="tel" id="phone" name="phone" placeholder="705-555-1234" autocomplete="tel" pattern="[\d\s\-\+\(\)\.]{7,20}">
                        <div class="intake-form__error">Please enter a valid phone number</div>
                    </div>

                    <div class="intake-form__group">
                        <label class="intake-form__label" for="business">Business name</label>
                        <input class="intake-form__input" type="text" id="business" name="business" required placeholder="Your business or project name" autocomplete="organization">
                        <div class="intake-form__error">Please enter your business name</div>
                    </div>
                </div>

                <!-- Step 2: Project Details (fields vary by tier) -->
                <div class="intake-step" data-step="2">
                    <h2 class="intake-step__title">About your project</h2>

                    <div class="intake-form__group">
                        <label class="intake-form__label" for="website">Current website <span>(if any)</span></label>
                        <input class="intake-form__input" type="url" id="website" name="website" placeholder="https://yourbusiness.com">
                    </div>

                    <!-- General (no tier): situation picker + description -->
                    <fieldset class="intake-form__group tier-field tier-field--general visible" id="fieldSituationPicker" style="border:none;padding:0;margin:0;">
                        <legend class="intake-form__label">What best describes your situation?</legend>
                        <div class="intake-situation-options" id="situationOptions">
                            <label class="intake-situation__option">
                                <input type="radio" name="situation_type" value="new_site" class="intake-situation__radio">
                                <span class="intake-situation__card">
                                    <strong>I need a website</strong>
                                    <span>First site or simple marketing site</span>
                                </span>
                            </label>
                            <label class="intake-situation__option">
                                <input type="radio" name="situation_type" value="rebuild_grow" class="intake-situation__radio">
                                <span class="intake-situation__card">
                                    <strong>I need to rebuild or grow</strong>
                                    <span>Outgrown my current brand or website</span>
                                </span>
                            </label>
                            <label class="intake-situation__option">
                                <input type="radio" name="situation_type" value="ongoing_support" class="intake-situation__radio">
                                <span class="intake-situation__card">
                                    <strong>I need ongoing support</strong>
                                    <span>Monthly updates on an existing site</span>
                                </span>
                            </label>
                        </div>
                    </fieldset>

                    <div class="intake-form__group tier-field tier-field--general tier-field--general-desc visible" id="fieldGeneral">
                        <label class="intake-form__label" for="description">Tell us more</label>
                        <textarea class="intake-form__textarea" id="description" name="description" placeholder="Tell us what prompted you to reach out. What do you need help with?"></textarea>
                    </div>

                    <!-- Amber (Build): brief description -->
                    <div class="intake-form__group tier-field tier-field--amber" id="fieldAmber">
                        <label class="intake-form__label" for="brief">Brief description of what you need</label>
                        <textarea class="intake-form__textarea" id="brief" name="brief" placeholder="What kind of site do you need? Any specific pages, features, or functionality?"></textarea>
                        <p class="intake-form__help">Build projects are async-first — zero meetings by default.</p>
                    </div>

                    <!-- Violet (Transform): situation + timeline -->
                    <div class="tier-field tier-field--violet" id="fieldViolet">
                        <div class="intake-form__group">
                            <label class="intake-form__label" for="situation">What's your current situation?</label>
                            <textarea class="intake-form__textarea" id="situation" name="situation" placeholder="What's not working? What are you trying to achieve?"></textarea>
                        </div>
                        <div class="intake-form__group">
                            <label class="intake-form__label" for="violet_timeline">Ideal timeline</label>
                            <select class="intake-form__select" id="violet_timeline" name="timeline">
                                <option value="" disabled selected>Select a timeline</option>
                                <option value="4_8_weeks">4–8 weeks</option>
                                <option value="2_3_months">2–3 months</option>
                                <option value="3_plus_months">3+ months</option>
                                <option value="exploring">Just exploring options</option>
                            </select>
                        </div>
                        <div class="intake-form__group">
                            <label class="intake-form__label" for="violet_budget">Budget range <span>(optional)</span></label>
                            <select class="intake-form__select" id="violet_budget" name="budget">
                                <option value="" selected>Prefer not to say</option>
                                <option value="2500_5000">$2,500 – $5,000</option>
                                <option value="5000_10000">$5,000 – $10,000</option>
                                <option value="10000_plus">$10,000+</option>
                            </select>
                        </div>
                        <p class="intake-form__help">Transform projects include 2–4 structured meetings.</p>
                    </div>

                    <!-- Blue (Care): current site status + request type -->
                    <div class="tier-field tier-field--blue" id="fieldBlue">
                        <div class="intake-form__group">
                            <label class="intake-form__label" for="site_status">Current site status</label>
                            <select class="intake-form__select" id="site_status" name="site_status">
                                <option value="" disabled selected>Select status</option>
                                <option value="live_healthy">Live and working fine</option>
                                <option value="live_issues">Live but has issues</option>
                                <option value="needs_updates">Needs regular updates</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div class="intake-form__group">
                            <label class="intake-form__label" for="care_request">What kind of support do you need?</label>
                            <textarea class="intake-form__textarea" id="care_request" name="care_request" placeholder="Small updates, new sections, performance work, etc."></textarea>
                        </div>
                        <p class="intake-form__help">Care requests are handled asynchronously on a monthly cycle.</p>
                    </div>
                </div>

                <!-- Step 3: Logistics + Confirmation -->
                <div class="intake-step" data-step="3">
                    <h2 class="intake-step__title">Timeline & details</h2>

                    <!-- General/Amber only: timeline select -->
                    <div class="intake-form__group tier-field tier-field--general tier-field--amber visible" id="fieldTimelineGeneral">
                        <label class="intake-form__label" for="gen_timeline">When do you need this done?</label>
                        <select class="intake-form__select" id="gen_timeline" name="timeline">
                            <option value="" disabled selected>Select a timeline</option>
                            <option value="asap">As soon as possible</option>
                            <option value="2_4_weeks">Within 2–4 weeks</option>
                            <option value="1_3_months">Within 1–3 months</option>
                            <option value="exploring">Just exploring options</option>
                        </select>
                    </div>

                    <!-- General/Amber only: budget -->
                    <div class="intake-form__group tier-field tier-field--general tier-field--amber visible" id="fieldBudgetGeneral">
                        <label class="intake-form__label" for="gen_budget">Budget range <span>(optional)</span></label>
                        <select class="intake-form__select" id="gen_budget" name="budget">
                            <option value="" selected>Prefer not to say</option>
                            <option value="under_750">Under $750</option>
                            <option value="750_2500">$750 – $2,500</option>
                            <option value="2500_5000">$2,500 – $5,000</option>
                            <option value="5000_plus">$5,000+</option>
                        </select>
                    </div>

                    <div class="intake-form__group">
                        <label class="intake-form__label" for="context">Anything else? <span>(optional)</span></label>
                        <textarea class="intake-form__textarea" id="context" name="context" placeholder="Goals, concerns, or anything else we should know."></textarea>
                    </div>
                </div>

                <!-- Navigation -->
                <div class="intake-nav">
                    <button type="button" class="intake-nav__btn intake-nav__btn--back intake-nav__btn--hidden" id="backBtn">Back</button>
                    <button type="button" class="intake-nav__btn intake-nav__btn--next" id="nextBtn">Continue</button>
                    <button type="submit" class="intake-nav__btn intake-nav__btn--submit" id="submitBtn" style="display:none;">Submit</button>
                </div>
            </form>

            <!-- Success -->
            <div class="intake-success" id="successState">
                <div class="intake-success__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <h2 class="intake-success__title">We've got it</h2>
                <p class="intake-success__text">Thanks for reaching out. We'll review your intake and follow up within one business day with a clear next step.</p>
                <a href="/" class="intake-success__cta">Back to homepage &rarr;</a>
            </div>
        </div>
    </main>

    <!-- Toast container -->
    <div class="intake-toast" id="intakeToast"></div>

    <script is:inline>
    (function() {
        var form = document.getElementById('intakeForm');
        var steps = document.querySelectorAll('.intake-step');
        var progressFill = document.getElementById('progressFill');
        var progressText = document.getElementById('progressText');
        var backBtn = document.getElementById('backBtn');
        var nextBtn = document.getElementById('nextBtn');
        var submitBtn = document.getElementById('submitBtn');
        var successState = document.getElementById('successState');
        var toast = document.getElementById('intakeToast');

        var currentStep = 1;
        var totalSteps = 3;

        // Read tier and offer from URL params
        var params = new URLSearchParams(window.location.search);
        var tierParam = params.get('tier') || '';
        var offerParam = params.get('offer') || '';

        // Set hidden fields
        document.getElementById('hiddenTier').value = tierParam;
        document.getElementById('hiddenOffer').value = offerParam;

        // Tier name map for display
        var tierNames = {
            'amber': 'Build',
            'violet': 'Transform',
            'blue': 'Care'
        };

        // Offer name map for display
        var offerNames = {
            'starter-onepage': 'Starter Site — One-Page',
            'starter-multipage': 'Starter Site — Multi-Page',
            'fullsite-booking': 'Full Site + Booking',
            'foundation-growth': 'Website Foundation + Growth',
            'smb-platform': 'SMB Platform',
            'brand-platform': 'Brand Design + Platform',
            'bronze': 'Bronze Care',
            'silver': 'Silver Care',
            'gold': 'Gold Care'
        };

        // Set source and subject based on tier
        var sourceEl = document.getElementById('hiddenSource');
        var subjectEl = document.getElementById('hiddenSubject');

        if (tierParam && tierNames[tierParam]) {
            sourceEl.value = 'tier-intake-' + tierParam;
            var tierLabel = tierNames[tierParam];
            var offerLabel = offerNames[offerParam] || offerParam || '';
            subjectEl.value = 'New ' + tierLabel + ' Lead' + (offerLabel ? ' — ' + offerLabel : '');
        } else {
            sourceEl.value = 'tier-intake';
            subjectEl.value = 'New Lead — General Intake';
        }

        // Show tier badges
        var badgesEl = document.getElementById('tierBadges');
        if (tierParam && tierNames[tierParam]) {
            var tierBadge = document.createElement('span');
            tierBadge.className = 'intake-tier-badge intake-tier-badge--' + tierParam;
            tierBadge.textContent = tierNames[tierParam];
            badgesEl.appendChild(tierBadge);

            if (offerParam && offerNames[offerParam]) {
                var offerBadge = document.createElement('span');
                offerBadge.className = 'intake-tier-badge intake-tier-badge--' + tierParam;
                offerBadge.textContent = offerNames[offerParam];
                badgesEl.appendChild(offerBadge);
            }
        }

        // Show/hide tier-specific fields
        function configureTierFields() {
            // Hide all tier fields
            document.querySelectorAll('.tier-field').forEach(function(el) {
                el.classList.remove('visible');
            });

            var tierClass = '';
            if (tierParam === 'amber') tierClass = 'amber';
            else if (tierParam === 'violet') tierClass = 'violet';
            else if (tierParam === 'blue') tierClass = 'blue';
            else tierClass = 'general';

            // Show fields matching this tier
            document.querySelectorAll('.tier-field--' + tierClass).forEach(function(el) {
                el.classList.add('visible');
            });
        }
        configureTierFields();

        // GA4: form_start on first interaction
        (function() {
            var intakeStarted = false;
            form.addEventListener('focusin', function() {
                if (intakeStarted) return;
                intakeStarted = true;
                if (typeof gtag === 'function') {
                    gtag('event', 'form_start', {
                        form_id: 'tier_intake',
                        form_location: '/intake',
                        item_category: tierParam || '',
                        item_id: offerParam || ''
                    });
                }
            });
        })();

        // Situation picker — dynamically changes placeholder + reveals description (progressive disclosure)
        (function() {
            var situationRadios = document.querySelectorAll('.intake-situation__radio');
            var descriptionField = document.getElementById('description');
            var descriptionWrap = document.getElementById('fieldGeneral');
            if (!situationRadios.length || !descriptionField) return;

            var placeholders = {
                'new_site': 'What kind of site do you need? How many pages? Any specific features?',
                'rebuild_grow': 'What\'s not working with your current site or brand? What are you trying to achieve?',
                'ongoing_support': 'What kind of updates or support do you need? How often?'
            };

            situationRadios.forEach(function(radio) {
                radio.addEventListener('change', function() {
                    if (placeholders[radio.value]) {
                        descriptionField.placeholder = placeholders[radio.value];
                    }
                    // Reveal description textarea with animation
                    if (descriptionWrap && !descriptionWrap.classList.contains('revealed')) {
                        descriptionWrap.classList.add('revealed');
                        setTimeout(function() { descriptionField.focus(); }, 350);
                    }
                });
            });
        })();

        // Input completion indicators — show checkmark when fields are valid
        (function() {
            var inputs = form.querySelectorAll('.intake-form__input, .intake-form__textarea, .intake-form__select');
            inputs.forEach(function(input) {
                function checkComplete() {
                    var group = input.closest('.intake-form__group');
                    if (!group) return;
                    var val = input.value.trim();
                    var isSelect = input.tagName === 'SELECT';
                    var hasValue = isSelect ? (val && !input.selectedOptions[0].disabled) : val.length > 0;
                    var isValid = input.checkValidity();
                    group.classList.toggle('is-complete', hasValue && isValid);
                }
                input.addEventListener('blur', checkComplete);
                input.addEventListener('change', checkComplete);
            });
        })();

        function showToast(message, type) {
            toast.textContent = message;
            toast.className = 'intake-toast intake-toast--' + type + ' visible';
            setTimeout(function() { toast.classList.remove('visible'); }, 4000);
        }

        var summaryEl = document.getElementById('intakeSummary');
        var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function updateUI(direction) {
            var oldStep = document.querySelector('.intake-step.active');
            var newStep = document.querySelector('[data-step="' + currentStep + '"]');

            if (reduceMotion || !oldStep || oldStep === newStep) {
                // No animation: instant switch
                steps.forEach(function(s) {
                    s.classList.remove('active', 'exiting');
                    if (parseInt(s.dataset.step) === currentStep) s.classList.add('active');
                });
            } else {
                // Animated transition: exit old → enter new
                oldStep.classList.add('exiting');
                oldStep.classList.remove('active');
                setTimeout(function() {
                    oldStep.classList.remove('exiting');
                    newStep.classList.add('active');
                }, 200);
            }

            var pct = Math.round((currentStep / totalSteps) * 100);
            progressFill.style.width = pct + '%';
            progressText.textContent = 'Step ' + currentStep + ' of ' + totalSteps;

            backBtn.classList.toggle('intake-nav__btn--hidden', currentStep === 1);

            if (currentStep === totalSteps) {
                nextBtn.style.display = 'none';
                submitBtn.style.display = 'block';
            } else {
                nextBtn.style.display = 'block';
                submitBtn.style.display = 'none';
            }

            // Build summary chips for completed steps
            updateSummary();

            document.querySelector('.intake-content').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function updateSummary() {
            if (!summaryEl) return;
            summaryEl.innerHTML = '';

            // Only show summary after step 1
            if (currentStep <= 1) return;

            var nameVal = document.getElementById('name').value.trim();
            var emailVal = document.getElementById('email').value.trim();
            var bizVal = document.getElementById('business').value.trim();

            if (nameVal) addChip(nameVal);
            if (bizVal) addChip(bizVal);
            if (emailVal) addChip(emailVal);

            // Step 2 summary (only if on step 3)
            if (currentStep > 2) {
                var situationRadio = document.querySelector('.intake-situation__radio:checked');
                if (situationRadio) {
                    var card = situationRadio.closest('.intake-situation__option');
                    var label = card ? card.querySelector('strong') : null;
                    if (label) addChip(label.textContent);
                }
            }
        }

        function addChip(text) {
            var chip = document.createElement('span');
            chip.className = 'intake-summary__chip';
            chip.textContent = text;
            summaryEl.appendChild(chip);
        }

        function validateStep(step) {
            var stepEl = document.querySelector('[data-step="' + step + '"]');
            var groups = stepEl.querySelectorAll('.intake-form__group');
            var valid = true;

            groups.forEach(function(group) {
                // Skip hidden tier fields
                var tierField = group.closest('.tier-field');
                if (tierField && !tierField.classList.contains('visible')) return;

                group.classList.remove('has-error');
                var input = group.querySelector('.intake-form__input, .intake-form__textarea, .intake-form__select');
                if (input && input.required && !input.value.trim()) {
                    group.classList.add('has-error');
                    valid = false;
                }
                if (input && input.type === 'email' && input.value.trim()) {
                    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value.trim())) {
                        group.classList.add('has-error');
                        valid = false;
                    }
                }
                if (input && input.type === 'tel' && input.value.trim()) {
                    if (!/^[\d\s\-\+\(\)\.]{7,20}$/.test(input.value.trim())) {
                        group.classList.add('has-error');
                        valid = false;
                    }
                }
            });

            if (!valid) {
                showToast('Please fill in the required fields.', 'error');
                var firstError = stepEl.querySelector('.has-error .intake-form__input, .has-error .intake-form__textarea');
                if (firstError) firstError.focus();
            }

            return valid;
        }

        nextBtn.addEventListener('click', function() {
            if (!validateStep(currentStep)) return;
            if (currentStep < totalSteps) {
                currentStep++;
                updateUI();
                // GA4: step progression
                if (typeof gtag === 'function') {
                    gtag('event', 'checkout_progress', {
                        step: currentStep,
                        form_id: 'tier_intake',
                        item_category: tierParam || '',
                        item_id: offerParam || ''
                    });
                }
            }
        });

        backBtn.addEventListener('click', function() {
            if (currentStep > 1) {
                currentStep--;
                updateUI();
            }
        });

        form.addEventListener('submit', function(e) {
            e.preventDefault();

            if (!validateStep(currentStep)) return;

            submitBtn.disabled = true;
            submitBtn.classList.add('intake-nav__btn--loading');

            var formData = new FormData(form);

            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: { 'Accept': 'application/json' }
            })
            .then(function(response) {
                if (response.ok) {
                    form.classList.add('hidden');
                    form.style.display = 'none';
                    document.querySelector('.intake-progress').style.display = 'none';
                    badgesEl.style.display = 'none';
                    successState.classList.add('active');

                    // Conversion tracking
                    if (typeof bbConvert === 'function') {
                        bbConvert('form_submit', 'tier_intake');
                    }

                    // Notify API
                    fetch('/api/notify', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            type: 'intake',
                            source: sourceEl.value,
                            name: formData.get('name'),
                            email: formData.get('email'),
                            phone: formData.get('phone') || '',
                            business: formData.get('business'),
                            website: formData.get('website') || '',
                            tier: tierParam,
                            offer: offerParam,
                            situation: formData.get('situation') || '',
                            description: formData.get('description') || '',
                            brief: formData.get('brief') || '',
                            care_request: formData.get('care_request') || '',
                            site_status: formData.get('site_status') || '',
                            timeline: formData.get('timeline') || '',
                            budget: formData.get('budget') || '',
                            context: formData.get('context') || ''
                        })
                    }).catch(function() {});

                    document.cookie = 'bb_intake_completed=1; path=/; max-age=86400; domain=.bertrandgroup.ca; secure; samesite=lax';

                } else {
                    throw new Error('Submission failed');
                }
            })
            .catch(function() {
                submitBtn.disabled = false;
                submitBtn.classList.remove('intake-nav__btn--loading');
                showToast('Something went wrong. Please try again.', 'error');
            });
        });

        // Keyboard: Enter advances steps (except on textareas)
        form.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') {
                e.preventDefault();
                if (currentStep < totalSteps) {
                    nextBtn.click();
                } else {
                    submitBtn.click();
                }
            }
        });
    })();
    </script>

    <GesturePrevention />
</IntakeLayout>
