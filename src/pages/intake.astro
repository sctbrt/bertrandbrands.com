                    <circle cx="310" cy="160" r="2" fill="rgba(139, 92, 246, 0.30)"/>
                    <!-- Violet branches -->
                    <line x1="445" y1="75" x2="460" y2="45" stroke="rgba(139, 92, 246, 0.15)" stroke-width="1" stroke-dasharray="3 5"/>
                    <line x1="445" y1="75" x2="465" y2="105" stroke="rgba(139, 92, 246, 0.12)" stroke-width="1" stroke-dasharray="3 5"/>
                    <line x1="355" y1="125" x2="380" y2="150" stroke="rgba(139, 92, 246, 0.10)" stroke-width="1" stroke-dasharray="2 6"/>

                    <!-- === BLUE PATH — from bottom === -->
