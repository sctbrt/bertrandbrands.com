                    <!-- Blue origin node -->
                    <circle cx="250" cy="365" r="6" stroke="rgba(37, 99, 235, 0.40)" stroke-width="1.5"/>
                    <circle cx="250" cy="365" r="2.5" fill="rgba(37, 99, 235, 0.50)"/>
                    <!-- Blue waypoints -->
                    <circle cx="250" cy="330" r="2.5" fill="rgba(37, 99, 235, 0.35)"/>
                    <circle cx="250" cy="290" r="3" fill="rgba(37, 99, 235, 0.40)"/>
                    <circle cx="250" cy="248" r="2" fill="rgba(37, 99, 235, 0.30)"/>
                    <!-- Blue branches -->
                    <line x1="250" y1="365" x2="215" y2="380" stroke="rgba(37, 99, 235, 0.15)" stroke-width="1" stroke-dasharray="3 5"/>
                    <line x1="250" y1="365" x2="285" y2="380" stroke="rgba(37, 99, 235, 0.12)" stroke-width="1" stroke-dasharray="3 5"/>
                    <line x1="250" y1="290" x2="225" y2="300" stroke="rgba(37, 99, 235, 0.10)" stroke-width="1" stroke-dasharray="2 6"/>

                    <!-- === CONVERGENCE POINT — center === -->
                    <circle cx="250" cy="200" r="30" stroke="rgba(255, 255, 255, 0.06)" stroke-width="1"/>
                    <circle cx="250" cy="200" r="18" stroke="rgba(139, 92, 246, 0.30)" stroke-width="1.5"/>
                    <circle cx="250" cy="200" r="8" stroke="rgba(139, 92, 246, 0.45)" stroke-width="2"/>
