            </div>
            <h1 class="intake-title">Get a quote</h1>
            <p class="intake-subtitle">Tell us about your project. We'll review and follow up within one business day.</p>

            <!-- Tier badges (populated by JS based on URL params) -->
            <div class="intake-tier-badges" id="tierBadges"></div>

            <!-- Progress -->
            <div class="intake-progress">
                <div class="intake-progress__bar">
                    <div class="intake-progress__fill" id="progressFill" style="width: 33%"></div>
                </div>
                <p class="intake-progress__text" id="progressText">Step 1 of 3</p>
