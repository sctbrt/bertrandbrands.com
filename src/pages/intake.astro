                <input type="hidden" name="_subject" id="hiddenSubject" value="New Lead — General Intake">
                <input type="hidden" name="tier" id="hiddenTier" value="">
                <input type="hidden" name="offer" id="hiddenOffer" value="">
                <input type="text" name="_gotcha" class="form-honeypot" tabindex="-1" autocomplete="off">

                <!-- Step 1: Contact Info (same for all tiers) -->
                <div class="intake-step active" data-step="1">
                    <h2 class="intake-step__title">Contact info</h2>

                    <div class="intake-form__group">
                        <label class="intake-form__label" for="name">Name</label>
