            <!-- Step summary (populated by JS after step 1) -->
            <div class="intake-summary" id="intakeSummary" aria-live="polite"></div>

            <!-- Form -->
            <form class="intake-form" id="intakeForm" action="https://formspree.io/f/xnjjgoay" method="POST">
                <input type="hidden" name="source" id="hiddenSource" value="tier-intake">
