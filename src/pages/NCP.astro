---
/**
 * Private discovery questionnaire for Mike Fulcher / NCP Electrical.
 * Served at /NCP (vanity URL sent directly to the client).
 *
 * - Unlisted: noindex, nofollow, not in sitemap, not linked from any nav.
 *   Companion to the warm-intro letter at /welcome/mike-fulcher.
 * - Self-contained styles (no shared.css classes). V14 surface — dark/amber/glass.
 * - On finish: POSTs answers to Formspree + /api/notify (source: 'discovery-ncp'),
 *   then offers the client a copy via copy / download / print.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import VisitorNotify from '../components/VisitorNotify.astro';
---

<BaseLayout
    title="NCP Electrical · Discovery Session — Bertrand Brands"
    description="A short, tap-friendly discovery session to shape NCP Electrical's brand and website with Bertrand Brands."
    robots="noindex, nofollow"
>
    <div class="discovery">
        <div class="discovery__glow" aria-hidden="true"></div>
        <div class="discovery__glow discovery__glow--violet" aria-hidden="true"></div>
        <div class="discovery__glow discovery__glow--blue" aria-hidden="true"></div>

        <div class="topbar">
            <div class="topbar__inner">
                <div class="brandlock">
                    <img src="/assets/dot-logomark.svg" alt="" class="brandlock__mark" width="26" height="26" loading="eager" fetchpriority="high" />
                    <div class="brandlock__text">
                        <small>Bertrand Brands</small>
                        <strong>Discovery Session</strong>
                    </div>
                </div>
                <div class="stepcount" id="ncpStep">Welcome</div>
            </div>
            <div class="progress"><i id="ncpBar"></i></div>
        </div>

        <main class="wrap" id="ncpWrap"></main>

        <nav class="navbar" aria-label="Questionnaire navigation">
            <div class="navbar__inner">
                <button class="btn btn-ghost" id="ncpBack" type="button">Back</button>
                <button class="btn btn-primary" id="ncpNext" type="button">Begin</button>
            </div>
        </nav>

        <div class="toast" id="ncpToast" role="status" aria-live="polite">Copied</div>
    </div>

    <VisitorNotify />
</BaseLayout>

<style is:inline>
    /* ============================================================
       NCP Electrical — Discovery Session
       V14 surface, self-contained. All selectors scoped under
       .discovery so the deferred shared.css can't cascade in.
       Brand remap: light "paper" original → BB dark / amber / glass.
       ============================================================ */

    /* BaseLayout injects a desktop-only phone modal (gated on includeMainCss).
       Its hide rules live in shared.css, which this page loads deferred — if
       that deferred media-swap loses the race, the modal renders unstyled in
       normal flow (a stray "Please call (705) 413-3705" fragment). This page
       has no tel: links and never opens it, so hard-hide it unconditionally. */
    .phone-modal-backdrop { display: none !important; }

    .discovery {
        /* Local remap — original semantic names point at BB tokens. */
        --ink: var(--text);
        --ink-soft: var(--text);
        --muted: var(--text-muted);
        --faint: var(--text-subtle);
        --line: var(--border);
        --line-strong: var(--border-hover);
        --paper-2: rgba(var(--highlight-rgb), 0.03);
        --card: rgba(var(--highlight-rgb), 0.04);
        --accent: var(--build-accent);
        --accent-deep: var(--build-accent-hover);
        --accent-wash: rgba(var(--build-rgb), 0.13);
        --good: var(--color-success);
        --radius: var(--radius-lg);
        --shadow: 0 1px 2px rgba(0, 0, 0, 0.4), 0 8px 28px rgba(0, 0, 0, 0.45);
        --shadow-lift: 0 2px 4px rgba(0, 0, 0, 0.5), 0 18px 44px rgba(0, 0, 0, 0.6);
        /* Tri-colour (Conversation-tier signature): amber -> violet -> blue */
        --tri-gradient: linear-gradient(120deg, #D97706 0%, #8B5CF6 52%, #2563EB 100%);
        --tri-gradient-text: linear-gradient(95deg, #F59E0B, #A78BFA 55%, #60A5FA);
        --tri-sweep: linear-gradient(90deg, #D97706, #8B5CF6, #2563EB, #8B5CF6, #D97706);
        --btn-tri-shadow: 0 4px 16px rgba(139, 92, 246, 0.28);
        --btn-tri-shadow-lift: 0 8px 24px rgba(139, 92, 246, 0.4);

        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--font-body);
        line-height: 1.5;
    }

    /* Living ambient tri-tone glow — three counter-rhythm breathers (LOCKED: ambient light moves) */
    .discovery__glow {
        position: fixed;
        top: -15vh;
        right: -10vw;
        width: 70vw;
        height: 70vw;
        max-width: 820px;
        max-height: 820px;
        background: radial-gradient(circle at center,
            rgba(var(--build-rgb), 0.10) 0%,
            rgba(var(--build-rgb), 0.04) 38%,
            transparent 70%);
        filter: blur(50px);
        pointer-events: none;
        z-index: 0;
        animation: ncpBreathe 22s var(--ease-in-out) infinite;
    }
    .discovery__glow--violet {
        position: fixed;
        top: 28vh;
        left: -18vw;
        width: 58vw;
        height: 58vw;
        max-width: 680px;
        max-height: 680px;
        background: radial-gradient(circle at center,
            rgba(var(--transform-rgb), 0.09) 0%,
            rgba(var(--transform-rgb), 0.035) 40%,
            transparent 70%);
        filter: blur(55px);
        pointer-events: none;
        z-index: 0;
        animation: ncpBreatheViolet 26s var(--ease-in-out) -6s infinite;
    }
    .discovery__glow--blue {
        position: fixed;
        bottom: -16vh;
        right: 4vw;
        width: 62vw;
        height: 62vw;
        max-width: 720px;
        max-height: 720px;
        background: radial-gradient(circle at center,
            rgba(var(--care-rgb), 0.08) 0%,
            rgba(var(--care-rgb), 0.03) 40%,
            transparent 70%);
        filter: blur(60px);
        pointer-events: none;
        z-index: 0;
        animation: ncpBreatheBlue 30s var(--ease-in-out) -14s infinite;
    }

    @keyframes ncpBreathe {
        0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.9; }
        30% { transform: translate(-3vw, 2vh) scale(1.06); opacity: 1; }
        60% { transform: translate(2vw, -2vh) scale(0.96); opacity: 0.8; }
    }
    @keyframes ncpBreatheViolet {
        0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.8; }
        35% { transform: translate(3vw, -2vh) scale(1.07); opacity: 0.95; }
        70% { transform: translate(-2vw, 3vh) scale(0.95); opacity: 0.7; }
    }
    @keyframes ncpBreatheBlue {
        0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.75; }
        40% { transform: translate(-3vw, -2vh) scale(1.05); opacity: 0.9; }
        75% { transform: translate(2vw, 2vh) scale(0.96); opacity: 0.65; }
    }

    .discovery .eyebrow {
        font-family: var(--font-body);
        font-size: var(--text-2xs);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: var(--font-medium);
    }

    .discovery .wrap {
        position: relative;
        z-index: 1;
        max-width: 760px;
        margin: 0 auto;
        padding: 0 20px 168px;
    }

    /* ---------- top bar / progress ---------- */
    .discovery .topbar {
        position: sticky;
        top: 0;
        z-index: 40;
        backdrop-filter: saturate(1.4) blur(var(--glass-blur));
        -webkit-backdrop-filter: saturate(1.4) blur(var(--glass-blur));
        background: rgba(var(--bg-rgb), 0.72);
        border-bottom: 1px solid var(--line);
    }
    .discovery .topbar__inner {
        max-width: 760px;
        margin: 0 auto;
        padding: 14px 20px 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }
    .discovery .brandlock { display: flex; align-items: center; gap: 12px; }
    .discovery .brandlock__mark {
        width: 34px;
        height: auto;
        display: block;
        filter: brightness(0) invert(1);
        opacity: 0.95;
    }
    .discovery .brandlock__text { transform: translateY(2px); }
    .discovery .brandlock__text small {
        display: block;
        font-size: 10px;
        letter-spacing: 0.24em;
        line-height: 1;
        margin-bottom: 1px;
        color: var(--muted);
        text-transform: uppercase;
    }
    .discovery .brandlock__text strong {
        font-family: var(--font-display);
        font-weight: var(--font-normal);
        font-size: 15px;
        line-height: 1;
        letter-spacing: 0.01em;
        color: var(--ink);
    }
    .discovery .stepcount {
        font-size: var(--text-xs);
        letter-spacing: 0.06em;
        color: var(--muted);
        white-space: nowrap;
    }
    .discovery .progress { height: 3px; background: var(--line); width: 100%; }
    .discovery .progress > i {
        display: block;
        height: 100%;
        width: 0;
        background: var(--tri-sweep);
        background-size: 300% 100%;
        box-shadow: 0 0 12px rgba(139, 92, 246, 0.45);
        transition: width 0.4s var(--ease-out);
        animation: ncpTriSweep 10s linear infinite;
    }
    @keyframes ncpTriSweep {
        from { background-position: 0 0; }
        to { background-position: 300% 0; }
    }

    /* ---------- screens ---------- */
    .discovery .screen { display: none; animation: ncpRise 0.45s var(--ease-out); }
    .discovery .screen.active { display: block; }
    @keyframes ncpRise {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: none; }
    }

    .discovery .sec-head { padding: 48px 0 8px; }
    .discovery .sec-head .eyebrow { margin-bottom: 14px; }
    .discovery .sec-head h2 {
        font-family: var(--font-display);
        font-weight: var(--font-light);
        font-size: clamp(26px, 5vw, 38px);
        letter-spacing: -0.02em;
        line-height: 1.05;
        color: var(--ink);
    }
    .discovery .sec-head p {
        margin-top: 12px;
        color: var(--muted);
        font-size: var(--text-base);
        max-width: 56ch;
        line-height: 1.6;
    }

    /* ---------- question block ---------- */
    .discovery .q {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 22px 22px 24px;
        margin-top: 18px;
        box-shadow: var(--shadow);
    }
    .discovery .q-num {
        font-size: var(--text-2xs);
        color: var(--accent);
        letter-spacing: 0.14em;
        font-weight: var(--font-semibold);
        text-transform: uppercase;
    }
    .discovery .q-label {
        font-family: var(--font-body);
        font-weight: var(--font-semibold);
        font-size: var(--text-lg);
        letter-spacing: -0.01em;
        margin-top: 6px;
        line-height: 1.3;
        color: var(--ink);
    }
    .discovery .q-help { color: var(--muted); font-size: var(--text-sm); margin-top: 5px; }
    .discovery .q-body { margin-top: 16px; }

    /* option grids */
    .discovery .opts { display: grid; gap: 10px; }
    .discovery .opts.cols-1 { grid-template-columns: 1fr; }
    .discovery .opts.cols-2 { grid-template-columns: 1fr 1fr; }
    .discovery .opts.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
    @media (max-width: 560px) { .discovery .opts.cols-3 { grid-template-columns: 1fr 1fr; } }

    .discovery .opt {
        position: relative;
        border: 1.5px solid var(--line-strong);
        background: var(--paper-2);
        border-radius: var(--radius);
        padding: 13px 14px;
        cursor: pointer;
        user-select: none;
        transition: border-color 0.15s, background 0.15s, transform 0.08s, box-shadow 0.15s;
        display: flex;
        align-items: center;
        gap: 11px;
        font-size: var(--text-sm);
        font-weight: var(--font-medium);
        color: var(--muted);
        min-height: 50px;
    }
    .discovery .opt:hover {
        border-color: rgba(var(--build-rgb), 0.55);
        background: rgba(var(--highlight-rgb), 0.06);
        color: var(--ink);
        transform: translateY(-1px);
        box-shadow: var(--shadow);
    }
    .discovery .opt:active { transform: translateY(0); }
    .discovery .opt:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
    }
    .discovery .opt .dot {
        flex: 0 0 auto;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid var(--line-strong);
        transition: 0.15s;
        position: relative;
    }
    .discovery .opt.multi .dot { border-radius: 6px; }
    .discovery .opt.sel {
        border-color: var(--accent);
        background: var(--accent-wash);
        color: var(--ink);
        font-weight: var(--font-semibold);
    }
    .discovery .opt.sel .dot { border-color: var(--accent); background: var(--accent); }
    .discovery .opt.sel .dot::after {
        content: "";
        position: absolute;
        inset: 0;
        margin: auto;
        width: 8px;
        height: 8px;
        border-radius: inherit;
        background: #fff;
    }
    .discovery .opt.multi.sel .dot::after {
        width: 6px;
        height: 10px;
        border-radius: 0;
        border: solid #fff;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg) translate(-1px, -1px);
        background: transparent;
        top: 2px;
        left: 0;
        right: 0;
        bottom: 0;
    }

    /* swatches */
    .discovery .swatch { flex-direction: column; align-items: flex-start; gap: 9px; padding: 13px; }
    .discovery .swatch .chips {
        display: flex;
        gap: 0;
        border-radius: var(--radius-md);
        overflow: hidden;
        width: 100%;
        height: 34px;
        border: 1px solid rgba(var(--highlight-rgb), 0.1);
    }
    .discovery .swatch .chips span { flex: 1; }
    .discovery .swatch .cap { font-size: var(--text-sm); font-weight: var(--font-semibold); }

    /* slider */
    .discovery .slider-wrap { padding: 6px 2px 2px; }
    .discovery .slider-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px; }
    .discovery .slider-val {
        font-family: var(--font-display);
        font-weight: var(--font-normal);
        font-size: var(--text-2xl);
        color: var(--accent);
    }
    .discovery .slider-val small {
        font-family: var(--font-body);
        font-weight: var(--font-medium);
        font-size: var(--text-sm);
        color: var(--muted);
    }
    .discovery input[type=range] {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 6px;
        border-radius: var(--radius-pill);
        background: var(--line-strong);
        outline: none;
        margin: 10px 0 4px;
    }
    .discovery input[type=range]::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--bg-elevated);
        border: 3px solid var(--accent);
        cursor: pointer;
        box-shadow: 0 2px 10px rgba(var(--build-rgb), 0.45);
        transition: transform 0.1s;
    }
    .discovery input[type=range]::-webkit-slider-thumb:active { transform: scale(1.12); }
    .discovery input[type=range]::-moz-range-thumb {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--bg-elevated);
        border: 3px solid var(--accent);
        cursor: pointer;
        box-shadow: 0 2px 10px rgba(var(--build-rgb), 0.45);
    }
    .discovery input[type=range]:focus-visible::-webkit-slider-thumb {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
    }
    .discovery .ends {
        display: flex;
        justify-content: space-between;
        font-size: var(--text-xs);
        color: var(--muted);
        font-weight: var(--font-semibold);
    }
    .discovery .ends span:first-child { text-align: left; }
    .discovery .ends span:last-child { text-align: right; }

    /* spectrum */
    .discovery .spectrum .ends span { max-width: 45%; }
    .discovery .spectrum-read {
        text-align: center;
        font-size: var(--text-xs);
        color: var(--accent);
        letter-spacing: 0.08em;
        margin-top: 8px;
        font-weight: var(--font-semibold);
        text-transform: uppercase;
    }

    /* text input */
    .discovery .txt {
        width: 100%;
        border: 1.5px solid var(--line-strong);
        background: var(--paper-2);
        border-radius: var(--radius);
        padding: 13px 14px;
        font: inherit;
        font-size: var(--text-sm);
        color: var(--ink);
        transition: 0.15s;
    }
    .discovery .txt::placeholder { color: var(--faint); }
    .discovery .txt:focus {
        outline: none;
        border-color: var(--accent);
        background: rgba(var(--highlight-rgb), 0.05);
        box-shadow: 0 0 0 4px rgba(var(--build-rgb), 0.15);
    }
    .discovery textarea.txt { resize: vertical; min-height: 90px; line-height: 1.5; }
    .discovery .optional-tag {
        font-size: var(--text-2xs);
        letter-spacing: 0.12em;
        color: var(--good);
        text-transform: uppercase;
        font-weight: var(--font-semibold);
        border: 1px solid rgba(34, 197, 94, 0.3);
        background: rgba(34, 197, 94, 0.1);
        padding: 2px 7px;
        border-radius: var(--radius-pill);
        margin-left: 8px;
    }

    /* ---------- cover ---------- */
    .discovery .cover { text-align: left; padding: 60px 0 0; }
    .discovery .cover .kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line-strong);
        background: var(--card);
        border-radius: var(--radius-pill);
        padding: 7px 14px;
        margin-bottom: 26px;
    }
    .discovery .cover .kicker b {
        font-size: var(--text-2xs);
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: var(--font-medium);
        color: var(--muted);
    }
    .discovery .spark {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 4px var(--accent-wash);
    }
    .discovery .cover h1 {
        font-family: var(--font-display);
        font-weight: var(--font-light);
        font-size: clamp(34px, 8vw, 60px);
        line-height: 1;
        letter-spacing: -0.03em;
        color: var(--ink);
    }
    .discovery .cover h1 em {
        font-style: normal;
        background: var(--tri-gradient-text);
        background-size: 200% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
        animation: ncpTriShift 12s var(--ease-in-out) infinite;
    }
    @keyframes ncpTriShift {
        0%, 100% { background-position: 0 0; }
        50% { background-position: 100% 0; }
    }
    .discovery .cover .lede {
        margin-top: 20px;
        font-size: var(--text-lg);
        color: var(--ink);
        max-width: 54ch;
        line-height: 1.6;
    }
    .discovery .meta-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 30px; }
    .discovery .meta {
        border: 1px solid var(--line);
        background: var(--card);
        border-radius: var(--radius);
        padding: 12px 16px;
        box-shadow: var(--shadow);
    }
    .discovery .meta small {
        display: block;
        font-size: var(--text-2xs);
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--faint);
    }
    .discovery .meta b {
        font-family: var(--font-display);
        font-weight: var(--font-normal);
        font-size: var(--text-base);
        color: var(--ink);
    }
    .discovery .cover-note {
        margin-top: 30px;
        padding: 16px 18px;
        border-left: 3px solid var(--accent);
        background: var(--paper-2);
        border-radius: 0 var(--radius) var(--radius) 0;
        font-size: var(--text-sm);
        color: var(--muted);
        line-height: 1.6;
    }

    /* ---------- footer nav ---------- */
    .discovery .navbar {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 50;
        background: rgba(var(--bg-rgb), 0.85);
        backdrop-filter: saturate(1.6) blur(var(--glass-blur));
        -webkit-backdrop-filter: saturate(1.6) blur(var(--glass-blur));
        border-top: 1px solid var(--line);
    }
    .discovery .navbar__inner {
        max-width: 760px;
        margin: 0 auto;
        padding: 14px 20px calc(14px + env(safe-area-inset-bottom, 0px));
        display: flex;
        gap: 12px;
        align-items: center;
    }
    .discovery .btn {
        font: inherit;
        font-weight: var(--font-semibold);
        font-size: var(--text-sm);
        border-radius: var(--radius-pill);
        padding: 14px 22px;
        cursor: pointer;
        border: 1.5px solid transparent;
        transition: 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        justify-content: center;
    }
    .discovery .btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .discovery .btn-primary {
        background: var(--tri-gradient);
        background-size: 160% 100%;
        background-position: 0 0;
        color: #fff;
        flex: 1;
        box-shadow: var(--btn-tri-shadow);
    }
    .discovery .btn-primary:hover {
        background-position: 100% 0;
        transform: translateY(-1px);
        box-shadow: var(--btn-tri-shadow-lift);
    }
    .discovery .btn-accent {
        background: var(--tri-gradient);
        background-size: 160% 100%;
        background-position: 0 0;
        color: #fff;
        box-shadow: var(--btn-tri-shadow);
    }
    .discovery .btn-accent:hover {
        background-position: 100% 0;
        transform: translateY(-1px);
        box-shadow: var(--btn-tri-shadow-lift);
    }
    .discovery .btn-ghost {
        background: transparent;
        border-color: var(--line-strong);
        color: var(--muted);
    }
    .discovery .btn-ghost:hover { border-color: var(--ink); color: var(--ink); }
    .discovery .btn[disabled] {
        opacity: 0.35;
        cursor: not-allowed;
        transform: none !important;
        box-shadow: none !important;
    }

    /* ---------- review ---------- */
    .discovery .done-badge {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: var(--good);
        display: grid;
        place-items: center;
        margin-bottom: 18px;
    }
    .discovery .done-badge::after {
        content: "";
        width: 14px;
        height: 24px;
        border: solid #fff;
        border-width: 0 4px 4px 0;
        transform: rotate(45deg) translate(-1px, -2px);
    }
    .discovery .summary {
        margin-top: 18px;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--card);
        box-shadow: var(--shadow);
        overflow: hidden;
    }
    .discovery .summary textarea {
