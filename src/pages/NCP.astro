  var FLOW = [COVER].concat(SECTIONS, [REVIEW]);

  function esc(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function boot() {
    var root = document.querySelector('.discovery');
    if (!root || root.dataset.booted === '1') return;
    root.dataset.booted = '1';

    var answers = {};
    var idx = 0;
    var submitState = 'idle'; // idle | sending | sent | error

    var wrap = root.querySelector('#ncpWrap');
    var bar = root.querySelector('#ncpBar');
    var stepEl = root.querySelector('#ncpStep');
    var backBtn = root.querySelector('#ncpBack');
    var nextBtn = root.querySelector('#ncpNext');
    var toastEl = root.querySelector('#ncpToast');
    var navbarEl = root.querySelector('.navbar');
    if (!wrap || !bar || !stepEl || !backBtn || !nextBtn) return;

    /* ---------- rendering ---------- */
    function render() {
      var node = FLOW[idx];
      var total = SECTIONS.length;

      var pct = 0;
      if (node.type === 'cover') pct = 2;
      else if (node.type === 'review') pct = 100;
      else pct = (idx / (total + 1)) * 100;
      bar.style.width = pct + '%';

      if (node.type === 'cover') stepEl.textContent = 'Welcome';
      else if (node.type === 'review') stepEl.textContent = 'Complete';
      else stepEl.textContent = 'Step ' + idx + ' / ' + total;

      backBtn.style.visibility = idx === 0 ? 'hidden' : 'visible';
      if (node.type === 'review') {
        nextBtn.style.display = 'none';
        backBtn.textContent = 'Back to questions';
      } else {
        if (navbarEl) navbarEl.style.display = '';
        nextBtn.style.display = 'inline-flex';
        nextBtn.style.flex = '1';
        backBtn.textContent = 'Back';
        if (node.type === 'cover') { nextBtn.textContent = 'Begin'; nextBtn.className = 'btn btn-accent'; }
        else if (node === SECTIONS[SECTIONS.length - 1]) { nextBtn.textContent = 'Finish'; nextBtn.className = 'btn btn-primary'; }
        else { nextBtn.textContent = 'Continue'; nextBtn.className = 'btn btn-primary'; }
      }

      if (node.type === 'cover') { wrap.innerHTML = coverHTML(); }
      else if (node.type === 'review') { renderReview(); return; }
      else { wrap.innerHTML = sectionHTML(node); }

      window.scrollTo({ top: 0, behavior: 'instant' });
      bindInputs();
    }

    function coverHTML() {
      return '' +
      '<div class="screen active cover">' +
        '<span class="kicker"><i class="spark"></i><b>Client Discovery</b></span>' +
        '<h1>Let\'s get to know<br><em>NCP Electrical.</em></h1>' +
        '<p class="lede">This is a short, tap-friendly session to help us understand your business, your customers, and what you want this project to do for you. Most questions are buttons and sliders, so it should take about 8 to 10 minutes.</p>' +
        '<div class="meta-row">' +
          '<div class="meta"><small>Prepared for</small><b>Mike Fulcher</b></div>' +
          '<div class="meta"><small>Business</small><b>NCP Electrical</b></div>' +
          '<div class="meta"><small>Location</small><b>Greater Sudbury, ON</b></div>' +
        '</div>' +
        '<div class="cover-note">There are no right or wrong answers. Go with your first instinct. Anything you skip, we will simply cover in conversation. When you are done, just tap Finish and your answers come straight to us.</div>' +
      '</div>';
    }

    function sectionHTML(sec) {
      var h = '<div class="screen active">' +
        '<div class="sec-head"><div class="eyebrow">' + esc(sec.eyebrow) + '</div><h2>' + esc(sec.title) + '</h2><p>' + esc(sec.sub) + '</p></div>';
      sec.questions.forEach(function (q, i) {
        h += '<div class="q">' +
          '<div class="q-num">Q' + String(i + 1).padStart(2, '0') + '</div>' +
          '<div class="q-label">' + esc(q.label) + (q.optional ? '<span class="optional-tag">Optional</span>' : '') + '</div>' +
          (q.help ? '<div class="q-help">' + esc(q.help) + '</div>' : '') +
          '<div class="q-body">' + fieldHTML(q) + '</div>' +
        '</div>';
      });
      h += '</div>';
      return h;
    }

    function fieldHTML(q) {
      var a = answers[q.id];
      if (q.type === 'text') {
        var pre = a != null ? a : (q.value || '');
        if (q.area) return '<textarea class="txt" data-id="' + q.id + '" placeholder="' + esc(q.placeholder || '') + '">' + esc(pre) + '</textarea>';
        return '<input class="txt" type="text" data-id="' + q.id + '" placeholder="' + esc(q.placeholder || '') + '" value="' + esc(pre) + '">';
      }
      if (q.type === 'radio' || q.type === 'checkbox') {
        var multi = q.type === 'checkbox';
        var cols = q.cols || 1;
        var h = '<div class="opts cols-' + cols + '">';
        q.options.forEach(function (opt) {
          var sel = multi ? (Array.isArray(a) && a.indexOf(opt) > -1) : (a === opt);
          h += '<div class="opt ' + (multi ? 'multi' : '') + ' ' + (sel ? 'sel' : '') + '" role="button" tabindex="0" aria-pressed="' + (sel ? 'true' : 'false') + '" data-id="' + q.id + '" data-val="' + esc(opt) + '" data-multi="' + multi + '">' +
            '<span class="dot"></span><span>' + esc(opt) + '</span></div>';
        });
        return h + '</div>';
      }
      if (q.type === 'swatch') {
        var cols2 = q.cols || 2;
        var hs = '<div class="opts cols-' + cols2 + '">';
        q.options.forEach(function (opt) {
          var sel = (a === opt.cap);
          var chips = opt.chips.map(function (c) { return '<span style="background:' + esc(c) + '"></span>'; }).join('');
          hs += '<div class="opt swatch ' + (sel ? 'sel' : '') + '" role="button" tabindex="0" aria-pressed="' + (sel ? 'true' : 'false') + '" data-id="' + q.id + '" data-val="' + esc(opt.cap) + '" data-multi="false">' +
            '<div class="chips">' + chips + '</div><div class="cap">' + esc(opt.cap) + '</div></div>';
        });
        return hs + '</div>';
      }
      if (q.type === 'slider') {
        var val = a != null ? a : q.default;
        var display = sliderLabel(q, val);
        return '<div class="slider-wrap" data-id="' + q.id + '">' +
          '<div class="slider-top"><span class="slider-val">' + display + '</span></div>' +
          '<input type="range" min="' + q.min + '" max="' + q.max + '" step="' + q.step + '" value="' + val + '" ' +
            'data-id="' + q.id + '" data-suffix="' + esc(q.suffix || '') + '" data-topcap="' + esc(q.topcap || '') + '" data-zerocap="' + esc(q.zerocap || '') + '" aria-label="' + esc(q.label) + '">' +
          '<div class="ends"><span>' + q.min + '</span><span>' + esc(q.topcap || q.max) + '</span></div>' +
        '</div>';
      }
      if (q.type === 'spectrum') {
        var sv = a != null ? a : 50;
        return '<div class="slider-wrap spectrum" data-id="' + q.id + '">' +
          '<input type="range" min="0" max="100" step="1" value="' + sv + '" data-id="' + q.id + '" data-left="' + esc(q.left) + '" data-right="' + esc(q.right) + '" data-spectrum="1" aria-label="' + esc(q.label) + '">' +
          '<div class="ends"><span>' + esc(q.left) + '</span><span>' + esc(q.right) + '</span></div>' +
          '<div class="spectrum-read" id="read-' + q.id + '">' + spectrumRead(sv, q.left, q.right) + '</div>' +
        '</div>';
      }
      return '';
    }

    function sliderLabel(q, val) {
      if (q.zerocap && Number(val) === Number(q.min)) return q.zerocap;
      var v = val;
      if (q.topcap && Number(val) === Number(q.max)) v = q.topcap;
      return esc(v) + ' <small>' + esc(q.suffix || '') + '</small>';
    }
    function spectrumRead(val, left, right) {
      val = Number(val);
      if (val <= 33) return 'Closer to: ' + left.toUpperCase();
      if (val >= 67) return 'Closer to: ' + right.toUpperCase();
      return 'Right in the middle';
    }

    /* ---------- binding ---------- */
    function toggleOpt(el) {
      var id = el.dataset.id, val = el.dataset.val, multi = el.dataset.multi === 'true';
      if (multi) {
        if (!Array.isArray(answers[id])) answers[id] = [];
        var i = answers[id].indexOf(val);
        if (i > -1) { answers[id].splice(i, 1); el.classList.remove('sel'); el.setAttribute('aria-pressed', 'false'); }
        else { answers[id].push(val); el.classList.add('sel'); el.setAttribute('aria-pressed', 'true'); }
      } else {
        answers[id] = val;
        el.parentElement.querySelectorAll('.opt').forEach(function (o) { o.classList.remove('sel'); o.setAttribute('aria-pressed', 'false'); });
        el.classList.add('sel'); el.setAttribute('aria-pressed', 'true');
      }
    }

    function bindInputs() {
      wrap.querySelectorAll('.opt').forEach(function (el) {
        el.addEventListener('click', function () { toggleOpt(el); });
        el.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ' || e.key === 'Spacebar') { e.preventDefault(); toggleOpt(el); }
        });
      });
      wrap.querySelectorAll('.txt').forEach(function (el) {
        if (answers[el.dataset.id] == null && el.value) answers[el.dataset.id] = el.value;
        el.addEventListener('input', function () { answers[el.dataset.id] = el.value; });
      });
      wrap.querySelectorAll('input[type=range]').forEach(function (el) {
        el.addEventListener('input', function () {
          var id = el.dataset.id; answers[id] = Number(el.value);
          if (el.dataset.spectrum) {
            var r = wrap.querySelector('#read-' + id);
            if (r) r.textContent = spectrumRead(el.value, el.dataset.left, el.dataset.right);
          } else {
            var sw = el.closest('.slider-wrap');
            var q = findQ(id);
            sw.querySelector('.slider-val').innerHTML = sliderLabel(q, el.value);
          }
        });
        if (answers[el.dataset.id] == null) answers[el.dataset.id] = Number(el.value);
      });
    }
    function findQ(id) {
      for (var s = 0; s < SECTIONS.length; s++) {
        for (var j = 0; j < SECTIONS[s].questions.length; j++) {
          if (SECTIONS[s].questions[j].id === id) return SECTIONS[s].questions[j];
        }
      }
      return {};
    }

    /* ---------- navigation ---------- */
    function go(dir) {
      idx += dir;
      if (idx < 0) idx = 0;
      if (idx > FLOW.length - 1) idx = FLOW.length - 1;
      render();
    }

    /* ---------- review / submit / export ---------- */
    function renderReview() {
      nextBtn.style.display = 'none';

      if (submitState === 'sent') {
        if (navbarEl) navbarEl.style.display = 'none';
        wrap.innerHTML = thankYouHTML();
        bindReview();
      } else if (submitState === 'error') {
        if (navbarEl) navbarEl.style.display = '';
        backBtn.style.visibility = 'visible';
        backBtn.textContent = 'Back to questions';
        wrap.innerHTML = errorHTML();
        bindReview();
      } else if (submitState === 'sending') {
        if (navbarEl) navbarEl.style.display = '';
        backBtn.style.visibility = 'hidden';
        wrap.innerHTML = sendingHTML();
      } else {
        // idle — kick off the send, show the sending state in the meantime
        submitState = 'sending';
        if (navbarEl) navbarEl.style.display = '';
        backBtn.style.visibility = 'hidden';
        wrap.innerHTML = sendingHTML();
        window.scrollTo({ top: 0, behavior: 'instant' });
        submitDiscovery().then(function (r) {
          submitState = (r && r.ok) ? 'sent' : 'error';
          renderReview();
        }).catch(function () {
          submitState = 'error';
          renderReview();
        });
        return;
      }

      window.scrollTo({ top: 0, behavior: 'instant' });
    }

    function submitDiscovery() {
      var nm = (answers.contact || 'Mike Fulcher');

      // Instant heads-up via Pushover (fire-and-forget; never gates success)
      try {
        fetch('/api/notify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            type: 'intake',
            source: 'discovery-ncp',
            name: nm,
            email: answers.email || '',
            phone: answers.phone || '',
            business: answers.biz || 'NCP Electrical',
            service: 'Discovery Session'
          })
        }).catch(function () {});
      } catch (e) {}

      // Formspree delivers the full summary by email — this call gates success
      return fetch('https://formspree.io/f/xnjjgoay', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          _subject: 'NCP Electrical — Discovery session complete',
          source: 'discovery-ncp',
          entry_type: 'DISCOVERY',
          name: nm,
          email: answers.email || '',
          phone: answers.phone || '',
          business: answers.biz || 'NCP Electrical',
          summary: buildSummary()
        })
      }).then(function (res) {
        return { ok: !!(res && res.ok) };
      }, function () {
        return { ok: false };
      });
    }

    function sendingHTML() {
      return '<div class="screen active">' +
        '<div class="sec-head" style="padding-top:46px">' +
          '<div class="ncp-spinner" aria-hidden="true"></div>' +
          '<div class="eyebrow">Sending</div>' +
          '<h2>Sending your answers&hellip;</h2>' +
          '<p>One moment, this only takes a second.</p>' +
        '</div>' +
      '</div>';
    }

    function thankYouHTML() {
      var first = (answers.contact || 'Mike Fulcher').trim().split(/\s+/)[0] || 'there';
      return '<div class="screen active">' +
        '<div class="sec-head sec-head--review" style="padding-top:46px">' +
          '<div class="done-badge" aria-hidden="true"></div>' +
          '<div class="eyebrow">All sent</div>' +
          '<h2>Thank you, ' + esc(first) + '.</h2>' +
          '<p>Your answers are on their way to Bertrand Brands. We will read through everything and reach out shortly, usually within one business day. There is nothing else you need to do.</p>' +
        '</div>' +
        '<div class="keepcopy">' +
          '<span class="keepcopy__label">Want a copy for your records?</span>' +
          '<div class="export-row">' +
            '<button class="btn btn-ghost" type="button" data-act="download">Download a copy</button>' +
            '<button class="btn btn-ghost" type="button" data-act="print">Print / Save PDF</button>' +
          '</div>' +
        '</div>' +
        '<pre class="summary-print" aria-hidden="true">' + esc(buildSummary()) + '</pre>' +
      '</div>';
    }

    function errorHTML() {
      return '<div class="screen active">' +
        '<div class="sec-head sec-head--review" style="padding-top:46px">' +
          '<div class="eyebrow">Almost there</div>' +
          '<h2>We could not send it automatically.</h2>' +
          '<p>No problem, your answers are safe right here. Tap Try again, or send them over with any of the buttons below.</p>' +
        '</div>' +
        '<div class="summary"><textarea id="ncpSummary" spellcheck="false">' + esc(buildSummary()) + '</textarea></div>' +
        '<div class="export-row">' +
          '<button class="btn btn-accent" type="button" data-act="retry">Try again</button>' +
          '<button class="btn btn-ghost" type="button" data-act="copy">Copy summary</button>' +
          '<button class="btn btn-ghost" type="button" data-act="download">Download as file</button>' +
          '<button class="btn btn-ghost" type="button" data-act="print">Print / Save PDF</button>' +
        '</div>' +
      '</div>';
    }

    function bindReview() {
      var row = wrap.querySelector('.export-row');
      if (!row) return;
      row.querySelectorAll('[data-act]').forEach(function (b) {
        b.addEventListener('click', function () {
          var act = b.dataset.act;
          if (act === 'copy') copySummary();
          else if (act === 'download') downloadSummary();
          else if (act === 'print') window.print();
          else if (act === 'retry') { submitState = 'idle'; renderReview(); }
        });
      });
    }

    function fmt(v) {
      if (v == null || v === '') return '(skipped)';
      if (Array.isArray(v)) return v.length ? v.join(', ') : '(skipped)';
      return v;
    }
    function fmtSpectrum(id) {
      var q = findQ(id); var v = answers[id];
      if (v == null) return '(skipped)';
      return spectrumRead(v, q.left, q.right).replace('Closer to: ', '').replace('Right in the middle', 'Balanced (middle)') + '  [' + v + '/100]';
    }
    function fmtSlider(id) {
      var q = findQ(id); var v = answers[id];
      if (v == null) return '(skipped)';
      if (q.zerocap && v === q.min) return q.zerocap;
      var out = (q.topcap && v === q.max) ? q.topcap : v;
      return out + ' ' + (q.suffix || '');
    }

    function buildSummary() {
      var d = new Date();
      var date = d.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
      var L = [];
      L.push('NCP ELECTRICAL  -  DISCOVERY SUMMARY');
      L.push('Prepared with Bertrand Brands  |  ' + date);
      L.push('Greater Sudbury, Ontario');
      L.push('==================================================');
      SECTIONS.forEach(function (sec) {
        L.push('');
        L.push('# ' + sec.title.toUpperCase());
        L.push('--------------------------------------------------');
        sec.questions.forEach(function (q) {
          var val;
          if (q.type === 'spectrum') val = fmtSpectrum(q.id);
          else if (q.type === 'slider') val = fmtSlider(q.id);
          else val = fmt(answers[q.id]);
          L.push('• ' + q.label);
          L.push('    > ' + val);
        });
      });
      L.push('');
      L.push('==================================================');
      L.push('End of summary. Reviewed by Bertrand Brands.');
      return L.join('\n');
    }

    function getSummaryText() {
      var box = wrap.querySelector('#ncpSummary');
      return box ? box.value : buildSummary();
    }
    function copySummary() {
      var box = wrap.querySelector('#ncpSummary');
      var ok = false;
      if (box) {
        box.select(); box.setSelectionRange(0, 999999);
        try { ok = document.execCommand('copy'); } catch (e) {}
      }
      if (navigator.clipboard) { navigator.clipboard.writeText(getSummaryText()).then(function () {}, function () {}); ok = true; }
      toast(ok ? 'Summary copied' : 'Select all and copy');
    }
    function downloadSummary() {
      var blob = new Blob([getSummaryText()], { type: 'text/plain' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url; a.download = 'NCP-Electrical-Discovery.txt';
      document.body.appendChild(a); a.click(); a.remove();
      URL.revokeObjectURL(url);
      toast('File downloaded');
    }
    function toast(msg) {
      if (!toastEl) return;
      toastEl.textContent = msg; toastEl.classList.add('show');
      setTimeout(function () { toastEl.classList.remove('show'); }, 1900);
    }

    backBtn.addEventListener('click', function () { go(-1); });
    nextBtn.addEventListener('click', function () { go(1); });

    render();
  }

  if (!window.__ncpDiscoveryBound) {
    window.__ncpDiscoveryBound = true;
    document.addEventListener('astro:page-load', boot);
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
})();
</script>
