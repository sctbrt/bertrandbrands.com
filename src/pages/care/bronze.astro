---
/**
 * Bronze Care Plan — V10 care detail page.
 * Blue accent (#2563EB) with bronze hint. Follows starter.astro pattern with care credit system.
 */
import ServiceDetailLayout from '../../layouts/ServiceDetailLayout.astro';
import InlineIntakeForm from '../../components/InlineIntakeForm.astro';
import StickyMobileCTA from '../../components/StickyMobileCTA.astro';

const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="Bronze Care Plan — $249/mo | Bertrand Brands"
    description="Basic maintenance and updates. 4 credits/month, response within 1 business day, 3–5 day turnaround. $249/mo CAD."
    canonical="https://bertrandbrands.ca/care/bronze"
    ogTitle="Bronze Care Plan — Bertrand Brands"
    ogDescription="Basic maintenance and updates. 4 credits/month, response within 1 business day. $249/mo CAD."
    schemaJson={{
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "Bronze Care Plan",
        "description": "Basic maintenance and updates with 4 credits per month, response within 1 business day, 3–5 day turnaround.",
        "provider": {
            "@type": "ProfessionalService",
            "name": "Bertrand Brands — Brand & Web Systems",
            "url": "https://bertrandbrands.ca"
        },
        "offers": {
            "@type": "Offer",
            "price": "249",
            "priceCurrency": "CAD",
            "priceSpecification": {
                "@type": "UnitPriceSpecification",
                "price": "249",
                "priceCurrency": "CAD",
                "unitText": "MONTH"
            }
        }
    }}
    spotlightColor="rgba(37, 99, 235, 0.15)"
    accentRgb="37, 99, 235"
>
    <Fragment slot="head">
        <style is:inline>
            /* Bronze-specific: third spotlight + metallic accent overrides */
            .service-page__spotlight--3 { width: 300px; height: 300px; background: rgba(205, 127, 50, 0.12); top: 30%; right: 10%; animation: organicBreathe 24s ease-in-out infinite 1s; }
            .service-subbrand__name { color: #CD7F32; }
            .service-card { background: rgba(205, 127, 50, 0.04); border: 1px solid rgba(205, 127, 50, 0.15); }
            .service-card__label { color: rgba(205, 127, 50, 0.8); }
            .service-card__list li::before { background: rgba(205, 127, 50, 0.6); }
            .service-hero__illustration-wrap::before {
                background: radial-gradient(circle, rgba(205, 127, 50, 0.35) 0%, rgba(37, 99, 235, 0.15) 45%, rgba(37, 99, 235, 0) 65%);
            }

            /* Credit breakdown */
            .care-credits { max-width: 700px; margin: 0 auto var(--space-xl); position: relative; z-index: 1; }
            .care-credits__title { font-size: var(--text-lg); font-weight: 500; color: var(--text); margin-bottom: var(--space-sm); text-align: center; }
            .care-credits__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-sm); }
            .care-credit { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: var(--radius-md); padding: var(--space-md); }
            .care-credit__label { font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.25rem; }
            .care-credit__label--micro { color: #D97706; }
            .care-credit__label--standard { color: #8B5CF6; }
            .care-credit__cost { font-size: var(--text-sm); font-weight: 500; color: var(--text); margin-bottom: 0.5rem; }
            .care-credit__examples { list-style: none; padding: 0; margin: 0; }
            .care-credit__examples li { font-size: var(--text-xs); color: var(--text-muted); margin-bottom: 0.25rem; line-height: 1.4; }
            .care-credits__note { text-align: center; margin-top: var(--space-sm); font-size: var(--text-xs); color: var(--text-subtle); }

            @media (max-width: 768px) {
                .care-credits__grid { grid-template-columns: 1fr; }
                .care-credit { padding: var(--space-sm); }
            }
        </style>
    </Fragment>

    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--3" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/care" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Care Plans
            </a>

            <a href="/care" class="service-subbrand">
                <img src="/assets/bg-brands-logomark.png" alt="" class="service-subbrand__mark" width="40" height="40">
                <span class="service-subbrand__name">Bronze</span>
            </a>

            <section class="service-hero">
                <div class="service-hero__illustration-wrap">
                <svg class="service-hero__illustration" viewBox="40 40 420 320" fill="none" aria-hidden="true">
                    <!-- Horizontal baseline -->
                    <line x1="80" y1="280" x2="420" y2="280" stroke="rgba(37, 99, 235, 0.20)" stroke-width="1.5"/>
                    <!-- Subtle grid lines -->
                    <line x1="80" y1="180" x2="420" y2="180" stroke="rgba(37, 99, 235, 0.08)" stroke-width="1"/>
                    <line x1="80" y1="230" x2="420" y2="230" stroke="rgba(37, 99, 235, 0.06)" stroke-width="1" stroke-dasharray="4 8"/>
                    <line x1="250" y1="80" x2="250" y2="320" stroke="rgba(37, 99, 235, 0.06)" stroke-width="1" stroke-dasharray="4 8"/>
                    <!-- Single steady orbit ring -->
                    <circle cx="250" cy="200" r="80" stroke="rgba(205, 127, 50, 0.25)" stroke-width="2" fill="none"/>
                    <!-- Inner ring -->
                    <circle cx="250" cy="200" r="45" stroke="rgba(205, 127, 50, 0.15)" stroke-width="1" fill="none"/>
                    <!-- Center core -->
                    <circle cx="250" cy="200" r="6" stroke="rgba(205, 127, 50, 0.35)" stroke-width="1.5" fill="none"/>
                    <circle cx="250" cy="200" r="2.5" fill="rgba(205, 127, 50, 0.55)"/>
                    <!-- 4 checkpoint nodes on orbit (representing 4 credits) — bronze tint -->
                    <circle cx="330" cy="200" r="4" fill="rgba(205, 127, 50, 0.50)"/>
                    <circle cx="250" cy="120" r="4" fill="rgba(205, 127, 50, 0.50)"/>
                    <circle cx="170" cy="200" r="4" fill="rgba(205, 127, 50, 0.50)"/>
                    <circle cx="250" cy="280" r="4" fill="rgba(205, 127, 50, 0.50)"/>
                    <!-- Connecting spokes -->
                    <line x1="250" y1="155" x2="250" y2="125" stroke="rgba(37, 99, 235, 0.15)" stroke-width="1"/>
                    <line x1="285" y1="200" x2="325" y2="200" stroke="rgba(37, 99, 235, 0.15)" stroke-width="1"/>
                    <line x1="250" y1="245" x2="250" y2="275" stroke="rgba(37, 99, 235, 0.15)" stroke-width="1"/>
                    <line x1="215" y1="200" x2="175" y2="200" stroke="rgba(37, 99, 235, 0.15)" stroke-width="1"/>
                    <!-- Base anchor points -->
                    <circle cx="120" cy="280" r="3" fill="rgba(37, 99, 235, 0.18)"/>
                    <circle cx="380" cy="280" r="3" fill="rgba(37, 99, 235, 0.18)"/>
                    <!-- Subtle steady-state arc -->
                    <path d="M 130 260 Q 250 160 370 260" stroke="rgba(37, 99, 235, 0.10)" stroke-width="1" stroke-dasharray="3 6" fill="none"/>
                </svg>
                </div>
                <h1 class="service-hero__headline">Steady maintenance, clear scope.</h1>
                <p class="service-hero__description">The essentials &mdash; regular updates and fixes with defined credits, predictable response times, and no surprises.</p>
            </section>

            <section class="service-content">
                <div class="service-card">
                    <div class="service-card__section">
                        <p class="service-card__text">The Bronze plan keeps your site current and functional with a set number of monthly credits. You know exactly what you get, and we handle the rest.</p>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">What's included</p>
                        <ul class="service-card__list">
                            <li>Text, image, and link updates (Micro)</li>
                            <li>Small CSS tweaks (Micro)</li>
                            <li>Metadata and SEO updates (Micro)</li>
                            <li>Monthly status check-in</li>
                            <li>Rollover not included &mdash; use it or lose it</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>New page creation</li>
                            <li>Complex integrations</li>
                            <li>Performance optimization</li>
                            <li>CRO analysis</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <ul class="service-card__list">
                            <li>Sites that need steady attention</li>
                            <li>Post-launch maintenance</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">$249/mo CAD</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Credits</p>
                                <p class="service-card__meta-value">4 per month</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Response time</p>
                                <p class="service-card__meta-value">Within 1 business day</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Turnaround</p>
                                <p class="service-card__meta-value">3&ndash;5 business days</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meeting cadence</p>
                                <p class="service-card__meta-value">None included</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="care-credits">
                    <h2 class="care-credits__title">How your credits work</h2>
                    <div class="care-credits__grid">
                        <div class="care-credit">
                            <p class="care-credit__label care-credit__label--micro">Micro &middot; 1 credit</p>
                            <p class="care-credit__cost">Quick fixes</p>
                            <ul class="care-credit__examples">
                                <li>Text or image swap</li>
                                <li>Link or button fix</li>
                                <li>Metadata tweak</li>
                                <li>Small CSS adjustment</li>
                                <li>Add or remove a simple block</li>
                            </ul>
                        </div>
                        <div class="care-credit">
                            <p class="care-credit__label care-credit__label--standard">Standard &middot; 2 credits</p>
                            <p class="care-credit__cost">Meaningful updates</p>
                            <ul class="care-credit__examples">
                                <li>New section on existing page</li>
                                <li>Landing page iteration</li>
                                <li>Form changes or additions</li>
                                <li>Embed or integration swap</li>
                                <li>Blog post upload + formatting</li>
                            </ul>
                        </div>
                    </div>
                    <p class="care-credits__note">Credits are scoped units of work, not hours. Anything outside plan scope becomes a fixed-scope project quote.</p>
                </div>
            </section>

            <section class="service-cta">
                <div id="intakePrompt">
                    <InlineIntakeForm
                        serviceName="Bronze Care"
                        serviceSlug="bronze"
                        tierColor="#2563EB"
                        tierName="CARE"
                    />
                </div>
                <div class="service-cta__card" id="bookingPrompt" style="display: none;">
                    <h2 class="service-cta__title">Ready to schedule</h2>
                    <p class="service-cta__text">Your intake is complete. We'll be in touch within 1 business day to confirm next steps.</p>
                    <a href="/intake" class="service-cta__button">View intake form &rarr;</a>
                </div>
            </section>
        </div>
    </main>

    <footer class="service-footer">
        <div class="service-footer__cta">
            <p class="service-footer__cta-text">Not sure which plan?</p>
            <a href="/care" class="service-footer__cta-link">Compare all Care plans &rarr;</a>
        </div>
        <p class="service-footer__text">&copy; {currentYear} Bertrand Brands. All rights reserved.</p>
        <p class="footer-division"><a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a> &middot; <a href="/privacy">Privacy</a></p>
        <p class="service-footer__phone"><a href="tel:+17054133705" class="phone-link__mobile">(705) 413-3705</a><span class="phone-link__desktop">(705) 413-3705</span></p>
    </footer>

    <script is:inline>
        (function() {
            var intakePrompt = document.getElementById('intakePrompt');
            var bookingPrompt = document.getElementById('bookingPrompt');
            function hasIntakeAccess() {
                return document.cookie.split(';').some(function(c) {
                    return c.trim().startsWith('bb_intake_completed=') || c.trim().startsWith('bb_returning_client=');
                });
            }
            if (hasIntakeAccess() && intakePrompt && bookingPrompt) {
                intakePrompt.style.display = 'none';
                bookingPrompt.style.display = 'block';
            }
        })();
    </script>

    <StickyMobileCTA
        href="#inlineIntakeCard"
        heroSelector=".service-hero"
        formSelector="#inlineIntakeCard"
    />
</ServiceDetailLayout>
