---
/**
 * Gold Care Plan — V10 care detail page.
 * Blue accent (#2563EB) with gold hint. Follows starter.astro pattern with care credit system.
 * Gold is gated — "By application" pricing, "Apply" CTA.
 */
import ServiceDetailLayout from '../../layouts/ServiceDetailLayout.astro';
import InlineIntakeForm from '../../components/InlineIntakeForm.astro';
import StickyMobileCTA from '../../components/StickyMobileCTA.astro';

const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="Gold Care Plan — By Application | Bertrand Brands"
    description="Dedicated priority support. 24 credits/month, same-day response, 24–72 hour turnaround. Limited seats, by application."
    canonical="https://bertrandbrands.ca/care/gold"
    ogTitle="Gold Care Plan — Bertrand Brands"
    ogDescription="Dedicated priority support. 24 credits/month, same-day response. Limited seats, by application."
    schemaJson={{
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "Gold Care Plan",
        "description": "Dedicated priority support with 24 credits per month, same-day response, 24–72 hour turnaround. Limited seats, by application.",
        "provider": {
            "@type": "ProfessionalService",
            "name": "Bertrand Brands — Brand & Web Systems",
            "url": "https://bertrandbrands.ca"
        }
    }}
    spotlightColor="rgba(37, 99, 235, 0.15)"
    accentRgb="37, 99, 235"
>
    <Fragment slot="head">
        <style is:inline>
            /* Gold-specific: third spotlight + metallic accent overrides */
            .service-page__spotlight--3 { width: 340px; height: 340px; background: rgba(212, 175, 55, 0.14); top: 20%; left: 15%; animation: organicBreathe 20s ease-in-out infinite 0.8s; }
            .service-subbrand__name { color: #D4AF37; }
            .service-card { background: rgba(212, 175, 55, 0.04); border: 1px solid rgba(212, 175, 55, 0.18); }
            .service-card__label { color: rgba(212, 175, 55, 1); }
            .service-card__list li::before { background: rgba(212, 175, 55, 0.6); }
            .service-hero__illustration-wrap::before {
                background: radial-gradient(circle, rgba(212, 175, 55, 0.35) 0%, rgba(37, 99, 235, 0.12) 45%, rgba(37, 99, 235, 0) 65%);
            }

            /* Gold scarcity block */
            .service-scarcity { background: rgba(212, 175, 55, 0.03); border: 1px dashed rgba(212, 175, 55, 0.18); border-radius: var(--radius-md); padding: var(--space-md); max-width: 700px; margin: 0 auto var(--space-lg); text-align: center; }
            .service-scarcity__text { font-size: var(--text-sm); color: var(--text-muted); }

            /* Credit breakdown */
            .care-credits { max-width: 700px; margin: 0 auto var(--space-xl); position: relative; z-index: 1; }
            .care-credits__title { font-size: var(--text-lg); font-weight: 500; color: var(--text); margin-bottom: var(--space-sm); text-align: center; }
            .care-credits__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-sm); }
            .care-credit { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: var(--radius-md); padding: var(--space-md); }
            .care-credit__label { font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.25rem; }
            .care-credit__label--micro { color: #D97706; }
            .care-credit__label--standard { color: #8B5CF6; }
            .care-credit__label--advanced { color: #2563EB; }
            .care-credit__cost { font-size: var(--text-sm); font-weight: 500; color: var(--text); margin-bottom: 0.5rem; }
            .care-credit__examples { list-style: none; padding: 0; margin: 0; }
            .care-credit__examples li { font-size: var(--text-xs); color: var(--text-muted); margin-bottom: 0.25rem; line-height: 1.4; }
            .care-credits__note { text-align: center; margin-top: var(--space-sm); font-size: var(--text-xs); color: var(--text-subtle); }

            @media (max-width: 768px) {
                .service-scarcity { padding: var(--space-sm); }
                .care-credits__grid { grid-template-columns: 1fr; }
                .care-credit { padding: var(--space-sm); }
            }
        </style>
    </Fragment>

    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--3" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/care" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Care Plans
            </a>

            <a href="/care" class="service-subbrand">
                <img src="/assets/bg-brands-logomark.png" alt="" class="service-subbrand__mark" width="40" height="40">
                <span class="service-subbrand__name">Gold</span>
            </a>

            <section class="service-hero">
                <div class="service-hero__illustration-wrap">
                <svg class="service-hero__illustration" viewBox="40 40 420 320" fill="none" aria-hidden="true">
                    <!-- Baseline -->
                    <line x1="70" y1="300" x2="430" y2="300" stroke="rgba(37, 99, 235, 0.18)" stroke-width="1.5"/>
                    <!-- Subtle grid -->
                    <line x1="70" y1="160" x2="430" y2="160" stroke="rgba(37, 99, 235, 0.06)" stroke-width="1" stroke-dasharray="4 8"/>
                    <line x1="70" y1="230" x2="430" y2="230" stroke="rgba(37, 99, 235, 0.08)" stroke-width="1"/>
                    <line x1="250" y1="60" x2="250" y2="330" stroke="rgba(37, 99, 235, 0.06)" stroke-width="1" stroke-dasharray="4 8"/>
                    <line x1="160" y1="80" x2="160" y2="320" stroke="rgba(37, 99, 235, 0.04)" stroke-width="1" stroke-dasharray="3 10"/>
                    <line x1="340" y1="80" x2="340" y2="320" stroke="rgba(37, 99, 235, 0.04)" stroke-width="1" stroke-dasharray="3 10"/>
                    <!-- Outer ring (largest) -->
                    <circle cx="250" cy="190" r="110" stroke="rgba(212, 175, 55, 0.18)" stroke-width="2" fill="none"/>
                    <!-- Middle ring -->
                    <circle cx="250" cy="190" r="70" stroke="rgba(212, 175, 55, 0.25)" stroke-width="2" fill="none"/>
                    <!-- Inner ring -->
                    <circle cx="250" cy="190" r="35" stroke="rgba(212, 175, 55, 0.32)" stroke-width="1.5" fill="none"/>
                    <!-- Core — gold tint -->
                    <circle cx="250" cy="190" r="10" stroke="rgba(212, 175, 55, 0.45)" stroke-width="1.5" fill="none"/>
                    <circle cx="250" cy="190" r="4" fill="rgba(212, 175, 55, 0.60)"/>
                    <!-- Crown apex — gold tint -->
                    <path d="M 220 80 L 250 60 L 280 80" stroke="rgba(212, 175, 55, 0.50)" stroke-width="2" fill="none"/>
                    <circle cx="250" cy="60" r="4" fill="rgba(212, 175, 55, 0.55)"/>
                    <circle cx="220" cy="80" r="3" fill="rgba(212, 175, 55, 0.40)"/>
                    <circle cx="280" cy="80" r="3" fill="rgba(212, 175, 55, 0.40)"/>
                    <!-- Connection from crown to outer ring — gold tint -->
                    <line x1="250" y1="64" x2="250" y2="80" stroke="rgba(212, 175, 55, 0.30)" stroke-width="1.5"/>
                    <!-- Outer orbital nodes -->
                    <circle cx="360" cy="190" r="4.5" fill="rgba(212, 175, 55, 0.30)"/>
                    <circle cx="250" cy="80" r="4.5" fill="rgba(212, 175, 55, 0.30)"/>
                    <circle cx="140" cy="190" r="4.5" fill="rgba(212, 175, 55, 0.30)"/>
                    <circle cx="250" cy="300" r="4.5" fill="rgba(212, 175, 55, 0.30)"/>
                    <!-- Middle orbital nodes -->
                    <circle cx="320" cy="190" r="3.5" fill="rgba(212, 175, 55, 0.25)"/>
                    <circle cx="250" cy="120" r="3.5" fill="rgba(212, 175, 55, 0.25)"/>
                    <circle cx="180" cy="190" r="3.5" fill="rgba(212, 175, 55, 0.25)"/>
                    <circle cx="250" cy="260" r="3.5" fill="rgba(212, 175, 55, 0.25)"/>
                    <!-- Diagonal spoke lines -->
                    <line x1="285" y1="155" x2="318" y2="140" stroke="rgba(37, 99, 235, 0.10)" stroke-width="1"/>
                    <line x1="215" y1="155" x2="182" y2="140" stroke="rgba(37, 99, 235, 0.10)" stroke-width="1"/>
                    <line x1="285" y1="225" x2="318" y2="240" stroke="rgba(37, 99, 235, 0.10)" stroke-width="1"/>
                    <line x1="215" y1="225" x2="182" y2="240" stroke="rgba(37, 99, 235, 0.10)" stroke-width="1"/>
                    <!-- Corner waypoints -->
                    <circle cx="318" cy="140" r="2.5" fill="rgba(37, 99, 235, 0.18)"/>
                    <circle cx="182" cy="140" r="2.5" fill="rgba(37, 99, 235, 0.18)"/>
                    <circle cx="318" cy="240" r="2.5" fill="rgba(37, 99, 235, 0.18)"/>
                    <circle cx="182" cy="240" r="2.5" fill="rgba(37, 99, 235, 0.18)"/>
                    <!-- Base anchor nodes -->
                    <circle cx="110" cy="300" r="3" fill="rgba(37, 99, 235, 0.15)"/>
                    <circle cx="390" cy="300" r="3" fill="rgba(37, 99, 235, 0.15)"/>
                    <!-- Subtle filled zone -->
                    <rect x="215" y="165" width="70" height="50" rx="2" fill="rgba(212, 175, 55, 0.03)" stroke="rgba(212, 175, 55, 0.06)" stroke-width="1"/>
                    <!-- Subtle dedication arcs -->
                    <path d="M 160 100 Q 250 70 340 100" stroke="rgba(212, 175, 55, 0.12)" stroke-width="1" stroke-dasharray="3 6" fill="none"/>
                    <path d="M 120 280 Q 250 220 380 280" stroke="rgba(212, 175, 55, 0.08)" stroke-width="1" stroke-dasharray="2 6" fill="none"/>
                </svg>
                </div>
                <h1 class="service-hero__headline">Dedicated support, on call.</h1>
                <p class="service-hero__description">Our highest level of care &mdash; same-day response, priority over all other plans, and the capacity to handle whatever comes up.</p>
            </section>

            <section class="service-content">
                <div class="service-card">
                    <div class="service-card__section">
                        <p class="service-card__text">Gold is for businesses that need us ready. Same-day response, the highest credit allocation, and priority over every other plan. This is a dedicated support relationship &mdash; not a generic retainer.</p>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">What's included</p>
                        <ul class="service-card__list">
                            <li>Everything in Silver, plus:</li>
                            <li>New pages from existing patterns (Advanced)</li>
                            <li>Heavier layout work (Advanced)</li>
                            <li>Priority over all other plans</li>
                            <li>Fit + capacity confirmed before onboarding</li>
                            <li>Dedicated support relationship</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Full redesigns (those become project quotes)</li>
                            <li>Brand identity work</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <ul class="service-card__list">
                            <li>Businesses that need us on call</li>
                            <li>High-volume update needs</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">By application</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Credits</p>
                                <p class="service-card__meta-value">24 per month</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Response time</p>
                                <p class="service-card__meta-value">Same business day</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Turnaround</p>
                                <p class="service-card__meta-value">24&ndash;72 hour target</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meeting cadence</p>
                                <p class="service-card__meta-value">1&ndash;2x monthly</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="service-scarcity">
                    <p class="service-scarcity__text">Limited seats. Fit + capacity confirmed before onboarding.</p>
                </div>

                <div class="care-credits">
                    <h2 class="care-credits__title">How your credits work</h2>
                    <div class="care-credits__grid">
                        <div class="care-credit">
                            <p class="care-credit__label care-credit__label--micro">Micro &middot; 1 credit</p>
                            <p class="care-credit__cost">Quick fixes</p>
                            <ul class="care-credit__examples">
                                <li>Text or image swap</li>
                                <li>Link or button fix</li>
                                <li>Metadata tweak</li>
                                <li>Small CSS adjustment</li>
                                <li>Add or remove a simple block</li>
                            </ul>
                        </div>
                        <div class="care-credit">
                            <p class="care-credit__label care-credit__label--standard">Standard &middot; 2 credits</p>
                            <p class="care-credit__cost">Meaningful updates</p>
                            <ul class="care-credit__examples">
                                <li>New section on existing page</li>
                                <li>Landing page iteration</li>
                                <li>Form changes or additions</li>
                                <li>Embed or integration swap</li>
                                <li>Blog post upload + formatting</li>
                            </ul>
                        </div>
                        <div class="care-credit">
                            <p class="care-credit__label care-credit__label--advanced">Advanced &middot; 4 credits</p>
                            <p class="care-credit__cost">Structural work</p>
                            <ul class="care-credit__examples">
                                <li>New page from existing patterns</li>
                                <li>Heavier layout work</li>
                                <li>Performance sweep</li>
                                <li>Structured CRO pass + implementation</li>
                            </ul>
                        </div>
                    </div>
                    <p class="care-credits__note">Credits are scoped units of work, not hours. Anything outside plan scope becomes a fixed-scope project quote.</p>
                </div>
            </section>

            <section class="service-cta">
                <div id="intakePrompt">
                    <InlineIntakeForm
                        serviceName="Gold Care"
                        serviceSlug="gold"
                        tierColor="#2563EB"
                        tierName="CARE"
                    />
                </div>
                <div class="service-cta__card" id="bookingPrompt" style="display: none;">
                    <h2 class="service-cta__title">Application received</h2>
                    <p class="service-cta__text">Your application is complete. We'll be in touch within 1 business day to confirm fit and next steps.</p>
                    <a href="/intake" class="service-cta__button">View intake form &rarr;</a>
                </div>
            </section>
        </div>
    </main>

    <footer class="service-footer">
        <div class="service-footer__cta">
            <p class="service-footer__cta-text">Not sure which plan?</p>
            <a href="/care" class="service-footer__cta-link">Compare all Care plans &rarr;</a>
        </div>
        <p class="service-footer__text">&copy; {currentYear} Bertrand Brands. All rights reserved.</p>
        <p class="footer-division"><a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a> &middot; <a href="/privacy">Privacy</a></p>
        <p class="service-footer__phone"><a href="tel:+17054133705" class="phone-link__mobile">(705) 413-3705</a><span class="phone-link__desktop">(705) 413-3705</span></p>
    </footer>

    <script is:inline>
        (function() {
            var intakePrompt = document.getElementById('intakePrompt');
            var bookingPrompt = document.getElementById('bookingPrompt');
            function hasIntakeAccess() {
                return document.cookie.split(';').some(function(c) {
                    return c.trim().startsWith('bb_intake_completed=') || c.trim().startsWith('bb_returning_client=');
                });
            }
            if (hasIntakeAccess() && intakePrompt && bookingPrompt) {
                intakePrompt.style.display = 'none';
                bookingPrompt.style.display = 'block';
            }
        })();
    </script>

    <StickyMobileCTA
        href="#inlineIntakeCard"
        text="Apply"
        subtext="Limited seats — we confirm fit first"
        heroSelector=".service-hero"
        formSelector="#inlineIntakeCard"
    />
</ServiceDetailLayout>
