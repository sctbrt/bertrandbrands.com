---
/**
 * Sudbury Focus Studio — Google Ads landing page (local campaign).
 * HeaderMinimal standard variant with "Get started →" CTA.
 * Google Ads: AW-17925090292 with phone + form conversion events.
 * Two schema blocks: Service (with geo) + FAQPage.
 * 2-step Formspree form, sticky mobile CTA, scroll fade-in.
 * All CSS uses sb- prefix.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderMinimal from '../components/HeaderMinimal.astro';
import SkipLink from '../components/SkipLink.astro';
import VisitorNotify from '../components/VisitorNotify.astro';
import GesturePrevention from '../components/GesturePrevention.astro';

const currentYear = new Date().getFullYear();
---

<BaseLayout
    title="Sudbury Web Design & Branding — Websites from $750 | Bertrand Brands"
    description="Custom-coded websites for Sudbury small businesses. Fixed pricing from $750. No templates, no WordPress. Strategy-first web design by a real dev team. Based in Greater Sudbury, Ontario."
    canonical="https://bertrandbrands.ca/sudbury"
    ogTitle="Sudbury Web Design & Branding — Websites from $750 | Bertrand Brands"
    ogDescription="Custom-coded websites from $750. Fixed pricing, fast turnaround. No templates. Based in Greater Sudbury, Ontario."
    schemaJson={{
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "B Build — Sudbury",
        "description": "Fixed-scope web and brand work for small businesses in Greater Sudbury and Northern Ontario.",
        "provider": {
            "@type": "ProfessionalService",
            "name": "Bertrand Brands — Brand & Web Systems",
            "url": "https://bertrandbrands.ca",
            "telephone": "+17054133705",
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Greater Sudbury",
                "addressRegion": "Ontario",
                "addressCountry": "CA"
            },
            "geo": {
                "@type": "GeoCoordinates",
                "latitude": 46.4917,
                "longitude": -80.9930
            },
            "sameAs": ["https://linkedin.com/in/sudburyon"]
        },
        "areaServed": [
            { "@type": "City", "name": "Greater Sudbury", "containedInPlace": { "@type": "AdministrativeArea", "name": "Ontario" } },
            { "@type": "AdministrativeArea", "name": "Northern Ontario" }
        ],
        "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Website & Brand Services",
            "itemListElement": [
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Starter Site — One-Page + Contact" }, "price": "750", "priceCurrency": "CAD" },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Website Foundation + Growth System" }, "description": "Full website rebuild with content strategy, conversion UX, and growth playbook" },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bronze — Monthly Care Plan" }, "price": "249", "priceCurrency": "CAD", "description": "Monthly website maintenance and updates" }
            ]
        }
    }}
>
    <Fragment slot="head">
        <!-- FAQPage Schema (second schema block) -->
        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "Does Bertrand Brands work with Sudbury businesses?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. Bertrand Brands is based in Greater Sudbury, Ontario and works with local businesses across Sudbury and Northern Ontario, as well as clients across Canada."
                    }
                },
                {
                    "@type": "Question",
                    "name": "How much does a website cost for a small business in Sudbury?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Bertrand Brands offers fixed-price website services starting at $750 CAD for a Starter Site — One-Page + Contact (7\u201310 days). Larger projects like our Website Foundation + Growth System are scoped to your needs. Monthly care plans start at $249/mo. No hourly billing."
                    }
                },
                {
                    "@type": "Question",
                    "name": "How fast can I get a new website?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Starter sites launch in 7\u201310 business days. Transform projects like the Website Foundation + Growth System take 4\u20138 weeks depending on complexity."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Do I need to come to an office in Sudbury?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "No. All work is done remotely. Communication happens over video calls and email. You can get started from the website at any time."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Can you fix my existing website in Sudbury?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. If your website is outdated, unclear, or not generating leads, Bertrand Brands can help. Our Website Foundation + Growth System is a full website rebuild with content strategy, conversion UX, and a growth playbook. We work with Sudbury businesses to make their websites clear, structured, and effective."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Is there a web designer near me in Sudbury?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Bertrand Brands is based in Greater Sudbury, Ontario. All work is done remotely with fixed pricing and fast turnaround \u2014 no need for in-person meetings. Call 705-413-3705 or visit bertrandbrands.ca to get started."
                    }
                }
            ]
        })} />

        <style is:inline>
            html { touch-action: pan-x pan-y; }

            /* Override header visibility for landing pages */
            .header {
                opacity: 1 !important;
                visibility: visible !important;
                pointer-events: auto !important;
                transform: translateY(0) !important;
            }
            .header__logo-icon { opacity: 1 !important; }
            .header__wordmark { opacity: 1 !important; }

            /* ============================================================
               MOBILE CONVERSION LAYOUT
               sb- prefix for Sudbury-specific styles
               ============================================================ */

            .sb-container {
                max-width: 800px;
                margin: 0 auto;
                padding: 0 clamp(1.5rem, 5vw, 3rem);
            }

            /* ---- Hero ---- */
            .sb-hero {
                position: relative;
                overflow: hidden;
                display: flex;
                align-items: center;
                justify-content: center;
                text-align: center;
                padding: 10rem var(--space-md) var(--space-lg);
            }
            .sb-hero__content {
                position: relative;
                z-index: 1;
                max-width: 620px;
            }

            /* ---- Hero Spotlights ---- */
            .sb-hero__spotlight {
                position: absolute;
                border-radius: 50%;
                filter: blur(100px);
                opacity: 0;
                pointer-events: none;
                z-index: 0;
                will-change: transform, opacity;
                transform: translateZ(0);
                backface-visibility: hidden;
                contain: layout style;
            }
            .sb-hero__spotlight--orange {
                width: 500px;
                height: 500px;
                background: radial-gradient(circle, rgba(217, 119, 6, 0.8) 0%, rgba(217, 119, 6, 0.25) 40%, transparent 65%);
                bottom: 5%;
                left: -8%;
                animation: sbFadeIn 3s ease-out forwards, sbFloatOrange 45s ease-in-out 3s infinite;
            }
            .sb-hero__spotlight--warm {
                width: 450px;
                height: 450px;
                background: radial-gradient(circle, rgba(251, 191, 36, 0.7) 0%, rgba(251, 191, 36, 0.22) 40%, transparent 65%);
                top: 10%;
                left: 25%;
                animation: sbFadeIn 3.5s ease-out 0.4s forwards, sbFloatWarm 38s ease-in-out 3.9s infinite;
            }
            .sb-hero__spotlight--blue {
                width: 450px;
                height: 450px;
                background: radial-gradient(circle, rgba(37, 99, 235, 0.7) 0%, rgba(37, 99, 235, 0.22) 40%, transparent 65%);
                top: 0%;
                right: -6%;
                animation: sbFadeIn 4s ease-out 0.8s forwards, sbFloatBlue 50s ease-in-out 4.8s infinite;
            }

            /* Spotlight fade-in (gentle appearance on page load) */
            @keyframes sbFadeIn {
                0% { opacity: 0; transform: scale(0.85) translateZ(0); filter: blur(140px); }
                100% { opacity: 0.4; transform: scale(1) translateZ(0); filter: blur(100px); }
            }

            /* Organic drift — orange: bottom-left, wanders right and up */
            @keyframes sbFloatOrange {
                0%, 100% {
                    transform: translate(0, 0) scale(1) translateZ(0);
                    opacity: 0.4;
                    border-radius: 50% 50% 50% 50%;
                }
                12% {
                    transform: translate(12vw, -6vh) scale(1.06) translateZ(0);
                    opacity: 0.36;
                    border-radius: 58% 42% 55% 45%;
                }
                28% {
                    transform: translate(28vw, -12vh) scale(0.95) translateZ(0);
                    opacity: 0.32;
                    border-radius: 44% 56% 42% 58%;
                }
                45% {
                    transform: translate(36vw, -4vh) scale(1.04) translateZ(0);
                    opacity: 0.38;
                    border-radius: 55% 45% 58% 42%;
                }
                62% {
                    transform: translate(24vw, 4vh) scale(0.96) translateZ(0);
                    opacity: 0.34;
                    border-radius: 42% 58% 46% 54%;
                }
                80% {
                    transform: translate(10vw, 2vh) scale(1.03) translateZ(0);
                    opacity: 0.38;
                    border-radius: 56% 44% 50% 50%;
                }
            }

            /* Organic drift — violet: centre, figure-eight wander */
            @keyframes sbFloatWarm {
                0%, 100% {
                    transform: translate(0, 0) scale(1) translateZ(0);
                    opacity: 0.3;
                    border-radius: 50% 50% 50% 50%;
                }
                14% {
                    transform: translate(14vw, -8vh) scale(1.05) translateZ(0);
                    opacity: 0.34;
                    border-radius: 56% 44% 52% 48%;
                }
                30% {
                    transform: translate(6vw, 8vh) scale(0.94) translateZ(0);
                    opacity: 0.27;
                    border-radius: 46% 54% 44% 56%;
                }
                48% {
                    transform: translate(-12vw, 5vh) scale(1.03) translateZ(0);
                    opacity: 0.32;
                    border-radius: 54% 46% 56% 44%;
                }
                66% {
                    transform: translate(-8vw, -6vh) scale(0.97) translateZ(0);
                    opacity: 0.28;
                    border-radius: 44% 56% 48% 52%;
                }
                82% {
                    transform: translate(4vw, -2vh) scale(1.02) translateZ(0);
                    opacity: 0.31;
                    border-radius: 52% 48% 54% 46%;
                }
            }

            /* Organic drift — blue: upper-right, drifts to lower-left */
            @keyframes sbFloatBlue {
                0%, 100% {
                    transform: translate(0, 0) scale(1) translateZ(0);
                    opacity: 0.34;
                    border-radius: 50% 50% 50% 50%;
                }
                12% {
                    transform: translate(-10vw, 5vh) scale(1.04) translateZ(0);
                    opacity: 0.3;
                    border-radius: 54% 46% 48% 52%;
                }
                28% {
                    transform: translate(-24vw, 10vh) scale(0.96) translateZ(0);
                    opacity: 0.28;
                    border-radius: 43% 57% 54% 46%;
                }
                45% {
                    transform: translate(-32vw, 4vh) scale(1.05) translateZ(0);
                    opacity: 0.32;
                    border-radius: 57% 43% 46% 54%;
                }
                62% {
                    transform: translate(-20vw, -2vh) scale(0.95) translateZ(0);
                    opacity: 0.29;
                    border-radius: 46% 54% 57% 43%;
                }
                80% {
                    transform: translate(-8vw, -1vh) scale(1.02) translateZ(0);
                    opacity: 0.32;
                    border-radius: 52% 48% 43% 57%;
                }
            }
            .sb-hero__eyebrow {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.18em;
                color: #a78bfa;
                margin-bottom: var(--space-md);
            }
            .sb-hero__title {
                font-family: var(--font-display);
                font-size: clamp(1.75rem, 6vw, 3rem);
                font-weight: 600;
                line-height: 1.2;
                letter-spacing: -0.02em;
                color: var(--text);
                margin-bottom: var(--space-sm);
            }
            .sb-hero__subhead {
                font-family: var(--font-body);
                font-size: var(--text-base);
                font-weight: 400;
                color: #d4d4d4;
                line-height: 1.7;
                margin-bottom: var(--space-md);
                max-width: 520px;
                margin-left: auto;
                margin-right: auto;
            }
            .sb-hero__actions {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: var(--space-xs);
            }
            .sb-hero__cta {
                display: inline-block;
                background: var(--accent);
                color: #0a0a0a;
                font-family: var(--font-body);
                font-size: var(--text-base);
                font-weight: 500;
                padding: 0.875rem 2rem;
                border-radius: var(--radius-md);
                letter-spacing: 0.01em;
                text-decoration: none;
                transition: background var(--duration-fast) ease, transform var(--duration-fast) ease;
            }
            .sb-hero__cta:hover {
                background: var(--accent-hover);
                transform: translateY(-1px);
            }
            .sb-hero__or {
                font-family: var(--font-body);
                font-size: var(--text-2xs);
                font-weight: 400;
                color: var(--text-subtle);
                margin: 0.125rem 0;
                text-transform: uppercase;
                letter-spacing: 0.1em;
            }
            .sb-hero__phone {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 400;
                color: var(--text-muted);
                text-decoration: none;
                transition: color var(--duration-fast) ease;
            }
            .sb-hero__phone:hover {
                color: var(--text);
            }
            .sb-hero__phone-number {
                color: var(--text);
                font-weight: 500;
            }
            .sb-hero__secondary {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 400;
                color: var(--text-muted);
                margin-top: var(--space-sm);
                text-decoration: none;
                transition: color var(--duration-fast) ease;
            }
            .sb-hero__secondary:hover {
                color: var(--text);
            }
            /* Spotlight mobile optimization */
            @media (max-width: 768px) {
                .sb-hero__spotlight {
                    filter: blur(50px);
                }
                .sb-hero__spotlight--orange { width: 350px; height: 350px; }
                .sb-hero__spotlight--warm { width: 300px; height: 300px; }
                .sb-hero__spotlight--blue { width: 300px; height: 300px; }
            }
            @media (prefers-reduced-motion: reduce) {
                .sb-hero__spotlight {
                    animation: none !important;
                    opacity: 0.25;
                }
            }
            @media (max-width: 480px) {
                .sb-hero {
                    padding: 7rem var(--space-sm) var(--space-lg);
                }
                .sb-hero__title {
                    font-size: clamp(1.5rem, 8vw, 2.25rem);
                }
                .sb-hero__spotlight--orange { width: 280px; height: 280px; }
                .sb-hero__spotlight--warm { width: 240px; height: 240px; }
                .sb-hero__spotlight--blue { width: 240px; height: 240px; }
            }

            /* ---- Proof Strip ---- */
            .sb-proof {
                padding: 0 0 var(--space-lg);
            }
            .sb-proof__grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: var(--space-sm);
                max-width: 620px;
                margin: 0 auto;
            }
            .sb-proof__item {
                text-align: center;
                padding: var(--space-sm) var(--space-xs);
            }
            .sb-proof__number {
                display: block;
                font-family: var(--font-display);
                font-size: var(--text-2xl);
                font-weight: 300;
                color: var(--text);
                letter-spacing: -0.02em;
                line-height: 1.1;
            }
            .sb-proof__label {
                display: block;
                font-family: var(--font-body);
                font-size: var(--text-xs);
                color: var(--text-subtle);
                margin-top: 0.35rem;
                letter-spacing: 0.02em;
            }

            @media (max-width: 480px) {
                .sb-proof__number { font-size: var(--text-xl); }
                .sb-proof__label { font-size: var(--text-2xs); }
            }

            /* ---- Starter Card (Primary Offering) ---- */
            .sb-starter {
                padding: var(--space-lg) 0;
            }
            .sb-starter__card {
                background: linear-gradient(135deg, #1a1207 0%, #16110a 100%);
                border: 1px solid rgba(217, 119, 6, 0.2);
                border-radius: var(--radius-lg);
                padding: var(--space-md);
                max-width: 480px;
                margin: 0 auto;
            }
            .sb-starter__badge {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                margin-bottom: var(--space-sm);
                flex-wrap: wrap;
            }
            .sb-starter__badge-rec {
                font-family: var(--font-body);
                font-size: 0.6875rem;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                color: #fbbf24;
                background: rgba(217, 119, 6, 0.15);
                padding: 0.25rem 0.625rem;
                border-radius: var(--radius-sm);
            }
            .sb-starter__badge-time {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 400;
                color: #d4d4d8;
            }
            .sb-starter__title {
                font-family: var(--font-display);
                font-size: clamp(1.25rem, 4vw, 1.5rem);
                font-weight: 600;
                color: var(--text);
                margin-bottom: 0.75rem;
                letter-spacing: -0.01em;
            }
            .sb-starter__desc {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 400;
                color: #d4d4d8;
                line-height: 1.7;
                margin-bottom: var(--space-sm);
            }
            .sb-starter__list {
                list-style: none;
                padding: 0;
                margin: 0 0 var(--space-md);
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
            }
            .sb-starter__list li {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 400;
                color: #e4e4e7;
                padding-left: 1.25rem;
                position: relative;
            }
            .sb-starter__list li::before {
                content: "\2713";
                position: absolute;
                left: 0;
                color: #a78bfa;
                font-size: var(--text-sm);
            }
            .sb-starter__cta {
                display: inline-block;
                background: var(--accent);
                color: #0a0a0a;
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 500;
                padding: 0.75rem 1.75rem;
                border-radius: var(--radius-md);
                text-decoration: none;
                transition: background var(--duration-fast) ease, transform var(--duration-fast) ease;
                margin-bottom: var(--space-sm);
            }
            .sb-starter__cta:hover {
                background: var(--accent-hover);
                transform: translateY(-1px);
            }
            .sb-starter__price {
                display: flex;
                align-items: baseline;
                gap: 0.5rem;
                flex-wrap: wrap;
            }
            .sb-starter__amount {
                font-family: var(--font-display);
                font-size: var(--text-lg);
                font-weight: 500;
                color: #e4e4e7;
            }
            .sb-starter__note {
                font-family: var(--font-body);
                font-size: var(--text-xs);
                font-weight: 400;
                color: #a1a1aa;
            }
            @media (max-width: 480px) {
                .sb-starter__card {
                    padding: var(--space-sm);
                }
            }

            /* ---- How It Works ---- */
            .sb-hiw {
                padding: var(--space-lg) 0;
            }
            .sb-hiw__title {
                font-family: var(--font-display);
                font-size: clamp(1.125rem, 3vw, 1.375rem);
                font-weight: 600;
                color: var(--text);
                margin-bottom: var(--space-md);
                letter-spacing: -0.01em;
            }
            .sb-hiw__grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: var(--space-sm);
            }
            .sb-hiw__step {
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
                background: var(--bg-elevated);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg);
                padding: var(--space-4);
            }
            .sb-hiw__num {
                font-family: var(--font-display);
                font-size: var(--text-sm);
                font-weight: 600;
                color: var(--text-subtle);
                width: 28px;
                height: 28px;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 1px solid var(--border-hover);
                border-radius: 50%;
                flex-shrink: 0;
            }
            .sb-hiw__heading {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 500;
                color: var(--text);
            }
            .sb-hiw__desc {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 400;
                color: var(--text-muted);
                line-height: 1.6;
            }
            @media (max-width: 768px) {
                .sb-hiw__grid {
                    grid-template-columns: 1fr;
                    gap: var(--space-sm);
                }
                .sb-hiw__step {
                    flex-direction: row;
                    align-items: flex-start;
                    gap: 0.75rem;
                    padding: var(--space-3) var(--space-4);
                }
                .sb-hiw__num {
                    margin-top: 2px;
                }
            }

            /* ---- Trust Strip ---- */
            .sb-trust {
                padding: var(--space-lg) 0;
            }
            .sb-trust__card {
                background: var(--bg-elevated);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg);
                padding: var(--space-6) var(--space-8);
            }
            .sb-trust__title {
                font-family: var(--font-display);
                font-size: clamp(1rem, 3vw, 1.25rem);
                font-weight: 500;
                color: var(--text);
                margin-bottom: var(--space-sm);
                letter-spacing: -0.01em;
            }
            .sb-trust__list {
                list-style: none;
                padding: 0;
                margin: 0;
                display: flex;
                flex-direction: column;
                gap: 0.625rem;
            }
            .sb-trust__item {
                font-family: var(--font-body);
                font-size: var(--text-sm);
                font-weight: 400;
                color: var(--text-muted);
                padding-left: 1.25rem;
                position: relative;
            }
            .sb-trust__item::before {
                content: "\2014";
                position: absolute;
                left: 0;
                color: var(--text-subtle);
            }
            @media (max-width: 480px) {
                .sb-trust__card {
                    padding: var(--space-4) var(--space-4);
                }
            }

            /* ---- Other Services ---- */
            .sb-other {
                padding: var(--space-lg) 0;
            }
            .sb-other__intro {
                font-family: var(--font-display);
                font-size: clamp(1rem, 3vw, 1.25rem);
                font-weight: 500;
                color: var(--text);
                margin-bottom: var(--space-md);
                letter-spacing: -0.01em;
            }
            .sb-other__grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: var(--space-sm);
            }
            /* Card surface handled by .tier-card / .tier-card--build */
            .sb-other__card {
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
                text-decoration: none;
                color: inherit;
            }
            .sb-other__name {
                font-family: var(--font-display);
                font-size: var(--text-base);
                font-weight: 500;
                color: var(--text);
                letter-spacing: -0.01em;
            }
            .sb-other__timeline {
                font-family: var(--font-body);
