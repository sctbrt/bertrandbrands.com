            <div class="sb-footer__bottom">
                <p class="sb-footer__copy">&copy; {currentYear} Bertrand Brands. All rights reserved.</p>
                <p class="footer-division"><a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a></p>
                <p class="sb-footer__links">
                    <a href="/?skip">Home</a> &middot;
                    <a href="/?skip#packages">All Services</a>
                </p>
                <p class="sb-footer__phone"><a href="tel:+17054133705" class="phone-link__mobile" title="Call Bertrand Brands">705-413-3705</a><span class="phone-link__desktop">705-413-3705</span></p>
            </div>
        </div>
    </footer>

    <!-- Sticky CTA (Mobile Only) -->
    <div class="sb-sticky" id="stickyCta" aria-hidden="true">
        <div class="sb-sticky__inner">
            <a href="#get-started" class="sb-sticky__cta">Free quote &rarr;</a>
            <a href="tel:+17054133705" class="sb-sticky__phone" title="Call Bertrand Brands">Call us</a>
        </div>
    </div>

    <script is:inline>
        // Phone click tracking now handled globally by BaseLayout

        // Capture gclid from URL params for offline conversion tracking
        (function() {
            var gclid = new URLSearchParams(window.location.search).get('gclid');
            if (gclid) {
                var field = document.getElementById('gclidField');
                if (field) field.value = gclid;
            }
        })();

        // Two-step form logic
        (function() {
            var continueBtn = document.getElementById('formContinueBtn');
            var step2 = document.getElementById('formStep2');
            if (!continueBtn || !step2) return;

            continueBtn.addEventListener('click', function() {
                step2.classList.add('sb-form__step2--visible');
                continueBtn.style.display = 'none';
                step2.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            });
        })();

        // Form submission
        (function() {
            var form = document.getElementById('sudburyForm');
            var submitBtn = document.getElementById('submitBtn');
            var feedback = document.getElementById('formFeedback');
            if (!form || !submitBtn) return;

            form.addEventListener('submit', async function(e) {
                e.preventDefault();

                submitBtn.disabled = true;
                submitBtn.textContent = 'Submitting...';
                feedback.className = 'sb-form__feedback';
                feedback.textContent = '';

                try {
                    var response = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify(Object.fromEntries(new FormData(form)))
                    });

                    if (response.ok) {
                        // Capture form data before reset
                        var formData = new FormData(form);

                        feedback.className = 'sb-form__feedback sb-form__feedback--success';
                        feedback.textContent = 'Got it. We\'ll be in touch within 1 business day.';
                        form.reset();

                        // Pushover notification
                        fetch('/api/notify', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                type: 'intake',
                                source: 'sudbury_focus_studio',
                                service: formData.get('offering') || '',
                                name: formData.get('name') || '',
                                email: formData.get('email') || '',
                                business: formData.get('business') || '',
                                website: formData.get('website') || '',
                                details: formData.get('details') || ''
                            })
                        }).catch(function() {});

                        // Enhanced Conversions — send user data for better attribution
                        if (typeof gtag === 'function') {
                            gtag('set', 'user_data', {
                                email: formData.get('email') || ''
                            });
                        }

                        // Google Ads: Lead — Intake Submitted
                        if (typeof gtag === 'function') {
                            gtag('event', 'conversion', {
                                'send_to': 'AW-17925090292/3B0-CJDv6vUbEPTXrONC',
                                'value': 1.0,
                                'currency': 'CAD'
                            });
                        }
                    } else {
                        throw new Error('Submission failed');
                    }
                } catch (error) {
                    feedback.className = 'sb-form__feedback sb-form__feedback--error';
                    feedback.textContent = 'Something went wrong. Please try again or email hello@bertrandgroup.ca';
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Fix my website \u2192';
                }
            });
        })();

        // Sticky CTA — show when hero exits, hide when form enters
        (function() {
            var hero = document.getElementById('hero');
            var formSection = document.getElementById('get-started');
            var sticky = document.getElementById('stickyCta');
            if (!hero || !sticky) return;

            var heroVisible = true;
            var formVisible = false;

            function updateVisibility() {
                var shouldShow = !heroVisible && !formVisible;
                sticky.classList.toggle('sb-sticky--visible', shouldShow);
                sticky.setAttribute('aria-hidden', !shouldShow);
            }

            var heroObserver = new IntersectionObserver(function(entries) {
                heroVisible = entries[0].isIntersecting;
                updateVisibility();
            }, { threshold: 0 });

            heroObserver.observe(hero);

            if (formSection) {
                var formObserver = new IntersectionObserver(function(entries) {
                    formVisible = entries[0].isIntersecting;
                    updateVisibility();
                }, { threshold: 0.1 });
                formObserver.observe(formSection);
            }
        })();

        // Scroll fade-in observer
        (function() {
            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                document.querySelectorAll('.sb-fade').forEach(function(el) {
                    el.classList.add('revealed');
                });
                return;
            }

            var observer = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('revealed');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.15 });

            document.querySelectorAll('.sb-fade').forEach(function(el) {
                observer.observe(el);
            });
        })();

    </script>

    <GesturePrevention />

    <VisitorNotify />
</BaseLayout>
