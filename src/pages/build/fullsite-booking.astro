---
/**
 * Full Site — Multi-Page + Booking detail page.
 * Amber accent (#D97706). Single-offer detail with InlineIntakeForm.
 * Part of the Build (Amber) tier at /build.
 */
import ServiceDetailLayout from '../../layouts/ServiceDetailLayout.astro';
import InlineIntakeForm from '../../components/InlineIntakeForm.astro';
import StickyMobileCTA from '../../components/StickyMobileCTA.astro';
import { breadcrumbList, schemaGraph, PROVIDER, AREA_SERVED } from '../../lib/schema';


const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="Full Site — Multi-Page + Booking | Bertrand Brands"
    description="5-10 page website with booking integration, reviews, FAQ, analytics, and conversion UX. Scoped pricing, 3-4 weeks."
    canonical="https://bertrandbrands.ca/build/fullsite-booking"
    ogTitle="Full Site — Multi-Page + Booking | Bertrand Brands"
    ogDescription="A comprehensive website with booking integration and conversion-focused service pages. Scoped pricing, 3-4 weeks."
    serviceName="Full Site — Multi-Page + Booking"
    serviceTier="Build"
    serviceSlug="fullsite-booking"
    schemaJson={schemaGraph(
        breadcrumbList([
            { name: "Bertrand Brands", url: "https://bertrandbrands.ca/" },
            { name: "Build", url: "https://bertrandbrands.ca/build" },
            { name: "Full Site + Booking", url: "https://bertrandbrands.ca/build/fullsite-booking" }
        ]),
        {
            "@type": "Service",
            "name": "Full Site — Multi-Page + Booking",
            "url": "https://bertrandbrands.ca/build/fullsite-booking",
            "description": "A comprehensive website with booking integration, conversion-focused service pages, and everything needed to turn visitors into clients.",
            "provider": PROVIDER,
            "areaServed": AREA_SERVED
        }
    )}
    spotlightColor="rgba(217, 119, 6, 0.15)"
    accentRgb="217, 119, 6"
>
    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/build" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Build
            </a>

            <a href="/build" class="service-subbrand">
                <img src="/assets/dot-logomark.svg" alt="" class="service-subbrand__mark" width="40" height="40" />
                <span class="service-subbrand__sep" aria-hidden="true">|</span>
                <span class="service-subbrand__name">Full Site + Booking</span>
            </a>

            <section class="service-hero">
                <div class="service-hero__illustration-wrap">
                <svg class="service-hero__illustration" viewBox="40 40 420 320" fill="none" aria-hidden="true">
                    <!-- Calendar/booking schematic -->
                    <!-- Main calendar frame -->
                    <rect x="110" y="80" width="220" height="200" rx="6" stroke="rgba(217, 119, 6, 0.22)" stroke-width="1.5" fill="rgba(217, 119, 6, 0.03)"/>
                    <!-- Calendar header bar -->
                    <rect x="110" y="80" width="220" height="36" rx="6" fill="rgba(217, 119, 6, 0.06)" stroke="rgba(217, 119, 6, 0.15)" stroke-width="1"/>
                    <line x1="110" y1="116" x2="330" y2="116" stroke="rgba(217, 119, 6, 0.15)" stroke-width="1"/>
                    <!-- Header dots (month navigation) -->
                    <circle cx="135" cy="98" r="3" stroke="rgba(217, 119, 6, 0.25)" stroke-width="1"/>
                    <circle cx="305" cy="98" r="3" stroke="rgba(217, 119, 6, 0.25)" stroke-width="1"/>
                    <!-- Month title line -->
                    <line x1="190" y1="98" x2="250" y2="98" stroke="rgba(217, 119, 6, 0.20)" stroke-width="2"/>
                    <!-- Day grid — 7 columns, 4 rows -->
                    <!-- Row 1 -->
                    <rect x="120" y="126" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="150" y="126" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="180" y="126" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="210" y="126" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="240" y="126" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="270" y="126" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="300" y="126" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <!-- Row 2 -->
                    <rect x="120" y="158" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="150" y="158" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="180" y="158" width="24" height="24" rx="3" fill="rgba(217, 119, 6, 0.10)" stroke="rgba(217, 119, 6, 0.25)" stroke-width="1.5"/>
                    <rect x="210" y="158" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="240" y="158" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="270" y="158" width="24" height="24" rx="3" fill="rgba(217, 119, 6, 0.06)" stroke="rgba(217, 119, 6, 0.15)" stroke-width="1"/>
                    <rect x="300" y="158" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <!-- Row 3 -->
                    <rect x="120" y="190" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="150" y="190" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="180" y="190" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="210" y="190" width="24" height="24" rx="3" fill="rgba(217, 119, 6, 0.06)" stroke="rgba(217, 119, 6, 0.15)" stroke-width="1"/>
                    <rect x="240" y="190" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="270" y="190" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="300" y="190" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <!-- Row 4 -->
                    <rect x="120" y="222" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="150" y="222" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="180" y="222" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="210" y="222" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="240" y="222" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="270" y="222" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="300" y="222" width="24" height="24" rx="3" fill="none" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <!-- Selected day highlight dot -->
                    <circle cx="192" cy="170" r="2" fill="rgba(217, 119, 6, 0.40)"/>
                    <!-- Connection line from calendar to page stack -->
                    <path d="M 330 180 Q 360 180 380 140" stroke="rgba(217, 119, 6, 0.12)" stroke-width="1" stroke-dasharray="3 5" fill="none"/>
                    <!-- Small page stack (website) -->
                    <rect x="370" y="100" width="60" height="80" rx="3" stroke="rgba(217, 119, 6, 0.15)" stroke-width="1" fill="rgba(217, 119, 6, 0.025)"/>
                    <line x1="380" y1="118" x2="420" y2="118" stroke="rgba(217, 119, 6, 0.15)" stroke-width="1"/>
                    <line x1="380" y1="130" x2="415" y2="130" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <line x1="380" y1="140" x2="410" y2="140" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <rect x="380" y="150" width="30" height="12" rx="2" fill="rgba(217, 119, 6, 0.06)" stroke="rgba(217, 119, 6, 0.12)" stroke-width="1"/>
                    <!-- Review stars beneath calendar -->
                    <circle cx="180" cy="300" r="3" fill="rgba(217, 119, 6, 0.20)"/>
                    <circle cx="195" cy="300" r="3" fill="rgba(217, 119, 6, 0.20)"/>
                    <circle cx="210" cy="300" r="3" fill="rgba(217, 119, 6, 0.20)"/>
                    <circle cx="225" cy="300" r="3" fill="rgba(217, 119, 6, 0.20)"/>
                    <circle cx="240" cy="300" r="3" fill="rgba(217, 119, 6, 0.12)"/>
                    <!-- Analytics line -->
                    <path d="M 120 320 L 160 310 L 200 315 L 240 295 L 280 290 L 320 275" stroke="rgba(217, 119, 6, 0.15)" stroke-width="1.5" fill="none"/>
                    <circle cx="320" cy="275" r="2.5" fill="rgba(217, 119, 6, 0.25)"/>
                </svg>
                </div>
                <h1 class="service-hero__headline">The full package, built to convert.</h1>
                <p class="service-hero__description">A comprehensive website with booking integration, conversion-focused service pages, and everything needed to turn visitors into clients.</p>
            </section>

            <section class="service-content">
                <div class="service-card">
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <ul class="service-card__list">
                            <li>Service businesses ready for online booking</li>
                            <li>Established teams</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">Scoped to project</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Timeline</p>
                                <p class="service-card__meta-value">3&ndash;4 weeks</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Revisions</p>
                                <p class="service-card__meta-value">2 rounds</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meetings</p>
                                <p class="service-card__meta-value">0 meetings</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__text" style="font-size: var(--text-sm); color: var(--text-subtle); margin-top: -0.5rem;">Optional 15-min clarification call</p>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">What&rsquo;s included</p>
                        <ul class="service-card__list">
                            <li>5&ndash;10 page website</li>
                            <li>Booking or scheduling integration</li>
                            <li>Service pages with conversion UX</li>
                            <li>Reviews + testimonials section</li>
                            <li>FAQ + sticky CTAs</li>
                            <li>Analytics setup</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Custom brand identity</li>
                            <li>CRM or dashboard build</li>
                            <li>Automation workflows</li>
                            <li>Ongoing maintenance</li>
                        </ul>
                    </div>
                </div>
            </section>

            <section class="service-cta">
                <div id="intakePrompt">
                    <InlineIntakeForm
                        serviceName="Full Site + Booking"
                        serviceSlug="fullsite-booking"
                        tierColor="#D97706"
                        tierName="BUILD"
                        step2Label="What do you need?"
                        step2Placeholder="Tell us about your business and what you'd like your website to do."
                    />
                </div>
                <div class="service-cta__card" id="bookingPrompt" style="display: none;">
                    <h2 class="service-cta__title">Ready to schedule</h2>
                    <p class="service-cta__text">Your intake is complete. We'll be in touch within 1 business day to confirm next steps.</p>
                    <a href="/intake" class="service-cta__button">View intake form &rarr;</a>
                </div>
            </section>
        </div>
    </main>

    <footer class="service-footer">
        <div class="service-footer__cta">
            <p class="service-footer__cta-text">Not sure which Build offer?</p>
            <a href="/build" class="service-footer__cta-link">View all Build offers &rarr;</a>
        </div>
        <p class="service-footer__text">&copy; {currentYear} Bertrand Brands. All rights reserved.</p>
        <p class="footer-division"><a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a> &middot; <a href="/privacy">Privacy</a></p>
        <p class="service-footer__phone"><a href="tel:+17054133705" class="phone-link__mobile">(705) 413-3705</a><span class="phone-link__desktop">(705) 413-3705</span></p>
    </footer>

    <script is:inline>
        (function() {
            var intakePrompt = document.getElementById('intakePrompt');
            var bookingPrompt = document.getElementById('bookingPrompt');
            function hasIntakeAccess() {
                return document.cookie.split(';').some(function(c) {
                    return c.trim().startsWith('bb_intake_completed=') || c.trim().startsWith('bb_returning_client=');
                });
            }
            if (hasIntakeAccess() && intakePrompt && bookingPrompt) {
                intakePrompt.style.display = 'none';
                bookingPrompt.style.display = 'block';
            }
        })();
    </script>

    <StickyMobileCTA
        href="#inlineIntakeCard"
        heroSelector=".service-hero"
        formSelector="#inlineIntakeCard"
    />
</ServiceDetailLayout>
