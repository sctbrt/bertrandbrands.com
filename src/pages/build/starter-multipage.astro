---
/**
 * Starter Site — Multi-Page + Contact detail page.
 * Amber accent (#D97706). Single-offer detail with InlineIntakeForm.
 * Part of the Build (Amber) tier at /build.
 */
import ServiceDetailLayout from '../../layouts/ServiceDetailLayout.astro';
import InlineIntakeForm from '../../components/InlineIntakeForm.astro';
import StickyMobileCTA from '../../components/StickyMobileCTA.astro';

const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="Starter Site — Multi-Page + Contact | Bertrand Brands"
    description="A 3-5 page marketing website with service pages, contact CTAs, and SEO fundamentals. Scoped pricing, 2-3 weeks."
    canonical="https://bertrandbrands.ca/build/starter-multipage"
    ogTitle="Starter Site — Multi-Page + Contact | Bertrand Brands"
    ogDescription="A focused multi-page website with service or product pages. Scoped pricing, 2-3 weeks."
    schemaJson={{
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "Starter Site — Multi-Page + Contact",
        "description": "A focused multi-page website with service or product pages, built for businesses that need more room to present what they do.",
        "provider": {
            "@type": "ProfessionalService",
            "name": "Bertrand Brands — Brand & Web Systems",
            "url": "https://bertrandbrands.ca"
        }
    }}
    spotlightColor="rgba(217, 119, 6, 0.15)"
    accentRgb="217, 119, 6"
>
    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/build" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Build
            </a>

            <a href="/build" class="service-subbrand">
                <img src="/assets/bg-brands-logomark.png" alt="" class="service-subbrand__mark" width="40" height="40">
                <span class="service-subbrand__name">Starter Multi-Page</span>
            </a>

            <section class="service-hero">
                <div class="service-hero__illustration-wrap">
                <svg class="service-hero__illustration" viewBox="40 40 420 320" fill="none" aria-hidden="true">
                    <!-- Stacked page rectangles representing multi-page architecture -->
                    <!-- Back page (farthest) -->
                    <rect x="170" y="60" width="180" height="220" rx="4" stroke="rgba(217, 119, 6, 0.10)" stroke-width="1" fill="rgba(217, 119, 6, 0.015)"/>
                    <!-- Middle page -->
                    <rect x="150" y="80" width="180" height="220" rx="4" stroke="rgba(217, 119, 6, 0.15)" stroke-width="1" fill="rgba(217, 119, 6, 0.025)"/>
                    <!-- Front page (main) -->
                    <rect x="130" y="100" width="180" height="220" rx="4" stroke="rgba(217, 119, 6, 0.22)" stroke-width="1.5" fill="rgba(217, 119, 6, 0.04)"/>
                    <!-- Content lines on front page -->
                    <line x1="150" y1="135" x2="250" y2="135" stroke="rgba(217, 119, 6, 0.25)" stroke-width="2"/>
                    <line x1="150" y1="160" x2="290" y2="160" stroke="rgba(217, 119, 6, 0.12)" stroke-width="1"/>
                    <line x1="150" y1="175" x2="280" y2="175" stroke="rgba(217, 119, 6, 0.10)" stroke-width="1"/>
                    <line x1="150" y1="190" x2="270" y2="190" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <!-- Section divider -->
                    <line x1="150" y1="215" x2="290" y2="215" stroke="rgba(217, 119, 6, 0.06)" stroke-width="1" stroke-dasharray="4 4"/>
                    <!-- Content block -->
                    <rect x="150" y="230" width="60" height="40" rx="2" fill="rgba(217, 119, 6, 0.04)" stroke="rgba(217, 119, 6, 0.10)" stroke-width="1"/>
                    <rect x="220" y="230" width="60" height="40" rx="2" fill="rgba(217, 119, 6, 0.04)" stroke="rgba(217, 119, 6, 0.10)" stroke-width="1"/>
                    <!-- CTA button on front page -->
                    <rect x="150" y="285" width="80" height="20" rx="4" fill="rgba(217, 119, 6, 0.08)" stroke="rgba(217, 119, 6, 0.20)" stroke-width="1"/>
                    <!-- Connection lines between pages -->
                    <line x1="310" y1="140" x2="350" y2="120" stroke="rgba(217, 119, 6, 0.12)" stroke-width="1" stroke-dasharray="3 5"/>
                    <line x1="310" y1="200" x2="340" y2="200" stroke="rgba(217, 119, 6, 0.12)" stroke-width="1" stroke-dasharray="3 5"/>
                    <line x1="310" y1="260" x2="350" y2="280" stroke="rgba(217, 119, 6, 0.12)" stroke-width="1" stroke-dasharray="3 5"/>
                    <!-- Navigation dots -->
                    <circle cx="370" cy="120" r="4" stroke="rgba(217, 119, 6, 0.20)" stroke-width="1"/>
                    <circle cx="360" cy="200" r="4" stroke="rgba(217, 119, 6, 0.20)" stroke-width="1"/>
                    <circle cx="370" cy="280" r="4" stroke="rgba(217, 119, 6, 0.20)" stroke-width="1"/>
                    <!-- Small page labels -->
                    <circle cx="370" cy="120" r="1.5" fill="rgba(217, 119, 6, 0.25)"/>
                    <circle cx="360" cy="200" r="1.5" fill="rgba(217, 119, 6, 0.25)"/>
                    <circle cx="370" cy="280" r="1.5" fill="rgba(217, 119, 6, 0.25)"/>
                    <!-- Baseline grid -->
                    <line x1="80" y1="340" x2="420" y2="340" stroke="rgba(217, 119, 6, 0.06)" stroke-width="1"/>
                </svg>
                </div>
                <h1 class="service-hero__headline">Multiple pages, one clear purpose.</h1>
                <p class="service-hero__description">A focused multi-page website with service or product pages, built for businesses that need more room to present what they do.</p>
            </section>

            <section class="service-content">
                <div class="service-card">
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <ul class="service-card__list">
                            <li>Growing businesses, multiple services</li>
                            <li>Teams needing dedicated pages</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">Scoped to project</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Timeline</p>
                                <p class="service-card__meta-value">2&ndash;3 weeks</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Revisions</p>
                                <p class="service-card__meta-value">2 rounds</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meetings</p>
                                <p class="service-card__meta-value">0 meetings</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__text" style="font-size: var(--text-xs); color: var(--text-subtle); margin-top: -0.5rem;">Optional 15-min clarification call</p>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">What&rsquo;s included</p>
                        <ul class="service-card__list">
                            <li>3&ndash;5 page marketing website</li>
                            <li>Mobile-first fast-loading</li>
                            <li>Service or product pages</li>
                            <li>Contact form + CTAs</li>
                            <li>Light brand cleanup</li>
                            <li>SEO fundamentals</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Custom brand identity</li>
                            <li>Booking/scheduling integration</li>
                            <li>CRM or dashboard</li>
                            <li>Ongoing maintenance</li>
                        </ul>
                    </div>
                </div>

                <div class="service-addon">
                    <p class="service-addon__title">+$599 Brandmark Kit add-on</p>
                    <p class="service-addon__text">Need a logo? Add a professional brandmark system to your Multi-Page build.</p>
                </div>
            </section>

            <section class="service-cta">
                <div id="intakePrompt">
                    <InlineIntakeForm
                        serviceName="Starter Multi-Page"
                        serviceSlug="starter-multipage"
                        tierColor="#D97706"
                        tierName="BUILD"
                        step2Label="What do you need?"
                        step2Placeholder="Tell us about your business and what you'd like your website to do."
                    />
                </div>
                <div class="service-cta__card" id="bookingPrompt" style="display: none;">
                    <h2 class="service-cta__title">Ready to schedule</h2>
                    <p class="service-cta__text">Your intake is complete. We'll be in touch within 1 business day to confirm next steps.</p>
                    <a href="/intake" class="service-cta__button">View intake form &rarr;</a>
                </div>
            </section>
        </div>
    </main>

    <footer class="service-footer">
        <div class="service-footer__cta">
            <p class="service-footer__cta-text">Not sure which Build offer?</p>
            <a href="/build" class="service-footer__cta-link">View all Build offers &rarr;</a>
        </div>
        <p class="service-footer__text">&copy; {currentYear} Bertrand Brands. All rights reserved.</p>
        <p class="footer-division"><a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a> &middot; <a href="/privacy">Privacy</a></p>
        <p class="service-footer__phone"><a href="tel:+17054133705" class="phone-link__mobile">(705) 413-3705</a><span class="phone-link__desktop">(705) 413-3705</span></p>
    </footer>

    <script is:inline>
        (function() {
            var intakePrompt = document.getElementById('intakePrompt');
            var bookingPrompt = document.getElementById('bookingPrompt');
            function hasIntakeAccess() {
                return document.cookie.split(';').some(function(c) {
                    return c.trim().startsWith('bb_intake_completed=') || c.trim().startsWith('bb_returning_client=');
                });
            }
            if (hasIntakeAccess() && intakePrompt && bookingPrompt) {
                intakePrompt.style.display = 'none';
                bookingPrompt.style.display = 'block';
            }
        })();
    </script>

    <StickyMobileCTA
        href="#inlineIntakeCard"
        heroSelector=".service-hero"
        formSelector="#inlineIntakeCard"
    />
</ServiceDetailLayout>
