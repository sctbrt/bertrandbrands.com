---
/**
 * Starter Site — One-Page + Contact detail page.
 * Amber accent (#D97706). Single-offer detail with InlineIntakeForm.
 * Part of the Build (Amber) tier at /build.
 */
import ServiceDetailLayout from '../../layouts/ServiceDetailLayout.astro';
import InlineIntakeForm from '../../components/InlineIntakeForm.astro';
import StickyMobileCTA from '../../components/StickyMobileCTA.astro';
import { breadcrumbList, schemaGraph, PROVIDER, AREA_SERVED } from '../../lib/schema';


const currentYear = new Date().getFullYear();
---

<ServiceDetailLayout
    title="Starter Site — One-Page + Contact | Bertrand Brands"
    description="A clean one-page marketing website to get you live. Mobile-first, fast-loading, single CTA. $750 CAD, 7-10 business days."
    canonical="https://bertrandbrands.ca/build/starter-onepage"
    ogTitle="Starter Site — One-Page + Contact | Bertrand Brands"
    ogDescription="A clean one-page marketing website to get you live. $750 CAD, 7-10 business days."
    serviceName="Starter Site — One-Page + Contact"
    serviceTier="Build"
    serviceSlug="starter-onepage"
    servicePrice="750"
    schemaJson={schemaGraph(
        breadcrumbList([
            { name: "Bertrand Brands", url: "https://bertrandbrands.ca/" },
            { name: "Build", url: "https://bertrandbrands.ca/build" },
            { name: "Starter One-Page", url: "https://bertrandbrands.ca/build/starter-onepage" }
        ]),
        {
            "@type": "Service",
            "name": "Starter Site — One-Page + Contact",
            "url": "https://bertrandbrands.ca/build/starter-onepage",
            "description": "A clean, credible one-page website built to get you online fast with a clear call-to-action and professional presentation.",
            "provider": PROVIDER,
            "areaServed": AREA_SERVED,
            "offers": {
                "@type": "Offer",
                "url": "https://bertrandbrands.ca/build/starter-onepage",
                "price": "750",
                "priceCurrency": "CAD",
                "availability": "https://schema.org/InStock"
            }
        }
    )}
    spotlightColor="rgba(217, 119, 6, 0.15)"
    accentRgb="217, 119, 6"
>
    <div class="service-page__spotlight service-page__spotlight--1" aria-hidden="true"></div>
    <div class="service-page__spotlight service-page__spotlight--2" aria-hidden="true"></div>

    <main class="service-page" id="main-content">
        <div class="container">
            <a href="/build" class="service-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Back to Build
            </a>

            <a href="/build" class="service-subbrand">
                <img src="/assets/dot-logomark.svg" alt="" class="service-subbrand__mark" width="40" height="40" />
                <span class="service-subbrand__sep" aria-hidden="true">|</span>
                <span class="service-subbrand__name">Starter One-Page</span>
            </a>

            <section class="service-hero">
                <div class="service-hero__illustration-wrap">
                <svg class="service-hero__illustration" viewBox="45 50 410 290" fill="none" aria-hidden="true">
                    <!-- Launch trajectory -->
                    <line x1="80" y1="320" x2="420" y2="80" stroke="rgba(217, 119, 6, 0.25)" stroke-width="1.5"/>
                    <!-- Horizontal grid lines -->
                    <line x1="60" y1="140" x2="440" y2="140" stroke="rgba(217, 119, 6, 0.12)" stroke-width="1"/>
                    <line x1="60" y1="200" x2="440" y2="200" stroke="rgba(217, 119, 6, 0.18)" stroke-width="1"/>
                    <line x1="60" y1="260" x2="440" y2="260" stroke="rgba(217, 119, 6, 0.12)" stroke-width="1"/>
                    <line x1="60" y1="320" x2="440" y2="320" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1"/>
                    <!-- Vertical grid lines -->
                    <line x1="250" y1="60" x2="250" y2="340" stroke="rgba(217, 119, 6, 0.10)" stroke-width="1" stroke-dasharray="4 6"/>
                    <line x1="165" y1="80" x2="165" y2="340" stroke="rgba(217, 119, 6, 0.06)" stroke-width="1" stroke-dasharray="3 8"/>
                    <line x1="335" y1="80" x2="335" y2="340" stroke="rgba(217, 119, 6, 0.06)" stroke-width="1" stroke-dasharray="3 8"/>
                    <!-- Target circle -->
                    <circle cx="420" cy="80" r="16" stroke="rgba(217, 119, 6, 0.20)" stroke-width="1"/>
                    <circle cx="420" cy="80" r="8" stroke="rgba(217, 119, 6, 0.25)" stroke-width="1.5"/>
                    <circle cx="420" cy="80" r="2.5" fill="rgba(217, 119, 6, 0.30)"/>
                    <!-- Intersection nodes -->
                    <circle cx="193" cy="235" r="3" fill="rgba(217, 119, 6, 0.20)"/>
                    <circle cx="250" cy="200" r="3.5" fill="rgba(217, 119, 6, 0.25)"/>
                    <circle cx="307" cy="165" r="3" fill="rgba(217, 119, 6, 0.20)"/>
                    <!-- Base marker -->
                    <circle cx="80" cy="320" r="4" stroke="rgba(217, 119, 6, 0.18)" stroke-width="1"/>
                    <!-- Subtle filled zone -->
                    <rect x="165" y="200" width="170" height="60" rx="2" fill="rgba(217, 119, 6, 0.03)" stroke="rgba(217, 119, 6, 0.06)" stroke-width="1"/>
                    <!-- Construction arc -->
                    <path d="M 100 300 Q 250 180 400 100" stroke="rgba(217, 119, 6, 0.08)" stroke-width="1" stroke-dasharray="2 6" fill="none"/>
                </svg>
                </div>
                <h1 class="service-hero__headline">Get live with a single focused page.</h1>
                <p class="service-hero__description">A clean, credible one-page website built to get you online fast &mdash; with a clear call-to-action and professional presentation.</p>
            </section>

            <section class="service-content">
                <div class="service-card">
                    <div class="service-card__section">
                        <p class="service-card__label">What&rsquo;s included</p>
                        <ul class="service-card__list">
                            <li>One-page marketing website</li>
                            <li>Mobile-first fast-loading</li>
                            <li>Single primary CTA</li>
                            <li>Contact form</li>
                            <li>Light brand cleanup (typography, colors, spacing)</li>
                            <li>Basic local SEO setup</li>
                            <li>Launch-ready deployment</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Not included</p>
                        <ul class="service-card__list service-card__list--excluded">
                            <li>Custom brand identity</li>
                            <li>Multi-page architecture</li>
                            <li>Booking/scheduling integration</li>
                            <li>Ongoing maintenance</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__label">Best for</p>
                        <ul class="service-card__list">
                            <li>New businesses, first website</li>
                            <li>Solo professionals</li>
                        </ul>
                    </div>
                    <div class="service-card__section">
                        <div class="service-card__meta">
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Pricing</p>
                                <p class="service-card__meta-value">$750 CAD</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Timeline</p>
                                <p class="service-card__meta-value">7&ndash;10 business days</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Revisions</p>
                                <p class="service-card__meta-value">1 round</p>
                            </div>
                            <div class="service-card__meta-item">
                                <p class="service-card__label">Meetings</p>
                                <p class="service-card__meta-value">Optional</p>
                            </div>
                        </div>
                    </div>
                    <div class="service-card__section">
                        <p class="service-card__text" style="font-size: var(--text-sm); color: var(--text-subtle); margin-top: -0.5rem;">Request a check-in call any time. No scheduled meetings required.</p>
                    </div>
                </div>

                <div class="service-addon">
                    <p class="service-addon__title">+$599 Brandmark Kit add-on</p>
                    <p class="service-addon__text">Need a logo? Add a professional brandmark system to your Starter build.</p>
                </div>
            </section>

            <section class="service-cta">
                <div id="intakePrompt">
                    <InlineIntakeForm
                        serviceName="Starter One-Page"
                        serviceSlug="starter-onepage"
                        tierColor="#D97706"
                        tierName="BUILD"
                        step2Label="What do you need?"
                        step2Placeholder="Tell us about your business and what you'd like your website to do."
                    />
                </div>
                <div class="service-cta__card" id="bookingPrompt" style="display: none;">
                    <h2 class="service-cta__title">Ready to schedule</h2>
                    <p class="service-cta__text">Your intake is complete. We'll be in touch within 1 business day to confirm next steps.</p>
                    <a href="/intake" class="service-cta__button">View intake form &rarr;</a>
                </div>
            </section>
        </div>
    </main>

    <footer class="service-footer">
        <div class="service-footer__cta">
            <p class="service-footer__cta-text">Not sure which Build offer?</p>
            <a href="/build" class="service-footer__cta-link">View all Build offers &rarr;</a>
        </div>
        <p class="service-footer__text">&copy; {currentYear} Bertrand Brands. All rights reserved.</p>
        <p class="footer-division"><a href="https://bertrandgroup.ca">A division of Bertrand Group Canada</a> &middot; <a href="/privacy">Privacy</a></p>
        <p class="service-footer__phone"><a href="tel:+17054133705" class="phone-link__mobile">(705) 413-3705</a><span class="phone-link__desktop">(705) 413-3705</span></p>
    </footer>

    <script is:inline>
        (function() {
            var intakePrompt = document.getElementById('intakePrompt');
            var bookingPrompt = document.getElementById('bookingPrompt');
            function hasIntakeAccess() {
                return document.cookie.split(';').some(function(c) {
                    return c.trim().startsWith('bb_intake_completed=') || c.trim().startsWith('bb_returning_client=');
                });
            }
            if (hasIntakeAccess() && intakePrompt && bookingPrompt) {
                intakePrompt.style.display = 'none';
                bookingPrompt.style.display = 'block';
            }
        })();
    </script>

    <StickyMobileCTA
        href="#inlineIntakeCard"
        heroSelector=".service-hero"
        formSelector="#inlineIntakeCard"
    />
</ServiceDetailLayout>
