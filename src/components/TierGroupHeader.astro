---
import { Image } from 'astro:assets';
import logomark from '../assets/bg-brands-logomark.png';

interface Props {
    tierName: string;
    tierClass: 'build' | 'transform' | 'care';
    subtitle: string;
}

const { tierName, tierClass, subtitle } = Astro.props;
---

<div class={`tier-group__header tier-group--${tierClass}`}>
    <Image
        src={logomark}
        alt=""
        class="tier-group__logomark"
        width={32}
        height={32}
        format="webp"
        loading="lazy"
    />
    <span class="tier-group__name">{tierName}</span>
    <span class="tier-group__subtitle">{subtitle}</span>
</div>
