---
interface Props {
    serviceName: string;
    serviceSlug: string;
    tierColor: string;
    tierName: string;
    step2Label?: string;
    step2Placeholder?: string;
}

const {
    serviceName, serviceSlug, tierColor, tierName,
    step2Label = "What\u2019s not working?",
    step2Placeholder = "What feels unclear, outdated, or ineffective about your current brand or website?",
} = Astro.props;
---

<section class="inline-intake" style={`--tier-color: ${tierColor};`}>
    <div class="inline-intake__card" id="inlineIntakeCard">
        <h2 class="inline-intake__title">Start with an intake</h2>
        <p class="inline-intake__subhead">Send your details. We&rsquo;ll confirm fit and next steps within 1 business day.</p>

        <form class="inline-intake__form" id="inlineIntakeForm" action="https://formspree.io/f/xnjjgoay" method="POST">
            <input type="hidden" name="source" value={`inline-${serviceSlug}`}>
            <input type="hidden" name="tier" value={tierName}>
            <input type="hidden" name="entry_type" value="INLINE_INTAKE">
            <input type="hidden" name="service" value={serviceName}>
            <input type="hidden" name="_subject" value={`New Lead — ${serviceName}`}>
            <input type="text" name="_gotcha" class="form-honeypot" tabindex="-1" autocomplete="off">

            <!-- Step 1 fields -->
            <div class="inline-intake__field">
                <label class="inline-intake__label" for="inlineName">Your name</label>
                <input id="inlineName" name="name" type="text" class="inline-intake__input" placeholder="Full name" required>
            </div>

            <div class="inline-intake__field">
                <label class="inline-intake__label" for="inlineEmail">Email</label>
                <input id="inlineEmail" name="email" type="email" class="inline-intake__input" placeholder="you@example.com" required>
            </div>

            <div class="inline-intake__field">
                <label class="inline-intake__label" for="inlineBusiness">Business name</label>
                <input id="inlineBusiness" name="business" type="text" class="inline-intake__input" placeholder="Your business or organization" required>
            </div>

            <button type="button" class="inline-intake__next" id="inlineContinueBtn">Continue &rarr;</button>

            <!-- Step 2 fields (hidden initially) -->
            <div class="inline-intake__step2" id="inlineStep2">
                <div class="inline-intake__field inline-intake__field--step2">
                    <label class="inline-intake__label" for="inlineWebsite">Your website (if you have one)</label>
                    <input id="inlineWebsite" name="website" type="url" class="inline-intake__input" placeholder="https://yoursite.com">
                </div>

                <div class="inline-intake__field inline-intake__field--step2">
                    <label class="inline-intake__label" for="inlineDetails">{step2Label}</label>
                    <textarea id="inlineDetails" name="details" class="inline-intake__textarea" placeholder={step2Placeholder} rows="4"></textarea>
                </div>

                <button type="submit" class="inline-intake__submit" id="inlineSubmitBtn">Submit intake &rarr;</button>

                <p class="inline-intake__disclaimer">No obligation. We&rsquo;ll review and respond before any work begins.</p>
            </div>

            <div class="inline-intake__feedback" id="inlineFeedback"></div>
        </form>
    </div>

    <div class="inline-intake__success" id="inlineSuccess" style="display: none;">
        <div class="inline-intake__card">
            <h2 class="inline-intake__title">Got it — we&rsquo;ll be in touch</h2>
            <p class="inline-intake__subhead">We&rsquo;ll review your details and respond within 1 business day. If you&rsquo;d like to move faster, call us at <a href="tel:+17054133705" style="color: var(--tier-color);">(705) 413-3705</a>.</p>
            <a href="/" class="inline-intake__cta">Back to homepage &rarr;</a>
        </div>
    </div>
</section>

<style is:inline>
    .inline-intake__card {
        background: color-mix(in srgb, var(--tier-color) 5%, transparent);
        border: 1px solid color-mix(in srgb, var(--tier-color) 15%, transparent);
        border-radius: var(--radius-lg, 16px);
        padding: var(--space-lg, 2rem);
    }

    .inline-intake__title {
        font-family: var(--font-display);
        font-size: clamp(1.25rem, 4vw, 1.5rem);
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.5rem;
        letter-spacing: -0.01em;
    }

    .inline-intake__subhead {
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: 400;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: var(--space-md);
        max-width: 480px;
    }

    .inline-intake__form {
        max-width: 480px;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .inline-intake__field {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
    }

    .inline-intake__field--step2 {
        animation: inlineFadeIn 0.3s var(--ease-out);
    }

    @keyframes inlineFadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
        .inline-intake__field--step2 {
            animation: none;
        }
    }

    .inline-intake__label {
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--text);
    }

    .inline-intake__input,
    .inline-intake__textarea {
        font-family: var(--font-body);
        font-size: var(--text-base);
        font-weight: 400;
        color: var(--text);
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius-md, 8px);
        padding: 0.75rem 0.875rem;
        transition: border-color var(--duration-fast) ease;
        width: 100%;
        box-sizing: border-box;
    }

    .inline-intake__input::placeholder,
    .inline-intake__textarea::placeholder {
        color: var(--text-subtle);
    }

    .inline-intake__input:focus,
    .inline-intake__textarea:focus {
        outline: none;
        border-color: var(--tier-color);
    }

    .inline-intake__textarea {
        resize: vertical;
        min-height: 100px;
    }

    .inline-intake__next,
    .inline-intake__submit {
        display: inline-block;
        font-family: var(--font-body);
        font-size: var(--text-base);
        font-weight: 500;
        padding: 0.875rem 2rem;
        border-radius: var(--radius-md, 8px);
        border: none;
        cursor: pointer;
        transition: background var(--duration-fast) ease, transform var(--duration-fast) ease;
        align-self: flex-start;
        min-height: 44px;
    }

    .inline-intake__next {
        background: var(--bg-elevated);
        color: var(--text);
        border: 1px solid var(--border);
    }

    .inline-intake__next:hover {
        border-color: var(--tier-color);
    }

    .inline-intake__submit {
        background: var(--tier-color);
        color: #0a0a0a;
    }

    .inline-intake__submit:hover {
        filter: brightness(0.9);
        transform: translateY(-1px);
    }

    .inline-intake__submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .inline-intake__disclaimer {
        font-family: var(--font-body);
        font-size: var(--text-xs);
        font-weight: 400;
        color: var(--text-subtle);
        margin-top: 0.25rem;
    }

    .inline-intake__step2 {
        display: none;
    }

    .inline-intake__step2--visible {
        display: contents;
    }

    .inline-intake__feedback {
        margin-top: var(--space-sm);
        padding: var(--space-sm);
        border-radius: var(--radius-md, 8px);
        text-align: center;
        font-family: var(--font-body);
        font-size: var(--text-sm);
        display: none;
    }

    .inline-intake__feedback--success {
        display: block;
        background: rgba(34, 197, 94, 0.1);
        border: 1px solid rgba(34, 197, 94, 0.3);
        color: #22c55e;
    }

    .inline-intake__feedback--error {
        display: block;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #ef4444;
    }

    .inline-intake__success .inline-intake__card {
        text-align: center;
    }

    .inline-intake__success .inline-intake__subhead {
        max-width: none;
    }

    .inline-intake__cta {
        display: inline-block;
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--tier-color);
        transition: opacity var(--duration-fast) ease;
    }

    .inline-intake__cta:hover {
        opacity: 0.8;
    }
</style>

<script is:inline>
    // Two-step form logic
    (function() {
        var continueBtn = document.getElementById('inlineContinueBtn');
        var step2 = document.getElementById('inlineStep2');
        if (!continueBtn || !step2) return;

        continueBtn.addEventListener('click', function() {
            // Validate step 1 fields
            var name = document.getElementById('inlineName');
            var email = document.getElementById('inlineEmail');
            var business = document.getElementById('inlineBusiness');

            if (!name.value.trim() || !email.value.trim() || !business.value.trim()) {
                // Trigger native validation
                var form = document.getElementById('inlineIntakeForm');
                if (form) form.reportValidity();
                return;
            }

            step2.classList.add('inline-intake__step2--visible');
            continueBtn.style.display = 'none';
            step2.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

            // GA4: step 1 complete → step 2 visible
            if (typeof gtag === 'function') {
                var slug = document.querySelector('#inlineIntakeForm input[name="source"]');
                gtag('event', 'checkout_progress', {
                    step: 2,
                    form_id: 'inline_intake',
                    item_id: slug ? slug.value : ''
                });
            }
        });

        // GA4: form_start on first interaction
        var started = false;
        var card = document.getElementById('inlineIntakeCard');
        if (card) {
            card.addEventListener('focusin', function() {
                if (started) return;
                started = true;
                if (typeof gtag === 'function') {
                    var slug = document.querySelector('#inlineIntakeForm input[name="source"]');
                    gtag('event', 'form_start', {
                        form_id: 'inline_intake',
                        form_location: window.location.pathname,
                        item_id: slug ? slug.value : ''
                    });
                }
            });
        }
    })();

    // Form submission
    (function() {
        var form = document.getElementById('inlineIntakeForm');
        var submitBtn = document.getElementById('inlineSubmitBtn');
        var feedback = document.getElementById('inlineFeedback');
        var card = document.getElementById('inlineIntakeCard');
        var success = document.getElementById('inlineSuccess');
        if (!form || !submitBtn) return;

        form.addEventListener('submit', async function(e) {
            e.preventDefault();

            submitBtn.disabled = true;
            submitBtn.textContent = 'Submitting...';
            feedback.className = 'inline-intake__feedback';
            feedback.textContent = '';

            try {
                var formData = new FormData(form);

                var response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(Object.fromEntries(formData))
                });

                if (response.ok) {
                    // Set intake completed cookie (24-hour expiry)
                    var expires = new Date(Date.now() + 24 * 60 * 60 * 1000).toUTCString();
                    var emailHash = btoa(formData.get('email')).substring(0, 16);
                    document.cookie = 'bb_intake_completed=' + emailHash + '; expires=' + expires + '; path=/; domain=.bertrandgroup.ca; secure; samesite=lax';

                    // Show success state
                    if (card) card.style.display = 'none';
                    if (success) success.style.display = 'block';

                    // Conversion tracking
                    var serviceSlug = formData.get('source') ? formData.get('source').replace('inline-', '') : 'unknown';
                    if (typeof bbConvert === 'function') bbConvert('form_submit', 'inline_' + serviceSlug);

                    // Pushover notification
                    fetch('/api/notify', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            type: 'intake',
                            source: 'inline-' + (formData.get('source') ? formData.get('source').replace('inline-', '') : 'unknown'),
                            service: formData.get('service') || '',
                            name: formData.get('name') || '',
                            email: formData.get('email') || '',
                            business: formData.get('business') || '',
                            website: formData.get('website') || '',
                            details: formData.get('details') || ''
                        })
                    }).catch(function() {});
                } else {
                    throw new Error('Submission failed');
                }
            } catch (error) {
                feedback.className = 'inline-intake__feedback inline-intake__feedback--error';
                feedback.textContent = 'Something went wrong. Please try again or email hello@bertrandgroup.ca';
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Submit intake \u2192';
            }
        });
    })();
</script>
