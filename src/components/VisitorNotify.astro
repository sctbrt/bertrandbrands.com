---
/**
 * VisitorNotify — Silent Pushover notification on page load.
 * Sends page path, referrer, and UTM params to /api/notify.
 * Geolocation uses Vercel headers (server-side). No visible side effects.
 */
---

<script is:inline data-astro-rerun>
(function() {
  if (typeof navigator !== 'undefined' && navigator.webdriver) return;
  // Set owner flag via ?owner param (persists in localStorage)
  if (window.location.search.indexOf('owner') !== -1) {
    try { localStorage.setItem('bb_owner', '1'); } catch(e) {}
  }
  // Skip visitor notifications for site owner
  try { if (localStorage.getItem('bb_owner') === '1') return; } catch(e) {}

  // Capture UTM parameters for source attribution
  var params = new URLSearchParams(window.location.search);
  var utm = {};
  if (params.get('utm_source')) utm.source = params.get('utm_source');
  if (params.get('utm_medium')) utm.medium = params.get('utm_medium');
  if (params.get('utm_campaign')) utm.campaign = params.get('utm_campaign');
  if (params.get('gclid')) utm.gclid = '1';

  // Defer notification to avoid competing with intro animation
  setTimeout(function() {
    fetch('/api/notify', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        type: 'visitor',
        page: window.location.pathname,
        referrer: document.referrer || '',
        utm: Object.keys(utm).length > 0 ? utm : undefined
      })
    }).catch(function() {});
  }, 3000);
})();
</script>
