    @media (max-width: 1024px) and (min-width: 769px) {
        .bpos__features { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<script is:inline>
    (function() {
        var toggle = document.getElementById('bposBillingToggle');
        var grid = document.getElementById('bposPlanGrid');
        if (!toggle || !grid) return;

        var buttons = toggle.querySelectorAll('.bpos__toggle-btn');

        buttons.forEach(function(btn) {
            btn.addEventListener('click', function() {
                var billing = btn.getAttribute('data-billing');
                buttons.forEach(function(b) { b.classList.remove('active'); });
                btn.classList.add('active');

                grid.querySelectorAll('[data-' + billing + ']').forEach(function(el) {
                    var val = el.getAttribute('data-' + billing);
                    if (val !== null) el.textContent = val;
                });
            });
        });
    })();
</script>
