    }

    /* ── RESPONSIVE ────────────────────────────────────────── */
    @media (max-width: 768px) {
        .bpos { padding: 4rem 1rem 3rem; }
        .bpos__features { grid-template-columns: 1fr; }
        .bpos__plans { grid-template-columns: 1fr; }
        .bpos__stats { flex-wrap: wrap; gap: 1.5rem; }
