---
/**
 * BPOSSection — Cinematic B-POS showcase for bertrandbrands.ca.
 * Apple-esque product introduction: hero → features → pricing.
 * Dark island with its own brand identity (blue-to-amber sweep).
 *
 * Pricing from CLAUDE.md §22:
 *   Standard: $79/mo or $69/mo annual ($828/yr)
 *   Pro:      $129/mo or $109/mo annual ($1,308/yr)
 *   Early Bird: $49/mo annual ($588/yr) — first 10 customers
 */
---

<section class="bpos" id="bpos">
    <!-- Ambient glow layers -->
    <div class="bpos__glow bpos__glow--blue"></div>
    <div class="bpos__glow bpos__glow--amber"></div>

    <div class="bpos__inner">

        <!-- ═══════════════════════════════════════════════════════
             HERO — Cinematic product introduction
             ═══════════════════════════════════════════════════════ -->
        <div class="bpos__hero reveal" data-scroll="fade-up">
            <p class="bpos__hero-label">Introducing</p>
            <h2 class="bpos__hero-title">
                B-POS
            </h2>
            <p class="bpos__hero-subtitle">
                Restaurant Point of Sale
            </p>
            <p class="bpos__hero-desc">
                Offline-first. Runs on any device. Zero processing fees.
            </p>
            <p class="bpos__hero-origin">Made in Sudbury, Ontario 🇨🇦</p>

            <!-- Product shot in device frame -->
            <div class="bpos__hero-device">
                <div class="bpos__device-frame">
                    <div class="bpos__device-screen">
                        <img
                            src="/assets/bpos-og-hero.png"
                            alt="B-POS restaurant point of sale interface"
                            width="960"
                            height="540"
                            loading="lazy"
                        />
                    </div>
                    <!-- Reflection -->
                    <div class="bpos__device-reflection"></div>
                </div>
            </div>

            <!-- CTA row below hero -->
            <div class="bpos__hero-ctas">
                <a href="https://pos.bertrandgroup.ca" target="_blank" rel="noopener noreferrer" class="bpos__cta bpos__cta--primary">
                    Try the Demo
                </a>
                <a href="#bpos-pricing" class="bpos__cta bpos__cta--ghost">
                    See Pricing ↓
                </a>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════
             STATS — Key numbers
             ═══════════════════════════════════════════════════════ -->
        <div class="bpos__stats reveal" data-scroll="fade-up">
            <div class="bpos__stat">
                <span class="bpos__stat-value">$0</span>
                <span class="bpos__stat-label">Processing Fees</span>
            </div>
            <div class="bpos__stat-divider"></div>
            <div class="bpos__stat">
                <span class="bpos__stat-value">100%</span>
                <span class="bpos__stat-label">Offline Capable</span>
            </div>
            <div class="bpos__stat-divider"></div>
            <div class="bpos__stat">
                <span class="bpos__stat-value">Any</span>
                <span class="bpos__stat-label">Device</span>
            </div>
            <div class="bpos__stat-divider"></div>
            <div class="bpos__stat">
                <span class="bpos__stat-value">52</span>
                <span class="bpos__stat-label">Seats Supported</span>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════
             FEATURES — Scroll-reveal cards
             ═══════════════════════════════════════════════════════ -->
        <div class="bpos__features">
            <div class="bpos__feature reveal" data-scroll="fade-up">
                <div class="bpos__feature-icon">🗺️</div>
                <h3 class="bpos__feature-title">Interactive Floor Plan</h3>
                <p class="bpos__feature-desc">
                    Booths, high tops, bar seats, and private rooms. Drag to arrange.
                    Real-time status colors show availability at a glance.
                </p>
            </div>
            <div class="bpos__feature reveal" data-scroll="fade-up">
                <div class="bpos__feature-icon">📋</div>
                <h3 class="bpos__feature-title">Full Order Lifecycle</h3>
                <p class="bpos__feature-desc">
                    Courses, modifiers, split checks by seat or item. Allergen alerts.
                    Auto-gratuity. Everything from seat to settlement.
                </p>
            </div>
            <div class="bpos__feature reveal" data-scroll="fade-up">
                <div class="bpos__feature-icon">🍸</div>
                <h3 class="bpos__feature-title">Bar & Lounge</h3>
                <p class="bpos__feature-desc">
                    Open tabs, happy hour pricing, drink recipes, pour tracking.
                    Auto-close at 2 AM with card-on-file charging.
                </p>
            </div>
            <div class="bpos__feature reveal" data-scroll="fade-up">
                <div class="bpos__feature-icon">🖥️</div>
                <h3 class="bpos__feature-title">Kitchen Display</h3>
                <p class="bpos__feature-desc">
                    Station-based routing, course firing, timing alerts.
                    Allergy banners that can't be dismissed. 86 board in real-time.
                </p>
            </div>
            <div class="bpos__feature reveal" data-scroll="fade-up">
                <div class="bpos__feature-icon">📊</div>
                <h3 class="bpos__feature-title">Full P&L Reporting</h3>
                <p class="bpos__feature-desc">
                    Revenue by category, COGS, labor cost, margins.
                    ROI/PIP auto-calculation. CSV and PDF export.
                </p>
            </div>
            <div class="bpos__feature reveal" data-scroll="fade-up">
                <div class="bpos__feature-icon">🔒</div>
                <h3 class="bpos__feature-title">Offline-First Architecture</h3>
                <p class="bpos__feature-desc">
                    Every terminal holds a full database. Internet goes down?
                    Keep serving. Data syncs when you're back online.
                </p>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════
             SAVINGS CALLOUT
             ═══════════════════════════════════════════════════════ -->
        <div class="bpos__savings reveal" data-scroll="fade-up">
            <div class="bpos__savings-amount">$14,400<span>/yr</span></div>
            <p class="bpos__savings-text">
                That's how much a restaurant doing $50K/mo saves by switching from Toast or Square.
                <strong>B-POS charges zero processing fees.</strong> Bring your own processor.
            </p>
        </div>

        <!-- ═══════════════════════════════════════════════════════
             PRICING
             ═══════════════════════════════════════════════════════ -->
        <div class="bpos__pricing" id="bpos-pricing">
            <h3 class="bpos__pricing-title reveal" data-scroll="fade-up">Simple, Honest Pricing</h3>
            <p class="bpos__pricing-sub reveal" data-scroll="fade-up">No contracts. No processing fees. Cancel anytime.</p>

            <!-- Billing toggle -->
            <div class="bpos__toggle reveal" data-scroll="fade-up" id="bposBillingToggle">
                <button class="bpos__toggle-btn active" data-billing="month" type="button">Monthly</button>
                <button class="bpos__toggle-btn" data-billing="year" type="button">
                    Annual
                    <span class="bpos__toggle-badge">Save 13–15%</span>
                </button>
            </div>

            <!-- Early Bird -->
            <p class="bpos__early reveal" data-scroll="fade-up">
                <span class="bpos__early-tag">Limited</span>
                Early Bird — First 10 customers lock in <strong>$49/mo</strong> for life
            </p>

            <!-- Plan cards -->
            <div class="bpos__plans reveal" data-scroll="cascade" id="bposPlanGrid">
                <!-- Standard -->
                <div class="bpos__card" data-plan="standard">
                    <div class="bpos__card-header">
                        <h4 class="bpos__card-name">Standard</h4>
                        <p class="bpos__card-desc">Everything you need to run service</p>
                    </div>
                    <div class="bpos__card-price">
                        <span class="bpos__price" data-month="$79" data-year="$828">$79</span>
                        <span class="bpos__period" data-month="/mo" data-year="/yr">/mo</span>
                    </div>
                    <p class="bpos__annual-note" data-month="" data-year="$69/mo billed annually"></p>
                    <div class="bpos__card-divider"></div>
                    <ul class="bpos__plan-features">
                        <li>Full POS — orders, payments, floor plan</li>
                        <li>Up to 4 terminals</li>
                        <li>Cash &amp; card payments (BYO processor)</li>
                        <li>Receipt printing</li>
                        <li>Basic daily reporting</li>
                        <li>Menu management &amp; allergen tracking</li>
                        <li>Employee PIN login</li>
                        <li>Multi-terminal LAN sync</li>
                    </ul>
                    <div class="bpos__card-actions">
                        <a href="https://pos.bertrandgroup.ca" target="_blank" rel="noopener noreferrer" class="bpos__cta bpos__cta--outline">Try the Demo</a>
                    </div>
                </div>

                <!-- Pro -->
                <div class="bpos__card bpos__card--pro" data-plan="pro">
                    <span class="bpos__card-badge">Most Popular</span>
                    <div class="bpos__card-header">
                        <h4 class="bpos__card-name">Pro</h4>
                        <p class="bpos__card-desc">Full suite for serious operations</p>
                    </div>
                    <div class="bpos__card-price">
                        <span class="bpos__price bpos__price--accent" data-month="$129" data-year="$1,308">$129</span>
                        <span class="bpos__period" data-month="/mo" data-year="/yr">/mo</span>
                    </div>
                    <p class="bpos__annual-note" data-month="" data-year="$109/mo billed annually"></p>
                    <div class="bpos__card-divider"></div>
                    <ul class="bpos__plan-features">
                        <li class="bpos__plan-features-inherit">Everything in Standard, plus:</li>
                        <li>Up to 8 terminals</li>
                        <li>Kitchen Display System (KDS)</li>
                        <li>Bar tabs &amp; happy hour pricing</li>
                        <li>Inventory management &amp; COGS</li>
                        <li>Advanced reporting &amp; full P&amp;L</li>
                        <li>Employee scheduling &amp; tips</li>
                        <li>Gift cards &amp; private room booking</li>
                        <li>AI-powered insights &amp; forecasting</li>
                        <li>Cloud backup &amp; custom branding</li>
                    </ul>
                    <div class="bpos__card-actions">
                        <a href="https://pos.bertrandgroup.ca" target="_blank" rel="noopener noreferrer" class="bpos__cta bpos__cta--primary">Start Free Trial</a>
                        <a href="https://pos.bertrandgroup.ca" target="_blank" rel="noopener noreferrer" class="bpos__cta bpos__cta--ghost">Try the Demo →</a>
                    </div>
                </div>
            </div>

            <p class="bpos__footnote reveal" data-scroll="fade-up">
                14-day free trial &middot; No credit card required &middot; Cancel anytime
            </p>
        </div>
    </div>
</section>

<style>
    /* ══════════════════════════════════════════════════════════
       B-POS SECTION — Dark island, own brand identity
       ══════════════════════════════════════════════════════════ */
    .bpos {
        position: relative;
        background: #050508;
        padding: 6rem 1.5rem 5rem;
        overflow: hidden;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        width: 100vw;
    }

    /* Ambient glows */
    .bpos__glow { position: absolute; inset: 0; pointer-events: none; }
    .bpos__glow--blue {
        background: radial-gradient(ellipse 50% 30% at 25% 15%, rgba(59,130,246,0.07), transparent);
    }
    .bpos__glow--amber {
        background: radial-gradient(ellipse 40% 30% at 75% 85%, rgba(245,158,11,0.05), transparent);
    }

    .bpos__inner {
        position: relative;
        max-width: 1080px;
        margin: 0 auto;
        z-index: 1;
    }

    /* ── HERO ──────────────────────────────────────────────── */
    .bpos__hero {
        text-align: center;
        margin-bottom: 4rem;
    }

    .bpos__hero-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: #60a5fa;
        margin-bottom: 1rem;
    }

    .bpos__hero-title {
        font-family: 'Inter', sans-serif;
        font-size: clamp(3.5rem, 10vw, 6rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1;
        margin: 0;
        background: linear-gradient(135deg, #e8e6de 0%, #f0eee6 40%, #60a5fa 70%, #f59e0b 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .bpos__hero-subtitle {
        font-family: 'Inter', sans-serif;
        font-size: clamp(1.25rem, 3vw, 1.75rem);
        font-weight: 300;
        color: #8a8a9a;
        margin-top: 0.5rem;
        letter-spacing: 0.02em;
    }

    .bpos__hero-desc {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        color: #555;
        margin-top: 1rem;
        letter-spacing: 0.01em;
    }

    .bpos__hero-origin {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #444;
        margin-top: 0.75rem;
    }

    /* Device frame */
    .bpos__hero-device {
        margin: 3rem auto 2.5rem;
        max-width: 860px;
        perspective: 1200px;
    }

    .bpos__device-frame {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        background: #0a0a0f;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow:
            0 0 0 1px rgba(255,255,255,0.04),
            0 20px 60px rgba(0,0,0,0.6),
            0 0 80px rgba(59,130,246,0.06);
        transform: rotateX(2deg);
        transition: transform 0.6s ease;
    }

    .bpos__device-frame:hover {
        transform: rotateX(0deg);
    }

    .bpos__device-screen img {
        display: block;
        width: 100%;
        height: auto;
    }

    .bpos__device-reflection {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            165deg,
            rgba(255,255,255,0.03) 0%,
            transparent 40%
        );
        pointer-events: none;
    }

    /* Hero CTAs */
    .bpos__hero-ctas {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 0.5rem;
    }

    /* ── STATS ─────────────────────────────────────────────── */
    .bpos__stats {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 2.5rem;
        margin-bottom: 5rem;
        padding: 2rem 0;
    }

    .bpos__stat { text-align: center; }

    .bpos__stat-value {
        display: block;
        font-family: 'Inter', sans-serif;
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 700;
        color: #f0eee6;
        letter-spacing: -0.01em;
    }

    .bpos__stat-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        font-weight: 400;
        color: #555;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-top: 0.25rem;
        display: block;
    }

    .bpos__stat-divider {
        width: 1px;
        height: 40px;
        background: linear-gradient(180deg, transparent, rgba(255,255,255,0.1), transparent);
    }

    /* ── FEATURES ──────────────────────────────────────────── */
    .bpos__features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-bottom: 5rem;
    }

    .bpos__feature {
        padding: 2rem;
        border-radius: 16px;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        transition: border-color 300ms ease, background 300ms ease;
    }

    .bpos__feature:hover {
        border-color: rgba(59,130,246,0.2);
        background: rgba(59,130,246,0.03);
    }

    .bpos__feature-icon {
        font-size: 1.75rem;
        margin-bottom: 1rem;
    }

    .bpos__feature-title {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        font-weight: 600;
        color: #e0e0e0;
        margin: 0 0 0.5rem;
    }

    .bpos__feature-desc {
        font-family: 'Inter', sans-serif;
        font-size: 0.8125rem;
        color: #777;
        line-height: 1.6;
        margin: 0;
    }

    /* ── SAVINGS CALLOUT ───────────────────────────────────── */
    .bpos__savings {
        text-align: center;
        margin-bottom: 5rem;
        padding: 3rem 2rem;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(59,130,246,0.05), rgba(245,158,11,0.03));
        border: 1px solid rgba(59,130,246,0.12);
    }

    .bpos__savings-amount {
        font-family: 'Inter', sans-serif;
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        background: linear-gradient(135deg, #60a5fa, #f59e0b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .bpos__savings-amount span {
        font-size: 0.4em;
        font-weight: 400;
        opacity: 0.7;
    }

    .bpos__savings-text {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        color: #777;
        max-width: 560px;
        margin: 1rem auto 0;
        line-height: 1.6;
    }

    .bpos__savings-text strong {
        color: #ccc;
    }

    /* ── PRICING ───────────────────────────────────────────── */
    .bpos__pricing {
        text-align: center;
    }

    .bpos__pricing-title {
        font-family: 'Inter', sans-serif;
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 600;
        color: #f0eee6;
        margin: 0 0 0.5rem;
    }

    .bpos__pricing-sub {
        font-family: 'Inter', sans-serif;
        font-size: 0.9375rem;
        color: #666;
        margin-bottom: 2rem;
    }

    /* Toggle */
    .bpos__toggle {
        display: flex;
        justify-content: center;
        gap: 2px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 3px;
        max-width: 300px;
        margin: 0 auto 1rem;
    }

    .bpos__toggle-btn {
        flex: 1;
        background: none;
        border: none;
        color: #666;
        font-family: 'Inter', sans-serif;
        font-size: 0.8125rem;
        font-weight: 500;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        transition: all 150ms ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .bpos__toggle-btn.active {
        background: rgba(255,255,255,0.08);
        color: #e0e0e0;
    }

    .bpos__toggle-badge {
        font-size: 0.5625rem;
        background: linear-gradient(135deg, #3b82f6, #60a5fa);
        color: #fff;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 600;
    }

    /* Early bird */
    .bpos__early {
        font-family: 'Inter', sans-serif;
        font-size: 0.8125rem;
        color: #666;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .bpos__early strong { color: #60a5fa; }

    .bpos__early-tag {
        font-size: 0.5625rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #f59e0b;
        border: 1px solid rgba(245,158,11,0.4);
        border-radius: 4px;
        padding: 2px 8px;
    }

    /* Plan cards */
    .bpos__plans {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        max-width: 780px;
        margin: 0 auto 2rem;
        text-align: left;
    }

    .bpos__card {
        position: relative;
        background: rgba(255,255,255,0.025);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 16px;
        padding: 2rem;
        transition: border-color 200ms ease;
    }

    .bpos__card:hover { border-color: rgba(255,255,255,0.12); }

    .bpos__card--pro {
        border-color: rgba(59,130,246,0.3);
        background: rgba(59,130,246,0.03);
    }

    .bpos__card--pro:hover { border-color: rgba(59,130,246,0.5); }

    .bpos__card-badge {
        position: absolute;
        top: -11px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #fff;
        font-family: 'Inter', sans-serif;
        font-size: 0.625rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 4px 14px;
        border-radius: 6px;
        white-space: nowrap;
    }

    .bpos__card-name {
        font-family: 'Inter', sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: #f0eee6;
        margin: 0;
    }

    .bpos__card-desc {
        font-family: 'Inter', sans-serif;
        font-size: 0.8125rem;
        color: #666;
        margin-top: 0.25rem;
    }

    .bpos__card-price {
        display: flex;
        align-items: baseline;
        gap: 4px;
        margin: 1rem 0 0.25rem;
    }

    .bpos__price {
        font-family: 'Inter', sans-serif;
        font-size: clamp(1.75rem, 3vw, 2.25rem);
        font-weight: 700;
        color: #f0eee6;
    }

    .bpos__price--accent {
        background: linear-gradient(135deg, #60a5fa, #93c5fd);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .bpos__period {
        font-family: 'Inter', sans-serif;
        font-size: 0.8125rem;
        color: #555;
    }

    .bpos__annual-note {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        color: #60a5fa;
        min-height: 1.2em;
    }

    .bpos__card-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
        margin: 1.25rem 0;
    }

    .bpos__plan-features {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .bpos__plan-features li {
        font-family: 'Inter', sans-serif;
        font-size: 0.8125rem;
        color: #999;
        padding-left: 1.4rem;
        position: relative;
        line-height: 1.4;
    }

    .bpos__plan-features li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: #3b82f6;
        font-weight: 600;
    }

    .bpos__plan-features-inherit {
        font-weight: 500;
        color: #bbb !important;
    }

    .bpos__plan-features-inherit::before {
        content: '' !important;
    }

    /* CTAs / Buttons */
    .bpos__card-actions {
        margin-top: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .bpos__cta {
        display: inline-block;
        text-align: center;
        font-family: 'Inter', sans-serif;
