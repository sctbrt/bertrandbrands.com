---
interface Props {
    href: string;
    text?: string;
    subtext?: string;
    heroSelector: string;
    formSelector: string;
}

const {
    href,
    text = 'Start intake',
    subtext = 'Response within 1 business day',
    heroSelector,
    formSelector
} = Astro.props;
---

<div class="sticky-cta" id="stickyCta" aria-hidden="true">
    <div class="sticky-cta__inner">
        <a href={href} class="sticky-cta__button">{text} &rarr;</a>
        {subtext && <p class="sticky-cta__sub">{subtext}</p>}
    </div>
</div>

<style is:inline>
    .sticky-cta {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 90;
        background: rgba(10, 10, 10, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 0.75rem var(--space-sm, 1rem);
        transform: translateY(100%);
        transition: transform 0.3s cubic-bezier(0.33, 1, 0.68, 1);
        pointer-events: none;
    }

    .sticky-cta--visible {
        transform: translateY(0);
        pointer-events: auto;
    }

    .sticky-cta__inner {
        max-width: 600px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .sticky-cta__button {
        display: inline-block;
        padding: 0.75rem 1.75rem;
        background: var(--accent, #D97706);
        color: #0a0a0a;
        font-family: var(--font-body, 'Inter', sans-serif);
        font-size: var(--text-sm, 0.875rem);
        font-weight: 600;
        text-decoration: none;
        border-radius: 8px;
        transition: filter 0.15s ease, transform 0.15s ease;
        min-height: 44px;
        line-height: 1.4;
    }

    .sticky-cta__button:hover {
        filter: brightness(0.9);
        transform: translateY(-1px);
    }

    .sticky-cta__sub {
        font-family: var(--font-body, 'Inter', sans-serif);
        font-size: var(--text-xs, 0.75rem);
        color: var(--text-subtle, #737373);
        margin: 0;
    }

    @media (min-width: 769px) {
        .sticky-cta {
            display: none;
        }
    }
</style>

<script is:inline define:vars={{ heroSelector, formSelector }}>
    (function() {
        var exitElement = document.querySelector(heroSelector);
        var enterElement = document.querySelector(formSelector);
        var sticky = document.getElementById('stickyCta');
        if (!exitElement || !sticky) return;

        var exitVisible = true;
        var enterVisible = false;

        function updateVisibility() {
            var shouldShow = !exitVisible && !enterVisible;
            sticky.classList.toggle('sticky-cta--visible', shouldShow);
            sticky.setAttribute('aria-hidden', String(!shouldShow));
        }

        var exitObserver = new IntersectionObserver(function(entries) {
            exitVisible = entries[0].isIntersecting;
            updateVisibility();
        }, { threshold: 0 });
        exitObserver.observe(exitElement);

        if (enterElement) {
            var enterObserver = new IntersectionObserver(function(entries) {
                enterVisible = entries[0].isIntersecting;
                updateVisibility();
            }, { threshold: 0.1 });
            enterObserver.observe(enterElement);
        }
    })();
</script>
