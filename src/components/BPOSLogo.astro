---
/**
 * BPOSLogo.astro — Reusable animated B·POS logo lockup
 *
 * Features: Dot-matrix B, ·POS text, comet light-strike orbit.
 *
 * Props:
 *   tag      — HTML heading tag or 'div' (default: 'div')
 *   size     — 'lg' (homepage teaser) | 'hero' (product page hero) | 'sm' (inline)
 *   id       — optional id attribute on the name element
 *   noArc    — disable the orbiting arc (default: false)
 *   variant  — 'gradient' (tri-colour) | 'white' (all white) (default: 'gradient')
 */

interface Props {
    tag?: 'h1' | 'h2' | 'h3' | 'div' | 'span';
    size?: 'lg' | 'hero' | 'sm';
    id?: string;
    noArc?: boolean;
    variant?: 'gradient' | 'white';
}

const { tag: Tag = 'div', size = 'lg', id, noArc = false, variant = 'gradient' } = Astro.props;
const isWhite = variant === 'white';

const nameClass = [
    'bpos-logo__name',
    `bpos-logo--${size}`,
].filter(Boolean).join(' ');
---

<div class={noArc ? 'bpos-logo' : 'bpos-logo bpos-logo__arc-wrap'}>
    {!noArc && <div class="bpos-logo__arc" aria-hidden="true"></div>}
    <Tag class={nameClass} id={id}>
        <span class={isWhite ? 'bpos-logo__text bpos-logo__text--white' : 'bpos-logo__text bpos-logo__text--gradient'}>
            <svg class="bpos-logo__dotB" viewBox="100 50 310 420" aria-hidden="true">
                <defs>
                    <linearGradient id="bposLogoGrad" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color={isWhite ? '#ffffff' : '#D97706'}/>
                        <stop offset="45%" stop-color={isWhite ? '#ffffff' : '#8B5CF6'}/>
                        <stop offset="100%" stop-color={isWhite ? '#e0e0e0' : '#60A5FA'}/>
                    </linearGradient>
                </defs>
                <g fill={isWhite ? '#ffffff' : 'url(#bposLogoGrad)'}>
                    <circle cx="144" cy="88" r="22"/><circle cx="200" cy="88" r="22"/>
                    <circle cx="256" cy="88" r="22"/><circle cx="312" cy="88" r="22"/>
                    <circle cx="144" cy="144" r="22"/><circle cx="200" cy="144" r="22"/>
                    <circle cx="312" cy="144" r="22"/><circle cx="368" cy="144" r="22"/>
                    <circle cx="144" cy="200" r="22"/><circle cx="200" cy="200" r="22"/>
                    <circle cx="312" cy="200" r="22"/><circle cx="368" cy="200" r="22"/>
                    <circle cx="144" cy="256" r="22"/><circle cx="200" cy="256" r="22"/>
                    <circle cx="256" cy="256" r="22"/><circle cx="312" cy="256" r="22"/>
                    <circle cx="144" cy="312" r="22"/><circle cx="200" cy="312" r="22"/>
                    <circle cx="312" cy="312" r="22"/><circle cx="368" cy="312" r="22"/>
                    <circle cx="144" cy="368" r="22"/><circle cx="200" cy="368" r="22"/>
                    <circle cx="312" cy="368" r="22"/><circle cx="368" cy="368" r="22"/>
                    <circle cx="144" cy="424" r="22"/><circle cx="200" cy="424" r="22"/>
                    <circle cx="256" cy="424" r="22"/><circle cx="312" cy="424" r="22"/>
                </g>
            </svg><span class={isWhite ? 'bpos-logo__dot bpos-logo__dot--white' : 'bpos-logo__dot'}></span>POS
        </span>
    </Tag>
</div>

<style>
    /* ── Base ── */
    .bpos-logo {
        display: inline-block;
        text-align: center;
    }

    .bpos-logo__name {
        font-family: var(--font-display);
        font-weight: 300;
        letter-spacing: -0.03em;
        line-height: 1;
        margin: 0;
    }

    /* ── Sizes ── */
    .bpos-logo--lg {
        font-size: clamp(3.5rem, 10vw, 6rem);
    }
    .bpos-logo--hero {
        font-size: clamp(4rem, 12vw, 8rem);
    }
    .bpos-logo--sm {
        font-size: clamp(1.5rem, 4vw, 2.5rem);
    }

    /* ── Text variants ── */
    .bpos-logo__text--gradient {
        background: linear-gradient(135deg, #D97706 0%, #8B5CF6 45%, #60A5FA 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .bpos-logo__text--white {
        color: #ffffff;
    }

    /* ── Dot-matrix B ── */
    .bpos-logo__dotB {
        display: inline-block;
        height: 0.78em;
        width: auto;
        vertical-align: -0.06em;
        margin-right: 0.02em;
    }

    /* ── Middle dot ── */
    .bpos-logo__dot {
        display: inline-block;
        width: 0.18em;
        height: 0.18em;
        border-radius: 50%;
        background: #8B5CF6;
        vertical-align: 0.25em;
        margin: 0 0.05em;
    }
    .bpos-logo__dot--white {
        background: #ffffff;
    }

    /* ── Comet orbit arc (Saturn ring) ── */
    .bpos-logo__arc-wrap {
        position: relative;
        perspective: 900px;
        overflow: visible;
    }

    .bpos-logo__arc-wrap .bpos-logo__name {
        position: relative;
        z-index: 2;
    }

    .bpos-logo__arc {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 130%;
        height: 220%;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
        transform-origin: center center;
        /* Back pass: dimmer atmospheric tail — feels "behind" the text */
        background: conic-gradient(
            from 0deg,
            transparent 0deg,
            transparent 160deg,
            rgba(96, 165, 250, 0.015) 200deg,
            rgba(139, 92, 246, 0.04) 240deg,
            rgba(167, 139, 250, 0.08) 265deg,
            rgba(217, 119, 6, 0.15) 285deg,
            rgba(245, 158, 11, 0.35) 295deg,
            rgba(255, 220, 120, 0.55) 301deg,
            rgba(255, 255, 255, 0.7) 305deg,
            rgba(255, 220, 120, 0.4) 309deg,
            rgba(245, 158, 11, 0.18) 318deg,
            rgba(96, 165, 250, 0.05) 335deg,
            transparent 355deg,
            transparent 360deg
        );
        /* Thicker ring band for more presence */
        mask-image: radial-gradient(ellipse at center, transparent 40%, black 44%, black 56%, transparent 60%);
        -webkit-mask-image: radial-gradient(ellipse at center, transparent 40%, black 44%, black 56%, transparent 60%);
        filter: blur(3px);
        animation: bposComet 16s linear infinite;
    }

    /* Front-pass flare — brighter, sharper, feels "in front" of text */
    .bpos-logo__arc::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: conic-gradient(
            from 0deg,
            transparent 0deg,
            transparent 290deg,
            rgba(245, 158, 11, 0.25) 297deg,
            rgba(255, 220, 120, 0.8) 302deg,
            rgba(255, 255, 255, 1) 305deg,
            rgba(255, 220, 120, 0.6) 308deg,
            rgba(217, 119, 6, 0.2) 315deg,
            transparent 326deg,
            transparent 360deg
        );
        /* Tighter band — sharper leading edge */
        mask-image: radial-gradient(ellipse at center, transparent 42%, black 46%, black 54%, transparent 58%);
        -webkit-mask-image: radial-gradient(ellipse at center, transparent 42%, black 46%, black 54%, transparent 58%);
        filter: blur(1px);
        z-index: 3;
    }

    /* Bloom halo — soft outward glow around the comet head */
    .bpos-logo__arc::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: conic-gradient(
            from 0deg,
            transparent 0deg,
            transparent 295deg,
            rgba(245, 158, 11, 0.06) 300deg,
            rgba(255, 220, 120, 0.15) 303deg,
            rgba(255, 255, 255, 0.2) 305deg,
            rgba(255, 220, 120, 0.12) 307deg,
            rgba(245, 158, 11, 0.04) 312deg,
            transparent 320deg,
            transparent 360deg
        );
        /* Wider band — bleeds outward past the ring for atmospheric bloom */
        mask-image: radial-gradient(ellipse at center, transparent 34%, black 40%, black 60%, transparent 66%);
        -webkit-mask-image: radial-gradient(ellipse at center, transparent 34%, black 40%, black 60%, transparent 66%);
        filter: blur(8px);
        z-index: 1;
    }

    @keyframes bposComet {
        /* Smooth rotation + gentle tilt drift + opacity depth */
        0%   { transform: translate(-50%, -50%) rotateX(62deg) rotateY(0deg) rotate(0deg); opacity: 0.7; }
        25%  { transform: translate(-50%, -50%) rotateX(60deg) rotateY(1.5deg) rotate(90deg); opacity: 0.45; }
        50%  { transform: translate(-50%, -50%) rotateX(63deg) rotateY(0deg) rotate(180deg); opacity: 0.7; }
        75%  { transform: translate(-50%, -50%) rotateX(60deg) rotateY(-1.5deg) rotate(270deg); opacity: 1; }
        100% { transform: translate(-50%, -50%) rotateX(62deg) rotateY(0deg) rotate(360deg); opacity: 0.7; }
    }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
        .bpos-logo__arc {
            animation: none;
            transform: translate(-50%, -50%) rotateX(62deg);
            opacity: 0.5;
        }
    }
</style>
