---
/**
 * AnnouncementBanner — Apple-style slim product banner above the header.
 * Currently promotes B-POS. Self-contained styles + localStorage dismissal.
 */
---

<script is:inline>
(function () {
  var STORAGE_KEY = 'bb_banner_bpos_v1';
  try { if (localStorage.getItem(STORAGE_KEY)) return; } catch(e) { return; }

  var style = document.createElement('style');
  style.textContent = [
    '.ann-bar{position:fixed;top:0;left:0;right:0;z-index:1060;transform:translateY(-100%);opacity:0;transition:transform 0.4s cubic-bezier(0.33,1,0.68,1),opacity 0.3s ease}',
    '.ann-bar.is-visible{transform:translateY(0);opacity:1}',
    '.ann-bar__inner{display:flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.55rem 1rem;background:rgba(10,10,10,0.85);border-bottom:1px solid rgba(255,255,255,0.06);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px)}',
    '.ann-bar__link{display:flex;align-items:center;gap:0.5rem;text-decoration:none;color:inherit}',
    '.ann-bar__text{margin:0;font-size:0.8125rem;color:rgba(255,255,255,0.7);letter-spacing:0.01em}',
    '.ann-bar__text strong{color:#fff;font-weight:500}',
    '.ann-bar__cta{font-size:0.8125rem;color:#60A5FA;font-weight:500;white-space:nowrap}',
    '.ann-bar__cta:hover{text-decoration:underline}',
    '.ann-bar__close{flex-shrink:0;display:flex;align-items:center;justify-content:center;width:22px;height:22px;padding:0;border:none;border-radius:4px;background:transparent;color:rgba(255,255,255,0.3);font-size:16px;line-height:1;cursor:pointer;transition:color 0.15s ease,background 0.15s ease;margin-left:0.25rem}',
    '.ann-bar__close:hover{color:rgba(255,255,255,0.7);background:rgba(255,255,255,0.08)}',
    '@media(max-width:600px){.ann-bar__inner{padding:0.5rem 0.75rem;gap:0.375rem}.ann-bar__text{font-size:0.6875rem}.ann-bar__cta{font-size:0.6875rem}}',
    '.ann-bar.is-visible ~ .header{transform:translateY(var(--ann-bar-h,36px))}'
  ].join('');
  document.head.appendChild(style);

  var banner = document.createElement('div');
  banner.className = 'ann-bar';
  banner.id = 'annBar';
  banner.setAttribute('role', 'status');
  banner.innerHTML = '<div class="ann-bar__inner">'
    + '<a href="/bpos" class="ann-bar__link">'
    + '<p class="ann-bar__text">Introducing <strong>B-POS</strong> \u2014 Restaurant point of sale. Offline-first.</p>'
    + '<span class="ann-bar__cta">Learn more \u203A</span>'
    + '</a>'
    + '<button class="ann-bar__close" aria-label="Dismiss">\u00d7</button>'
    + '</div>';

  document.body.prepend(banner);

  banner.querySelector('.ann-bar__close').addEventListener('click', function (e) {
    e.preventDefault();
    banner.classList.remove('is-visible');
    document.documentElement.style.setProperty('--ann-bar-h', '0px');
    try { localStorage.setItem(STORAGE_KEY, '1'); } catch(e) {}
    setTimeout(function () { banner.remove(); }, 400);
  });

  // Show after intro finishes (or immediately on sub-pages)
  var delay = document.querySelector('.intro') ? 4500 : 600;
  setTimeout(function () {
    var h = banner.getBoundingClientRect().height;
    document.documentElement.style.setProperty('--ann-bar-h', h + 'px');
    banner.classList.add('is-visible');
  }, delay);
})();
</script>
