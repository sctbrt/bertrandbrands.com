---
/**
 * HeaderCanonical — Homepage-only header (HTML only).
 * Uses bare anchor links (#about, #process, #services) since it's on the SPA.
 * Visibility is controlled by the intro animation script (starts hidden).
 * Mobile menu, ambient lighting, and wordmark animation are handled by
 * the homepage's own inline scripts (avoids double-binding).
 */
---

<header class="header">
    <div class="header__glass">
        <div class="header__inner">
            <a href="/?skip" class="header__logo" data-astro-reload>
                <img src="/assets/dot-logomark.svg" alt="" class="header__logo-icon" width="40" height="40" loading="eager" fetchpriority="high" />
                <span class="header__wordmark" aria-label="Bertrand Brands">BERTRAND BRANDS</span>
            </a>
            <button class="header__toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="mainNav">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <nav class="header__nav" id="mainNav">
              <div class="header__nav-pill">
                <div class="header__dropdown">
                  <button class="header__dropdown-trigger header__link" type="button" aria-controls="mainMenu" aria-expanded="false">
                    Menu
                    <svg class="header__dropdown-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                      <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <div class="header__dropdown-menu" id="mainMenu" role="menu">
                    <a href="#packages" class="header__dropdown-item" role="menuitem"><span class="header__dropdown-item-name">Services</span></a>
                    <a href="#process" class="header__dropdown-item" role="menuitem"><span class="header__dropdown-item-name">How It Works</span></a>
                    <a href="#about" class="header__dropdown-item" role="menuitem"><span class="header__dropdown-item-name">About</span></a>
                    <a href="/compare" class="header__dropdown-item" role="menuitem"><span class="header__dropdown-item-name">Compare</span></a>
                  </div>
                </div>
                <a href="tel:+17054133705" class="header__link header__link--cta header__link--cta-call">Call Now</a>
                <a href="/intake" class="header__link header__link--cta header__link--cta-form">Get a Quote</a>
              </div>
            </nav>
        </div>
    </div>
</header>
